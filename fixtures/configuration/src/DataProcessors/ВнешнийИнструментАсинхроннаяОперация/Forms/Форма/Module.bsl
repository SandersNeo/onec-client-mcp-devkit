#Область ОписаниеПеременных

&НаКлиенте
Перем АктивныеЗадачи;

&НаКлиенте
Перем ОбработчикОжиданияПодключен;

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	ОтключитьОбработчикТаймера();
	
	Мсп_Сервер.ОтменитьРегистрацию(ИмяПровайдера());
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ЗарегистрироватьИнструменты(Команда)
	Оповещение = Новый ОписаниеОповещения("ЗапуститьТаймер", ЭтотОбъект);
	ОписаниеИнструмента = Мсп_Сервер.НовыйИнструмент(
		"Timer",
		"Отсчтитывает нужно количество секунд и отправляет ответ с текущим временем",
		СхемаВходныхПараметров(),
		Оповещение,
		Истина);
	Мсп_Сервер.ЗарегистрироватьИнструмент(ОписаниеИнструмента, ИмяПровайдера());
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьПанельУправления(Команда)
	ОткрытьФорму("ОбщаяФорма.Мсп_УправлениеMCP");
КонецПроцедуры

&НаКлиенте
Процедура ЗапуститьСервер(Команда)
	
	Мсп_Сервер.ЗапуститьСервер(9874);
	
КонецПроцедуры

#КонецОбласти

#Область Инструменты

&НаКлиенте
Функция ИмяПровайдера()
	Возврат "Асинхронные операции";
КонецФункции

&НаКлиенте
Функция ЗапуститьТаймер(Запрос, ДополнительныеПараметры) Экспорт
	Тики = Мсп_Коллекции.Свойство(Запрос.Аргументы, "ticks", 0);
	Если ТипЗнч(Тики) <> Тип("Число") Тогда
		Возврат Мсп_Сервер.ОшибкаИнструмента("INVALID_PARAMS", "ticks must be number");
	КонецЕсли;
	Если Тики <= 0 Тогда
		Возврат Мсп_Сервер.ОшибкаИнструмента("INVALID_PARAMS", "ticks must be positive");
	КонецЕсли;
	
	ИдентификаторЗапроса = Запрос.Идентификатор;
	Если ИдентификаторЗапроса = Неопределено Тогда
		Возврат Мсп_Сервер.ОшибкаИнструмента("ACTION_FAILED", "request id is required");
	КонецЕсли;
	Контекст = Запрос.Контекст;
	ТокенПрогресса = Контекст.progressToken;
	
	Если АктивныеЗадачи = Неопределено Тогда
		АктивныеЗадачи = Новый Массив;
	КонецЕсли;
	
	АктивныеЗадачи.Добавить(Новый Структура(
		"ИдентификаторЗапроса,ТокенПрогресса,ТикиВсего,ТикиОсталось",
		ИдентификаторЗапроса,
		ТокенПрогресса,
		Тики,
		Тики));
	
	ПодключитьОбработчикТаймера();
КонецФункции

&НаКлиенте
Процедура ОбработатьТаймер() Экспорт
	Если АктивныеЗадачи = Неопределено Или АктивныеЗадачи.Количество() = 0 Тогда
		ОтключитьОбработчикТаймера();
		Возврат;
	КонецЕсли;
	
	Индекс = АктивныеЗадачи.Количество() - 1;
	Пока Индекс >= 0 Цикл
		Задача = АктивныеЗадачи[Индекс];
		ИдентификаторЗапроса = Задача.ИдентификаторЗапроса;
		
		Попытка
			Задача.ТикиОсталось = Задача.ТикиОсталось - 1;
			
			Если Задача.ТикиОсталось <= 0 Тогда
				Результат = Мсп_Результаты.JSON(Новый Структура(
					"message,completedAt,ticks",
					"Timer completed",
					Строка(ТекущаяДата()),
					Задача.ТикиВсего));
				Мсп_Сервер.ЗавершитьВызовИнструментаУспешно(ИдентификаторЗапроса, Результат);
				АктивныеЗадачи.Удалить(Индекс);
			Иначе
				Мсп_ТранспортКлиент.УведомитьОПрогрессе(
					Задача.ТокенПрогресса,
					Задача.ТикиВсего - Задача.ТикиОсталось,
					Задача.ТикиВсего,
					"Timer is running");
				АктивныеЗадачи[Индекс] = Задача;
			КонецЕсли;
		Исключение
			Мсп_Сервер.ЗавершитьВызовИнструментаСОшибкой(ИдентификаторЗапроса, "ACTION_FAILED", ОписаниеОшибки());
			АктивныеЗадачи.Удалить(Индекс);
		КонецПопытки;
		
		Индекс = Индекс - 1;
	КонецЦикла;
	
	Если АктивныеЗадачи.Количество() = 0 Тогда
		ОтключитьОбработчикТаймера();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПодключитьОбработчикТаймера()
	Если ОбработчикОжиданияПодключен = Неопределено Тогда
		ОбработчикОжиданияПодключен = Ложь;
	КонецЕсли;
	
	Если ОбработчикОжиданияПодключен Тогда
		Возврат;
	КонецЕсли;
	
	ПодключитьОбработчикОжидания("ОбработатьТаймер", 1, Ложь);
	ОбработчикОжиданияПодключен = Истина;
КонецПроцедуры

&НаКлиенте
Процедура ОтключитьОбработчикТаймера()
	Если ОбработчикОжиданияПодключен = Неопределено Тогда
		ОбработчикОжиданияПодключен = Ложь;
	КонецЕсли;
	
	Если Не ОбработчикОжиданияПодключен Тогда
		Возврат;
	КонецЕсли;
	
	ОтключитьОбработчикОжидания("ОбработатьТаймер");
	ОбработчикОжиданияПодключен = Ложь;
КонецПроцедуры

// Возвращает JSON-схему входных параметров запуска.
&НаКлиенте
Функция СхемаВходныхПараметров()
	Свойства = Новый Структура;
	Свойства.Вставить("ticks", Мсп_СхемаПараметров.НовыйСвойствоСхемы("number", "Количество секунд ожидания"));
	Возврат Мсп_СхемаПараметров.НовыйСхемаОбъекта(
		Свойства,
		СтрРазделить("ticks", ","));
КонецФункции

#КонецОбласти
