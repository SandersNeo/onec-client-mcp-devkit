		"Отсчтитывает нужно количество секунд и отправляет ответ с текущим временем",
		СхемаВходныхПараметров(),
		Новый ОписаниеОповещения("ЗапуститьТаймер", ЭтотОбъект),
		ИмяПровайдера(),
		Истина));
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьПанельУправления(Команда)
	ОткрытьФорму("ОбщаяФорма.Мсп_УправлениеMCP");
КонецПроцедуры

&НаКлиенте
Процедура ЗапуститьСервер(Команда)
	
	Мсп_Сервер.ЗапуститьСервер(9874);
	
КонецПроцедуры

#КонецОбласти

#Область Инструменты

&НаКлиенте
Функция ИмяПровайдера()
	Возврат "Асинхронные операции";
КонецФункции

&НаКлиенте
Функция ЗапуститьТаймер(Запрос, ДополнительныеПараметры) Экспорт
	Тики = Мсп_Коллекции.Свойство(Запрос.Аргументы, "ticks", 0);
	Если ТипЗнч(Тики) <> Тип("Число") Тогда
		Возврат Мсп_Сервер.ОшибкаИнструмента("INVALID_PARAMS", "ticks must be number");
	КонецЕсли;
	Если Тики <= 0 Тогда
		Возврат Мсп_Сервер.ОшибкаИнструмента("INVALID_PARAMS", "ticks must be positive");
	КонецЕсли;
	
	ИдентификаторЗадачи = Мсп_Коллекции.Свойство(Запрос.Контекст, "taskId", "");
	Если Не ЗначениеЗаполнено(ИдентификаторЗадачи) Тогда
		Возврат Мсп_Сервер.ОшибкаИнструмента("ACTION_FAILED", "task id is required");
	КонецЕсли;
	
	ОбработчикЗавершения = Мсп_Коллекции.Свойство(Запрос, "ОбработчикЗавершения", Неопределено);
	Если ОбработчикЗавершения = Неопределено Тогда
		Возврат Мсп_Сервер.ОшибкаИнструмента("ACTION_FAILED", "completion handler is required");
	КонецЕсли;
	
	Если АктивныеЗадачи = Неопределено Тогда
		АктивныеЗадачи = Новый Массив;
	КонецЕсли;
	
	АктивныеЗадачи.Добавить(Новый Структура(
		"ИдентификаторЗадачи,ТикиВсего,ТикиОсталось,ОбработчикЗавершения",
		ИдентификаторЗадачи,
		Тики,
		Тики,
		ОбработчикЗавершения));
	
	Мсп_Сервер.УстановитьСтатусЗадачи(ИдентификаторЗадачи, "working", "Timer started");
	Мсп_Сервер.УведомитьОПрогрессеЗадачи(ИдентификаторЗадачи, 0, Тики, "Task accepted");
	ПодключитьОбработчикТаймера();
	
КонецФункции

&НаКлиенте
Процедура ОбработатьТаймер() Экспорт
	Если АктивныеЗадачи = Неопределено Или АктивныеЗадачи.Количество() = 0 Тогда
		ОтключитьОбработчикТаймера();
		Возврат;
	КонецЕсли;
	
	Индекс = АктивныеЗадачи.Количество() - 1;
	Пока Индекс >= 0 Цикл
		Задача = АктивныеЗадачи[Индекс];
		ИдентификаторЗадачи = Задача.ИдентификаторЗадачи;
		
		Если Мсп_Сервер.ЗадачаОтменена(ИдентификаторЗадачи) Тогда
			Мсп_Сервер.УстановитьСтатусЗадачи(ИдентификаторЗадачи, "cancelled", "Timer cancelled");
			Мсп_Сервер.ОчиститьОтменуЗадачи(ИдентификаторЗадачи);
			АктивныеЗадачи.Удалить(Индекс);
			Индекс = Индекс - 1;
			Продолжить;
		КонецЕсли;
		
		Попытка
			Задача.ТикиОсталось = Задача.ТикиОсталось - 1;
			Прогресс = Задача.ТикиВсего - Задача.ТикиОсталось;
			Мсп_Сервер.УведомитьОПрогрессеЗадачи(
				ИдентификаторЗадачи,
				Прогресс,
				Задача.ТикиВсего,
				СтрШаблон("Tick %1 of %2", Прогресс, Задача.ТикиВсего));
			
			Если Задача.ТикиОсталось <= 0 Тогда
				Результат = Новый Структура(
					"message,completedAt,ticks",
					"Timer completed",
					Строка(ТекущаяДата()),
					Задача.ТикиВсего);
				ВыполнитьОбработкуОповещения(Задача.ОбработчикЗавершения, Результат);
				АктивныеЗадачи.Удалить(Индекс);
			Иначе
				АктивныеЗадачи[Индекс] = Задача;
			КонецЕсли;
		Исключение
			ВыполнитьОбработкуОповещения(
				Задача.ОбработчикЗавершения,
				Мсп_Сервер.ОшибкаИнструмента("ACTION_FAILED", ОписаниеОшибки()));
			АктивныеЗадачи.Удалить(Индекс);
		КонецПопытки;
		
		Индекс = Индекс - 1;
	КонецЦикла;
	
	Если АктивныеЗадачи.Количество() = 0 Тогда
		ОтключитьОбработчикТаймера();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПодключитьОбработчикТаймера()
	Если ОбработчикОжиданияПодключен = Неопределено Тогда
		ОбработчикОжиданияПодключен = Ложь;
	КонецЕсли;
	
	Если ОбработчикОжиданияПодключен Тогда
		Возврат;
	КонецЕсли;
	
	ПодключитьОбработчикОжидания("ОбработатьТаймер", 1, Ложь);
	ОбработчикОжиданияПодключен = Истина;
КонецПроцедуры

&НаКлиенте
Процедура ОтключитьОбработчикТаймера()
	Если ОбработчикОжиданияПодключен = Неопределено Тогда
		ОбработчикОжиданияПодключен = Ложь;
	КонецЕсли;
	
	Если Не ОбработчикОжиданияПодключен Тогда
		Возврат;
	КонецЕсли;
	
	ОтключитьОбработчикОжидания("ОбработатьТаймер");
	ОбработчикОжиданияПодключен = Ложь;
КонецПроцедуры

// Возвращает JSON-схему входных параметров запуска.
&НаКлиенте
Функция СхемаВходныхПараметров()
	Свойства = Новый Структура;
	Свойства.Вставить("ticks", Мсп_СхемаПараметров.НовыйСвойствоСхемы("number", "Количество секунд ожидания"));
	Возврат Мсп_СхемаПараметров.НовыйСхемаОбъекта(Свойства);
КонецФункции

#КонецОбласти
