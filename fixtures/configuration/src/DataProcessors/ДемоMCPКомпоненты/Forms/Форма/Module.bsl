#Область ОбработчикиСобытийФормы

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	Мсп_Сервер.ОтменитьРегистрацию(ИсточникРегистрации());
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Асинх Процедура ЗарегистрироватьКомпоненты(Команда)
	Источник = ИсточникРегистрации();
	ПеререгистрироватьКомпоненты(Источник);
	Если Мсп_ТранспортКлиент.СерверЗапущен() Тогда
		Ждать Мсп_ТранспортКлиент.СинхронизироватьИнструменты();
		Ждать Мсп_ТранспортКлиент.СинхронизироватьРесурсы();
		Ждать Мсп_ТранспортКлиент.СинхронизироватьПромпты();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Асинх Процедура ЗапуститьСервер(Команда)
	ПеререгистрироватьКомпоненты(ИсточникРегистрации());
	ИнформацияОСервере = Мсп_Сервер.НоваяИнформацияОСервере(
		"demo-fixture-mcp",
		"1.0.0",
		"Demo Fixture MCP",
		"Демо обработка fixtures/configuration с инструментом, ресурсами и промптом");
	ПараметрыСервера = Мсп_Сервер.НовыйПараметрыСервера(
		9874,
		"*",
		30,
		ИнформацияОСервере);
	Ждать Мсп_Сервер.Запустить(ПараметрыСервера);
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьПанельУправления(Команда)
	ОткрытьФорму("ОбщаяФорма.Мсп_УправлениеMCP");
КонецПроцедуры

#КонецОбласти

#Область Регистрация

&НаКлиенте
Функция ИсточникРегистрации()
	Возврат "ДемоMCPКомпоненты";
КонецФункции

&НаКлиенте
Процедура ПеререгистрироватьКомпоненты(ИсточникРегистрации)
	Мсп_Сервер.ОтменитьРегистрацию(ИсточникРегистрации);
	ЗарегистрироватьИнструменты(ИсточникРегистрации);
	ЗарегистрироватьРесурсы(ИсточникРегистрации);
	ЗарегистрироватьПромпты(ИсточникРегистрации);
КонецПроцедуры

&НаКлиенте
Процедура ЗарегистрироватьИнструменты(ИсточникРегистрации)
	Свойства = Новый Структура;
	Свойства.Вставить("text", Мсп_Схема.НовыйСвойствоСхемы("string", "Текст для demo echo"));
	ТребуемыеПоля = Новый Массив;
	ТребуемыеПоля.Добавить("text");

	Инструмент = Мсп_Сервер.НовыйИнструмент(
		"demo_echo",
		"Возвращает demo JSON-ответ с исходным текстом и длиной строки",
		Мсп_Схема.НовыйСхемаОбъекта(Свойства, ТребуемыеПоля),
		Новый ОписаниеОповещения("ОбработатьDemoEcho", ЭтотОбъект));

	Мсп_Сервер.ЗарегистрироватьИнструмент(Инструмент, ИсточникРегистрации);
КонецПроцедуры

&НаКлиенте
Процедура ЗарегистрироватьРесурсы(ИсточникРегистрации)
	Ресурс = Мсп_Сервер.НовыйРесурс(
		"demo://about",
		"Demo About",
		"Статическая информация о demo fixture",
		"application/json",
		Новый ОписаниеОповещения("ПрочитатьDemoРесурс", ЭтотОбъект));
	Мсп_Сервер.ЗарегистрироватьРесурс(Ресурс, ИсточникРегистрации);

	ШаблонРесурса = Мсп_Сервер.НовыйШаблонРесурса(
		"demo://items/{id}",
		"Demo Item",
		"Возвращает demo resource по идентификатору",
		"application/json",
		Новый ОписаниеОповещения("ПрочитатьDemoШаблонРесурса", ЭтотОбъект));
	Мсп_Сервер.ЗарегистрироватьШаблонРесурса(ШаблонРесурса, ИсточникРегистрации);
КонецПроцедуры

&НаКлиенте
Процедура ЗарегистрироватьПромпты(ИсточникРегистрации)
	АргументыПромпта = Новый Массив;
	АргументыПромпта.Добавить(
		Новый Структура(
			"name,description,required",
			"topic",
			"Тема для demo-промпта",
			Истина));

	Промпт = Мсп_Сервер.НовыйПромпт(
		"demo_topic_prompt",
		"Формирует demo prompt по теме",
		АргументыПромпта,
		Новый ОписаниеОповещения("ПолучитьDemoПромпт", ЭтотОбъект));
	Мсп_Сервер.ЗарегистрироватьПромпт(Промпт, ИсточникРегистрации);
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиMCP

&НаКлиенте
Функция ОбработатьDemoEcho(Запрос, ДополнительныеПараметры = Неопределено) Экспорт
	ТекстЗапроса = Мсп_Коллекции.Свойство(Запрос.Аргументы, "text", "");
	Если Не ЗначениеЗаполнено(ТекстЗапроса) Тогда
		Мсп_Ошибки.НекорректныеПараметры("text is required");
	КонецЕсли;

	Данные = Новый Структура(
		"text,length,source",
		ТекстЗапроса,
		СтрДлина(ТекстЗапроса),
		ИсточникРегистрации());

	Возврат Мсп_Результаты.JSON(Данные);
КонецФункции

&НаКлиенте
Функция ПрочитатьDemoРесурс(Запрос, ДополнительныеПараметры = Неопределено) Экспорт
	Данные = Новый Структура(
		"source,kind,uri",
		ИсточникРегистрации(),
		"resource",
		Запрос.Контекст.uri);

	Возврат Мсп_Результаты.Ресурс(Запрос.Контекст.uri, Данные);
КонецФункции

&НаКлиенте
Функция ПрочитатьDemoШаблонРесурса(Запрос, ДополнительныеПараметры = Неопределено) Экспорт
	ИдентификаторЭлемента = Мсп_Коллекции.Свойство(Запрос.Контекст.arguments, "id", "");
	Если Не ЗначениеЗаполнено(ИдентификаторЭлемента) Тогда
		Мсп_Ошибки.НекорректныеПараметры("id is required");
	КонецЕсли;

	Данные = Новый Структура(
		"id,title,uriTemplate",
		ИдентификаторЭлемента,
		"Demo item " + ИдентификаторЭлемента,
		Запрос.Контекст.uriTemplate);

	Возврат Мсп_Результаты.Ресурс(Запрос.Контекст.uri, Данные);
КонецФункции

&НаКлиенте
Функция ПолучитьDemoПромпт(Запрос, ДополнительныеПараметры = Неопределено) Экспорт
	Тема = Мсп_Коллекции.Свойство(Запрос.Аргументы, "topic", "");
	Если Не ЗначениеЗаполнено(Тема) Тогда
		Мсп_Ошибки.НекорректныеПараметры("topic is required");
	КонецЕсли;

	Возврат Мсп_Результаты.ТекстовыйПромпт("Подготовь краткое резюме по теме: " + Тема);
КонецФункции

#КонецОбласти
