#Область ПрограммныйИнтерфейс

// Регистрирует сценарии тестового модуля.
Процедура ИсполняемыеСценарии() Экспорт
	ЮТТесты.ДобавитьТест("ПолучитьТестКлиентВозвращаетЗначениеИзПамяти")
		.ДобавитьТест("ОстановитьБезАктивногоКлиента")
		.ДобавитьТест("ОстановитьСбрасываетСостояниеПриОшибкеРазрыва");
КонецПроцедуры

// Проверяет чтение тест-клиента из состояния.
Процедура ПолучитьТестКлиентВозвращаетЗначениеИзПамяти() Экспорт
	ПодготовитьСостояниеТестКлиента(Новый Структура("Имя", "КлиентИзПамяти"));

	ТестКлиент = ВызватьФункциюМодуля("Мсп_УправлениеТестКлиентом", "ПолучитьТестКлиент");

	ЮТест.ОжидаетЧто(ТестКлиент).Свойство("Имя").Равно("КлиентИзПамяти");
КонецПроцедуры

// Проверяет результат остановки без активного клиента.
Процедура ОстановитьБезАктивногоКлиента() Экспорт
	ПодготовитьСостояниеТестКлиента();

	Результат = ВызватьФункциюМодуля("Мсп_УправлениеТестКлиентом", "Остановить");

	ЮТест.ОжидаетЧто(Результат)
		.Свойство("Остановлен").Равно(Ложь)
		.Свойство("Ошибка").Равно("test client not started");
КонецПроцедуры

// Проверяет, что состояние очищается даже при ошибке разрыва соединения.
Процедура ОстановитьСбрасываетСостояниеПриОшибкеРазрыва() Экспорт
	ПодготовитьСостояниеТестКлиента(Новый Структура("Имя", "НекорректныйКлиент"));

	Результат = ВызватьФункциюМодуля("Мсп_УправлениеТестКлиентом", "Остановить");
	Память = ПолучитьСостояниеЗначение("ПамятьТестКлиент", Неопределено);

	ЮТест.ОжидаетЧто(Результат)
		.Свойство("Остановлен").Равно(Ложь)
		.Свойство("Ошибка").Заполнено();
	ЮТест.ОжидаетЧто(Память)
		.Свойство("ТестКлиент").НеЗаполнено()
		.Свойство("Подключен").Равно(Ложь)
		.Свойство("ПоследняяОшибка").Заполнено();
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ПодготовитьСостояниеТестКлиента(ТестКлиент = Неопределено)
	УстановитьСостояниеЗначение(
		"ПараметрыЛогирования",
		Новый Структура("Логировать,УровеньЛога,ФайлЛога", Ложь, "error", ""));
	Память = Новый Структура;
	Если ТестКлиент <> Неопределено Тогда
		Память.Вставить("ТестКлиент", ТестКлиент);
	КонецЕсли;
	УстановитьСостояниеЗначение("ПамятьТестКлиент", Память);
КонецПроцедуры

Процедура УстановитьСостояниеЗначение(Имя, Значение)
	Параметры = Новый Массив;
	Параметры.Добавить(Имя);
	Параметры.Добавить(Значение);
	ЮТМетодыСлужебный.ВыполнитьМетодКонфигурации("Мсп_СостояниеКлиент", "УстановитьСостояниеЗначение", Параметры);
КонецПроцедуры

Функция ПолучитьСостояниеЗначение(Имя, ЗначениеПоУмолчанию)
	Параметры = Новый Массив;
	Параметры.Добавить(Имя);
	Параметры.Добавить(ЗначениеПоУмолчанию);
	Возврат ЮТМетодыСлужебный.ВызватьФункциюКонфигурации("Мсп_СостояниеКлиент", "ПолучитьСостояниеЗначение", Параметры, Ложь);
КонецФункции

Функция ВызватьФункциюМодуля(ИмяМодуля, ИмяМетода, Параметры = Неопределено)
	Возврат ЮТМетодыСлужебный.ВызватьФункциюКонфигурации(ИмяМодуля, ИмяМетода, Параметры, Ложь);
КонецФункции

#КонецОбласти
