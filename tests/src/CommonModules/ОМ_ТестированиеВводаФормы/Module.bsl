	РезультатПоля = Мсп_ФормыКлиент.НайтиОбъекты(URIКорня(РезультатОткрытия), "field", Неопределено, "СписокВыбора", 5);
	ЮТест.ОжидаетЧто(РезультатПоля.Объекты).ИмеетДлину(1);

	Результат = Мсп_ФормыКлиент.ВыбратьПоURI(РезультатПоля.Объекты[0].uri, "Значение2");

	ЮТест.ОжидаетЧто(Результат)
