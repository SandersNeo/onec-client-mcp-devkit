#Область СлужебныйПрограммныйИнтерфейс

Процедура ИсполняемыеСценарии() Экспорт

	ЮТТесты
		.Перед("ЗапуститьТестКлиент")
		.После("ОстановитьТестКлиент")
		.ДобавитьТест("УправляемыеЭлементы_СнапшотФормы")
		.ДобавитьТест("УправляемыеЭлементы_ВыполнитьДействие")
		.ДобавитьТест("УправляемыеЭлементы_ВыборЗначенияИзСписка")
		.ДобавитьТест("УправляемыеЭлементы_СкрытьПоказатьПоле")
		.ДобавитьТест("ПростыеПоляВвода_СнапшотФормы")
		.ДобавитьТест("ПростыеПоляВвода_ВводТекста")
		.ДобавитьТест("ГруппыИВкладки_СнапшотФормы");

КонецПроцедуры

Процедура ЗапуститьТестКлиент() Экспорт
	ПомощникТестированияКлиента.ЗапуститьТестКлиент();
КонецПроцедуры

Процедура ОстановитьТестКлиент() Экспорт
	ПомощникТестированияКлиента.ОстановитьТестКлиент();
КонецПроцедуры

Процедура ПередКаждымТестом() Экспорт
	ПомощникТестированияКлиента.ЗакрытьВсеОкна();
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ОткрытьФормуТестирования(Команда)
	Возврат Мсп_ФормыКлиент.ОткрытьФормуПоКоманде("e1cib/command/DataProcessor.ТестированиеВвода.Command." + Команда);
КонецФункции

Функция URIКорня(РезультатОткрытия)
	Если ЗначениеЗаполнено(РезультатОткрытия.FormURI) Тогда
		Возврат РезультатОткрытия.FormURI;
	КонецЕсли;
	Возврат РезультатОткрытия.WindowURI;
КонецФункции

// УправляемыеЭлементы

Процедура УправляемыеЭлементы_СнапшотФормы() Экспорт
	РезультатОткрытия = ОткрытьФормуТестирования("ОткрытьУправляемыеЭлементы");
	ЮТест.ОжидаетЧто(РезультатОткрытия.Успех).ЭтоИстина();
	
	Снимок = Мсп_ФормыКлиент.СформироватьСнимокФормы(
		Мсп_ФормыКлиент.ФормаПоURI(URIКорня(РезультатОткрытия)).Объект);
	
	ЮТест.ОжидаетЧто(Снимок)
		.Свойство("type").Равно("form")
		.Свойство("children").ИмеетДлинуБольше(0);
КонецПроцедуры

Процедура УправляемыеЭлементы_ВыполнитьДействие() Экспорт
	РезультатОткрытия = ОткрытьФормуТестирования("ОткрытьУправляемыеЭлементы");
	ЮТест.ОжидаетЧто(РезультатОткрытия.Успех).ЭтоИстина();

	РезультатКнопки = Мсп_ФормыКлиент.НайтиОбъекты(URIКорня(РезультатОткрытия), "button", Неопределено, "КнопкаВыполнитьДействие", 5);
	ЮТест.ОжидаетЧто(РезультатКнопки.Объекты).ИмеетДлину(1);

	Результат = Мсп_ФормыКлиент.НажатьПоURI(РезультатКнопки.Объекты[0].uri);

	ЮТест.ОжидаетЧто(Результат)
		.Свойство("Успех").ЭтоИстина()
		.Свойство("КодОшибки").НеЗаполнено();
КонецПроцедуры

Процедура УправляемыеЭлементы_ВыборЗначенияИзСписка() Экспорт
	РезультатОткрытия = ОткрытьФормуТестирования("ОткрытьУправляемыеЭлементы");
	ЮТест.ОжидаетЧто(РезультатОткрытия.Успех).ЭтоИстина();

	РезультатПоля = Мсп_ФормыКлиент.НайтиОбъекты(URIКорня(РезультатОткрытия), "field", Неопределено, "СписокВыбора", 5);
	ЮТест.ОжидаетЧто(РезультатПоля.Объекты).ИмеетДлину(1);

	Результат = Мсп_ФормыКлиент.ВыбратьПоURI(РезультатПоля.Объекты[0].uri, "Значение 2");

	ЮТест.ОжидаетЧто(Результат)
		.Свойство("Успех").ЭтоИстина()
		.Свойство("КодОшибки").НеЗаполнено();
	ЮТест.ОжидаетЧто(Результат.Данные)
		.Свойство("name").Равно("СписокВыбора")
		.Свойство("value").Равно("Значение 2");
КонецПроцедуры

