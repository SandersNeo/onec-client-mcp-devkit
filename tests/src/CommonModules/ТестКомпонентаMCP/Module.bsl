#Область ПрограммныйИнтерфейс

Процедура Инициализировать() Экспорт
	Состояние = Новый Структура;
	Состояние.Вставить("Инструменты", Новый Массив);
	Состояние.Вставить("Ресурсы", Новый Массив);
	Состояние.Вставить("ШаблоныРесурсов", Новый Массив);
	Состояние.Вставить("Промпты", Новый Массив);
	Состояние.Вставить("УведомленияИнструментов", 0);
	Состояние.Вставить("УведомленияРесурсов", 0);
	Состояние.Вставить("УведомленияПромптов", 0);
	Мсп_СостояниеКлиент.УстановитьЗначениеСостоянияСервера("ТестКомпонентаMCP", Состояние);
КонецПроцедуры

Функция Инструменты() Экспорт
	Возврат ТекущееСостояние().Инструменты;
КонецФункции

