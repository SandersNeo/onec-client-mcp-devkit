#Область ПрограммныйИнтерфейс

// Регистрирует сценарии тестового модуля.
Процедура ИсполняемыеСценарии() Экспорт
	ЮТТесты
		.Перед("ЗапуститьТестКлиент")
		.После("ОстановитьТестКлиент")
		.ДобавитьТест("СформироватьБазовыйСнимокФормыБезЗаголовка")
		.ДобавитьТест("СформироватьБазовыйСнимокФормыСЗаголовком")
		.ДобавитьТест("СформироватьСнимокФормыСтроитДеревоЭлементов")
		.ДобавитьТест("ФормаПоURIРеальногоКлиентаВозвращаетСнимок")
		.ДобавитьТест("ПоискЭлементаРеальнойФормыВозвращаетURI")
		.ДобавитьТест("URIФормыКодируетИмяФормы")
		.ДобавитьТест("URIЭлементаФормыКодируетИмяФормыИЭлемента");
КонецПроцедуры

// Запускает тест-клиент перед сценариями модуля.
Процедура ЗапуститьТестКлиент() Экспорт
	ОМ_ОкнаКлиент.ЗапуститьТестКлиент();
КонецПроцедуры

// Останавливает тест-клиент после сценариев модуля.
Процедура ОстановитьТестКлиент() Экспорт
	ОМ_ОкнаКлиент.ОстановтиьТестКлиент();
КонецПроцедуры

// Проверяет базовый снимок формы без заголовка.
Процедура СформироватьБазовыйСнимокФормыБезЗаголовка() Экспорт
	Снимок = Мсп_ФормыКлиент.СформироватьБазовыйСнимокФормы();

	ЮТест.ОжидаетЧто(Снимок)
		.Свойство("type").Равно("form")
		.Свойство("children").ИмеетДлину(0);
	ЮТест.ОжидаетЧто(Снимок.Свойство("title")).Равно(Ложь, "Заголовок не должен добавляться");
КонецПроцедуры

// Проверяет базовый снимок формы с заголовком.
Процедура СформироватьБазовыйСнимокФормыСЗаголовком() Экспорт
	Снимок = Мсп_ФормыКлиент.СформироватьБазовыйСнимокФормы("Справочник");

	ЮТест.ОжидаетЧто(Снимок)
		.Свойство("type").Равно("form")
		.Свойство("title").Равно("Справочник")
		.Свойство("children").ИмеетДлину(0);
КонецПроцедуры

// Проверяет контракт снимка формы и URI именованных элементов.
Процедура СформироватьСнимокФормыСтроитДеревоЭлементов() Экспорт
	ВложеннаяКнопка = Новый Структура(
		"ТипИнтерфейса,Имя,ТекстЗаголовка,ПодчиненныеОбъекты",
		"button",
		"КомандаОК",
		"ОК",
		Новый Массив);
	БезымяннаяГруппа = Новый Структура(
		"ТипИнтерфейса,Имя,ТекстЗаголовка,ПодчиненныеОбъекты",
		"group",
		"",
		"Панель",
		Новый Массив);
	БезымяннаяГруппа.ПодчиненныеОбъекты.Добавить(ВложеннаяКнопка);
	ПолеСумма = Новый Структура(
		"ТипИнтерфейса,Имя,ТекстЗаголовка,ПодчиненныеОбъекты",
		"field",
		"Сумма",
		"Сумма заказа",
		Новый Массив);
	Форма = Новый Структура(
		"ТипИнтерфейса,ИмяФормы,ТекстЗаголовка,ПодчиненныеОбъекты",
		"form",
		"Документ.Заказ",
		"Заказ клиента",
		Новый Массив);
	Форма.ПодчиненныеОбъекты.Добавить(БезымяннаяГруппа);
	Форма.ПодчиненныеОбъекты.Добавить(ПолеСумма);

	Снимок = Мсп_ФормыКлиент.СформироватьСнимокФормы(Форма);
	СнимокГруппы = Снимок.children[0];
	СнимокКнопки = СнимокГруппы.children[0];
	СнимокПоля = Снимок.children[1];

	ЮТест.ОжидаетЧто(Снимок)
		.Свойство("type").Равно("form")
		.Свойство("uri").Равно("form://%D0%94%D0%BE%D0%BA%D1%83%D0%BC%D0%B5%D0%BD%D1%82.%D0%97%D0%B0%D0%BA%D0%B0%D0%B7")
		.Свойство("title").Равно("Заказ клиента")
		.Свойство("name").Равно("Документ.Заказ")
		.Свойство("children").ИмеетДлину(2);
	ЮТест.ОжидаетЧто(СнимокГруппы)
		.Свойство("type").Равно("group")
		.Свойство("title").Равно("Панель")
		.Свойство("name").Равно("")
		.Свойство("children").ИмеетДлину(1);
	ЮТест.ОжидаетЧто(СнимокГруппы.Свойство("uri")).Равно(Ложь, "Безымянная группа не должна получать control URI");
	ЮТест.ОжидаетЧто(СнимокКнопки)
		.Свойство("type").Равно("button")
		.Свойство("uri").Равно("control://%D0%94%D0%BE%D0%BA%D1%83%D0%BC%D0%B5%D0%BD%D1%82.%D0%97%D0%B0%D0%BA%D0%B0%D0%B7/%D0%9A%D0%BE%D0%BC%D0%B0%D0%BD%D0%B4%D0%B0%D0%9E%D0%9A")
		.Свойство("children").ИмеетДлину(0);
	ЮТест.ОжидаетЧто(СнимокПоля)
		.Свойство("type").Равно("field")
		.Свойство("uri").Равно("control://%D0%94%D0%BE%D0%BA%D1%83%D0%BC%D0%B5%D0%BD%D1%82.%D0%97%D0%B0%D0%BA%D0%B0%D0%B7/%D0%A1%D1%83%D0%BC%D0%BC%D0%B0")
		.Свойство("title").Равно("Сумма заказа")
		.Свойство("name").Равно("Сумма");
КонецПроцедуры

// Проверяет разрешение URI реально открытой формы.
Процедура ФормаПоURIРеальногоКлиентаВозвращаетСнимок() Экспорт
	URI = URIФормыУправленияMCP();

	Результат = Мсп_ФормыКлиент.ФормаПоURI(URI);

	ЮТест.ОжидаетЧто(Результат)
		.Свойство("Объект").Существует()
		.Свойство("КодОшибки").НеЗаполнено()
		.Свойство("Ошибка").НеЗаполнено();

	Снимок = Мсп_ФормыКлиент.СформироватьСнимокФормы(Результат.Объект);

	ЮТест.ОжидаетЧто(Снимок)
		.Свойство("type").Равно("form")
		.Свойство("uri").Равно(URI)
		.Свойство("title").Равно("Управление MCP: Управление MCP")
		.Свойство("name").Равно(ИмяФормыУправленияMCP())
		.Свойство("children").ИмеетДлинуБольше(0);
КонецПроцедуры

// Проверяет поиск именованного элемента реальной формы.
Процедура ПоискЭлементаРеальнойФормыВозвращаетURI() Экспорт
	Результат = Мсп_ФормыКлиент.НайтиОбъекты(URIФормыУправленияMCP(), "field", "", "Порт", 0);

	ЮТест.ОжидаетЧто(Результат)
		.Свойство("КодОшибки").НеЗаполнено()
		.Свойство("Ошибка").НеЗаполнено();
	ЮТест.ОжидаетЧто(Результат.Объекты).ИмеетДлину(1);

	Описание = Результат.Объекты[0];

	ЮТест.ОжидаетЧто(Описание)
		.Свойство("type").Равно("field")
		.Свойство("title").Равно("Порт")
		.Свойство("name").Равно("Порт")
		.Свойство("uri").Равно(URIПоляПортУправленияMCP());
КонецПроцедуры

// Проверяет формирование URI формы.
Процедура URIФормыКодируетИмяФормы() Экспорт
	Форма = Новый Структура("ИмяФормы", "Справочник.Номенклатура.Форма?1");

	URI = Мсп_ФормыКлиент.URIФормы(Форма);

	ЮТест.ОжидаетЧто(URI).Равно("form://%D0%A1%D0%BF%D1%80%D0%B0%D0%B2%D0%BE%D1%87%D0%BD%D0%B8%D0%BA.%D0%9D%D0%BE%D0%BC%D0%B5%D0%BD%D0%BA%D0%BB%D0%B0%D1%82%D1%83%D1%80%D0%B0.%D0%A4%D0%BE%D1%80%D0%BC%D0%B0%3F1");
КонецПроцедуры

// Проверяет формирование URI элемента формы.
Процедура URIЭлементаФормыКодируетИмяФормыИЭлемента() Экспорт
	Форма = Новый Структура("ИмяФормы", "Документ.Заказ");
	Элемент = Новый Структура("Имя", "Поле/Сумма");

	URI = Мсп_ФормыКлиент.URIЭлементаФормы(Форма, Элемент);

	ЮТест.ОжидаетЧто(URI).Равно("control://%D0%94%D0%BE%D0%BA%D1%83%D0%BC%D0%B5%D0%BD%D1%82.%D0%97%D0%B0%D0%BA%D0%B0%D0%B7/%D0%9F%D0%BE%D0%BB%D0%B5%2F%D0%A1%D1%83%D0%BC%D0%BC%D0%B0");
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ИмяФормыУправленияMCP()
	Возврат "ОбщаяФорма.Мсп_УправлениеMCP";
КонецФункции

Функция URIФормыУправленияMCP()
	Возврат Мсп_ФормыКлиент.URIФормы(Новый Структура("ИмяФормы", ИмяФормыУправленияMCP()));
КонецФункции

Функция URIПоляПортУправленияMCP()
	Возврат Мсп_ФормыКлиент.URIЭлементаФормы(
		Новый Структура("ИмяФормы", ИмяФормыУправленияMCP()),
		Новый Структура("Имя", "Порт"));
КонецФункции

#КонецОбласти
