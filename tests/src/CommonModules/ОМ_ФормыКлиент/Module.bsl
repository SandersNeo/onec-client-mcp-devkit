#Область ПрограммныйИнтерфейс

// Регистрирует сценарии тестового модуля.
Процедура ИсполняемыеСценарии() Экспорт
	ЮТТесты
		.Перед("ЗапуститьТестКлиент")
		.После("ОстановитьТестКлиент")
		.ДобавитьТест("СформироватьБазовыйСнимокФормыБезЗаголовка")
		.ДобавитьТест("СформироватьБазовыйСнимокФормыСЗаголовком")
		.ДобавитьТест("СформироватьСнимокФормыСтроитДеревоЭлементов")
		.ДобавитьТест("ФормаПоURIРеальногоКлиентаВозвращаетСнимок")
		.ДобавитьТест("ПоискЭлементаРеальнойФормыВозвращаетURI")
		.ДобавитьТест("НажатиеКнопкиРеальнойФормыВозвращаетКонтекстДействия")
		.ДобавитьТест("ВводТекстаВРеальноеПолеВозвращаетНовоеЗначение")
		.ДобавитьТест("ВыборЗначенияВРеальномПолеВозвращаетНовоеЗначение")
		.ДобавитьТест("ВыборЗначенияПоИндексуВРеальномПолеВозвращаетНовоеЗначение")
		.ДобавитьТест("ВводВПолеРезультатаВозвращаетНовоеЗначение")
		.ДобавитьТест("НажатиеКнопкиМодальногоДиалогаОткрываетВопрос")
		.ДобавитьТест("НажатиеКнопкиМодальногоДиалогаОткрываетПредупреждение")
		.ДобавитьТест("НажатиеКнопкиМодальногоДиалогаОткрываетВводСтроки")
		.ДобавитьТест("НажатиеКнопкиМодальногоДиалогаОткрываетДочернююФорму")
		.ДобавитьТест("ВводТекстаВПростоеПоле")
		.ДобавитьТест("ВыборЗначенияВПолеСоСпискомВыбора")
		.ДобавитьТест("ПоискЭлементаНаВкладке")
		.ДобавитьТест("URIФормыКодируетИмяФормы")
		.ДобавитьТест("URIЭлементаФормыКодируетИмяФормыИЭлемента");
КонецПроцедуры

// Запускает тест-клиент перед сценариями модуля.
Процедура ЗапуститьТестКлиент() Экспорт
	ПомощникТестированияКлиента.ЗапуститьТестКлиент();
КонецПроцедуры

// Останавливает тест-клиент после сценариев модуля.
Процедура ОстановитьТестКлиент() Экспорт
	ПомощникТестированияКлиента.ОстановитьТестКлиент();
КонецПроцедуры

// Проверяет базовый снимок формы без заголовка.
Процедура СформироватьБазовыйСнимокФормыБезЗаголовка() Экспорт
	Снимок = Мсп_ФормыКлиент.СформироватьБазовыйСнимокФормы();

	ЮТест.ОжидаетЧто(Снимок)
		.Свойство("type").Равно("form")
		.Свойство("children").ИмеетДлину(0);
	ЮТест.ОжидаетЧто(Снимок.Свойство("title")).Равно(Ложь, "Заголовок не должен добавляться");
КонецПроцедуры

// Проверяет базовый снимок формы с заголовком.
Процедура СформироватьБазовыйСнимокФормыСЗаголовком() Экспорт
	Снимок = Мсп_ФормыКлиент.СформироватьБазовыйСнимокФормы("Справочник");

	ЮТест.ОжидаетЧто(Снимок)
		.Свойство("type").Равно("form")
		.Свойство("title").Равно("Справочник")
