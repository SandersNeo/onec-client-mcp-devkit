КонецФункции

Функция URIКорняОткрытойФормы(РезультатОткрытия)
	Если ЗначениеЗаполнено(РезультатОткрытия.FormURI) Тогда
		Возврат РезультатОткрытия.FormURI;
	КонецЕсли;

	Возврат РезультатОткрытия.WindowURI;
КонецФункции

Процедура ЗакрытьФормуПоИмени(ИмяФормы)
	ТестКлиент = Мсп_УправлениеТестКлиентом.ПолучитьТестКлиент();
	Если ТестКлиент = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Попытка
		НайденныеФормы = ТестКлиент.НайтиОбъекты(Тип("ТестируемаяФорма"));
	Исключение
		Возврат;
	КонецПопытки;

	Если НайденныеФормы = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Для Каждого Форма Из НайденныеФормы Цикл
		Попытка
			ИмяТекущейФормы = Форма.ИмяФормы;
			Если ИмяТекущейФормы = ИмяФормы Тогда
				Форма.Закрыть();
			КонецЕсли;
		Исключение
		КонецПопытки;
	КонецЦикла;
КонецПроцедуры

Процедура ЗакрытьАктивныйДиалог()
	РезультатОкна = Мсп_ОкнаКлиент.АктивноеОкноПриложения();
	Если РезультатОкна.Окно = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Для Каждого ПодчиненныйОбъект Из РезультатОкна.Окно.ПолучитьПодчиненныеОбъекты() Цикл
		Если ТипЗнч(ПодчиненныйОбъект) <> Тип("ТестируемаяФорма") Тогда
			Продолжить;
		КонецЕсли;

		Попытка
			КнопкаПоУмолчанию = ПодчиненныйОбъект.НайтиКнопкуПоУмолчанию();
			Если КнопкаПоУмолчанию <> Неопределено Тогда
				КнопкаПоУмолчанию.Нажать();
				Возврат;
			КонецЕсли;
		Исключение
		КонецПопытки;
	КонецЦикла;
КонецПроцедуры

#КонецОбласти
