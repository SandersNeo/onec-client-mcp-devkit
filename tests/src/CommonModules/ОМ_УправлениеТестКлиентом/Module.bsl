#Область СлужебныйПрограммныйИнтерфейс

// Регистрирует сценарии тестового модуля.
Процедура ИсполняемыеСценарии() Экспорт
	
	ЮТТесты
		.После("ОстановитьТестКлиент")
		.ДобавитьТест("ЗапуститьТестКлиент")
		.ДобавитьТест("ПодключитьТестКлиент")
		.ДобавитьТест("ПодключитьТестКлиентЧерезЗапуск")
		.ДобавитьТест("ПолучитьТестКлиентВозвращаетЗначениеИзПамяти")
		.ДобавитьТест("ОстановитьБезАктивногоКлиента")
		.ДобавитьТест("ОстановитьСбрасываетСостояниеПриОшибкеРазрыва")
		.ДобавитьТест("ПодключитьсяКНесуществующемуПорту")
		.ДобавитьТест("ЗакрытьТестКлиент")
		.ДобавитьТест("ЗакрытьБезАктивногоКлиента")
		.ДобавитьТест("ЗакрытьСбрасываетСостояние");
	
КонецПроцедуры

// Останавливает тест-клиент после сценариев модуля.
Процедура ОстановитьТестКлиент() Экспорт
	ПомощникТестированияКлиента.ОстановитьТестКлиент();
КонецПроцедуры

Процедура ЗапуститьТестКлиент() Экспорт
	
	ОчиститьСостояниеТестКлиента();
	
	Результат = Мсп_УправлениеТестКлиентом.Запустить(1999);
	ПропуститьЕслиТестКлиентНедоступен(Результат);
	
	ЮТест.ОжидаетЧто(Результат)
		.Свойство("Успех").ЭтоИстина()
		.Свойство("Запущен").ЭтоИстина()
		.Свойство("Подключен").ЭтоИстина()
		.Свойство("Ошибка").НеЗаполнено();
	
КонецПроцедуры

Процедура ПодключитьТестКлиент() Экспорт
	
	ОчиститьСостояниеТестКлиента();
	
	Результат = Мсп_УправлениеТестКлиентом.Подключиться(1999);
	ПропуститьЕслиТестКлиентНедоступен(Результат);
	
	ЮТест.ОжидаетЧто(Результат)
		.Свойство("Успех").ЭтоИстина()
		.Свойство("Подключен").ЭтоИстина()
		.Свойство("Ошибка").НеЗаполнено();
	
КонецПроцедуры

Процедура ПодключитьТестКлиентЧерезЗапуск() Экспорт
	
	ОчиститьСостояниеТестКлиента();
	
	Результат = Мсп_УправлениеТестКлиентом.Запустить(1999);
	ПропуститьЕслиТестКлиентНедоступен(Результат);
	
	ЮТест.ОжидаетЧто(Результат)
		.Свойство("Успех").ЭтоИстина()
		.Свойство("Запущен").ЭтоЛожь()
		.Свойство("Подключен").ЭтоИстина()
		.Свойство("Ошибка").НеЗаполнено();
	
КонецПроцедуры

// Проверяет чтение тест-клиента из состояния.
Процедура ПолучитьТестКлиентВозвращаетЗначениеИзПамяти() Экспорт
	ОчиститьСостояниеТестКлиента(Новый Структура("Имя", "КлиентИзПамяти"));

	ТестКлиент = Мсп_УправлениеТестКлиентом.ПолучитьТестКлиент();

	ЮТест.ОжидаетЧто(ТестКлиент).Свойство("Имя").Равно("КлиентИзПамяти");
КонецПроцедуры

// Проверяет результат остановки без активного клиента.
Процедура ОстановитьБезАктивногоКлиента() Экспорт
	ОчиститьСостояниеТестКлиента();
	Мсп_СостояниеКлиент.УстановитьЗначениеСостоянияСервера("ПамятьТестКлиент", Новый Структура);

	Результат = Мсп_УправлениеТестКлиентом.Остановить();

	ЮТест.ОжидаетЧто(Результат)
		.Свойство("Успех").Равно(Ложь)
		.Свойство("Остановлен").Равно(Ложь)
		.Свойство("Ошибка").Равно("test client not started");
КонецПроцедуры

// Проверяет, что состояние очищается даже при ошибке разрыва соединения.
Процедура ОстановитьСбрасываетСостояниеПриОшибкеРазрыва() Экспорт
	ОчиститьСостояниеТестКлиента(Новый Структура("Имя", "НекорректныйКлиент"));

	Результат = Мсп_УправлениеТестКлиентом.Остановить();
	Память = Мсп_СостояниеКлиент.ЗначениеСостоянияСервера("ПамятьТестКлиент", Неопределено);

	ЮТест.ОжидаетЧто(Результат)
		.Свойство("Успех").Равно(Ложь)
		.Свойство("Остановлен").Равно(Ложь)
		.Свойство("Ошибка").Заполнено();
	ЮТест.ОжидаетЧто(Память)
		.Свойство("ТестКлиент").НеЗаполнено()
		.Свойство("Подключен").Равно(Ложь)
		.Свойство("ПоследняяОшибка").Заполнено();
КонецПроцедуры

// Проверяет поведение при подключении к несуществующему порту.
Процедура ПодключитьсяКНесуществующемуПорту() Экспорт
	ОчиститьСостояниеТестКлиента();

	// Порт 59999 гарантированно не занят
	Результат = Мсп_УправлениеТестКлиентом.Подключиться(59999);

	// Подключение не должно удаться
	ЮТест.ОжидаетЧто(Результат)
		.Свойство("Подключен").Равно(Ложь)
		.Свойство("Ошибка").Заполнено();
КонецПроцедуры

// Проверяет результат закрытия активного клиента.
Процедура ЗакрытьТестКлиент() Экспорт
	ОчиститьСостояниеТестКлиента(Новый Структура("Имя", "КлиентДляЗакрытия"));

	Результат = Мсп_УправлениеТестКлиентом.Закрыть();

	// Закрытие вернёт ошибку из-за отсутствия реального тест-клиента,
	// но структура результата должна быть корректной
	ЮТест.ОжидаетЧто(Результат)
		.Свойство("Успех").Заполнено()
		.Свойство("Закрыт").Заполнено();
КонецПроцедуры

// Проверяет результат закрытия без активного клиента.
Процедура ЗакрытьБезАктивногоКлиента() Экспорт
	ОчиститьСостояниеТестКлиента();

	Результат = Мсп_УправлениеТестКлиентом.Закрыть();

	ЮТест.ОжидаетЧто(Результат)
		.Свойство("Успех").Равно(Ложь)
		.Свойство("Закрыт").Равно(Ложь)
		.Свойство("Ошибка").Равно("test client not started");
КонецПроцедуры

// Проверяет, что при закрытии состояние очищается.
Процедура ЗакрытьСбрасываетСостояние() Экспорт
	ОчиститьСостояниеТестКлиента(Новый Структура("Имя", "КлиентДляЗакрытия"));

	Мсп_УправлениеТестКлиентом.Закрыть();
	Память = Мсп_СостояниеКлиент.ЗначениеСостоянияСервера("ПамятьТестКлиент", Неопределено);

	// После закрытия память сбрасывается в пустую структуру
	ЮТест.ОжидаетЧто(Память).НеРавно(Неопределено);
	ЗначениеКлиента = Неопределено;
	Память.Свойство("ТестКлиент", ЗначениеКлиента);
	ЮТест.ОжидаетЧто(ЗначениеКлиента).НеЗаполнено();
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ОчиститьСостояниеТестКлиента(ТестКлиент = Неопределено)
	Мсп_СостояниеКлиент.УстановитьЗначениеСостоянияСервера(
		"ПараметрыЛогирования",
		Новый Структура("Логировать,УровеньЛога,ФайлЛога", Ложь, "error", ""));
	
	Если ТестКлиент <> Неопределено Тогда
		Память = Новый Структура;
		Память.Вставить("ТестКлиент", ТестКлиент);
		Мсп_СостояниеКлиент.УстановитьЗначениеСостоянияСервера("ПамятьТестКлиент", Память);
	КонецЕсли;
КонецПроцедуры

Процедура ПропуститьЕслиТестКлиентНедоступен(Результат)
	Если Не Результат.Успех Тогда
		ЮТест.Пропустить("test client unavailable: " + Результат.Ошибка);
	КонецЕсли;
КонецПроцедуры

#КонецОбласти
