#Область ПрограммныйИнтерфейс

// Регистрирует сценарии тестового модуля.
Процедура ИсполняемыеСценарии() Экспорт
	ЮТТесты
		.ДобавитьТест("ПолучитьСвойствоИзСтруктурыВозвращаетЗначение")
		.ДобавитьТест("ПолучитьСвойствоИзСтруктурыОтсутствующийКлючВозвращаетУмолчание")
		.ДобавитьТест("ПолучитьСвойствоИзСоответствияВозвращаетЗначение")
		.ДобавитьТест("ПолучитьСвойствоИзСоответствияОтсутствующийКлючВозвращаетУмолчание")
		.ДобавитьТест("ПолучитьСвойствоНеСтруктураНеСоответствиеВозвращаетУмолчание")
		.ДобавитьТест("ПолучитьСвойствоНеопределеноВозвращаетУмолчание");
КонецПроцедуры

// Проверяет получение существующего свойства из Структуры.
Процедура ПолучитьСвойствоИзСтруктурыВозвращаетЗначение() Экспорт
	Данные = Новый Структура("Имя,Возраст", "Тест", 10);

	ЮТест.ОжидаетЧто(Мсп_Коллекции.ПолучитьСвойство(Данные, "Имя", "")).Равно("Тест");
	ЮТест.ОжидаетЧто(Мсп_Коллекции.ПолучитьСвойство(Данные, "Возраст", 0)).Равно(10);
КонецПроцедуры

// Проверяет возврат значения по умолчанию для отсутствующего ключа в Структуре.
Процедура ПолучитьСвойствоИзСтруктурыОтсутствующийКлючВозвращаетУмолчание() Экспорт
	Данные = Новый Структура("Имя", "Тест");

	ЮТест.ОжидаетЧто(Мсп_Коллекции.ПолучитьСвойство(Данные, "НетТакого", "умолчание")).Равно("умолчание");
КонецПроцедуры

// Проверяет получение существующего ключа из Соответствия.
Процедура ПолучитьСвойствоИзСоответствияВозвращаетЗначение() Экспорт
	Данные = Новый Соответствие;
	Данные.Вставить("ключ", "значение");

	ЮТест.ОжидаетЧто(Мсп_Коллекции.ПолучитьСвойство(Данные, "ключ", "")).Равно("значение");
КонецПроцедуры

// Проверяет возврат значения по умолчанию для отсутствующего ключа в Соответствии.
Процедура ПолучитьСвойствоИзСоответствияОтсутствующийКлючВозвращаетУмолчание() Экспорт
	Данные = Новый Соответствие;

	ЮТест.ОжидаетЧто(Мсп_Коллекции.ПолучитьСвойство(Данные, "нет", 99)).Равно(99);
КонецПроцедуры

// Проверяет возврат значения по умолчанию для не-Структуры и не-Соответствия.
Процедура ПолучитьСвойствоНеСтруктураНеСоответствиеВозвращаетУмолчание() Экспорт
	ЮТест.ОжидаетЧто(Мсп_Коллекции.ПолучитьСвойство("строка", "ключ", "умолчание")).Равно("умолчание");
КонецПроцедуры

// Проверяет возврат значения по умолчанию при передаче Неопределено.
Процедура ПолучитьСвойствоНеопределеноВозвращаетУмолчание() Экспорт
	ЮТест.ОжидаетЧто(Мсп_Коллекции.ПолучитьСвойство(Неопределено, "ключ", "умолчание")).Равно("умолчание");
КонецПроцедуры

#КонецОбласти
