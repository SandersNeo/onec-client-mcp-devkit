#Область ПрограммныйИнтерфейс

// Регистрирует сценарии тестового модуля.
Процедура ИсполняемыеСценарии() Экспорт
	
	ЮТТесты
		.Перед("ЗапуститьТестКлиент")
		.После("ОстановитьТестКлиент")
		.ДобавитьТест("ПолучитьАктивноеОкноРеальногоКлиента")
		.ДобавитьТест("СписокОконПриложенияРеальногоКлиента")
		.ДобавитьТест("СписокОконПриложенияБезКлиента")
		.ДобавитьТест("СписокОконПриложенияСНекорректнымКлиентом")
		.ДобавитьТест("ПолучитьАктивноеОкноБезКлиента")
		.ДобавитьТест("ПолучитьАктивноеОкноСНекорректнымКлиентом")
		.ДобавитьТест("СформироватьСнимокОкна")
		.ДобавитьТест("URIОкнаКодируетНавигационнуюСсылку");
	
КонецПроцедуры

// Запускает тест-клиент перед интеграционными сценариями.
Процедура ЗапуститьТестКлиент() Экспорт
	ПодготовитьСостояниеТестКлиента();
	Результат = Мсп_УправлениеТестКлиентом.Запустить(1999);
	
	Если НЕ Результат.Успех Тогда
		ВызватьИсключение Результат.Ошибка;
	КонецЕсли;
КонецПроцедуры

// Останавливает тест-клиент после интеграционных сценариев.
Процедура ОстановитьТестКлиент() Экспорт
	Мсп_УправлениеТестКлиентом.Остановить();
КонецПроцедуры

// Проверяет получение активного окна реального тест-клиента.
Процедура ПолучитьАктивноеОкноРеальногоКлиента() Экспорт
	Результат = Мсп_ОкнаКлиент.АктивноеОкноПриложения();

	ЮТест.ОжидаетЧто(Результат)
		.Свойство("Окно").НеРавно(Неопределено)
		.Свойство("Ошибка").Равно("");

	Снимок = Мсп_ОкнаКлиент.СформироватьСнимокОкна(Результат.Окно);

	ЮТест.ОжидаетЧто(Снимок)
		.Свойство("type").Равно("window")
		.Свойство("title").Равно(Результат.Окно.Заголовок)
		.Свойство("isMain").Равно(Результат.Окно.Основное)
		.Свойство("homePage").Равно(Результат.Окно.НачальнаяСтраница)
		.Свойство("children").ИмеетДлину(0);
КонецПроцедуры

// Проверяет получение списка окон реального тест-клиента.
Процедура СписокОконПриложенияРеальногоКлиента() Экспорт
	Результат = Мсп_ОкнаКлиент.СписокОконПриложения();

	ЮТест.ОжидаетЧто(Результат)
		.Свойство("Ошибка").НеЗаполнено();
	ЮТест.ОжидаетЧто(Результат.Окна).ИмеетДлинуБольше(0);

	Снимок = Мсп_ОкнаКлиент.СформироватьСнимокОкна(Результат.Окна[0]);

	ЮТест.ОжидаетЧто(Снимок)
		.Свойство("type").Равно("window")
		.Свойство("title").Равно(Результат.Окна[0].Заголовок)
		.Свойство("isMain").Равно(Результат.Окна[0].Основное)
		.Свойство("homePage").Равно(Результат.Окна[0].НачальнаяСтраница)
		.Свойство("children").ИмеетДлину(0);
КонецПроцедуры

// Проверяет ошибку при отсутствии клиента.
Процедура ПолучитьАктивноеОкноБезКлиента() Экспорт
	ПодготовитьСостояниеТестКлиента();

	Результат = Мсп_ОкнаКлиент.АктивноеОкноПриложения();

	ЮТест.ОжидаетЧто(Результат)
		.Свойство("Окно").НеЗаполнено()
		.Свойство("Ошибка").Равно("test client not connected");
КонецПроцедуры

// Проверяет обработку ошибки при некорректном объекте клиента.
Процедура ПолучитьАктивноеОкноСНекорректнымКлиентом() Экспорт
	ПодготовитьСостояниеТестКлиента(Новый Структура("Имя", "НекорректныйКлиент"));

	Результат = Мсп_ОкнаКлиент.АктивноеОкноПриложения();

	ЮТест.ОжидаетЧто(Результат)
		.Свойство("Окно").НеЗаполнено()
		.Свойство("Ошибка").Заполнено();
КонецПроцедуры

// Проверяет ошибку при отсутствии клиента при чтении списка окон.
Процедура СписокОконПриложенияБезКлиента() Экспорт
	ПодготовитьСостояниеТестКлиента();

	Результат = Мсп_ОкнаКлиент.СписокОконПриложения();

	ЮТест.ОжидаетЧто(Результат)
		.Свойство("Ошибка").Равно("test client not connected")
		.Свойство("Окна").ИмеетДлину(0);
КонецПроцедуры

// Проверяет обработку ошибки при некорректном объекте клиента при чтении списка окон.
Процедура СписокОконПриложенияСНекорректнымКлиентом() Экспорт
	ПодготовитьСостояниеТестКлиента(Новый Структура("Имя", "НекорректныйКлиент"));

	Результат = Мсп_ОкнаКлиент.СписокОконПриложения();

	ЮТест.ОжидаетЧто(Результат)
		.Свойство("Ошибка").Заполнено()
		.Свойство("Окна").ИмеетДлину(0);
КонецПроцедуры

// Проверяет контракт снимка окна.
Процедура СформироватьСнимокОкна() Экспорт
	Окно = Новый Структура(
		"Заголовок,Основное,НачальнаяСтраница,НавигационнаяСсылка",
		"Главное окно",
		Истина,
		Ложь,
		"e1cib/list/Справочник.Номенклатура");

	Снимок = Мсп_ОкнаКлиент.СформироватьСнимокОкна(Окно);

	ЮТест.ОжидаетЧто(Снимок)
		.Свойство("type").Равно("window")
		.Свойство("uri").Равно("window://e1cib%2Flist%2F%D0%A1%D0%BF%D1%80%D0%B0%D0%B2%D0%BE%D1%87%D0%BD%D0%B8%D0%BA.%D0%9D%D0%BE%D0%BC%D0%B5%D0%BD%D0%BA%D0%BB%D0%B0%D1%82%D1%83%D1%80%D0%B0")
		.Свойство("title").Равно("Главное окно")
		.Свойство("isMain").Равно(Истина)
		.Свойство("homePage").Равно(Ложь)
		.Свойство("forms").ИмеетДлину(0)
		.Свойство("children").ИмеетДлину(0);
КонецПроцедуры

// Проверяет формирование URI окна.
Процедура URIОкнаКодируетНавигационнуюСсылку() Экспорт
	Окно = Новый Структура("НавигационнаяСсылка", "e1cib/list/Справочник.Номенклатура?filter=1");

	URI = Мсп_ОкнаКлиент.URIОкна(Окно);

	ЮТест.ОжидаетЧто(URI).Равно("window://e1cib%2Flist%2F%D0%A1%D0%BF%D1%80%D0%B0%D0%B2%D0%BE%D1%87%D0%BD%D0%B8%D0%BA.%D0%9D%D0%BE%D0%BC%D0%B5%D0%BD%D0%BA%D0%BB%D0%B0%D1%82%D1%83%D1%80%D0%B0%3Ffilter%3D1");
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ПодготовитьСостояниеТестКлиента(ТестКлиент = Неопределено)
	Мсп_СостояниеКлиент.УстановитьСостояниеЗначение(
		"ПараметрыЛогирования",
		Новый Структура("Логировать,УровеньЛога,ФайлЛога", Ложь, "error", ""));
	Память = Новый Структура;
	Если ТестКлиент <> Неопределено Тогда
		Память.Вставить("ТестКлиент", ТестКлиент);
	КонецЕсли;
	Мсп_СостояниеКлиент.УстановитьСостояниеЗначение("ПамятьТестКлиент", Память);
КонецПроцедуры

#КонецОбласти
