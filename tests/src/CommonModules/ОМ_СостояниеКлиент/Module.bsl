#Область ПрограммныйИнтерфейс

// Регистрирует сценарии тестового модуля.
Процедура ИсполняемыеСценарии() Экспорт
	ЮТТесты
		.ДобавитьТест("ПолучитьСостояниеВозвращаетСтруктуру")
		.ДобавитьТест("УстановитьСостояниеЗначениеСохраняетЗначение")
		.ДобавитьТест("ПолучитьСостояниеЗначениеВозвращаетУстановленное")
		.ДобавитьТест("ПолучитьСостояниеЗначениеВозвращаетУмолчаниеЕслиНет")
		.ДобавитьТест("УстановитьСостояниеЗначениеПерезаписывает")
		.ДобавитьТест("ПолучитьСостояниеВозвращаетОдинОбъект");
КонецПроцедуры

// Проверяет, что ПолучитьСостояние возвращает Структуру.
Процедура ПолучитьСостояниеВозвращаетСтруктуру() Экспорт
	ЮТест.ОжидаетЧто(ТипЗнч(Мсп_СостояниеКлиент.ПолучитьСостояние())).Равно(Тип("Структура"));
КонецПроцедуры

// Проверяет, что УстановитьСостояниеЗначение сохраняет значение.
Процедура УстановитьСостояниеЗначениеСохраняетЗначение() Экспорт
	ПодготовитьСостояние();

	Мсп_СостояниеКлиент.УстановитьСостояниеЗначение("ТестКлюч", "ТестЗначение");

	ЮТест.ОжидаетЧто(Мсп_СостояниеКлиент.ПолучитьСостояниеЗначение("ТестКлюч")).Равно("ТестЗначение");
КонецПроцедуры

// Проверяет, что ПолучитьСостояниеЗначение возвращает установленное значение.
Процедура ПолучитьСостояниеЗначениеВозвращаетУстановленное() Экспорт
	ПодготовитьСостояние();
	Мсп_СостояниеКлиент.УстановитьСостояниеЗначение("Число", 42);

	ЮТест.ОжидаетЧто(Мсп_СостояниеКлиент.ПолучитьСостояниеЗначение("Число")).Равно(42);
КонецПроцедуры

// Проверяет, что ПолучитьСостояниеЗначение возвращает значение по умолчанию при отсутствии ключа.
Процедура ПолучитьСостояниеЗначениеВозвращаетУмолчаниеЕслиНет() Экспорт
	ПодготовитьСостояние();

	ЮТест.ОжидаетЧто(Мсп_СостояниеКлиент.ПолучитьСостояниеЗначение("НесуществующийКлюч", "умолчание")).Равно("умолчание");
КонецПроцедуры

// Проверяет, что повторная установка перезаписывает значение.
Процедура УстановитьСостояниеЗначениеПерезаписывает() Экспорт
	ПодготовитьСостояние();
	Мсп_СостояниеКлиент.УстановитьСостояниеЗначение("Ключ", "старое");

	Мсп_СостояниеКлиент.УстановитьСостояниеЗначение("Ключ", "новое");

	ЮТест.ОжидаетЧто(Мсп_СостояниеКлиент.ПолучитьСостояниеЗначение("Ключ")).Равно("новое");
КонецПроцедуры

// Проверяет, что ПолучитьСостояние возвращает один и тот же объект.
Процедура ПолучитьСостояниеВозвращаетОдинОбъект() Экспорт
	Состояние1 = Мсп_СостояниеКлиент.ПолучитьСостояние();
	Состояние2 = Мсп_СостояниеКлиент.ПолучитьСостояние();

	ЮТест.ОжидаетЧто(Состояние1).Равно(Состояние2);
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ПодготовитьСостояние()
	Мсп_СостояниеКлиент.УстановитьСостояниеЗначение("ТестКлюч", Неопределено);
	Мсп_СостояниеКлиент.УстановитьСостояниеЗначение("Число", Неопределено);
	Мсп_СостояниеКлиент.УстановитьСостояниеЗначение("Ключ", Неопределено);
КонецПроцедуры

#КонецОбласти
