#Область ПрограммныйИнтерфейс

Процедура ЗарегистрироватьИнструменты() Экспорт
	Инструмент = Мсп_РеестрКлиент.НовыйОписаниеИнструмента();
	Инструмент.Имя = "legacy_tool";
	Мсп_РеестрКлиент.ЗарегистрироватьИнструмент(Инструмент);
КонецПроцедуры

Процедура ЗарегистрироватьРесурсы() Экспорт
	Ресурс = Мсп_РеестрКлиент.НовыйОписаниеРесурса();
	Ресурс.URI = "legacy://resource";
	Мсп_РеестрКлиент.ЗарегистрироватьРесурс(Ресурс);

	ШаблонРесурса = Мсп_РеестрКлиент.НовыйОписаниеШаблонаРесурса();
	ШаблонРесурса.URIШаблон = "legacy://{resource}";
	Мсп_РеестрКлиент.ЗарегистрироватьШаблонРесурса(ШаблонРесурса);
КонецПроцедуры

Процедура ЗарегистрироватьПромпты() Экспорт
	Промпт = Мсп_РеестрКлиент.НовыйОписаниеПромпта();
	Промпт.Имя = "legacy_prompt";
	Мсп_РеестрКлиент.ЗарегистрироватьПромпт(Промпт);
КонецПроцедуры

#КонецОбласти
