#Область ПрограммныйИнтерфейс

// Регистрирует сценарии тестового модуля.
Процедура ИсполняемыеСценарии() Экспорт
	ЮТТесты
		.ДобавитьТест("ИнициализироватьРеестрыСоздаетРеестры")
		.ДобавитьТест("НовыйОписаниеИнструментаВозвращаетСтруктуру")
		.ДобавитьТест("ЗарегистрироватьИнструментДобавляетВРеестр")
		.ДобавитьТест("ЗарегистрироватьИнструментБезИмениВызываетИсключение")
		.ДобавитьТест("НовыйОписаниеРесурсаВозвращаетСтруктуру")
		.ДобавитьТест("ЗарегистрироватьРесурсДобавляетВРеестр")
		.ДобавитьТест("ЗарегистрироватьРесурсБезURIВызываетИсключение")
		.ДобавитьТест("НовыйОписаниеШаблонаРесурсаВозвращаетСтруктуру")
		.ДобавитьТест("ЗарегистрироватьШаблонРесурсаДобавляетВРеестр")
		.ДобавитьТест("ЗарегистрироватьШаблонРесурсаБезURIШаблонаВызываетИсключение")
		.ДобавитьТест("НовыйОписаниеПромптаВозвращаетСтруктуру")
		.ДобавитьТест("ЗарегистрироватьПромптДобавляетВРеестр")
		.ДобавитьТест("ЗарегистрироватьПромптБезИмениВызываетИсключение")
		.ДобавитьТест("РеестрИнструментовВозвращаетСоответствие")
		.ДобавитьТест("РеестрРесурсовВозвращаетСоответствие")
		.ДобавитьТест("РеестрШаблоновРесурсовВозвращаетСоответствие")
		.ДобавитьТест("РеестрПромптовВозвращаетСоответствие");
КонецПроцедуры

// Проверяет, что ИнициализироватьРеестры создает все четыре реестра.
Процедура ИнициализироватьРеестрыСоздаетРеестры() Экспорт
	ПодготовитьСостояние();

	Мсп_РеестрКлиент.ИнициализироватьРеестры();

	ЮТест.ОжидаетЧто(ТипЗнч(Мсп_РеестрКлиент.РеестрИнструментов())).Равно(Тип("Соответствие"));
	ЮТест.ОжидаетЧто(ТипЗнч(Мсп_РеестрКлиент.РеестрРесурсов())).Равно(Тип("Соответствие"));
	ЮТест.ОжидаетЧто(ТипЗнч(Мсп_РеестрКлиент.РеестрШаблоновРесурсов())).Равно(Тип("Соответствие"));
	ЮТест.ОжидаетЧто(ТипЗнч(Мсп_РеестрКлиент.РеестрПромптов())).Равно(Тип("Соответствие"));
КонецПроцедуры

// Проверяет структуру нового описания инструмента.
Процедура НовыйОписаниеИнструментаВозвращаетСтруктуру() Экспорт
	Описание = Мсп_РеестрКлиент.НовыйОписаниеИнструмента();

	ЮТест.ОжидаетЧто(Описание)
		.Свойство("Имя").Равно("")
		.Свойство("Описание").Равно("")
		.Свойство("СхемаПараметров").Равно("");
КонецПроцедуры

// Проверяет, что ЗарегистрироватьИнструмент добавляет инструмент в реестр.
Процедура ЗарегистрироватьИнструментДобавляетВРеестр() Экспорт
	ПодготовитьСостояние();
	Описание = Мсп_РеестрКлиент.НовыйОписаниеИнструмента();
	Описание.Имя = "тест_инструмент";

	Мсп_РеестрКлиент.ЗарегистрироватьИнструмент(Описание);

	ЮТест.ОжидаетЧто(Мсп_РеестрКлиент.РеестрИнструментов().Получить("тест_инструмент")).НеРавно(Неопределено);
КонецПроцедуры

// Проверяет, что регистрация инструмента без имени вызывает исключение.
Процедура ЗарегистрироватьИнструментБезИмениВызываетИсключение() Экспорт
	ПодготовитьСостояние();
	Описание = Мсп_РеестрКлиент.НовыйОписаниеИнструмента();
	ЕстьИсключение = Ложь;

	Попытка
		Мсп_РеестрКлиент.ЗарегистрироватьИнструмент(Описание);
	Исключение
		ЕстьИсключение = Истина;
	КонецПопытки;

	ЮТест.ОжидаетЧто(ЕстьИсключение).ЭтоИстина();
КонецПроцедуры

