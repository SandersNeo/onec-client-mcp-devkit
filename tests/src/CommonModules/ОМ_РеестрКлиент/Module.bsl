КонецПроцедуры

// Проверяет, что ИнициализироватьРеестры создает все четыре реестра.
Процедура ИнициализироватьРеестрыСоздаетРеестры() Экспорт
	ПодготовитьСостояние();

	Мсп_РеестрКлиент.ИнициализироватьРеестры();

	ЮТест.ОжидаетЧто(ТипЗнч(Мсп_РеестрКлиент.РеестрИнструментов())).Равно(Тип("Соответствие"));
	ЮТест.ОжидаетЧто(ТипЗнч(Мсп_РеестрКлиент.РеестрРесурсов())).Равно(Тип("Соответствие"));
	ЮТест.ОжидаетЧто(ТипЗнч(Мсп_РеестрКлиент.РеестрШаблоновРесурсов())).Равно(Тип("Соответствие"));
	ЮТест.ОжидаетЧто(ТипЗнч(Мсп_РеестрКлиент.РеестрПромптов())).Равно(Тип("Соответствие"));
КонецПроцедуры

// Проверяет структуру нового описания инструмента.
