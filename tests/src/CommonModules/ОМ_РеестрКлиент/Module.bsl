// Проверяет совместимость нового пути отмены регистрации и legacy-пути по провайдеру.
Процедура ОтменаРегистрацииПоИсточникуИПровайдеруСовместимы() Экспорт
	ПодготовитьСостояние();

	LegacyРесурс = Мсп_РеестрКлиент.НовыйОписаниеРесурса();
	LegacyРесурс.URI = "test://legacy/provider-resource";
	LegacyРесурс.Провайдер = "LegacyProvider";
	Мсп_РеестрКлиент.ЗарегистрироватьРесурс(LegacyРесурс);

	SourceИнструмент1 = Мсп_Сервер.НовыйИнструмент(
		"source-tool-1",
		"",
		Новый Структура("type", "object"),
		Новый ОписаниеОповещения("ПодготовитьСостояние", ЭтотОбъект));
	Мсп_Сервер.ЗарегистрироватьИнструмент(SourceИнструмент1, "source-only-1");

	SourceИнструмент2 = Мсп_Сервер.НовыйИнструмент(
		"source-tool-2",
		"",
		Новый Структура("type", "object"),
		Новый ОписаниеОповещения("ПодготовитьСостояние", ЭтотОбъект));
	Мсп_Сервер.ЗарегистрироватьИнструмент(SourceИнструмент2, "source-only-2");

	Мсп_РеестрКлиент.ОтменитьРегистрацию("source-only-1");
	ЮТест.ОжидаетЧто(Мсп_РеестрКлиент.РеестрРесурсов().Получить("test://legacy/provider-resource")).НеРавно(Неопределено);
	ЮТест.ОжидаетЧто(Мсп_РеестрКлиент.РеестрИнструментов().Получить("source-tool-1")).Равно(Неопределено);
	ЮТест.ОжидаетЧто(Мсп_РеестрКлиент.РеестрИнструментов().Получить("source-tool-2")).НеРавно(Неопределено);

	Мсп_РеестрКлиент.ОтменитьРегистрациюПровайдера("LegacyProvider");
	ЮТест.ОжидаетЧто(Мсп_РеестрКлиент.РеестрРесурсов().Получить("test://legacy/provider-resource")).Равно(Неопределено);
	ЮТест.ОжидаетЧто(Мсп_РеестрКлиент.РеестрИнструментов().Получить("source-tool-2")).НеРавно(Неопределено);
КонецПроцедуры

