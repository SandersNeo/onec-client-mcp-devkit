// Проверяет, что УстановитьВключён меняет признак активности объекта в реестре.
Процедура УстановитьВключёнМеняетПризнакВРеестре() Экспорт
	ПодготовитьСостояние();
	Описание = Мсп_РеестрКлиент.НовыйОписаниеИнструмента();
	Описание.Имя = "тест_инструмент";
	Мсп_РеестрКлиент.ЗарегистрироватьИнструмент(Описание);

	Мсп_РеестрКлиент.УстановитьВключён(Мсп_РеестрКлиент.РеестрИнструментов(), "тест_инструмент", Ложь);

	ЮТест.ОжидаетЧто(Мсп_РеестрКлиент.РеестрИнструментов().Получить("тест_инструмент").Включён).Равно(Ложь);
КонецПроцедуры

// Проверяет, что РеестрИнструментов(Истина) возвращает только включённые инструменты.
Процедура РеестрИнструментовТолькоВключённыеФильтрует() Экспорт
	ПодготовитьСостояние();
	Включённый = Мсп_РеестрКлиент.НовыйОписаниеИнструмента();
	Включённый.Имя = "включённый";
	Мсп_РеестрКлиент.ЗарегистрироватьИнструмент(Включённый);

	Выключенный = Мсп_РеестрКлиент.НовыйОписаниеИнструмента();
	Выключенный.Имя = "выключенный";
	Выключенный.Включён = Ложь;
	Мсп_РеестрКлиент.ЗарегистрироватьИнструмент(Выключенный);

	Реестр = Мсп_РеестрКлиент.РеестрИнструментов(Истина);

	ЮТест.ОжидаетЧто(Реестр.Получить("включённый")).НеРавно(Неопределено);
	ЮТест.ОжидаетЧто(Реестр.Получить("выключенный")).Равно(Неопределено);
КонецПроцедуры

// Проверяет, что ОтменитьРегистрациюПровайдера удаляет все его объекты из реестров.
Процедура ОтменитьРегистрациюПровайдераУдаляетЕгоОбъекты() Экспорт
	ПодготовитьСостояние();

	Ресурс = Мсп_РеестрКлиент.НовыйОписаниеРесурса();
	Ресурс.URI = "test://provider/resource";
	Ресурс.Провайдер = "МойПровайдер";
	Мсп_РеестрКлиент.ЗарегистрироватьРесурс(Ресурс);

	ДругойРесурс = Мсп_РеестрКлиент.НовыйОписаниеРесурса();
	ДругойРесурс.URI = "test://provider/other-resource";
	ДругойРесурс.Провайдер = "ДругойПровайдер";
	Мсп_РеестрКлиент.ЗарегистрироватьРесурс(ДругойРесурс);

	Мсп_РеестрКлиент.ОтменитьРегистрациюПровайдера("МойПровайдер");

	ЮТест.ОжидаетЧто(Мсп_РеестрКлиент.РеестрРесурсов().Получить("test://provider/resource")).Равно(Неопределено);
	ЮТест.ОжидаетЧто(Мсп_РеестрКлиент.РеестрРесурсов().Получить("test://provider/other-resource")).НеРавно(Неопределено);
КонецПроцедуры

// Проверяет нормализацию отсутствующего ИсточникРегистрации в пустую строку.
Процедура РегистрацияНормализуетПустойИсточникРегистрации() Экспорт
	ПодготовитьСостояние();

	Инструмент = Мсп_РеестрКлиент.НовыйОписаниеИнструмента();
	Инструмент.Имя = "источник_инструмент";
	Мсп_РеестрКлиент.ЗарегистрироватьИнструмент(Инструмент);

	Ресурс = Мсп_РеестрКлиент.НовыйОписаниеРесурса();
	Ресурс.URI = "test://source/resource";
	Мсп_РеестрКлиент.ЗарегистрироватьРесурс(Ресурс);

	ШаблонРесурса = Мсп_РеестрКлиент.НовыйОписаниеШаблонаРесурса();
	ШаблонРесурса.URIШаблон = "test://source/resource/{id}";
	Мсп_РеестрКлиент.ЗарегистрироватьШаблонРесурса(ШаблонРесурса);

	Промпт = Мсп_РеестрКлиент.НовыйОписаниеПромпта();
	Промпт.Имя = "source_prompt";
	Мсп_РеестрКлиент.ЗарегистрироватьПромпт(Промпт);

	ЮТест.ОжидаетЧто(Мсп_РеестрКлиент.РеестрИнструментов().Получить("источник_инструмент").ИсточникРегистрации).Равно("");
	ЮТест.ОжидаетЧто(Мсп_РеестрКлиент.РеестрРесурсов().Получить("test://source/resource").ИсточникРегистрации).Равно("");
