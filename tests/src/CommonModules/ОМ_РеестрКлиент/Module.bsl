	Мсп_СостояниеКлиент.УстановитьЗначениеСостоянияСервера("Ресурсы", Новый Соответствие);
	Мсп_СостояниеКлиент.УстановитьЗначениеСостоянияСервера("ШаблоныРесурсов", Новый Соответствие);
	Мсп_СостояниеКлиент.УстановитьЗначениеСостоянияСервера("Промпты", Новый Соответствие);
КонецПроцедуры

#КонецОбласти
