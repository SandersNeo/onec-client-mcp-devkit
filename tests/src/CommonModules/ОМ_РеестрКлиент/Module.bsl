// Проверяет точное совпадение ИсточникРегистрации при отмене регистрации.
Процедура ОтменитьРегистрациюУдаляетТолькоПоТочномуСовпадениюИсточника() Экспорт
	ПодготовитьСостояние();

	ИнструментТочный = Мсп_РеестрКлиент.НовыйОписаниеИнструмента();
	ИнструментТочный.Имя = "tool-source-a";
	ИнструментТочный.Вставить("ИсточникРегистрации", "source-a");
	Мсп_РеестрКлиент.ЗарегистрироватьИнструмент(ИнструментТочный);

	РесурсПохожий = Мсп_РеестрКлиент.НовыйОписаниеРесурса();
	РесурсПохожий.URI = "test://source-ab";
	РесурсПохожий.Вставить("ИсточникРегистрации", "source-ab");
	Мсп_РеестрКлиент.ЗарегистрироватьРесурс(РесурсПохожий);

	ШаблонТочный = Мсп_РеестрКлиент.НовыйОписаниеШаблонаРесурса();
	ШаблонТочный.URIШаблон = "test://source-a/{id}";
	ШаблонТочный.Вставить("ИсточникРегистрации", "source-a");
	Мсп_РеестрКлиент.ЗарегистрироватьШаблонРесурса(ШаблонТочный);

	ПромптДругой = Мсп_РеестрКлиент.НовыйОписаниеПромпта();
	ПромптДругой.Имя = "prompt-other-source";
	ПромптДругой.Вставить("ИсточникРегистрации", "other-source");
	Мсп_РеестрКлиент.ЗарегистрироватьПромпт(ПромптДругой);

	Мсп_РеестрКлиент.ОтменитьРегистрацию("source-a");

	ЮТест.ОжидаетЧто(Мсп_РеестрКлиент.РеестрИнструментов().Получить("tool-source-a")).Равно(Неопределено);
	ЮТест.ОжидаетЧто(Мсп_РеестрКлиент.РеестрШаблоновРесурсов().Получить("test://source-a/{id}")).Равно(Неопределено);
	ЮТест.ОжидаетЧто(Мсп_РеестрКлиент.РеестрРесурсов().Получить("test://source-ab")).НеРавно(Неопределено);
	ЮТест.ОжидаетЧто(Мсп_РеестрКлиент.РеестрПромптов().Получить("prompt-other-source")).НеРавно(Неопределено);
