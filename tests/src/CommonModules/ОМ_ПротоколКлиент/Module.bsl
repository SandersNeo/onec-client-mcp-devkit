// Проверяет, что НовыйОписаниеИнструмента заполняет поля name, description, inputSchema.
Процедура НовыйОписаниеИнструментаЗаполняетПоля() Экспорт
	Схема = Новый Структура("type", "object");

	Описание = Мсп_ПротоколКлиент.НовыйОписаниеИнструмента("мой_инструмент", "Описание", Схема);

	ЮТест.ОжидаетЧто(Описание)
		.Свойство("name").Равно("мой_инструмент")
		.Свойство("description").Равно("Описание")
		.Свойство("inputSchema").Равно(Схема);
КонецПроцедуры

// Проверяет, что асинхронный инструмент публикует execution.taskSupport.
Процедура НовыйОписаниеИнструментаДляАсинхронногоИнструментаДобавляетExecution() Экспорт
	Схема = Новый Структура("type", "object");

	Описание = Мсп_ПротоколКлиент.НовыйОписаниеИнструмента("мой_инструмент", "Описание", Схема, Истина);

	ЮТест.ОжидаетЧто(Описание.Свойство("execution")).Равно(Истина);
	ЮТест.ОжидаетЧто(Описание.execution.taskSupport).Равно("optional");
КонецПроцедуры

// Проверяет, что внутренний запрос вызова создается через единый контракт.
Процедура НовыйЗапросВызоваЗаполняетКонтракт() Экспорт
	Аргументы = Новый Структура("ticks", 3);
	Контекст = Новый Структура("kind", "tools");

	Запрос = Мсп_ПротоколКлиент.НовыйЗапросВызова(Аргументы, Контекст, "task-123");

	ЮТест.ОжидаетЧто(Запрос)
		.Свойство("Аргументы").Равно(Аргументы)
		.Свойство("Контекст").Равно(Контекст)
		.Свойство("ИдентификаторЗадачи").Равно("task-123");
КонецПроцедуры

// Проверяет, что параметры завершения задачи создаются через единый контракт.
Процедура НовыйПараметрыЗавершенияЗадачиЗаполняетКонтракт() Экспорт
	Тело = Новый Структура("result", Новый Структура("content", Новый Массив));

	ПараметрыЗавершения = Мсп_ПротоколКлиент.НовыйПараметрыЗавершенияЗадачи(
		"completed",
		"",
		Тело);

	ЮТест.ОжидаетЧто(ПараметрыЗавершения)
		.Свойство("Статус").Равно("completed")
		.Свойство("Сообщение").Равно("")
		.Свойство("Тело").Равно(Тело);
КонецПроцедуры

// Проверяет, что успешный результат задачи нормализуется в result.
Процедура ПодготовитьЗавершениеЗадачиИнструментаДляУспехаВозвращаетResult() Экспорт
	Подготовлено = Мсп_ПротоколКлиент.ПодготовитьЗавершениеЗадачиИнструмента("готово");

	ЮТест.ОжидаетЧто(Подготовлено)
		.Свойство("Статус").Равно("completed");
	ЮТест.ОжидаетЧто(Подготовлено.Тело.result.content[0].text).Равно("готово");
КонецПроцедуры

// Проверяет, что бизнес-структура с полем error не воспринимается как envelope ошибки.
Процедура ПодготовитьЗавершениеЗадачиИнструментаНеСчитаетБизнесСтруктуруОшибкой() Экспорт
	Подготовлено = Мсп_ПротоколКлиент.ПодготовитьЗавершениеЗадачиИнструмента(
		Новый Структура("error,count", Ложь, 3));

	ЮТест.ОжидаетЧто(Подготовлено)
		.Свойство("Статус").Равно("completed");
	ЮТест.ОжидаетЧто(Подготовлено.Тело.result.content[0].text).НеРавно("");
КонецПроцедуры

// Проверяет, что ошибка инструмента нормализуется в error.
Процедура ПодготовитьЗавершениеЗадачиИнструментаДляОшибкиВозвращаетError() Экспорт
	ОшибкаИнструмента = Мсп_Сервер.ОшибкаИнструмента("ACTION_FAILED", "что-то пошло не так");
	Подготовлено = Мсп_ПротоколКлиент.ПодготовитьЗавершениеЗадачиИнструмента(ОшибкаИнструмента);

	ЮТест.ОжидаетЧто(Подготовлено)
		.Свойство("Статус").Равно("failed");
	ЮТест.ОжидаетЧто(Подготовлено.Тело.error.code).Равно(-32603);
	ЮТест.ОжидаетЧто(Подготовлено.Тело.error.message).Равно("ACTION_FAILED: что-то пошло не так");
КонецПроцедуры

// Проверяет, что явный envelope ошибки задачи сохраняет failed-статус.
Процедура ПодготовитьЗавершениеЗадачиИнструментаДляЯвнойОшибкиВозвращаетError() Экспорт
	Подготовлено = Мсп_ПротоколКлиент.ПодготовитьЗавершениеЗадачиИнструмента(
		Новый Структура("error", Новый Структура("code,message", -32601, "Not found")));

	ЮТест.ОжидаетЧто(Подготовлено)
		.Свойство("Статус").Равно("failed");
	ЮТест.ОжидаетЧто(Подготовлено.Тело.error.code).Равно(-32601);
	ЮТест.ОжидаетЧто(Подготовлено.Тело.error.message).Равно("Not found");
КонецПроцедуры

// Проверяет, что асинхронный инструмент можно вызвать без task-режима.
Процедура ВызоватьАсинхронныйИнструментВСинхронномРежимеВозвращаетОтвет() Экспорт
	ПодготовитьСостояние();
	ЗарегистрироватьТестовыйИнструмент("async_tool", "ОбработчикАсинхронногоИнструментаСКороткимОтветом", Истина);

	Ответ = Мсп_ПротоколКлиент.ВызватьИнструмент(1, Новый Структура("name", "async_tool"), "test-session");
	ЮТест.ОжидаетЧто(Ответ.jsonrpc).Равно("2.0");
	ЮТест.ОжидаетЧто(Ответ.result.content[0].text).Равно("async-result");
КонецПроцедуры

// Проверяет, что асинхронный инструмент без немедленного результата требует task-based вызов.
Процедура ВызоватьАсинхронныйИнструментВСинхронномРежимеБезРезультатаВозвращаетОшибку() Экспорт
	ПодготовитьСостояние();
	ЗарегистрироватьТестовыйИнструмент("async_tool", "ОбработчикАсинхронногоИнструмента", Истина);

	Ответ = Мсп_ПротоколКлиент.ВызватьИнструмент(1, Новый Структура("name", "async_tool"), "test-session");
	Ошибка = ПолучитьОшибкуОтвета(Ответ);

	ЮТест.ОжидаетЧто(Ошибка)
		.Свойство("code").Равно(-32601)
		.Свойство("message").Равно("Tool requires task-based invocation");
КонецПроцедуры

// Проверяет, что sync-вызов async-инструмента маппит ОшибкаИнструмента в JSON-RPC ошибку.
Процедура ВызоватьАсинхронныйИнструментВСинхронномРежимеОшибкаИнструментаВозвращаетОшибку() Экспорт
	ПодготовитьСостояние();
	ЗарегистрироватьТестовыйИнструмент("async_tool", "ОбработчикАсинхронногоИнструментаСОшибкой", Истина);

	Ответ = Мсп_ПротоколКлиент.ВызватьИнструмент(1, Новый Структура("name", "async_tool"), "test-session");
	Ошибка = ПолучитьОшибкуОтвета(Ответ);

	ЮТест.ОжидаетЧто(Ошибка)
		.Свойство("code").Равно(-32603)
		.Свойство("message").Равно("ACTION_FAILED: sync mode is not supported");
КонецПроцедуры

// Проверяет передачу идентификатора task-based задачи в асинхронный инструмент.
Процедура ВызоватьАсинхронныйИнструментВРежимеЗадачиПередаетИдентификаторЗадачи() Экспорт
	ПодготовитьСостояние();
	ЗарегистрироватьТестовыйИнструмент("async_tool", "ОбработчикАсинхронногоИнструмента", Истина);

	Параметры = Новый Структура(
		"name,arguments,executionMode,taskId,progressToken",
		"async_tool",
		Новый Структура("ticks", 3),
		"task",
		"task-123",
		"progress-123");
	Ответ = Мсп_ПротоколКлиент.ВызватьИнструмент("", Параметры, "test-session");
	ПоследнийАсинхронныйЗапрос = ПолучитьПоследнийАсинхронныйЗапрос();

	ЮТест.ОжидаетЧто(Ответ).ЭтоНеопределено();
	ЮТест.ОжидаетЧто(ПоследнийАсинхронныйЗапрос).НеРавно(Неопределено);
	ЮТест.ОжидаетЧто(ПоследнийАсинхронныйЗапрос)
		.Свойство("ИдентификаторЗадачи").Равно("task-123");
	ЮТест.ОжидаетЧто(ПоследнийАсинхронныйЗапрос.Контекст)
		.Свойство("executionMode").Равно("task")
		.Свойство("progressToken").Равно("progress-123")
		.Свойство("sessionId").Равно("test-session");
	ЮТест.ОжидаетЧто(ПоследнийАсинхронныйЗапрос.Контекст).НетСвойства("responseMode");
	ЮТест.ОжидаетЧто(ПоследнийАсинхронныйЗапрос.Контекст.meta)
		.Свойство("progressToken").Равно("progress-123");
КонецПроцедуры

// Проверяет, что обычный инструмент не принимает task-based вызов.
Процедура ВызватьСинхронныйИнструментВTaskРежимеВозвращаетОшибку() Экспорт
	ПодготовитьСостояние();
	ЗарегистрироватьТестовыйИнструмент("sync_tool", "ОбработчикИнструмента");

	Параметры = Новый Структура(
		"name,executionMode",
		"sync_tool",
		"task");
	Ответ = Мсп_ПротоколКлиент.ВызватьИнструмент("request-1", Параметры, "test-session");
	Ошибка = ПолучитьОшибкуОтвета(Ответ);

	ЮТест.ОжидаетЧто(Ошибка)
		.Свойство("code").Равно(-32601)
		.Свойство("message").Равно("Tool does not support task-based invocation");
КонецПроцедуры

