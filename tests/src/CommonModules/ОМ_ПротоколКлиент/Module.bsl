// Проверяет, что ПрочитатьРесурс с зарегистрированным ресурсом возвращает ответ с result.
Процедура ПрочитатьРесурсВозвращаетОтвет() Экспорт
	ПодготовитьСостояние();
	Описание = Мсп_РеестрКлиент.НовыйОписаниеРесурса();
	Описание.URI = "test://ресурс";
	Описание.MimeType = "application/json";
	Описание.Обработчик = Новый ОписаниеОповещения("ОбработчикРесурса", ЭтотОбъект);
	Мсп_РеестрКлиент.ЗарегистрироватьРесурс(Описание);

