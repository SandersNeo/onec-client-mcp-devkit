#Область ПрограммныйИнтерфейс

// Регистрирует сценарии тестового модуля.
Процедура ИсполняемыеСценарии() Экспорт
	ЮТТесты
		.ДобавитьТест("НовыйОписаниеИнструментаЗаполняетПоля")
		.ДобавитьТест("НовыйОписаниеРесурсаЗаполняетПоля")
		.ДобавитьТест("НовыйОписаниеШаблонаРесурсаЗаполняетПоля")
		.ДобавитьТест("НовыйОписаниеПромптаЗаполняетПоля")
		.ДобавитьТест("ВызоватьИнструментБезИмениВозвращаетОшибку")
		.ДобавитьТест("ВызоватьИнструментНезарегистрированныйВозвращаетОшибку")
		.ДобавитьТест("ВызоватьИнструментВозвращаетОтвет")
		.ДобавитьТест("ПрочитатьРесурсБезURIВозвращаетОшибку")
		.ДобавитьТест("ПрочитатьРесурсНезарегистрированныйВозвращаетОшибку")
		.ДобавитьТест("ПолучитьПромптБезИмениВозвращаетОшибку")
		.ДобавитьТест("ПолучитьПромптНезарегистрированныйВозвращаетОшибку");
КонецПроцедуры

// Проверяет, что НовыйОписаниеИнструмента заполняет поля name, description, inputSchema.
Процедура НовыйОписаниеИнструментаЗаполняетПоля() Экспорт
	Схема = Новый Структура("type", "object");

	Описание = Мсп_ПротоколКлиент.НовыйОписаниеИнструмента("мой_инструмент", "Описание", Схема);

	ЮТест.ОжидаетЧто(Описание)
		.Свойство("name").Равно("мой_инструмент")
		.Свойство("description").Равно("Описание")
		.Свойство("inputSchema").НеРавно(Неопределено);
КонецПроцедуры

// Проверяет, что НовыйОписаниеРесурса заполняет поля uri, name, description, mimeType.
Процедура НовыйОписаниеРесурсаЗаполняетПоля() Экспорт
	Описание = Мсп_ПротоколКлиент.НовыйОписаниеРесурса("test://ресурс", "Ресурс", "Описание", "application/json");

	ЮТест.ОжидаетЧто(Описание)
		.Свойство("uri").Равно("test://ресурс")
		.Свойство("name").Равно("Ресурс")
		.Свойство("mimeType").Равно("application/json");
КонецПроцедуры

// Проверяет, что НовыйОписаниеШаблонаРесурса заполняет поля uriTemplate, name, description, mimeType.
Процедура НовыйОписаниеШаблонаРесурсаЗаполняетПоля() Экспорт
	Описание = Мсп_ПротоколКлиент.НовыйОписаниеШаблонаРесурса("test://ресурс/{id}", "Шаблон", "Описание", "application/json");

	ЮТест.ОжидаетЧто(Описание)
		.Свойство("uriTemplate").Равно("test://ресурс/{id}")
		.Свойство("name").Равно("Шаблон");
КонецПроцедуры

// Проверяет, что НовыйОписаниеПромпта заполняет поля name, description, arguments.
Процедура НовыйОписаниеПромптаЗаполняетПоля() Экспорт
	Аргументы = Новый Структура("arg1", "описание");

	Описание = Мсп_ПротоколКлиент.НовыйОписаниеПромпта("мой_промпт", "Описание", Аргументы);

	ЮТест.ОжидаетЧто(Описание)
		.Свойство("name").Равно("мой_промпт")
		.Свойство("description").Равно("Описание")
		.Свойство("arguments").НеРавно(Неопределено);
КонецПроцедуры

// Проверяет, что ВызоватьИнструмент без имени возвращает JSON-RPC ошибку -32602.
Процедура ВызоватьИнструментБезИмениВозвращаетОшибку() Экспорт
	ПодготовитьСостояние();

	Ответ = Мсп_ПротоколКлиент.ВызоватьИнструмент(1, Новый Структура, "");

	ЮТест.ОжидаетЧто(Ответ.Свойство("error")).ЭтоИстина();
	ЮТест.ОжидаетЧто(Ответ.error.code).Равно(-32602);
КонецПроцедуры

// Проверяет, что ВызоватьИнструмент с незарегистрированным именем возвращает ошибку -32601.
Процедура ВызоватьИнструментНезарегистрированныйВозвращаетОшибку() Экспорт
	ПодготовитьСостояние();
	Параметры = Новый Структура("name", "несуществующий");

	Ответ = Мсп_ПротоколКлиент.ВызоватьИнструмент(1, Параметры, "");

	ЮТест.ОжидаетЧто(Ответ.Свойство("error")).ЭтоИстина();
	ЮТест.ОжидаетЧто(Ответ.error.code).Равно(-32601);
КонецПроцедуры

// Проверяет, что ВызоватьИнструмент с зарегистрированным обработчиком возвращает ответ с result.
Процедура ВызоватьИнструментВозвращаетОтвет() Экспорт
	ПодготовитьСостояние();
	Описание = Мсп_РеестрКлиент.НовыйОписаниеИнструмента();
	Описание.Имя = "тест";
	Описание.Обработчик = Новый ОписаниеОповещения("ОбработчикИнструмента", ЭтотОбъект);
	Мсп_РеестрКлиент.ЗарегистрироватьИнструмент(Описание);

	Параметры = Новый Структура("name", "тест");
	Ответ = Мсп_ПротоколКлиент.ВызоватьИнструмент(1, Параметры, "");

	ЮТест.ОжидаетЧто(Ответ.jsonrpc).Равно("2.0");
	ЮТест.ОжидаетЧто(Ответ.Свойство("result")).ЭтоИстина();
КонецПроцедуры

