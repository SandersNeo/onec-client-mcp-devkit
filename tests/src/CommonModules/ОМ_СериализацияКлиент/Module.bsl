#Область ПрограммныйИнтерфейс

// Регистрирует сценарии тестового модуля.
Процедура ИсполняемыеСценарии() Экспорт
	ЮТТесты
		.ДобавитьТест("ПрочитатьJSONСтрокуВозвращаетСтруктуру")
		.ДобавитьТест("ПрочитатьJSONСтрокуВозвращаетМассив")
		.ДобавитьТест("ПрочитатьJSONСтрокуВозвращаетСтроку")
		.ДобавитьТест("ПрочитатьJSONСтрокуБезОшибокВозвращаетОбъект")
		.ДобавитьТест("ПрочитатьJSONСтрокуБезОшибокВозвращаетУмолчаниеПриОшибке")
		.ДобавитьТест("СериализоватьВозвращаетJSONСтроку")
		.ДобавитьТест("СериализоватьРаундТрип");
КонецПроцедуры

// Проверяет чтение JSON-объекта в Структуру.
Процедура ПрочитатьJSONСтрокуВозвращаетСтруктуру() Экспорт
	Результат = Мсп_СериализацияКлиент.ПрочитатьJSONСтроку("{""name"":""test""}");

	ЮТест.ОжидаетЧто(ТипЗнч(Результат)).Равно(Тип("Соответствие"));
	ЮТест.ОжидаетЧто(Результат.Получить("name")).Равно("test");
КонецПроцедуры

// Проверяет чтение JSON-массива.
Процедура ПрочитатьJSONСтрокуВозвращаетМассив() Экспорт
	Результат = Мсп_СериализацияКлиент.ПрочитатьJSONСтроку("[1,2,3]");

	ЮТест.ОжидаетЧто(ТипЗнч(Результат)).Равно(Тип("Массив"));
	ЮТест.ОжидаетЧто(Результат.Количество()).Равно(3);
КонецПроцедуры

// Проверяет чтение JSON-строки.
Процедура ПрочитатьJSONСтрокуВозвращаетСтроку() Экспорт
	Результат = Мсп_СериализацияКлиент.ПрочитатьJSONСтроку("""привет""");

	ЮТест.ОжидаетЧто(Результат).Равно("привет");
КонецПроцедуры

// Проверяет, что ПрочитатьJSONСтрокуБезОшибок возвращает объект при корректном JSON.
Процедура ПрочитатьJSONСтрокуБезОшибокВозвращаетОбъект() Экспорт
	Результат = Мсп_СериализацияКлиент.ПрочитатьJSONСтрокуБезОшибок("{""x"":1}", Неопределено);

	ЮТест.ОжидаетЧто(Результат).НеРавно(Неопределено);
КонецПроцедуры

// Проверяет, что ПрочитатьJSONСтрокуБезОшибок возвращает значение по умолчанию при ошибке.
Процедура ПрочитатьJSONСтрокуБезОшибокВозвращаетУмолчаниеПриОшибке() Экспорт
	Результат = Мсп_СериализацияКлиент.ПрочитатьJSONСтрокуБезОшибок("не json", "умолчание");

	ЮТест.ОжидаетЧто(Результат).Равно("умолчание");
КонецПроцедуры

// Проверяет, что Сериализовать возвращает непустую JSON-строку.
Процедура СериализоватьВозвращаетJSONСтроку() Экспорт
	Данные = Новый Структура("ключ", "значение");

	Результат = Мсп_СериализацияКлиент.Сериализовать(Данные);

	ЮТест.ОжидаетЧто(ТипЗнч(Результат)).Равно(Тип("Строка"));
	ЮТест.ОжидаетЧто(Результат).Содержит("ключ");
КонецПроцедуры

// Проверяет раунд-трип: сериализация и обратное чтение.
Процедура СериализоватьРаундТрип() Экспорт
	Данные = Новый Структура("имя,число", "тест", 7);

	JSON = Мсп_СериализацияКлиент.Сериализовать(Данные);
	Прочитано = Мсп_СериализацияКлиент.ПрочитатьJSONСтроку(JSON);

	ЮТест.ОжидаетЧто(Прочитано).НеРавно(Неопределено);
КонецПроцедуры

#КонецОбласти
