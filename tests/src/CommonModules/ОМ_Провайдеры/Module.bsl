// Проверяет, что отсутствие опционального метода в английской локали не логируется как ошибка.
Процедура ОпциональныйМетодАнглийскаяЛокальНеЛогируется() Экспорт
	ИмяФайлаЛога = ЮТТестовыеДанные.НовоеИмяВременногоФайла("log");
	ЮТФайлы.ЗаписатьТекстВФайла(ИмяФайлаЛога, "");
	Мсп_СостояниеКлиент.УстановитьЗначениеСостоянияСервера(
		"ПараметрыЛогирования",
		Новый Структура("Логировать,УровеньЛога,ФайлЛога", Истина, "error", ИмяФайлаЛога));
	
	Ошибка = Новый Структура("Описание", "Object method not found (ЗарегистрироватьИнструменты)");
	Мсп_ПровайдерыКлиент.ОбработатьОшибкуОпциональногоМетода(Ошибка, "ЗарегистрироватьИнструменты");
	Мсп_СостояниеКлиент.УстановитьЗначениеСостоянияСервера(
		"ПараметрыЛогирования",
		Новый Структура("Логировать,УровеньЛога,ФайлЛога", Ложь, "error", ""));
	
	ЮТест.ОжидаетЧто(ЗначениеЗаполнено(ЮТФайлы.ДанныеТекстовогоФайла(ИмяФайлаЛога))).ЭтоЛожь();
КонецПроцедуры

