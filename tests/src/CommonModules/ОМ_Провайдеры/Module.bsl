#Область СлужебныеПроцедурыИФункции

Процедура ПодготовитьИнструменты()
	Мсп_РеестрКлиент.ИнициализироватьРеестры();
	Мсп_РеестрКлиент.РеестрИнструментов().Очистить();
	Мсп_ПровайдерыКлиент.ЗарегистрироватьПровайдеров();
КонецПроцедуры

Процедура ПодготовитьРесурсы()
	ПодготовитьПустыеРесурсы();
	Мсп_ПровайдерыКлиент.ЗарегистрироватьПровайдеров();
КонецПроцедуры

Процедура ПодготовитьПустыеРесурсы()
	Мсп_РеестрКлиент.ИнициализироватьРеестры();
	
	Мсп_РеестрКлиент.РеестрИнструментов().Очистить();
	Мсп_РеестрКлиент.РеестрРесурсов().Очистить();
	Мсп_РеестрКлиент.РеестрШаблоновРесурсов().Очистить();
	Мсп_РеестрКлиент.РеестрПромптов().Очистить();
КонецПроцедуры

Процедура ПодготовитьСостояниеТестКлиента()
	Мсп_СостояниеКлиент.УстановитьЗначениеСостоянияСервера(
		"ПараметрыЛогирования",
		Новый Структура("Логировать,УровеньЛога,ФайлЛога", Ложь, "error", ""));
	Мсп_СостояниеКлиент.УстановитьЗначениеСостоянияСервера("ПамятьТестКлиент", Новый Структура);
КонецПроцедуры

Процедура УстановитьТестКлиент()
	Мсп_СостояниеКлиент.УстановитьЗначениеСостоянияСервера(
		"ПараметрыЛогирования",
		Новый Структура("Логировать,УровеньЛога,ФайлЛога", Ложь, "error", ""));

	ТестКлиент = ТестКлиентМок();
	Память = Новый Структура;
	Память.Вставить("ТестКлиент", ТестКлиент);
	Мсп_СостояниеКлиент.УстановитьЗначениеСостоянияСервера("ПамятьТестКлиент", Память);
КонецПроцедуры

Функция ТестКлиентМок()
	ТестКлиентМок = Новый Структура;
	ТестКлиентМок.Вставить("РазорватьСоединение", ТестКлиентМок);
	ТестКлиентМок.Вставить("Закрыть", ТестКлиентМок);
	Возврат ТестКлиентМок;
КонецФункции

Функция ВызватьИнструмент(ИмяИнструмента, Аргументы)
	Параметры = Новый Структура("name,arguments", ИмяИнструмента, Аргументы);
	Идентификатор = "1";
	Возврат Мсп_ПротоколКлиент.ВызоватьИнструмент(Идентификатор, Параметры, "test-session");
КонецФункции

Функция ПолучитьДанныеОтвета(Ответ)
	Возврат ПолучитьДанныеОтветаИлиОшибки(Ответ);
КонецФункции

// Получает данные из ответа или из ошибки JSON-RPC.
Функция ПолучитьДанныеОтветаИлиОшибки(Ответ)
	Если Ответ = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;

	// Проверяем наличие ошибки
	Ошибка = Мсп_Коллекции.Свойство(Ответ, "error", Неопределено);
	Если Ошибка <> Неопределено Тогда
		Код = Мсп_Коллекции.Свойство(Ошибка, "code", 0);
		Сообщение = Мсп_Коллекции.Свойство(Ошибка, "message", "");
		// Разбираем сообщение вида "UI_NOT_READY: test client not started"
		Если СтрНайти(Сообщение, ":") > 0 Тогда
			Части = СтрРазделить(Сообщение, ":");
			Возврат Новый Структура("ok,error,details", Ложь, СокрЛП(Части[0]), СокрЛП(Части[1]));
		КонецЕсли;
		Возврат Новый Структура("ok,error", Ложь, Сообщение);
	КонецЕсли;

	// Получаем result
	Результат = Мсп_Коллекции.Свойство(Ответ, "result", Неопределено);
	Если Результат = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;

	Контент = Мсп_Коллекции.Свойство(Результат, "content", Неопределено);
	Если ТипЗнч(Контент) <> Тип("Массив") Тогда
		Возврат Неопределено;
	КонецЕсли;
	Если Контент.Количество() = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;

	Элемент = Контент[0];
	Текст = Мсп_Коллекции.Свойство(Элемент, "text", "");
	Если Не ЗначениеЗаполнено(Текст) Тогда
		Возврат Неопределено;
	КонецЕсли;

	Возврат Мсп_СериализацияКлиент.ПрочитатьJSONСтроку(Текст);
КонецФункции

#КонецОбласти
