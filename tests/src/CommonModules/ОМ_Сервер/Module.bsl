// Проверяет конструктор промпта.
Процедура НовыйПромптЗаполняетПоля() Экспорт
	Оповещение = Новый ОписаниеОповещения("ОбработчикТест", ЭтотОбъект);
	Аргументы = Новый Массив;
	Аргументы.Добавить(Новый Структура("name,description,required", "topic", "Тема", Истина));
	Описание = Мсп_Сервер.НовыйПромпт("summarize", "Описание промпта", Аргументы, Оповещение);

	ЮТест.ОжидаетЧто(Описание)
		.Свойство("Имя").Равно("summarize")
		.Свойство("Описание").Равно("Описание промпта")
		.Свойство("Аргументы").Равно(Аргументы)
		.Свойство("Обработчик").Равно(Оповещение);
	ЮТест.ОжидаетЧто(Описание.Провайдер).Равно("");
	ЮТест.ОжидаетЧто(Описание.Включён).Равно(Истина);
	ЮТест.ОжидаетЧто(Описание.ИсточникРегистрации).Равно("");
КонецПроцедуры

// Проверяет, что конструктор промпта принимает только массив аргументов.
Процедура НовыйПромптСНекорректнымиАргументамиВызываетИсключение() Экспорт
