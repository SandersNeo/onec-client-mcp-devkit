Функция ВызватьИПолучитьТекстИсключения(ИмяМетодаОшибки)
	Попытка
		Если ИмяМетодаОшибки = "НекорректныеПараметры" Тогда
			Мсп_Ошибки.НекорректныеПараметры("test");
		ИначеЕсли ИмяМетодаОшибки = "НеНайдено" Тогда
			Мсп_Ошибки.НеНайдено("test");
		ИначеЕсли ИмяМетодаОшибки = "Внутренняя" Тогда
			Мсп_Ошибки.Внутренняя("test");
		ИначеЕсли ИмяМетодаОшибки = "ДоступЗапрещен" Тогда
			Мсп_Ошибки.ДоступЗапрещен("test");
		ИначеЕсли ИмяМетодаОшибки = "СбойВыполнения" Тогда
			Мсп_Ошибки.СбойВыполнения("test");
		КонецЕсли;
	Исключение
		Возврат ОписаниеОшибки();
	КонецПопытки;

	Возврат "";
КонецФункции

Процедура ПроверитьКодОшибки(ИмяМетодаОшибки, ОжидаемыйКодОшибки)
	КодОшибки = ВызватьИПолучитьКодОшибки(ИмяМетодаОшибки);
	ЮТест.ОжидаетЧто(КодОшибки).Равно(ОжидаемыйКодОшибки);
КонецПроцедуры

Функция ВызватьИПолучитьКодОшибки(ИмяМетодаОшибки)
	Попытка
		Если ИмяМетодаОшибки = "НекорректныеПараметры" Тогда
			Мсп_Ошибки.НекорректныеПараметры("test");
		ИначеЕсли ИмяМетодаОшибки = "НеНайдено" Тогда
			Мсп_Ошибки.НеНайдено("test");
		ИначеЕсли ИмяМетодаОшибки = "Внутренняя" Тогда
			Мсп_Ошибки.Внутренняя("test");
		ИначеЕсли ИмяМетодаОшибки = "ДоступЗапрещен" Тогда
			Мсп_Ошибки.ДоступЗапрещен("test");
		ИначеЕсли ИмяМетодаОшибки = "СбойВыполнения" Тогда
			Мсп_Ошибки.СбойВыполнения("test");
		КонецЕсли;
	Исключение
		Информация = ИнформацияОбОшибке();
		Возврат Информация.Код;
	КонецПопытки;

	Возврат "";
КонецФункции

