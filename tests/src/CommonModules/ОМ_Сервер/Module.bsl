// Проверяет, что долгая операция больше штатного таймаута остается отложенной.
Процедура ДолгаяОперацияБольше30СекундОстаетсяОтложенной() Экспорт
	Мсп_РеестрКлиент.ИнициализироватьРеестры();
	Мсп_СостояниеКлиент.УстановитьЗначениеСостоянияСервера("ПоследнийЗапросДолгойОперации", Неопределено);
	Оповещение = Новый ОписаниеОповещения("ОбработчикДолгойОперации", ЭтотОбъект);
	Инструмент = Мсп_Сервер.НовыйИнструмент(
		"long-operation-31",
		"Long operation",
		Новый Структура("type", "object"),
		Оповещение,
		Истина);
	Мсп_Сервер.ЗарегистрироватьИнструмент(Инструмент, "ОМ_Сервер");

	ВызовИнструмента = Мсп_ПротоколКлиент.НовыйВызовИнструмента(
		"request-long-31",
		"long-operation-31",
		Новый Структура("durationSeconds", 31),
		"",
		"sync",
		"",
		"progress-long-31");

	НачалоВызова = ТекущаяУниверсальнаяДатаВМиллисекундах();
	Ответ = Мсп_ПротоколКлиент.ВызватьИнструмент(ВызовИнструмента);
	ДлительностьВызова = ТекущаяУниверсальнаяДатаВМиллисекундах() - НачалоВызова;
	ПоследнийЗапрос = Мсп_СостояниеКлиент.ЗначениеСостоянияСервера("ПоследнийЗапросДолгойОперации");

	ЮТест.ОжидаетЧто(Ответ).ЭтоНеопределено();
	ЮТест.ОжидаетЧто(ДлительностьВызова >= 30000).ЭтоИстина();
	ЮТест.ОжидаетЧто(ПоследнийЗапрос)
		.Свойство("Идентификатор").Равно("request-long-31");
	ЮТест.ОжидаетЧто(ПоследнийЗапрос.Аргументы.durationSeconds).Равно(31);
	ЮТест.ОжидаетЧто(ПоследнийЗапрос.Контекст.progressToken).Равно("progress-long-31");
КонецПроцедуры

