// Проверяет регистрацию v2-описаний с явным источником.
Процедура РегистрацияV2СохраняетИсточникРегистрации() Экспорт
	Мсп_РеестрКлиент.ИнициализироватьРеестры();

	Оповещение = Новый ОписаниеОповещения("ОбработчикТест", ЭтотОбъект);
	Источник = "ОМ_Сервер";
	Инструмент = Мсп_Сервер.НовыйИнструмент("tool-v2", "Описание", Новый Структура("type", "object"), Оповещение);
	Ресурс = Мсп_Сервер.НовыйРесурс("test://resource/v2", "Ресурс", "Описание", "application/json", Оповещение);
	ШаблонРесурса = Мсп_Сервер.НовыйШаблонРесурса("test://resource/{id}/v2", "Шаблон", "Описание", "application/json", Оповещение);
	Промпт = Мсп_Сервер.НовыйПромпт("prompt-v2", "Описание", Новый Структура, Оповещение);

	Мсп_Сервер.ЗарегистрироватьИнструмент(Инструмент, Источник);
	Мсп_Сервер.ЗарегистрироватьРесурс(Ресурс, Источник);
	Мсп_Сервер.ЗарегистрироватьШаблонРесурса(ШаблонРесурса, Источник);
	Мсп_Сервер.ЗарегистрироватьПромпт(Промпт, Источник);

	ЮТест.ОжидаетЧто(Мсп_РеестрКлиент.РеестрИнструментов().Получить("tool-v2").ИсточникРегистрации).Равно(Источник);
	ЮТест.ОжидаетЧто(Мсп_РеестрКлиент.РеестрРесурсов().Получить("test://resource/v2").ИсточникРегистрации).Равно(Источник);
	ЮТест.ОжидаетЧто(Мсп_РеестрКлиент.РеестрШаблоновРесурсов().Получить("test://resource/{id}/v2").ИсточникРегистрации).Равно(Источник);
	ЮТест.ОжидаетЧто(Мсп_РеестрКлиент.РеестрПромптов().Получить("prompt-v2").ИсточникРегистрации).Равно(Источник);
КонецПроцедуры

