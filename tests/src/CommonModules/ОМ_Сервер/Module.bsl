// Проверяет конструкторы схемы параметров с enum-полем.
Процедура СхемаПараметровСоздаетСхемуСEnum() Экспорт
	ДопустимыеЗначения = Новый Массив;
	ДопустимыеЗначения.Добавить("sync");
	ДопустимыеЗначения.Добавить("task");
	Свойство = Мсп_СхемаПараметров.НовыйСвойствоСхемыСEnum("string", "Режим", ДопустимыеЗначения);

	Свойства = Новый Структура;
	Свойства.Вставить("executionMode", Свойство);
	ТребуемыеПоля = Новый Массив;
	ТребуемыеПоля.Добавить("executionMode");
	Схема = Мсп_СхемаПараметров.НовыйСхемаОбъекта(Свойства, ТребуемыеПоля);

	ЮТест.ОжидаетЧто(Схема.type).Равно("object");
	ЮТест.ОжидаетЧто(Схема.properties.executionMode.enum).Равно(ДопустимыеЗначения);
	ЮТест.ОжидаетЧто(Схема.required).Равно(ТребуемыеПоля);
КонецПроцедуры

// Проверяет доступность имен в модуле ошибок.
Процедура ОшибкиВыбрасываютИсключения() Экспорт
	ПроверитьКодОшибки("НекорректныеПараметры", "INVALID_PARAMS");
