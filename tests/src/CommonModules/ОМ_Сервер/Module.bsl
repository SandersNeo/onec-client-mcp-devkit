// Проверяет, что НовыйИнструмент заполняет режим выполнения.
	Процедура НовыйИнструментЗаполняетРежимВыполнения() Экспорт
		Оповещение = Новый ОписаниеОповещения("ОбработчикТест", ЭтотОбъект);
		Схема = Новый Структура("type", "object");

	Описание = Мсп_Сервер.НовыйИнструмент("мой_инструмент_sync", "Описание", Схема, Оповещение);

	ЮТест.ОжидаетЧто(Описание.РежимВыполнения).Равно("sync");
	ЮТест.ОжидаетЧто(Описание.Включён).Равно(Истина);
	ЮТест.ОжидаетЧто(Описание.ОтложенныйОтвет).Равно(Ложь);
	ЮТест.ОжидаетЧто(Описание.ИсточникРегистрации).Равно("");
	КонецПроцедуры

	Процедура НовыйИнструментСОтложеннымОтветомЗаполняетПоля() Экспорт
		Оповещение = Новый ОписаниеОповещения("ОбработчикТест", ЭтотОбъект);
		Схема = Новый Структура("type", "object");

		Описание = Мсп_Сервер.НовыйИнструмент(
			"мой_инструмент_deferred",
			"Описание",
			Схема,
			Оповещение,
			Истина);

	ЮТест.ОжидаетЧто(Описание.РежимВыполнения).Равно("sync");
	ЮТест.ОжидаетЧто(Описание.ОтложенныйОтвет).Равно(Истина);
КонецПроцедуры

	// Проверяет, что конструктор не принимает некорректный признак отложенного ответа.
	Процедура НовыйИнструментСНекорректнымОтложеннымОтветомВызываетИсключение() Экспорт
	Оповещение = Новый ОписаниеОповещения("ОбработчикТест", ЭтотОбъект);
	СообщениеОшибки = "";

	Попытка
			Мсп_Сервер.НовыйИнструмент(
				"мой_инструмент_invalid",
				"Описание",
				Новый Структура("type", "object"),
				Оповещение,
				1);
	Исключение
		СообщениеОшибки = ОписаниеОшибки();
	КонецПопытки;

		ЮТест.ОжидаетЧто(СтрНайти(СообщениеОшибки, "ОтложенныйОтвет должен быть булевым.") > 0).ЭтоИстина();
	КонецПроцедуры

// Проверяет, что НовыйРесурс принимает явный mime type.
