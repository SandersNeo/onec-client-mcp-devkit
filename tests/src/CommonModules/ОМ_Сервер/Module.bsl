// Проверяет регистрацию описаний с явным источником.
Процедура РегистрацияСохраняетИсточникРегистрации() Экспорт
	Мсп_РеестрКлиент.ИнициализироватьРеестры();

	Оповещение = Новый ОписаниеОповещения("ОбработчикТест", ЭтотОбъект);
	Источник = "ОМ_Сервер";
	Инструмент = Мсп_Сервер.НовыйИнструмент("tool-contract", "Описание", Новый Структура("type", "object"), Оповещение);
	Ресурс = Мсп_Сервер.НовыйРесурс("test://resource/contract", "Ресурс", "Описание", "application/json", Оповещение);
	ШаблонРесурса = Мсп_Сервер.НовыйШаблонРесурса("test://resource/{id}/contract", "Шаблон", "Описание", "application/json", Оповещение);
	Промпт = Мсп_Сервер.НовыйПромпт("prompt-contract", "Описание", Новый Массив, Оповещение);

	Мсп_Сервер.ЗарегистрироватьИнструмент(Инструмент, Источник);
	Мсп_Сервер.ЗарегистрироватьРесурс(Ресурс, Источник);
	Мсп_Сервер.ЗарегистрироватьШаблонРесурса(ШаблонРесурса, Источник);
	Мсп_Сервер.ЗарегистрироватьПромпт(Промпт, Источник);

	ИнструментВРеестре = Мсп_РеестрКлиент.РеестрИнструментов().Получить("tool-contract");
	РесурсВРеестре = Мсп_РеестрКлиент.РеестрРесурсов().Получить("test://resource/contract");
	ШаблонВРеестре = Мсп_РеестрКлиент.РеестрШаблоновРесурсов().Получить("test://resource/{id}/contract");
	ПромптВРеестре = Мсп_РеестрКлиент.РеестрПромптов().Получить("prompt-contract");

	ЮТест.ОжидаетЧто(ИнструментВРеестре)
		.Свойство("ИсточникРегистрации").Равно(Источник)
		.Свойство("Включён").Равно(Истина);
	ЮТест.ОжидаетЧто(РесурсВРеестре)
		.Свойство("ИсточникРегистрации").Равно(Источник)
		.Свойство("Провайдер").Равно("")
		.Свойство("Включён").Равно(Истина);
	ЮТест.ОжидаетЧто(ШаблонВРеестре)
		.Свойство("ИсточникРегистрации").Равно(Источник)
		.Свойство("Провайдер").Равно("")
		.Свойство("Включён").Равно(Истина);
	ЮТест.ОжидаетЧто(ПромптВРеестре)
		.Свойство("ИсточникРегистрации").Равно(Источник)
		.Свойство("Провайдер").Равно("")
		.Свойство("Включён").Равно(Истина);

	ЮТест.ОжидаетЧто(Мсп_РеестрКлиент.РеестрИнструментов(Истина).Получить("tool-contract")).НеРавно(Неопределено);
	ЮТест.ОжидаетЧто(Мсп_РеестрКлиент.РеестрРесурсов(Истина).Получить("test://resource/contract")).НеРавно(Неопределено);
	ЮТест.ОжидаетЧто(Мсп_РеестрКлиент.РеестрШаблоновРесурсов(Истина).Получить("test://resource/{id}/contract")).НеРавно(Неопределено);
	ЮТест.ОжидаетЧто(Мсп_РеестрКлиент.РеестрПромптов(Истина).Получить("prompt-contract")).НеРавно(Неопределено);
КонецПроцедуры

