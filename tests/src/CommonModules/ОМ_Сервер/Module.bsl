// Проверяет, что НовыйИнструмент заполняет режим выполнения v2.
Процедура НовыйИнструментV2ЗаполняетРежимВыполнения() Экспорт
	Оповещение = Новый ОписаниеОповещения("ОбработчикТест", ЭтотОбъект);
	Схема = Новый Структура("type", "object");

	ОписаниеSync = Мсп_Сервер.НовыйИнструмент("мой_инструмент_sync", "Описание", Схема, Оповещение);
	ОписаниеTask = Мсп_Сервер.НовыйИнструмент("мой_инструмент_task", "Описание", Схема, Оповещение, "task");

	ЮТест.ОжидаетЧто(ОписаниеSync.РежимВыполнения).Равно("sync");
	ЮТест.ОжидаетЧто(ОписаниеTask.РежимВыполнения).Равно("task");
	ЮТест.ОжидаетЧто(ОписаниеSync).НетСвойства("Асинхронный");
	ЮТест.ОжидаетЧто(ОписаниеTask).НетСвойства("Асинхронный");
	ЮТест.ОжидаетЧто(ОписаниеSync).НетСвойства("Провайдер");
	ЮТест.ОжидаетЧто(ОписаниеTask).НетСвойства("Провайдер");
КонецПроцедуры

// Проверяет, что v2-конструктор не принимает недопустимый режим выполнения.
Процедура НовыйИнструментV2СНедопустимымРежимомВызываетИсключение() Экспорт
	Оповещение = Новый ОписаниеОповещения("ОбработчикТест", ЭтотОбъект);
	СообщениеОшибки = "";

	Попытка
		Мсп_Сервер.НовыйИнструмент(
			"мой_инструмент_invalid",
			"Описание",
			Новый Структура("type", "object"),
			Оповещение,
			"async");
	Исключение
		СообщениеОшибки = ОписаниеОшибки();
	КонецПопытки;

	ЮТест.ОжидаетЧто(СтрНайти(СообщениеОшибки, "РежимВыполнения должен быть sync или task.") > 0).ЭтоИстина();
КонецПроцедуры

