#Область СлужебныйПрограммныйИнтерфейс

// Регистрирует сценарии тестового модуля.
Процедура ИсполняемыеСценарии() Экспорт
	ЮТТесты
		.ДобавитьТест("НовыйОписаниеИнструментаЗаполняетПоля")
		.ДобавитьТест("НовыйОписаниеИнструментаЗаполняетАсинхронность")
		.ДобавитьТест("ПодготовитьЗапросИнструментаНормализуетTaskРежим")
		.ДобавитьТест("ПодготовитьЗапросИнструментаЧитаетProgressTokenИзMeta")
		.ДобавитьТест("ПараметрыВызоваИнструментаПрокидываютTaskIdИProgressToken")
		.ДобавитьТест("ПараметрыЧтенияРесурсаЗаполняютКонтракт")
		.ДобавитьТест("ПараметрыПолученияПромптаЗаполняютКонтракт")
		.ДобавитьТест("FacadeЗадачОбрабатываетОтменуИОчистку")
	;
КонецПроцедуры

// Проверяет, что НовыйОписаниеИнструмента заполняет поля Имя и Описание.
Процедура НовыйОписаниеИнструментаЗаполняетПоля() Экспорт
	Оповещение = Новый ОписаниеОповещения("ОбработчикТест", ЭтотОбъект);
	Схема = Новый Структура("type", "object");

	Описание = Мсп_Сервер.НовыйОписаниеИнструмента("мой_инструмент", "Описание инструмента", Схема, Оповещение);

	ЮТест.ОжидаетЧто(Описание)
		.Свойство("Имя").Равно("мой_инструмент")
		.Свойство("Описание").Равно("Описание инструмента")
		.Свойство("СхемаПараметров").Равно(Схема)
		.Свойство("Обработчик").Равно(Оповещение)
		.Свойство("Асинхронный").Равно(Ложь)
	;
КонецПроцедуры

// Проверяет, что НовыйОписаниеИнструмента заполняет признак асинхронности.
Процедура НовыйОписаниеИнструментаЗаполняетАсинхронность() Экспорт
	Оповещение = Новый ОписаниеОповещения("ОбработчикТест", ЭтотОбъект);
	Схема = Новый Структура("type", "object");

	Описание = Мсп_Сервер.НовыйОписаниеИнструмента("мой_инструмент", "Описание инструмента", Схема, Оповещение, "", Истина);

	ЮТест.ОжидаетЧто(Описание)
		.Свойство("Асинхронный").Равно(Истина)
	;
КонецПроцедуры

// Проверяет нормализацию входного MCP_TOOL_CALL для task-сценария.
Процедура ПодготовитьЗапросИнструментаНормализуетTaskРежим() Экспорт
	ЗапросJSON = "{""name"":""Timer"",""arguments"":{""ticks"":3},""executionMode"":""task"",""taskId"":""task-123"",""progressToken"":""progress-123""}";

	Контекст = Мсп_ТранспортСобытияКлиент.ПодготовитьЗапросИнструмента(ЗапросJSON);

	ЮТест.ОжидаетЧто(Контекст)
		.Свойство("РежимВыполнения").Равно("task")
		.Свойство("ИдентификаторЗадачи").Равно("task-123")
		.Свойство("ProgressToken").Равно("progress-123");
	ЮТест.ОжидаетЧто(Контекст).НетСвойства("РежимОтвета");
	ЮТест.ОжидаетЧто(Контекст.Запрос)
		.Свойство("name").Равно("Timer");
КонецПроцедуры

// Проверяет чтение progressToken из _meta при нормализации MCP_TOOL_CALL.
Процедура ПодготовитьЗапросИнструментаЧитаетProgressTokenИзMeta() Экспорт
	ЗапросJSON = "{""name"":""Timer"",""arguments"":{""ticks"":3},""_meta"":{""progressToken"":""progress-meta""},""progressToken"":""progress-root"",""id"":""request-1""}";

	Контекст = Мсп_ТранспортСобытияКлиент.ПодготовитьЗапросИнструмента(ЗапросJSON);

	ЮТест.ОжидаетЧто(Контекст)
		.Свойство("Идентификатор").Равно("request-1")
		.Свойство("ProgressToken").Равно("progress-meta");
КонецПроцедуры

// Проверяет прокидывание taskId и progressToken в параметры вызова протокола.
Процедура ПараметрыВызоваИнструментаПрокидываютTaskIdИProgressToken() Экспорт
	Контекст = Мсп_ТранспортСобытияКлиент.НовыйКонтекстЗапроса(
		Новый Структура("name,arguments", "Timer", Новый Структура("ticks", 3)),
		"",
		"task",
		"task-123",
		"progress-123");

	Параметры = Мсп_ТранспортСобытияКлиент.ПараметрыВызоваИнструмента(Контекст);

	ЮТест.ОжидаетЧто(Параметры)
		.Свойство("name").Равно("Timer")
		.Свойство("executionMode").Равно("task")
		.Свойство("taskId").Равно("task-123")
		.Свойство("progressToken").Равно("progress-123");
	ЮТест.ОжидаетЧто(Параметры).НетСвойства("responseMode");
	ЮТест.ОжидаетЧто(Параметры.arguments.ticks).Равно(3);
КонецПроцедуры

// Проверяет единый контракт параметров чтения ресурса.
Процедура ПараметрыЧтенияРесурсаЗаполняютКонтракт() Экспорт
	Контекст = Мсп_ТранспортСобытияКлиент.НовыйКонтекстЗапроса(
		Новый Структура(
			"uri,uriTemplate,arguments",
			"test://resource/1",
			"test://resource/{id}",
			Новый Структура("id", 1)),
		"request-1");

	Параметры = Мсп_ТранспортСобытияКлиент.ПараметрыЧтенияРесурса(Контекст);

	ЮТест.ОжидаетЧто(Параметры)
		.Свойство("uri").Равно("test://resource/1")
		.Свойство("uriTemplate").Равно("test://resource/{id}")
		.Свойство("arguments").НеРавно(Неопределено);
	ЮТест.ОжидаетЧто(Параметры.arguments.id).Равно(1);
КонецПроцедуры

// Проверяет единый контракт параметров получения промпта.
Процедура ПараметрыПолученияПромптаЗаполняютКонтракт() Экспорт
	Контекст = Мсп_ТранспортСобытияКлиент.НовыйКонтекстЗапроса(
		Новый Структура("name,arguments", "summarize", Новый Структура("topic", "tasks")),
		"request-1");

	Параметры = Мсп_ТранспортСобытияКлиент.ПараметрыПолученияПромпта(Контекст);

	ЮТест.ОжидаетЧто(Параметры)
		.Свойство("name").Равно("summarize")
		.Свойство("arguments").НеРавно(Неопределено);
	ЮТест.ОжидаетЧто(Параметры.arguments.topic).Равно("tasks");
КонецПроцедуры

// Проверяет, что facade задач использует единое хранилище отмены.
Процедура FacadeЗадачОбрабатываетОтменуИОчистку() Экспорт
	ИдентификаторЗадачи = "task-cancelled-1";
	Мсп_Сервер.ОчиститьОтменуЗадачи(ИдентификаторЗадачи);
	Мсп_ЗадачиКлиент.ОбработатьTaskCancelled("{""taskId"":""task-cancelled-1""}");

	ЮТест.ОжидаетЧто(Мсп_Сервер.ЗадачаОтменена(ИдентификаторЗадачи)).Равно(Истина);

	Мсп_Сервер.ОчиститьОтменуЗадачи(ИдентификаторЗадачи);
	ЮТест.ОжидаетЧто(Мсп_Сервер.ЗадачаОтменена(ИдентификаторЗадачи)).Равно(Ложь);
КонецПроцедуры

