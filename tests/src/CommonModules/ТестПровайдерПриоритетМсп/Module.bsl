#Область ПрограммныйИнтерфейс

Процедура Зарегистрировать(ИсточникРегистрации) Экспорт
	Инструмент = Мсп_РеестрКлиент.НовыйОписаниеИнструмента();
	Инструмент.Имя = "priority_tool";
	Инструмент.Вставить("ИсточникРегистрации", ИсточникРегистрации);
	Мсп_РеестрКлиент.ЗарегистрироватьИнструмент(Инструмент);

	Ресурс = Мсп_РеестрКлиент.НовыйОписаниеРесурса();
	Ресурс.URI = "priority://resource";
	Ресурс.Вставить("ИсточникРегистрации", ИсточникРегистрации);
	Мсп_РеестрКлиент.ЗарегистрироватьРесурс(Ресурс);

	ШаблонРесурса = Мсп_РеестрКлиент.НовыйОписаниеШаблонаРесурса();
	ШаблонРесурса.URIШаблон = "priority://resource/{id}";
	ШаблонРесурса.Вставить("ИсточникРегистрации", ИсточникРегистрации);
	Мсп_РеестрКлиент.ЗарегистрироватьШаблонРесурса(ШаблонРесурса);

	Промпт = Мсп_РеестрКлиент.НовыйОписаниеПромпта();
	Промпт.Имя = "priority_prompt";
	Промпт.Вставить("ИсточникРегистрации", ИсточникРегистрации);
	Мсп_РеестрКлиент.ЗарегистрироватьПромпт(Промпт);
КонецПроцедуры

#КонецОбласти
