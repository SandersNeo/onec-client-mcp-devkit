#Область ПрограммныйИнтерфейс

// Регистрирует ресурсы окон MCP.
Процедура ЗарегистрироватьРесурсы() Экспорт
	Мсп_РеестрКлиент.ЗарегистрироватьРесурс(НовыйОписаниеРесурса(
		"ui://active/window",
		"Активное окно",
		"Снимок активного окна тест-клиента",
		Новый ОписаниеОповещения("ОбработатьРесурсАктивногоОкна", Мсп_РесурсыОкнаКлиент)));
	Мсп_РеестрКлиент.ЗарегистрироватьРесурс(НовыйОписаниеРесурса(
		"ui://windows",
		"Окна",
		"Список окон тест-клиента",
		Новый ОписаниеОповещения("ОбработатьРесурсСпискаОкон", Мсп_РесурсыОкнаКлиент)));
КонецПроцедуры

// Возвращает снимок активного окна.
//
// Параметры:
//  Запрос - Структура - Запрос ресурса:
//   * Аргументы - Структура - Аргументы вызова.
//   * Контекст - Структура - Контекст вызова.
//  ДополнительныеПараметры - Произвольный - Дополнительные параметры вызова.
//
// Возвращаемое значение:
//  Структура - Результат чтения ресурса.
Функция ОбработатьРесурсАктивногоОкна(Запрос, ДополнительныеПараметры) Экспорт
	РезультатОкна = Мсп_ОкнаКлиент.ПолучитьАктивноеОкно();
	Если ЗначениеЗаполнено(РезультатОкна.Ошибка) Тогда
		Мсп_ЛогированиеКлиент.Ошибка("Active window resource error: %1", РезультатОкна.Ошибка);
		Возврат Неопределено;
	КонецЕсли;
	Если РезультатОкна.Окно = Неопределено Тогда
		Мсп_ЛогированиеКлиент.Ошибка("Active window resource error: window is undefined");
		Возврат Неопределено;
	КонецЕсли;

	Снимок = Мсп_ОкнаКлиент.СформироватьСнимокОкна(РезультатОкна.Окно);
	Возврат СформироватьРезультатРесурса(URIЗапроса(Запрос), Снимок);
КонецФункции

// Возвращает список окон.
//
// Параметры:
//  Запрос - Структура - Запрос ресурса:
//   * Аргументы - Структура - Аргументы вызова.
//   * Контекст - Структура - Контекст вызова.
//  ДополнительныеПараметры - Произвольный - Дополнительные параметры вызова.
//
// Возвращаемое значение:
//  Структура - Результат чтения ресурса.
Функция ОбработатьРесурсСпискаОкон(Запрос, ДополнительныеПараметры) Экспорт
	РезультатСписка = Мсп_ОкнаКлиент.ПолучитьСписокОкон();
	Если ЗначениеЗаполнено(РезультатСписка.Ошибка) Тогда
		Мсп_ЛогированиеКлиент.Ошибка("Windows list resource error: %1", РезультатСписка.Ошибка);
		Возврат Неопределено;
	КонецЕсли;
	
	Снимки = Новый Массив;
	Для Каждого Окно Из РезультатСписка.Окна Цикл
		Снимки.Добавить(Мсп_ОкнаКлиент.СформироватьСнимокОкна(Окно));
	КонецЦикла;
	Данные = НовыйДанныеСпискаОкон(Снимки);
	Возврат СформироватьРезультатРесурса(URIЗапроса(Запрос), Данные);
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция НовыйОписаниеРесурса(URI, Имя, Описание, Обработчик)
	ОписаниеРесурса = Мсп_РеестрКлиент.НовыйОписаниеРесурса();
	ОписаниеРесурса.URI = URI;
	ОписаниеРесурса.Имя = Имя;
	ОписаниеРесурса.Описание = Описание;
	ОписаниеРесурса.MimeType = "application/json";
	ОписаниеРесурса.Обработчик = Обработчик;
	Возврат ОписаниеРесурса;
КонецФункции

Функция СформироватьРезультатРесурса(URI, Данные)
	ТекстJSON = СериализоватьДанные(Данные);
	Если ТекстJSON = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	Контент = Новый Структура("uri,text,mimeType", URI, ТекстJSON, "application/json");
	МассивКонтента = Новый Массив;
	МассивКонтента.Добавить(Контент);
	Возврат Новый Структура("contents", МассивКонтента);
КонецФункции

Функция НовыйДанныеСпискаОкон(Снимки)
	Возврат Новый Структура("windows", Снимки);
КонецФункции

Функция СериализоватьДанные(Данные)
	Попытка
		Возврат Мсп_СериализацияКлиент.Сериализовать(Данные);
	Исключение
		Мсп_ЛогированиеКлиент.Ошибка(ИнформацияОбОшибке());
	КонецПопытки;
	Возврат Неопределено;
КонецФункции

Функция URIЗапроса(Запрос)
	Если Запрос = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	Возврат Мсп_Коллекции.ПолучитьСвойство(Запрос.Контекст, "uri", "");
КонецФункции

#КонецОбласти
