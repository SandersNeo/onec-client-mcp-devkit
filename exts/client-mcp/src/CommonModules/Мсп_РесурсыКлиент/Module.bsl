#Область ПрограммныйИнтерфейс

// Формирует результат чтения JSON-ресурса.
//
// Параметры:
//  URI - Строка - URI ресурса.
//  Данные - Произвольный - Данные ресурса, сериализуемые в JSON.
//
// Возвращаемое значение:
//  Структура - Результат чтения ресурса:
//  * contents - Массив из Структура - Контент ресурса.
Функция РезультатРесурса(URI, Данные) Экспорт
	Контент = НовыйКонтентРесурса(URI, Мсп_СериализацияКлиент.Сериализовать(Данные));
	Возврат НовыйРезультатЧтенияРесурса(Контент);
КонецФункции

// Формирует результат чтения JSON-ресурса по результату разрешения объекта.
//
// Параметры:
//  URI - Строка - URI ресурса.
//  РезультатРазрешения - Структура - Результат разрешения объекта ресурса.
//  ИмяПоляОбъекта - Строка - Имя поля с разрешенным объектом.
//  ИмяСущности - Строка - Имя сущности для сообщений об ошибке.
//  ОбработчикСнимка - ОписаниеОповещения - Обработчик формирования снимка объекта.
//
// Возвращаемое значение:
//  Произвольный - Результат чтения ресурса или описание ошибки ресурса.
Функция РезультатРесурсаИзРазрешения(URI, РезультатРазрешения, ИмяПоляОбъекта, ИмяСущности, ОбработчикСнимка) Экспорт
	КодОшибки = Мсп_Коллекции.Свойство(РезультатРазрешения, "КодОшибки", "");
	Если ЗначениеЗаполнено(КодОшибки) Тогда
		Ошибка = Мсп_Коллекции.Свойство(РезультатРазрешения, "Ошибка", "");
		ЛогироватьОшибкуРесурса(ИмяСущности, URI, Ошибка, КодОшибки);
		Возврат ОшибкаРесурса(КодОшибки, Ошибка);
	КонецЕсли;

	Объект = Мсп_Коллекции.Свойство(РезультатРазрешения, ИмяПоляОбъекта, Неопределено);
	Если Объект = Неопределено Тогда
		Ошибка = ИмяСущности + " is undefined";
		ЛогироватьОшибкуРесурса(ИмяСущности, URI, Ошибка);
		Возврат ОшибкаРесурса("ACTION_FAILED", Ошибка);
	КонецЕсли;

	Снимок = ВыполнитьОбработкуОповещения(ОбработчикСнимка, Объект);
	Если Снимок = Неопределено Тогда
		Ошибка = ИмяСущности + " snapshot is undefined";
		ЛогироватьОшибкуРесурса(ИмяСущности, URI, Ошибка);
		Возврат ОшибкаРесурса("ACTION_FAILED", Ошибка);
	КонецЕсли;

	Возврат РезультатРесурса(URI, Снимок);
КонецФункции

Функция ОшибкаРесурса(Код, Ошибка) Экспорт
	Возврат Новый Структура("КодОшибки, Ошибка", Код, Ошибка);
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Возвращает описание контента ресурса.
//
// Параметры:
//  URI - Строка - URI ресурса.
//  ТекстJSON - Строка - JSON-представление данных ресурса.
//
// Возвращаемое значение:
//  Структура - Описание контента ресурса:
//   * uri - Строка - URI ресурса.
//   * text - Строка - JSON-представление данных ресурса.
//   * mimeType - Строка - MIME-тип контента, всегда application/json.
Функция НовыйКонтентРесурса(URI, ТекстJSON)
	Возврат Новый Структура("uri, text, mimeType", URI, ТекстJSON, "application/json");
КонецФункции

// Возвращает результат чтения ресурса.
//
// Параметры:
//  Контент - Структура - Описание контента ресурса.
//
// Возвращаемое значение:
//  Структура:
//  * contents - Массив из Структура - Контент ресурса.
Функция НовыйРезультатЧтенияРесурса(Контент)
	МассивКонтента = Новый Массив;
	МассивКонтента.Добавить(Контент);
	Возврат Новый Структура("contents", МассивКонтента);
КонецФункции

Процедура ЛогироватьОшибкуРесурса(ИмяСущности, URI, Ошибка, КодОшибки = "")
	Если ЗначениеЗаполнено(КодОшибки) Тогда
		Мсп_ЛогированиеКлиент.Ошибка("%1 resource error uri=%2 code=%3 details=%4", ИмяСущности, URI, КодОшибки, Ошибка);
	Иначе
		Мсп_ЛогированиеКлиент.Ошибка("%1 resource error uri=%2: %3", ИмяСущности, URI, Ошибка);
	КонецЕсли;
КонецПроцедуры

#КонецОбласти
