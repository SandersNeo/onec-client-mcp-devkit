#Область ПрограммныйИнтерфейс

// Записывает сообщение в лог MCP.
//
// Параметры:
//  Текст - Строка - Текст сообщения.
//  Логировать - Булево - Признак необходимости логировать сообщение.
Процедура MCP_Лог(Текст, Логировать = Истина) Экспорт
	Если Логировать = Ложь Тогда
		Возврат;
	КонецЕсли;
	Время = Формат(ТекущаяДата(), "ДФ=yyyy-MM-dd HH:mm:ss");
	Сообщение = Новый СообщениеПользователю;
	Сообщение.Текст = СтрШаблон("[MCP %1] %2", Время, Текст);
	Сообщение.Сообщить();
КонецПроцедуры

#КонецОбласти
