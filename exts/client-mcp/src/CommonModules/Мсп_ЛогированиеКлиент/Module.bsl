#Область ПрограммныйИнтерфейс

// Записывает отладочное сообщение.
//
// Параметры:
//  Сообщение - Строка - Текст сообщения.
Процедура Отладка(Сообщение, П1 = "", П2 = "", П3 = "", П4 = "", П5 = "", П6 = "", П7 = "", П8 = "", П9 = "") Экспорт
	Лог(Сообщение, "debug", П1, П2, П3, П4, П5, П6, П7, П8, П9);
КонецПроцедуры

// Записывает информационное сообщение.
//
// Параметры:
//  Сообщение - Строка - Текст сообщения.
Процедура Информация(Сообщение, П1 = "", П2 = "", П3 = "", П4 = "", П5 = "", П6 = "", П7 = "", П8 = "", П9 = "") Экспорт
	Лог(Сообщение, "info", П1, П2, П3, П4, П5, П6, П7, П8, П9);
КонецПроцедуры

// Записывает предупреждение.
//
// Параметры:
//  Сообщение - Строка - Текст сообщения.
Процедура Важно(Сообщение, П1 = "", П2 = "", П3 = "", П4 = "", П5 = "", П6 = "", П7 = "", П8 = "", П9 = "") Экспорт
	Лог(Сообщение, "warn", П1, П2, П3, П4, П5, П6, П7, П8, П9);
КонецПроцедуры

// Записывает сообщение об ошибке.
//
// Параметры:
//  Сообщение - Строка, ИнформацияОбОшибке - Текст сообщения.
Процедура Ошибка(Знач Сообщение, П1 = "", П2 = "", П3 = "", П4 = "", П5 = "", П6 = "", П7 = "", П8 = "", П9 = "") Экспорт
	Если ТипЗнч(Сообщение) = Тип("ИнформацияОбОшибке") Тогда
		Сообщение = ОбработкаОшибок.ПодробноеПредставлениеОшибки(Сообщение);
	КонецЕсли;
	
	Лог(Сообщение, "error", П1, П2, П3, П4, П5, П6, П7, П8, П9);
КонецПроцедуры

Функция ПараметрыЛогирования() Экспорт
	Возврат Мсп_СостояниеКлиент.СостояниеСервера().ПараметрыЛогирования;
КонецФункции

// Устанавливает параметры логирования.
//
// Параметры:
//  Логировать - Булево - Признак необходимости логировать сообщения.
//  ФайлЛога - Строка - Путь к файлу лога.
//  УровеньЛога - Строка - Минимальный уровень логирования (debug, info, warn, error).
Процедура УстановитьПараметрыЛогирования(Логировать, ФайлЛога, УровеньЛога = Неопределено) Экспорт
	ПараметрыЛогирования = ПараметрыЛогирования();
	ПараметрыЛогирования.Логировать = Логировать;
	ПараметрыЛогирования.ФайлЛога = ФайлЛога;
	Если ЗначениеЗаполнено(УровеньЛога) Тогда
		ПроверитьУровеньЛога(УровеньЛога);
		ПараметрыЛогирования.УровеньЛога = УровеньЛога;
	КонецЕсли;
	
	Информация("Logging params applied");
	Информация("Logging params:level: %1; file: %2", УровеньЛога, ФайлЛога);
КонецПроцедуры

// Применяет параметры логирования из параметров запуска сервера.
//
// Параметры:
//  Параметры - Структура - Дополнительные параметры запуска:
//   * log - Булево - Признак необходимости логировать сообщения.
//   * logLevel - Строка - Минимальный уровень логирования (debug, info, warn, error).
//   * logFile - Строка - Путь к файлу логирования (пустая строка отключает запись).
Процедура ПрименитьПараметрыЗапуска(Параметры = Неопределено) Экспорт
	Если ТипЗнч(Параметры) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыЛогирования = ПараметрыЛогирования();
	ПрименитьПараметрыИзИсточника(ПараметрыЛогирования, Параметры);
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Записывает сообщение в лог MCP.
//
// Параметры:
//  Текст - Строка - Текст сообщения.
//  Уровень - Строка - Уровень логирования (debug, info, warn, error).
Процедура Лог(Знач Текст, Уровень, П1 = "", П2 = "", П3 = "", П4 = "", П5 = "", П6 = "", П7 = "", П8 = "", П9 = "")
	ПараметрыЛогирования = ПараметрыЛогирования();
	
	Если НЕ ПараметрыЛогирования.Логировать Тогда
		Возврат;
	КонецЕсли;
	
	Если ПриоритетУровняЛога(Уровень) < ПриоритетУровняЛога(ПараметрыЛогирования.УровеньЛога) Тогда
		Возврат;
	КонецЕсли;
	
	Текст = СтрШаблон(Текст +  "%10", П1, П2, П3, П4, П5, П6,  П7, П8, П9, "");
	Время = Формат(ТекущаяДата(), "ДФ=yyyy-MM-dd HH:mm:ss");
	УровеньОтображения = ВРег(Уровень);
	СообщениеПользователю = Новый СообщениеПользователю;
	СообщениеПользователю.Текст = СтрШаблон("[MCP %1 %2] %3", УровеньОтображения, Время, Текст);
	СообщениеПользователю.Сообщить();
	ЗаписатьЛогВФайл(ПараметрыЛогирования.ФайлЛога, СообщениеПользователю.Текст);
КонецПроцедуры

Функция ПриоритетУровняЛога(Уровень)
	Если Уровень = "debug" Тогда
		Возврат 10;
	ИначеЕсли Уровень = "warn" Тогда
		Возврат 30;
	ИначеЕсли Уровень = "error" Тогда
		Возврат 40;
	КонецЕсли;

	Возврат 20;
КонецФункции

// Применяет параметры логирования из источника в целевую структуру.
//
// Параметры:
//  ПараметрыЛогирования - Структура - Целевая структура параметров логирования.
//  Источник - Структура - Источник параметров (параметры запуска).
Процедура ПрименитьПараметрыИзИсточника(ПараметрыЛогирования, Источник)
	Если Источник.Свойство("log") Тогда
		ПараметрыЛогирования.Вставить("Логировать", Источник.log);
	КонецЕсли;
	
	Если Источник.Свойство("logLevel") Тогда
		ПроверитьУровеньЛога(Источник.logLevel);
		ПараметрыЛогирования.Вставить("УровеньЛога", Источник.logLevel);
	КонецЕсли;
	
	Если Источник.Свойство("logFile") Тогда
		ПараметрыЛогирования.Вставить("ФайлЛога", Источник.logFile);
	КонецЕсли;
КонецПроцедуры

Процедура ЗаписатьЛогВФайл(ФайлЛога, Сообщение)
	Если Не ЗначениеЗаполнено(ФайлЛога) Тогда
		Возврат;
	КонецЕсли;
	
	Попытка
		Запись = Новый ЗаписьТекста(ФайлЛога, КодировкаТекста.UTF8, , Истина);
		Запись.ЗаписатьСтроку(Сообщение);
		Запись.Закрыть();
	Исключение
		Время = Формат(ТекущаяДата(), "ДФ=yyyy-MM-dd HH:mm:ss");
		СообщениеПользователю = Новый СообщениеПользователю;
		СообщениеПользователю.Текст = СтрШаблон("[MCP ERROR %1] Log file writing error: %2", Время, ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		СообщениеПользователю.Сообщить();
		Возврат;
	КонецПопытки;
КонецПроцедуры

Процедура ПроверитьУровеньЛога(Уровень)
	Если ТипЗнч(Уровень) <> Тип("Строка") Тогда
		ВызватьИсключение "УровеньЛога должен быть строкой debug, info, warn или error.";
	КонецЕсли;

	Если Уровень <> "debug"
		И Уровень <> "info"
		И Уровень <> "warn"
		И Уровень <> "error" Тогда
		ВызватьИсключение "УровеньЛога должен быть debug, info, warn или error.";
	КонецЕсли;
КонецПроцедуры

#КонецОбласти
