#Область ПрограммныйИнтерфейс

// Записывает отладочное сообщение.
//
// Параметры:
//  Сообщение - Строка - Текст сообщения.
Процедура Отладка(Сообщение, П1 = "", П2 = "", П3 = "", П4 = "", П5 = "", П6 = "", П7 = "", П8 = "", П9 = "") Экспорт
	Лог(Сообщение, "debug", П1, П2, П3, П4, П5, П6, П7, П8, П9);
КонецПроцедуры

// Записывает информационное сообщение.
//
// Параметры:
//  Сообщение - Строка - Текст сообщения.
Процедура Информация(Сообщение, П1 = "", П2 = "", П3 = "", П4 = "", П5 = "", П6 = "", П7 = "", П8 = "", П9 = "") Экспорт
	Лог(Сообщение, "info", П1, П2, П3, П4, П5, П6, П7, П8, П9);
КонецПроцедуры

// Записывает предупреждение.
//
// Параметры:
//  Сообщение - Строка - Текст сообщения.
Процедура Важно(Сообщение, П1 = "", П2 = "", П3 = "", П4 = "", П5 = "", П6 = "", П7 = "", П8 = "", П9 = "") Экспорт
	Лог(Сообщение, "warn", П1, П2, П3, П4, П5, П6, П7, П8, П9);
КонецПроцедуры

// Записывает сообщение об ошибке.
//
// Параметры:
//  Сообщение - Строка, ИнформацияОбОшибке - Текст сообщения.
Процедура Ошибка(Знач Сообщение, П1 = "", П2 = "", П3 = "", П4 = "", П5 = "", П6 = "", П7 = "", П8 = "", П9 = "") Экспорт
	Если ТипЗнч(Сообщение) = Тип("ИнформацияОбОшибке") Тогда
		Сообщение = ОбработкаОшибок.ПодробноеПредставлениеОшибки(Сообщение);
	КонецЕсли;
	
	Лог(Сообщение, "error", П1, П2, П3, П4, П5, П6, П7, П8, П9);
КонецПроцедуры

// Возвращает признак включенного логирования.
//
// Возвращаемое значение:
//  Булево - Истина, если логирование включено.
Функция ЛогированиеВключено() Экспорт
	ПараметрыЛогирования = ПолучитьПараметрыЛогирования();
	Возврат ПараметрыЛогирования.Логировать;
КонецФункции

// Возвращает путь к файлу лога.
//
// Возвращаемое значение:
//  Строка - Путь к файлу лога или пустая строка.
Функция ПолучитьФайлЛога() Экспорт
	ПараметрыЛогирования = ПолучитьПараметрыЛогирования();
	Возврат ПараметрыЛогирования.ФайлЛога;
КонецФункции

// Возвращает минимальный уровень логирования.
//
// Возвращаемое значение:
//  Строка - Минимальный уровень логирования (debug, info, warn, error).
Функция ПолучитьУровеньЛога() Экспорт
	ПараметрыЛогирования = ПолучитьПараметрыЛогирования();
	Возврат ПараметрыЛогирования.УровеньЛога;
КонецФункции

// Устанавливает параметры логирования.
//
// Параметры:
//  Логировать - Булево - Признак необходимости логировать сообщения.
//  ФайлЛога - Строка - Путь к файлу лога.
//  УровеньЛога - Строка - Минимальный уровень логирования (debug, info, warn, error).
Процедура УстановитьПараметрыЛогирования(Логировать, ФайлЛога, УровеньЛога = Неопределено) Экспорт
	ПараметрыЛогирования = ПолучитьПараметрыЛогирования();
	ПараметрыЛогирования.Вставить("Логировать", Логировать);
	ПараметрыЛогирования.Вставить("ФайлЛога", ФайлЛога);
	Если ЗначениеЗаполнено(УровеньЛога) Тогда
		ПараметрыЛогирования.Вставить("УровеньЛога", УровеньЛога);
	КонецЕсли;
	Мсп_СостояниеКлиент.УстановитьСостояниеЗначение("ПараметрыЛогирования", ПараметрыЛогирования);
	Информация("Logging params applied");
	Информация("Logging params:level: %1; file: %2", УровеньЛога, ФайлЛога);
КонецПроцедуры

// Применяет параметры логирования из параметров запуска сервера.
//
// Параметры:
//  Параметры - Структура - Дополнительные параметры запуска:
//   * log - Булево - Признак необходимости логировать сообщения.
//   * logLevel - Строка - Минимальный уровень логирования (debug, info, warn, error).
//   * logFile - Строка - Путь к файлу логирования (пустая строка отключает запись).
Процедура ПрименитьПараметрыЗапуска(Параметры = Неопределено) Экспорт
	Если ТипЗнч(Параметры) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;

	ПараметрыЛогирования = ПолучитьПараметрыЛогирования();
	ЗначениеЛога = Неопределено;
	Если Параметры.Свойство("log", ЗначениеЛога) Тогда
		ПараметрыЛогирования.Вставить("Логировать", ЗначениеЛога);
	КонецЕсли;
	ЗначениеУровняЛога = Неопределено;
	Если Параметры.Свойство("logLevel", ЗначениеУровняЛога) Тогда
		ПараметрыЛогирования.Вставить("УровеньЛога", ЗначениеУровняЛога);
	КонецЕсли;
	ЗначениеФайлаЛога = Неопределено;
	Если Параметры.Свойство("logFile", ЗначениеФайлаЛога) Тогда
		ПараметрыЛогирования.Вставить("ФайлЛога", ЗначениеФайлаЛога);
	КонецЕсли;
	Мсп_СостояниеКлиент.УстановитьСостояниеЗначение("ПараметрыЛогирования", ПараметрыЛогирования);
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Записывает сообщение в лог MCP.
//
// Параметры:
//  Текст - Строка - Текст сообщения.
//  Уровень - Строка - Уровень логирования (debug, info, warn, error).
Процедура Лог(Знач Текст, Уровень, П1 = "", П2 = "", П3 = "", П4 = "", П5 = "", П6 = "", П7 = "", П8 = "", П9 = "")
	ПараметрыЛогирования = ПолучитьПараметрыЛогирования();
	
	Логировать = Истина;
	МинимальныйУровень = "info";
	ФайлЛога = "";
	ЗначениеЛогирования = Неопределено;
	Если ПараметрыЛогирования.Свойство("Логировать", ЗначениеЛогирования) Тогда
		Логировать = ЗначениеЛогирования;
	КонецЕсли;
	ЗначениеУровня = Неопределено;
	Если ПараметрыЛогирования.Свойство("УровеньЛога", ЗначениеУровня) Тогда
		МинимальныйУровень = ЗначениеУровня;
	КонецЕсли;
	ЗначениеФайла = Неопределено;
	Если ПараметрыЛогирования.Свойство("ФайлЛога", ЗначениеФайла) Тогда
		ФайлЛога = ЗначениеФайла;
	КонецЕсли;

	Если Логировать = Ложь Тогда
		Возврат;
	КонецЕсли;

	УровеньСообщения = НормализоватьУровеньЛога(Уровень);
	УровеньМинимальный = НормализоватьУровеньЛога(МинимальныйУровень);
	Если ПриоритетУровняЛога(УровеньСообщения) < ПриоритетУровняЛога(УровеньМинимальный) Тогда
		Возврат;
	КонецЕсли;
	
	Текст = СтрШаблон(Текст +  "%10", П1, П2, П3, П4, П5, П6,  П7, П8, П9, "");
	Время = Формат(ТекущаяДата(), "ДФ=yyyy-MM-dd HH:mm:ss");
	УровеньОтображения = ВРег(УровеньСообщения);
	СообщениеПользователю = Новый СообщениеПользователю;
	СообщениеПользователю.Текст = СтрШаблон("[MCP %1 %2] %3", УровеньОтображения, Время, Текст);
	СообщениеПользователю.Сообщить();
	ЗаписатьЛогВФайл(ФайлЛога, СообщениеПользователю.Текст);
КонецПроцедуры

Функция ПолучитьПараметрыЛогирования()
	ПараметрыЛогирования = Мсп_СостояниеКлиент.ПолучитьСостояниеЗначение(
		"ПараметрыЛогирования",
		Неопределено);
	Если ТипЗнч(ПараметрыЛогирования) <> Тип("Структура") Тогда
		Логировать = Мсп_СостояниеКлиент.ПолучитьСостояниеЗначение("Логировать", Истина);
		УровеньЛога = Мсп_СостояниеКлиент.ПолучитьСостояниеЗначение("УровеньЛога", "info");
		ФайлЛога = Мсп_СостояниеКлиент.ПолучитьСостояниеЗначение("ФайлЛога", "");
		ПараметрыЛогирования = Новый Структура("Логировать,УровеньЛога,ФайлЛога", Логировать, УровеньЛога, ФайлЛога);

		ПараметрыЗапуска = Мсп_СостояниеКлиент.ПолучитьСостояниеЗначение("Параметры", Неопределено);
		Если ТипЗнч(ПараметрыЗапуска) = Тип("Структура") Тогда
			ЗначениеЛога = Неопределено;
			Если ПараметрыЗапуска.Свойство("log", ЗначениеЛога) Тогда
				ПараметрыЛогирования.Вставить("Логировать", ЗначениеЛога);
			КонецЕсли;
			ЗначениеУровняЛога = Неопределено;
			Если ПараметрыЗапуска.Свойство("logLevel", ЗначениеУровняЛога) Тогда
				ПараметрыЛогирования.Вставить("УровеньЛога", ЗначениеУровняЛога);
			КонецЕсли;
			ЗначениеФайлаЛога = Неопределено;
			Если ПараметрыЗапуска.Свойство("logFile", ЗначениеФайлаЛога) Тогда
				ПараметрыЛогирования.Вставить("ФайлЛога", ЗначениеФайлаЛога);
			КонецЕсли;
		КонецЕсли;
	Иначе
		Если Не ПараметрыЛогирования.Свойство("Логировать") Тогда
			ПараметрыЛогирования.Вставить("Логировать", Истина);
		КонецЕсли;
		Если Не ПараметрыЛогирования.Свойство("УровеньЛога") Тогда
			ПараметрыЛогирования.Вставить("УровеньЛога", "info");
		КонецЕсли;
		Если Не ПараметрыЛогирования.Свойство("ФайлЛога") Тогда
			ПараметрыЛогирования.Вставить("ФайлЛога", "");
		КонецЕсли;
	КонецЕсли;

	Мсп_СостояниеКлиент.УстановитьСостояниеЗначение("ПараметрыЛогирования", ПараметрыЛогирования);

	Возврат ПараметрыЛогирования;
КонецФункции

Функция НормализоватьУровеньЛога(Уровень)
	Если Не ЗначениеЗаполнено(Уровень) Тогда
		Возврат "info";
	КонецЕсли;
	Возврат НРег(Строка(Уровень));
КонецФункции

Функция ПриоритетУровняЛога(Уровень)
	Уровень = НормализоватьУровеньЛога(Уровень);
	Если Уровень = "debug" Тогда
		Возврат 10;
	КонецЕсли;
	Если Уровень = "info" Тогда
		Возврат 20;
	КонецЕсли;
	Если Уровень = "warn" Тогда
		Возврат 30;
	КонецЕсли;
	Если Уровень = "error" Тогда
		Возврат 40;
	КонецЕсли;
	Возврат 20;
КонецФункции

Процедура ЗаписатьЛогВФайл(ФайлЛога, Сообщение)
	Если Не ЗначениеЗаполнено(ФайлЛога) Тогда
		Возврат;
	КонецЕсли;

	Попытка
		Запись = Новый ЗаписьТекста(ФайлЛога, КодировкаТекста.UTF8, , Истина);
		Запись.ЗаписатьСтроку(Сообщение);
		Запись.Закрыть();
	Исключение
		Время = Формат(ТекущаяДата(), "ДФ=yyyy-MM-dd HH:mm:ss");
		СообщениеПользователю = Новый СообщениеПользователю;
		СообщениеПользователю.Текст = СтрШаблон("[MCP ERROR %1] Log file writing error: %2", Время, ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		СообщениеПользователю.Сообщить();
		Возврат;
	КонецПопытки;
КонецПроцедуры

#КонецОбласти
