#Область СлужебныйПрограммныйИнтерфейс

// Формирует ответ на вызов инструмента MCP.
//
// Параметры:
//  Идентификатор - Произвольный - Идентификатор запроса.
//  Параметры - Структура - Параметры вызова инструмента.
//  Сессия - Строка - Идентификатор сессии.
//
// Возвращаемое значение:
//  Структура:
//  * jsonrpc - Строка - Версия протокола JSON-RPC.
//  * id - Произвольный - Идентификатор запроса.
Функция ВызоватьИнструмент(Идентификатор, Параметры, Сессия) Экспорт
	ИмяИнструмента = Мсп_Коллекции.ПолучитьСвойство(Параметры, "name", "");
	Аргументы = СформироватьАргументыИнструмента(Параметры);
	
	Если Не ЗначениеЗаполнено(ИмяИнструмента) Тогда
		Возврат СформироватьОшибку(Идентификатор, -32602, "Invalid params");
	КонецЕсли;

	ИнструментыРеестр = Мсп_РеестрКлиент.РеестрИнструментов();
	Дескриптор = ИнструментыРеестр.Получить(ИмяИнструмента);
	Если Дескриптор = Неопределено Тогда
		Возврат СформироватьОшибку(Идентификатор, -32601, "Tool not found");
	КонецЕсли;

	Контекст = СформироватьКонтекст("tools", ИмяИнструмента, Аргументы, Сессия, Идентификатор, Параметры);
	Запрос = Новый Структура("Аргументы, Контекст", Аргументы, Контекст);
	Возврат ВызватьОбработчик(
		Идентификатор,
		Дескриптор,
		Запрос,
		"tools",
		"Tool execution error",
		"Tool result is invalid");
КонецФункции

// Формирует ответ на чтение ресурса MCP.
//
// Параметры:
//  Идентификатор - Произвольный - Идентификатор запроса.
//  Параметры - Структура - Параметры чтения ресурса.
//  Сессия - Строка - Идентификатор сессии.
//
// Возвращаемое значение:
//  Структура:
//  * jsonrpc - Строка - Версия протокола JSON-RPC.
//  * id - Произвольный - Идентификатор запроса.
Функция ПрочитатьРесурс(Идентификатор, Параметры, Сессия) Экспорт
	Мсп_РеестрКлиент.ИнициализироватьРеестры();
	URI = Мсп_Коллекции.ПолучитьСвойство(Параметры, "uri", "");
	Если Не ЗначениеЗаполнено(URI) Тогда
		Возврат СформироватьОшибку(Идентификатор, -32602, "Invalid params");
	КонецЕсли;

	РесурсыРеестр = Мсп_РеестрКлиент.РеестрРесурсов();
	Дескриптор = РесурсыРеестр.Получить(URI);
	Если Дескриптор = Неопределено Тогда
		Возврат СформироватьОшибку(Идентификатор, -32601, "Resource not found");
	КонецЕсли;

	Контекст = СформироватьКонтекст("resources", URI, Параметры, Сессия, Идентификатор, Параметры);
	Запрос = Новый Структура("Аргументы, Контекст", Параметры, Контекст);
	Возврат ВызватьОбработчик(
		Идентификатор,
		Дескриптор,
		Запрос,
		"resources",
		"Resource execution error",
		"Resource result is invalid");
КонецФункции

// Формирует ответ на получение промпта MCP.
//
// Параметры:
//  Идентификатор - Произвольный - Идентификатор запроса.
//  Параметры - Структура - Параметры получения промпта.
//  Сессия - Строка - Идентификатор сессии.
//
// Возвращаемое значение:
//  Структура:
//  * jsonrpc - Строка - Версия протокола JSON-RPC.
//  * id - Произвольный - Идентификатор запроса.
Функция ПолучитьПромпт(Идентификатор, Параметры, Сессия) Экспорт
	Мсп_РеестрКлиент.ИнициализироватьРеестры();
	ИмяПромпта = Мсп_Коллекции.ПолучитьСвойство(Параметры, "name", "");
	Аргументы = Мсп_Коллекции.ПолучитьСвойство(Параметры, "arguments", Новый Структура);
	Если Не ЗначениеЗаполнено(ИмяПромпта) Тогда
		Возврат СформироватьОшибку(Идентификатор, -32602, "Invalid params");
	КонецЕсли;

	ПромптыРеестр = Мсп_РеестрКлиент.РеестрПромптов();
	Дескриптор = ПромптыРеестр.Получить(ИмяПромпта);
	Если Дескриптор = Неопределено Тогда
		Возврат СформироватьОшибку(Идентификатор, -32601, "Prompt not found");
	КонецЕсли;

	Контекст = СформироватьКонтекст("prompts", ИмяПромпта, Аргументы, Сессия, Идентификатор, Параметры);
	Запрос = Новый Структура("Аргументы, Контекст", Аргументы, Контекст);
	Возврат ВызватьОбработчик(
		Идентификатор,
		Дескриптор,
		Запрос,
		"prompts",
		"Prompt execution error",
		"Prompt result is invalid");
КонецФункции

// Формирует описание инструмента MCP.
//
// Параметры:
//  Имя - Строка - Имя инструмента.
//  Описание - Строка - Описание инструмента.
//  Схема - Структура, Соответствие - JSON-схема входных параметров.
//
// Возвращаемое значение:
//  Структура - Описание инструмента.
Функция НовыйОписаниеИнструмента(Имя, Описание, Схема) Экспорт
	Описание = Новый Структура("name,description,inputSchema", Имя, Описание, Схема);
	
	Возврат Описание;
КонецФункции

// Формирует описание ресурса MCP.
//
// Параметры:
//  URI - Строка - Идентификатор ресурса.
//  Имя - Строка - Имя ресурса.
//  Описание - Строка - Описание ресурса.
//  MimeType - Строка - MIME-тип ресурса.
//
// Возвращаемое значение:
//  Структура - Описание ресурса.
Функция НовыйОписаниеРесурса(URI, Имя, Описание, MimeType) Экспорт
	Данные = Новый Структура("uri,name,description,mimeType");
	Данные.uri = URI;
	Данные.name = Имя;
	Данные.description = Описание;
	Данные.mimeType = MimeType;
	
	Возврат Данные;
КонецФункции

// Формирует описание промпта MCP.
//
// Параметры:
//  Имя - Строка - Имя промпта.
//  Описание - Строка - Описание промпта.
//  Аргументы - Структура - Описание аргументов промпта.
//
// Возвращаемое значение:
//  Структура - Описание промпта.
Функция НовыйОписаниеПромпта(Имя, Описание, Аргументы) Экспорт
	Данные = Новый Структура("name,description,arguments");
	Данные.name = Имя;
	Данные.description = Описание;
	Данные.arguments = Аргументы;
	
	Возврат Данные;
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Формирует JSON-RPC ответ с результатом.
//
// Параметры:
//  Идентификатор - Произвольный - Идентификатор запроса.
//  Результат - Структура - Результат выполнения.
//
// Возвращаемое значение:
//  Структура:
//  * jsonrpc - Строка - Версия протокола JSON-RPC.
//  * id - Произвольный - Идентификатор запроса.
//  * result - Структура - Результат выполнения.
Функция СформироватьОтвет(Идентификатор, Результат)
	Ответ = Новый Структура("jsonrpc,id", "2.0", Идентификатор);
	Ответ.Вставить("result", Результат);
	Возврат Ответ;
КонецФункции

// Формирует JSON-RPC ответ с ошибкой.
//
// Параметры:
//  Идентификатор - Произвольный - Идентификатор запроса.
//  Код - Число - Код ошибки.
//  Сообщение - Строка - Сообщение об ошибке.
//
// Возвращаемое значение:
//  Структура:
//  * jsonrpc - Строка - Версия протокола JSON-RPC.
//  * id - Произвольный - Идентификатор запроса.
//  * error - Структура - Данные ошибки (code, message).
Функция СформироватьОшибку(Идентификатор, Код, Сообщение)
	Ответ = Новый Структура("jsonrpc,id", "2.0", Идентификатор);
	Ошибка = Новый Структура("code,message", Код, Сообщение);
	Ответ.Вставить("error", Ошибка);
	Возврат Ответ;
КонецФункции

// Формирует контекст вызова для обработчиков MCP.
//
// Параметры:
//  Kind - Строка - Тип контекста (tools/resources/prompts).
//  ИмяИлиURI - Строка - Имя инструмента/промпта или URI ресурса.
//  Аргументы - Структура - Аргументы вызова.
//  Сессия - Строка - Идентификатор сессии.
//  Идентификатор - Произвольный - Идентификатор запроса.
//  Raw - Произвольный - Исходные данные запроса.
//
// Возвращаемое значение:
//  Структура:
//  * kind - Строка - Тип контекста.
//  * arguments - Структура - Аргументы вызова.
//  * sessionId - Строка - Идентификатор сессии (может быть пустой).
//  * requestId - Произвольный - Идентификатор запроса.
//  * raw - Произвольный - Исходные данные запроса.
//  * meta - Структура - Метаданные запроса.
Функция СформироватьКонтекст(Kind, ИмяИлиURI, Аргументы, Сессия, Идентификатор, Raw)
	Meta = Новый Структура;
	Контекст = Новый Структура;
	Контекст.Вставить("kind", Kind);
	Если Kind = "resources" Тогда
		Контекст.Вставить("uri", ИмяИлиURI);
	Иначе
		Контекст.Вставить("name", ИмяИлиURI);
	КонецЕсли;
	Контекст.Вставить("arguments", Аргументы);
	Контекст.Вставить("sessionId", Сессия);
	Контекст.Вставить("requestId", Идентификатор);
	Контекст.Вставить("raw", Raw);
	Контекст.Вставить("meta", Meta);
	Возврат Контекст;
КонецФункции

// Формирует структуру аргументов вызова инструмента MCP.
//
// Параметры:
//  Параметры - Структура - Параметры вызова инструмента.
//
// Возвращаемое значение:
//  Структура - Аргументы вызова инструмента.
Функция СформироватьАргументыИнструмента(Параметры)
	Аргументы = Новый Структура;
	Для Каждого Элемент Из Мсп_Коллекции.ПолучитьСвойство(Параметры, "arguments", Новый Структура) Цикл
		Аргументы.Вставить(Элемент.Ключ, Элемент.Значение);
	КонецЦикла;
	
	Возврат Аргументы;
КонецФункции

// Формирует ответ по результату выполнения обработчика MCP.
//
// Параметры:
//  Идентификатор - Произвольный - Идентификатор запроса.
//  Дескриптор - Структура - Описание обработчика.
//  Запрос - Структура - Запрос вызова (Аргументы, Контекст).
//  ВидРезультата - Строка - Тип результата (tools/resources/prompts).
//  СообщениеОшибкаВыполнения - Строка - Ошибка выполнения обработчика.
//  СообщениеОшибкаРезультата - Строка - Ошибка результата обработчика.
//
// Возвращаемое значение:
//  Структура - JSON-RPC ответ.
Функция ВызватьОбработчик(Идентификатор, Дескриптор, Запрос, ВидРезультата, СообщениеОшибкаВыполнения, СообщениеОшибкаРезультата)
	Результат = ВыполнитьОповещение(Дескриптор.Обработчик, Запрос);
	Если Результат = Неопределено Тогда
		Возврат СформироватьОшибку(Идентификатор, -32603, СообщениеОшибкаВыполнения);
	КонецЕсли;

	Нормализовано = НормализоватьРезультатПоВиду(Результат, ВидРезультата, Дескриптор);
	Если Нормализовано = Неопределено Тогда
		Возврат СформироватьОшибку(Идентификатор, -32603, СообщениеОшибкаРезультата);
	КонецЕсли;

	Возврат СформироватьОтвет(Идентификатор, Нормализовано);
КонецФункции

// Нормализует результат выполнения обработчика MCP по типу результата.
//
// Параметры:
//  Результат - Произвольный - Результат обработчика.
//  ВидРезультата - Строка - Тип результата (tools/resources/prompts).
//  Дескриптор - Структура - Описание обработчика.
//
// Возвращаемое значение:
//  Структура - Нормализованный результат.
//  Неопределено - Результат не удалось нормализовать.
Функция НормализоватьРезультатПоВиду(Результат, ВидРезультата, Дескриптор)
	Если ВидРезультата = "tools" Тогда
		Возврат НормализоватьРезультатИнструмента(Результат);
	ИначеЕсли ВидРезультата = "resources" Тогда
		Возврат НормализоватьРезультатРесурса(Результат, Дескриптор);
	ИначеЕсли ВидРезультата = "prompts" Тогда
		Возврат НормализоватьРезультатПромпта(Результат);
	КонецЕсли;
	
	Возврат Неопределено;
КонецФункции

// Выполняет обработчик оповещения MCP.
//
// Параметры:
//  Оповещение - ОписаниеОповещения - Описание оповещения.
//  Запрос - Структура - Запрос вызова:
//   * Аргументы - Структура - Аргументы вызова.
//   * Контекст - Структура - Контекст вызова.
//
// Возвращаемое значение:
//  Произвольный - Результат выполнения обработчика.
//  Неопределено - Обработчик не задан или завершился с ошибкой.
Функция ВыполнитьОповещение(Оповещение, Запрос)
	Если Оповещение = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	Попытка
		Возврат ВыполнитьОбработкуОповещения(Оповещение, Запрос);
	Исключение
		Мсп_ЛогированиеКлиент.Ошибка(ИнформацияОбОшибке());
	КонецПопытки;
КонецФункции

// Нормализует результат выполнения инструмента MCP.
//
// Параметры:
//  Результат - Произвольный - Результат обработчика инструмента.
//
// Возвращаемое значение:
//  Структура:
//  * content - Произвольный - Контент результата.
//  Неопределено - Результат не удалось нормализовать.
Функция НормализоватьРезультатИнструмента(Результат)
	Если ТипЗнч(Результат) = Тип("Структура") И Результат.Свойство("content") Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если ТипЗнч(Результат) = Тип("Массив") Тогда
		Возврат Новый Структура("content", Результат);
	ИначеЕсли ТипЗнч(Результат) = Тип("Строка") Тогда
		Контент = Новый Массив;
		Контент.Добавить(Новый Структура("type,text", "text", Результат));
		Возврат Новый Структура("content", Контент);
	ИначеЕсли Результат <> Неопределено Тогда
		Попытка
			ТекстJSON = Мсп_СериализацияКлиент.Сериализовать(Результат);
		Исключение
			Мсп_ЛогированиеКлиент.Ошибка(ИнформацияОбОшибке());
			Возврат Неопределено;
		КонецПопытки;
		Контент = Новый Массив;
		Контент.Добавить(Новый Структура("type,text", "text", ТекстJSON));
		Возврат Новый Структура("content", Контент);
	КонецЕсли;
	
	Возврат Неопределено;
КонецФункции

// Нормализует результат чтения ресурса MCP.
//
// Параметры:
//  Результат - Произвольный - Результат обработчика ресурса.
//  Дескриптор - Структура - Описание ресурса.
//
// Возвращаемое значение:
//  Структура:
//  * contents - Произвольный - Контент ресурса.
//  Неопределено - Результат не удалось нормализовать.
Функция НормализоватьРезультатРесурса(Результат, Дескриптор)
	Если ТипЗнч(Результат) = Тип("Структура") И Результат.Свойство("contents") Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если ТипЗнч(Результат) = Тип("Массив") Тогда
		Возврат Новый Структура("contents", Результат);
	ИначеЕсли ТипЗнч(Результат) = Тип("Строка") Тогда
		Контент = Новый Структура("uri,text", Дескриптор.URI, Результат);
		Если ЗначениеЗаполнено(Дескриптор.MimeType) Тогда
			Контент.Вставить("mimeType", Дескриптор.MimeType);
		КонецЕсли;
		МассивКонтента = Новый Массив;
		МассивКонтента.Добавить(Контент);
		Возврат Новый Структура("contents", МассивКонтента);
	КонецЕсли;
	
	Возврат Неопределено;
КонецФункции

// Нормализует результат получения промпта MCP.
//
// Параметры:
//  Результат - Произвольный - Результат обработчика промпта.
//
// Возвращаемое значение:
//  Структура:
//  * messages - Произвольный - Список сообщений.
//  Неопределено - Результат не удалось нормализовать.
Функция НормализоватьРезультатПромпта(Результат)
	Если ТипЗнч(Результат) = Тип("Структура") Тогда
		Если Результат.Свойство("messages") Тогда
			Возврат Результат;
		КонецЕсли;
	КонецЕсли;
	
	Если ТипЗнч(Результат) = Тип("Массив") Тогда
		Возврат Новый Структура("messages", Результат);
	КонецЕсли;
	
	Если ТипЗнч(Результат) = Тип("Строка") Тогда
		
		Контент = Новый Массив;
		Контент.Добавить(Новый Структура("type,text", "text", Результат));
		Сообщение = Новый Структура("role,content", "user", Контент);
		Сообщения = Новый Массив;
		Сообщения.Добавить(Сообщение);
		
		Возврат Новый Структура("messages", Сообщения);
		
	КонецЕсли;
	
	Возврат Неопределено;
КонецФункции

