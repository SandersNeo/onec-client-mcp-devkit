#Область СлужебныйПрограммныйИнтерфейс

// Формирует ответ на вызов инструмента MCP.
//
// Параметры:
//  ВызовИнструмента - Структура - Описание вызова инструмента:
//   * Идентификатор - Произвольный - Идентификатор запроса.
//   * ИмяИнструмента - Строка - Имя инструмента.
//   * Аргументы - Структура, Соответствие - Аргументы вызова инструмента.
//   * Сессия - Строка - Идентификатор сессии.
//   * РежимВыполнения - Строка - Режим вызова инструмента.
//   * ИдентификаторЗадачи - Строка - Идентификатор task-based вызова.
//   * ProgressToken - Произвольный - Токен progress notifications.
//
// Возвращаемое значение:
//  Структура:
//  * jsonrpc - Строка - Версия протокола JSON-RPC.
//  * id - Произвольный - Идентификатор запроса.
Функция ВызватьИнструмент(ВызовИнструмента) Экспорт
	Попытка
		Дескриптор = ПолучитьДескрипторИнструмента(ВызовИнструмента);
		РежимИнструмента = ОпределитьРежимИнструмента(Дескриптор);
		ПроверитьВызовИнструмента(ВызовИнструмента, РежимИнструмента);
	Исключение
		Возврат ОбработатьОшибкуВалидацииВызоваИнструмента(
			Мсп_Коллекции.Свойство(ВызовИнструмента, "Идентификатор", Неопределено),
			ИнформацияОбОшибке());
	КонецПопытки;

	Если ВызовИнструмента.РежимВыполнения = "task"
		И ЗначениеЗаполнено(ВызовИнструмента.ИдентификаторЗадачи)
		И (РежимИнструмента = "sync" Или РежимИнструмента = "deferred") Тогда
		Мсп_ЗадачиКлиент.ЗавершитьЗадачуПоОтветуИнструмента(
			ВызовИнструмента.ИдентификаторЗадачи,
			СформироватьОшибкуЗадачи(-32601, "Tool does not support task-based invocation"));
		Возврат Неопределено;
	КонецЕсли;

	Контекст = СформироватьКонтекст(
		"tools",
		ВызовИнструмента.ИмяИнструмента,
		ВызовИнструмента.Аргументы,
		ВызовИнструмента.Сессия,
		ВызовИнструмента.Идентификатор,
		ВызовИнструмента,
		ВызовИнструмента.РежимВыполнения,
		ВызовИнструмента.ProgressToken);
	
	Запрос = НовыйЗапросВызова(
		ВызовИнструмента.Аргументы,
		Контекст,
		ВызовИнструмента.ИдентификаторЗадачи);
	Если РежимИнструмента = "deferred" Тогда
		Результат = ВызватьОтложенныйОбработчик(
			ВызовИнструмента.Идентификатор,
			Дескриптор,
			Запрос);
	Иначе
		Результат = ВызватьОбработчик(
			ВызовИнструмента.Идентификатор,
			Дескриптор,
			Запрос,
			"tools",
			"Tool execution error",
			"Tool result is invalid");
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ВызватьОтложенныйОбработчик(Идентификатор, Дескриптор, Запрос)
	Попытка
		Результат = ВыполнитьОповещение(Дескриптор.Обработчик, Запрос);
	Исключение
		Возврат ОбработатьОшибку(Идентификатор, ИнформацияОбОшибке());
	КонецПопытки;

	Если Результат = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;

	Если ЭтоОшибкаИнструмента(Результат) Тогда
		Возврат СформироватьОшибку(
			Идентификатор,
			КодMCPОшибкиИнструмента(Результат.КодОшибки),
			СообщениеОшибкиИнструмента(
				Результат.КодОшибки,
				Результат.Ошибка));
	КонецЕсли;

	Если Не ЭтоРезультатИнструмента(Результат) Тогда
		Возврат ВнутренняяОшибка(Идентификатор, "Tool result is invalid");
	КонецЕсли;

	Возврат СформироватьОтвет(Идентификатор, Результат);
КонецФункции

// Формирует ответ на чтение ресурса MCP.
//
// Параметры:
//  Идентификатор - Произвольный - Идентификатор запроса.
//  Параметры - Структура - Параметры чтения ресурса.
//  Сессия - Строка - Идентификатор сессии.
//
// Возвращаемое значение:
//  Структура:
//  * jsonrpc - Строка - Версия протокола JSON-RPC.
//  * id - Произвольный - Идентификатор запроса.
Функция ПрочитатьРесурс(Идентификатор, Параметры, Сессия) Экспорт
	Если ТипЗнч(Параметры) <> Тип("Структура") Тогда
		Возврат ОшибкаПараметров(Идентификатор);
	КонецЕсли;

	URI = Мсп_Коллекции.Свойство(Параметры, "uri", "");
	URIШаблон = Мсп_Коллекции.Свойство(Параметры, "uriTemplate", "");
	Попытка
		Аргументы = СформироватьАргументыРесурса(Параметры);
	Исключение
		Возврат ОшибкаПараметров(Идентификатор);
	КонецПопытки;
	Если Не ЗначениеЗаполнено(URI) Тогда
		Возврат ОшибкаПараметров(Идентификатор);
	КонецЕсли;
	
	Дескриптор = ОписаниеРесурса(URI, URIШаблон);
	Если Дескриптор = Неопределено Тогда
		Возврат НеНайдено(Идентификатор);
	КонецЕсли;
	
	Контекст = СформироватьКонтекст(
		"resources",
		URI,
		Аргументы,
		Сессия,
		Идентификатор,
		Параметры,
		"sync",
		Неопределено);
	Если ЗначениеЗаполнено(URIШаблон) Тогда
		Контекст.Вставить("uriTemplate", URIШаблон);
	КонецЕсли;
	Запрос = НовыйЗапросВызова(Параметры, Контекст);
	Возврат ВызватьОбработчикРесурса(
		Идентификатор,
		Дескриптор,
		Запрос,
		"Resource execution error",
		"Resource result is invalid",
		URI);
КонецФункции

// Формирует ответ на получение промпта MCP.
//
// Параметры:
//  Идентификатор - Произвольный - Идентификатор запроса.
//  Параметры - Структура - Параметры получения промпта.
//  Сессия - Строка - Идентификатор сессии.
//
// Возвращаемое значение:
//  Структура:
//  * jsonrpc - Строка - Версия протокола JSON-RPC.
//  * id - Произвольный - Идентификатор запроса.
Функция ПолучитьПромпт(Идентификатор, Параметры, Сессия) Экспорт
	Если ТипЗнч(Параметры) <> Тип("Структура") Тогда
		Возврат ОшибкаПараметров(Идентификатор);
	КонецЕсли;

	ИмяПромпта = Мсп_Коллекции.Свойство(Параметры, "name", "");
	Аргументы = Мсп_Коллекции.Свойство(Параметры, "arguments", Новый Структура);
	Если Не ЗначениеЗаполнено(ИмяПромпта) Тогда
		Возврат ОшибкаПараметров(Идентификатор);
	КонецЕсли;

	Если ТипЗнч(Аргументы) <> Тип("Структура") Тогда
		Возврат ОшибкаПараметров(Идентификатор);
	КонецЕсли;
	
	ПромптыРеестр = Мсп_РеестрКлиент.РеестрПромптов();
	Дескриптор = ПромптыРеестр.Получить(ИмяПромпта);
	Если Дескриптор = Неопределено Тогда
		Возврат НеНайдено(Идентификатор);
	КонецЕсли;
	
	Контекст = СформироватьКонтекст(
		"prompts",
		ИмяПромпта,
		Аргументы,
		Сессия,
		Идентификатор,
		Параметры,
		"sync",
		Неопределено);
	Запрос = НовыйЗапросВызова(Аргументы, Контекст);
	Возврат ВызватьОбработчик(
		Идентификатор,
		Дескриптор,
		Запрос,
		"prompts",
		"Prompt execution error",
		"Prompt result is invalid");
КонецФункции

// Формирует описание инструмента MCP.
//
// Параметры:
//  Имя - Строка - Имя инструмента.
//  Описание - Строка - Описание инструмента.
//  Схема - Структура, Соответствие - JSON-схема входных параметров.
//  РежимВыполнения - Строка - Режим выполнения инструмента. По умолчанию sync.
//
// Возвращаемое значение:
//  Структура - Описание инструмента.
Функция НовыйОписаниеИнструмента(Имя, Описание, Схема, РежимВыполнения = "sync") Экспорт
	Результат = Новый Структура("name,description,inputSchema", Имя, Описание, Схема);
	Если РежимВыполнения = "task" Тогда
		Результат.Вставить("execution", Новый Структура("taskSupport", "optional"));
	КонецЕсли;
	Возврат Результат;
КонецФункции

// Создает единый служебный контракт вызова инструмента.
//
// Параметры:
//  Идентификатор - Произвольный - Идентификатор запроса.
//  ИмяИнструмента - Строка - Имя инструмента.
//  Аргументы - Структура, Соответствие - Аргументы вызова инструмента.
//  Сессия - Строка - Идентификатор сессии.
//  РежимВыполнения - Строка - Режим вызова инструмента.
//  ИдентификаторЗадачи - Строка - Идентификатор task-based вызова.
//  ProgressToken - Произвольный - Токен progress notifications.
//
// Возвращаемое значение:
//  Структура - Описание вызова инструмента.
Функция НовыйВызовИнструмента(
	Идентификатор,
	ИмяИнструмента,
	Аргументы = Неопределено,
	Сессия = "",
	РежимВыполнения = "sync",
	ИдентификаторЗадачи = "",
	ProgressToken = Неопределено) Экспорт

	Аргументы = ПодготовитьАргументыВызоваИнструмента(Аргументы);

	ВызовИнструмента = Новый Структура;
	ВызовИнструмента.Вставить("Идентификатор", Идентификатор);
	ВызовИнструмента.Вставить("ИмяИнструмента", ИмяИнструмента);
	ВызовИнструмента.Вставить("Аргументы", Аргументы);
	ВызовИнструмента.Вставить("Сессия", Сессия);
	ВызовИнструмента.Вставить("РежимВыполнения", РежимВыполнения);
	ВызовИнструмента.Вставить("ИдентификаторЗадачи", ИдентификаторЗадачи);
	ВызовИнструмента.Вставить("ProgressToken", ProgressToken);

	Возврат ВызовИнструмента;
КонецФункции

// Создает внутренний запрос обработчика MCP.
//
// Параметры:
//  Аргументы - Структура, Соответствие - Аргументы вызова обработчика.
//  Контекст - Структура - Контекст вызова.
//  ИдентификаторЗадачи - Строка - Идентификатор task-based вызова, если есть.
//
// Возвращаемое значение:
//  Структура - Запрос обработчика:
//   * Аргументы - Структура, Соответствие - Аргументы вызова.
//   * Контекст - Структура - Контекст вызова.
//   * ИдентификаторЗадачи - Строка - Идентификатор MCP-задачи для task-based вызова.
Функция НовыйЗапросВызова(Аргументы, Контекст, ИдентификаторЗадачи = "") Экспорт
	Запрос = Новый Структура("Аргументы, Контекст, Идентификатор", Аргументы, Контекст, Контекст.requestId);
	Если ЗначениеЗаполнено(ИдентификаторЗадачи) Тогда
		Запрос.Вставить("ИдентификаторЗадачи", ИдентификаторЗадачи);
	КонецЕсли;

	Возврат Запрос;
КонецФункции

// Создает параметры завершения MCP-задачи.
//
// Параметры:
//  Статус - Строка - Статус MCP-задачи.
//  Сообщение - Строка - Человекочитаемое описание статуса.
//  Тело - Структура - JSON-тело для ЗавершитьЗадачу.
//
// Возвращаемое значение:
//  Структура - Параметры завершения:
//   * Статус - Строка - Статус MCP-задачи.
//   * Сообщение - Строка - Человекочитаемое описание статуса.
//   * Тело - Структура - JSON-тело для ЗавершитьЗадачу.
Функция НовыйПараметрыЗавершенияЗадачи(Статус, Сообщение, Тело) Экспорт
	ПараметрыЗавершения = Новый Структура;
	ПараметрыЗавершения.Вставить("Статус", Статус);
	ПараметрыЗавершения.Вставить("Сообщение", Сообщение);
	ПараметрыЗавершения.Вставить("Тело", Тело);

	Возврат ПараметрыЗавершения;
КонецФункции

// Подготавливает ответ для завершения task-based инструмента.
//
// Параметры:
//  РезультатИнструмента - Произвольный - Результат инструмента или структура ошибки.
//
// Возвращаемое значение:
//  Структура - Параметры завершения:
//   * Статус - Строка - Статус MCP-задачи.
//   * Сообщение - Строка - Человекочитаемое описание статуса.
//   * Тело - Структура - JSON-тело для ЗавершитьЗадачу.
Функция ПодготовитьЗавершениеЗадачиИнструмента(РезультатИнструмента) Экспорт
	ПараметрыЗавершения = ЯвноеЗавершениеЗадачиИнструмента(РезультатИнструмента);
	Если ПараметрыЗавершения <> Неопределено Тогда
		Возврат ПараметрыЗавершения;
	КонецЕсли;
	
	Если ЭтоОшибкаИнструмента(РезультатИнструмента) Тогда
		Возврат ПодготовитьОшибочноеЗавершениеЗадачиИнструмента(
			РезультатИнструмента.КодОшибки,
			РезультатИнструмента.Ошибка);
	КонецЕсли;
	
	Возврат ПодготовитьУспешноеЗавершениеЗадачиИнструмента(РезультатИнструмента);
КонецФункции

// Подготавливает обычный JSON-RPC ответ по результату инструмента.
//
// Параметры:
//  Идентификатор - Произвольный - Идентификатор запроса.
//  РезультатИнструмента - Произвольный - Результат инструмента или структура ошибки.
//
// Возвращаемое значение:
//  Структура - JSON-RPC ответ.
Функция ПодготовитьОтветЗапросаИнструмента(Идентификатор, РезультатИнструмента) Экспорт
	Если ЭтоОшибкаИнструмента(РезультатИнструмента) Тогда
		Возврат ПодготовитьОшибкуЗапросаИнструмента(
			Идентификатор,
			РезультатИнструмента.КодОшибки,
			РезультатИнструмента.Ошибка);
	КонецЕсли;

	Если Не ЭтоРезультатИнструмента(РезультатИнструмента) Тогда
		Возврат ВнутренняяОшибка(Идентификатор, "Tool result is invalid");
	КонецЕсли;

	Возврат СформироватьОтвет(Идентификатор, РезультатИнструмента);
КонецФункции

// Подготавливает JSON-RPC ошибку по коду инструмента.
//
// Параметры:
//  Идентификатор - Произвольный - Идентификатор запроса.
//  КодОшибки - Строка - Код ошибки инструмента.
//  Ошибка - Строка - Описание ошибки.
//
// Возвращаемое значение:
//  Структура - JSON-RPC ошибка.
Функция ПодготовитьОшибкуЗапросаИнструмента(Идентификатор, КодОшибки, Ошибка) Экспорт
	Возврат СформироватьОшибку(
		Идентификатор,
		КодMCPОшибкиИнструмента(КодОшибки),
		СообщениеОшибкиИнструмента(КодОшибки, Ошибка));
КонецФункции

Функция ПодготовитьУспешноеЗавершениеЗадачиИнструмента(РезультатИнструмента) Экспорт
	Если Не ЭтоРезультатИнструмента(РезультатИнструмента) Тогда
		Возврат ПодготовитьВнутреннююОшибкуЗавершенияЗадачиИнструмента("Tool result is invalid");
	КонецЕсли;

	Возврат НовыйПараметрыЗавершенияЗадачи(
		"completed",
		"",
		Новый Структура("result", РезультатИнструмента));
КонецФункции

Функция ПодготовитьОшибочноеЗавершениеЗадачиИнструмента(КодОшибки, Ошибка) Экспорт
	Возврат НовыйПараметрыЗавершенияЗадачи(
		"failed",
		Ошибка,
		СформироватьОшибкуЗадачи(
			КодMCPОшибкиИнструмента(КодОшибки),
			СообщениеОшибкиИнструмента(КодОшибки, Ошибка)));
КонецФункции

// Формирует описание ресурса MCP.
//
// Параметры:
//  URI - Строка - Идентификатор ресурса.
//  Имя - Строка - Имя ресурса.
//  Описание - Строка - Описание ресурса.
//  MimeType - Строка - MIME-тип ресурса.
//
// Возвращаемое значение:
//  Структура - Описание ресурса.
Функция НовыйОписаниеРесурса(URI, Имя, Описание, MimeType) Экспорт
	Данные = Новый Структура("uri,name,description,mimeType");
	Данные.uri = URI;
	Данные.name = Имя;
	Данные.description = Описание;
	Данные.mimeType = MimeType;
	
	Возврат Данные;
КонецФункции

// Формирует описание шаблона ресурса MCP.
//
// Параметры:
//  URIШаблон - Строка - Шаблон URI ресурса.
//  Имя - Строка - Имя шаблона ресурса.
//  Описание - Строка - Описание шаблона ресурса.
//  MimeType - Строка - MIME-тип ресурса.
//
// Возвращаемое значение:
//  Структура - Описание шаблона ресурса.
Функция НовыйОписаниеШаблонаРесурса(URIШаблон, Имя, Описание, MimeType) Экспорт
	Данные = Новый Структура("uriTemplate,name,description,mimeType");
	Данные.uriTemplate = URIШаблон;
	Данные.name = Имя;
	Данные.description = Описание;
	Данные.mimeType = MimeType;

	Возврат Данные;
КонецФункции

// Формирует описание промпта MCP.
//
// Параметры:
//  Имя - Строка - Имя промпта.
//  Описание - Строка - Описание промпта.
//  Аргументы - Массив - Описание аргументов промпта.
//
// Возвращаемое значение:
//  Структура - Описание промпта.
Функция НовыйОписаниеПромпта(Имя, Описание, Аргументы) Экспорт
	Данные = Новый Структура("name,description,arguments");
	Данные.name = Имя;
	Данные.description = Описание;
	Данные.arguments = Аргументы;
	
	Возврат Данные;
КонецФункции

Функция ОшибкаПараметров(Идентификатор) Экспорт
	Возврат СформироватьОшибку(Идентификатор, -32602, "Invalid params");
КонецФункции

Функция НеНайдено(Идентификатор) Экспорт
	Возврат СформироватьОшибку(Идентификатор, -32601, "Not found");
КонецФункции

Функция ВнутренняяОшибка(Идентификатор, Сообщение = "") Экспорт
	Возврат СформироватьОшибку(Идентификатор, -32603, "Internal error: " + Сообщение);
КонецФункции

Функция ОшибкаСервера(Идентификатор, Сообщение) Экспорт
	Возврат СформироватьОшибку(Идентификатор, -32000, Сообщение);
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Формирует JSON-RPC ответ с результатом.
//
// Параметры:
//  Идентификатор - Произвольный - Идентификатор запроса.
//  Результат - Структура - Результат выполнения.
//
// Возвращаемое значение:
//  Структура:
//  * jsonrpc - Строка - Версия протокола JSON-RPC.
//  * id - Произвольный - Идентификатор запроса.
//  * result - Структура - Результат выполнения.
Функция СформироватьОтвет(Идентификатор, Результат)
	Ответ = Новый Структура("jsonrpc,id", "2.0", Идентификатор);
	Ответ.Вставить("result", Результат);
	Возврат Ответ;
КонецФункции

Функция ОбработатьОшибку(Идентификатор, Ошибка)
	
	Если ЗначениеЗаполнено(Ошибка.Код) Тогда
		Возврат СформироватьОшибку(
			Идентификатор,
			КодMCPОшибкиРесурса(Ошибка.Код),
			СообщениеОшибкиРесурса(Ошибка.Код, Ошибка.Описание));
	Иначе
		Возврат ВнутренняяОшибка(Идентификатор, Ошибка.Описание);
	КонецЕсли;
	
КонецФункции

Функция ОбработатьОшибкуВалидацииВызоваИнструмента(Идентификатор, Ошибка)
	Если Ошибка.Код = "INVALID_PARAMS" Тогда
		Возврат СформироватьОшибку(Идентификатор, -32602, Ошибка.Описание);
	ИначеЕсли Ошибка.Код = "NOT_FOUND" Тогда
		Возврат СформироватьОшибку(Идентификатор, -32601, Ошибка.Описание);
	ИначеЕсли Ошибка.Код = "ACTION_FAILED" Тогда
		Возврат ВнутренняяОшибка(Идентификатор, Ошибка.Описание);
	КонецЕсли;

	Возврат ОбработатьОшибку(Идентификатор, Ошибка);
КонецФункции

// Формирует JSON-RPC ответ с ошибкой.
//
// Параметры:
//  Идентификатор - Произвольный - Идентификатор запроса.
//  Код - Число - Код ошибки.
//  Сообщение - Строка - Сообщение об ошибке.
//
// Возвращаемое значение:
//  Структура:
//  * jsonrpc - Строка - Версия протокола JSON-RPC.
//  * id - Произвольный - Идентификатор запроса.
//  * error - Структура - Данные ошибки (code, message).
Функция СформироватьОшибку(Идентификатор, Код, Сообщение)
	Ответ = Новый Структура("jsonrpc,id", "2.0", Идентификатор);
	Ошибка = Новый Структура("code, message", Код, Сообщение);
	Ответ.Вставить("error", Ошибка);
	Возврат Ответ;
КонецФункции

Функция СформироватьОшибкуЗадачи(Код, Сообщение)
	Ошибка = Новый Структура("code, message", Код, Сообщение);
	Возврат Новый Структура("error", Ошибка);
КонецФункции

// Формирует контекст вызова для обработчиков MCP.
//
// Параметры:
//  Kind - Строка - Тип контекста (tools/resources/prompts).
//  ИмяИлиURI - Строка - Имя инструмента/промпта или URI ресурса.
//  Аргументы - Структура - Аргументы вызова.
//  Сессия - Строка - Идентификатор сессии.
//  Идентификатор - Произвольный - Идентификатор запроса.
//  Raw - Произвольный - Исходные данные запроса.
//
// Возвращаемое значение:
//  Структура:
//  * kind - Строка - Тип контекста.
//  * arguments - Структура - Аргументы вызова.
//  * sessionId - Строка - Идентификатор сессии (может быть пустой).
//  * requestId - Произвольный - Идентификатор запроса.
//  * raw - Произвольный - Исходные данные запроса.
//  * meta - Структура - Метаданные запроса.
Функция СформироватьКонтекст(Kind, ИмяИлиURI, Аргументы, Сессия, Идентификатор, Raw, РежимВыполнения = "sync", ProgressToken = Неопределено)
	Meta = Новый Структура;
	Контекст = Новый Структура;
	Контекст.Вставить("kind", Kind);
	
	Если Kind = "resources" Тогда
		Контекст.Вставить("uri", ИмяИлиURI);
	Иначе
		Контекст.Вставить("name", ИмяИлиURI);
	КонецЕсли;
	
	Контекст.Вставить("arguments", Аргументы);
	Контекст.Вставить("sessionId", Сессия);
	Контекст.Вставить("requestId", Идентификатор);
	Контекст.Вставить("raw", Raw);
	Контекст.Вставить("executionMode", РежимВыполнения);
	Контекст.Вставить("progressToken", ProgressToken);
	Если Контекст.progressToken <> Неопределено Тогда
		Meta.Вставить("progressToken", Контекст.progressToken);
	КонецЕсли;
	Контекст.Вставить("meta", Meta);
	
	Возврат Контекст;
КонецФункции

Функция ПолучитьДескрипторИнструмента(ВызовИнструмента)
	Если Не ЗначениеЗаполнено(ВызовИнструмента.ИмяИнструмента) Тогда
		Мсп_Ошибки.НекорректныеПараметры("Invalid params");
	КонецЕсли;

	Дескриптор = Мсп_РеестрКлиент.РеестрИнструментов().Получить(ВызовИнструмента.ИмяИнструмента);
	Если Дескриптор = Неопределено Тогда
		Мсп_Ошибки.НеНайдено("Not found");
	КонецЕсли;

	Возврат Дескриптор;
КонецФункции

// Проверяет служебный контракт вызова инструмента.
// Transport-envelope валидируется в Мсп_ТранспортСобытияКлиент.
Процедура ПроверитьВызовИнструмента(ВызовИнструмента, РежимИнструмента)
	Если РежимИнструмента = Неопределено Тогда
		Мсп_Ошибки.Внутренняя("Tool execution mode is invalid");
	КонецЕсли;

	Если РежимИнструмента = "task" Тогда
		Если ВызовИнструмента.РежимВыполнения <> "task" Тогда
			Мсп_Ошибки.НеНайдено("Tool requires task-based invocation");
		КонецЕсли;
	КонецЕсли;

	Если ТипЗнч(ВызовИнструмента.Аргументы) <> Тип("Структура") Тогда
		Мсп_Ошибки.НекорректныеПараметры("Invalid params");
	КонецЕсли;
КонецПроцедуры

Функция ОпределитьРежимИнструмента(Дескриптор)
	Если Не ЭтоДопустимыйРежимВыполнения(Дескриптор.РежимВыполнения) Тогда
		Возврат Неопределено;
	КонецЕсли;

	Если Дескриптор.РежимВыполнения = "sync"
		И Дескриптор.ОтложенныйОтвет Тогда
		Возврат "deferred";
	КонецЕсли;

	Возврат Дескриптор.РежимВыполнения;
КонецФункции

Функция ЭтоДопустимыйРежимВыполнения(РежимВыполнения)
	Возврат РежимВыполнения = "sync"
		Или РежимВыполнения = "task";
КонецФункции

Функция ПодготовитьАргументыВызоваИнструмента(Аргументы)
	Если Аргументы = Неопределено Тогда
		Возврат Новый Структура;
	КонецЕсли;

	Если ТипЗнч(Аргументы) = Тип("Структура") Тогда
		Возврат Аргументы;
	КонецЕсли;

	Мсп_Ошибки.НекорректныеПараметры("Invalid params");
КонецФункции

// Формирует аргументы чтения ресурса MCP.
//
// Параметры:
//  Параметры - Структура - Параметры чтения ресурса.
//
// Возвращаемое значение:
//  Структура - Аргументы сопоставления шаблона ресурса.
Функция СформироватьАргументыРесурса(Параметры)
	ЕстьАргументы = Ложь;
	Аргументы = Неопределено;

	Если ТипЗнч(Параметры) = Тип("Структура") Тогда
		ЕстьАргументы = Параметры.Свойство("arguments", Аргументы);
	КонецЕсли;

	Если Не ЕстьАргументы Тогда
		Возврат Новый Структура;
	КонецЕсли;

	Если ТипЗнч(Аргументы) <> Тип("Структура") Тогда
		Мсп_Ошибки.НекорректныеПараметры("Invalid params");
	КонецЕсли;
	
	Возврат Аргументы;
КонецФункции

Функция ОписаниеРесурса(URI, URIШаблон)
	Дескриптор = Мсп_РеестрКлиент.РеестрРесурсов().Получить(URI);
	Если Дескриптор <> Неопределено Тогда
		Возврат Дескриптор;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(URIШаблон) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат Мсп_РеестрКлиент.РеестрШаблоновРесурсов().Получить(URIШаблон);
КонецФункции

// Формирует ответ по результату выполнения обработчика MCP.
//
// Параметры:
//  Идентификатор - Произвольный - Идентификатор запроса.
//  Дескриптор - Структура - Описание обработчика.
//  Запрос - Структура - Запрос вызова (Аргументы, Контекст).
//  ВидРезультата - Строка - Тип результата (tools/resources/prompts).
//  СообщениеОшибкаВыполнения - Строка - Ошибка выполнения обработчика.
//  СообщениеОшибкаРезультата - Строка - Ошибка результата обработчика.
//
// Возвращаемое значение:
//  Структура - JSON-RPC ответ.
Функция ВызватьОбработчик(Идентификатор, Дескриптор, Запрос, ВидРезультата, СообщениеОшибкаВыполнения, СообщениеОшибкаРезультата)
	Попытка
		Результат = ВыполнитьОповещение(Дескриптор.Обработчик, Запрос);
	Исключение
		Возврат ОбработатьОшибку(Идентификатор, ИнформацияОбОшибке());
	КонецПопытки;
	
	Если Результат = Неопределено Тогда
		Возврат ВнутренняяОшибка(Идентификатор, СообщениеОшибкаВыполнения);
	КонецЕсли;
	
	Если Не ЭтоВалидныйРезультатПоВиду(Результат, ВидРезультата) Тогда
		Возврат ВнутренняяОшибка(Идентификатор, СообщениеОшибкаРезультата);
	КонецЕсли;
	
	Возврат СформироватьОтвет(Идентификатор, Результат);
КонецФункции

Функция ВызватьОбработчикРесурса(Идентификатор, Дескриптор, Запрос, СообщениеОшибкаВыполнения, СообщениеОшибкаРезультата, URI)
	Попытка
		Результат = ВыполнитьОповещение(Дескриптор.Обработчик, Запрос);
	Исключение
		Возврат ОбработатьОшибку(Идентификатор, ИнформацияОбОшибке());
	КонецПопытки;
	
	Если Результат = Неопределено Тогда
		Возврат ВнутренняяОшибка(Идентификатор, СообщениеОшибкаВыполнения);
	КонецЕсли;
	
	Если ЭтоОшибкаРесурса(Результат) Тогда
		Возврат СформироватьОшибкуРесурса(
			Идентификатор,
			Результат.КодОшибки,
			Результат.Ошибка);
	КонецЕсли;
	
	Если Не ЭтоРезультатРесурса(Результат) Тогда
		Возврат ВнутренняяОшибка(Идентификатор, СообщениеОшибкаРезультата);
	КонецЕсли;
	
	Возврат СформироватьОтвет(Идентификатор, Результат);
КонецФункции

Функция СформироватьОшибкуРесурса(Идентификатор, КодОшибки, Ошибка)
	Возврат СформироватьОшибку(
		Идентификатор,
		КодMCPОшибкиРесурса(КодОшибки),
		СообщениеОшибкиРесурса(КодОшибки, Ошибка));
КонецФункции

Функция КодMCPОшибкиРесурса(КодОшибки)
	Если КодОшибки = "INVALID_URI"
		ИЛИ КодОшибки = "INVALID_PARAMS" Тогда
		Возврат -32602;
	ИначеЕсли КодОшибки = "ACTION_FAILED" Тогда
		Возврат -32603;
	ИначеЕсли КодОшибки = "ACTION_DENIED" Тогда
		Возврат -32001;
	КонецЕсли;
	
	Возврат -32000;
КонецФункции

Функция СообщениеОшибкиРесурса(КодОшибки, Ошибка)
	Если Не ЗначениеЗаполнено(Ошибка) Тогда
		Возврат КодОшибки;
	КонецЕсли;
	
	Возврат КодОшибки + ": " + Ошибка;
КонецФункции

Функция ЭтоОшибкаРесурса(Результат)
	Возврат ТипЗнч(Результат) = Тип("Структура")
		И Результат.Свойство("КодОшибки");
КонецФункции

Функция ЭтоОшибкаИнструмента(Результат)
	Если ТипЗнч(Результат) <> Тип("Структура") Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если Не Результат.Свойство("КодОшибки") Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Не Результат.Свойство("content")
		И Не Результат.Свойство("contents")
		И Не Результат.Свойство("messages");
КонецФункции

Функция КодMCPОшибкиИнструмента(КодОшибки)
	Возврат КодMCPОшибкиРесурса(КодОшибки);
КонецФункции

Функция СообщениеОшибкиИнструмента(КодОшибки, Ошибка)
	Возврат СообщениеОшибкиРесурса(КодОшибки, Ошибка);
КонецФункции

Функция ЭтоВалидныйРезультатПоВиду(Результат, ВидРезультата)
	Если ВидРезультата = "tools" Тогда
		Возврат ЭтоРезультатИнструмента(Результат);
	ИначеЕсли ВидРезультата = "resources" Тогда
		Возврат ЭтоРезультатРесурса(Результат);
	ИначеЕсли ВидРезультата = "prompts" Тогда
		Возврат ЭтоРезультатПромпта(Результат);
	КонецЕсли;
	
	Возврат Ложь;
КонецФункции

// Выполняет обработчик оповещения MCP.
//
// Параметры:
//  Оповещение - ОписаниеОповещения - Описание оповещения.
//  Запрос - Структура - Запрос вызова:
//   * Аргументы - Структура - Аргументы вызова.
//   * Контекст - Структура - Контекст вызова.
//
// Возвращаемое значение:
//  Произвольный - Результат выполнения обработчика.
//  Неопределено - Обработчик не задан или завершился с ошибкой.
Функция ВыполнитьОповещение(Оповещение, Запрос)
	Если Оповещение = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;

	Возврат ВыполнитьОбработкуОповещения(Оповещение, Запрос);
КонецФункции

Функция СообщениеЗавершенияЗадачи(ТелоОтвета)
	Ошибка = Мсп_Коллекции.Свойство(ТелоОтвета, "error", Неопределено);
	Если Ошибка <> Неопределено Тогда
		Возврат Мсп_Коллекции.Свойство(Ошибка, "message", "");
	КонецЕсли;
	
	Возврат "";
КонецФункции

Функция ЯвноеЗавершениеЗадачиИнструмента(РезультатИнструмента)
	Если ТипЗнч(РезультатИнструмента) <> Тип("Структура") Тогда
		Возврат Неопределено;
	КонецЕсли;

	ЕстьРезультат = Ложь;
	ЕстьОшибка = Ложь;
	Для Каждого Элемент Из РезультатИнструмента Цикл
		Если Элемент.Ключ = "result" Тогда
			ЕстьРезультат = Истина;
		ИначеЕсли Элемент.Ключ = "error" Тогда
			ЕстьОшибка = Истина;
		КонецЕсли;
	КонецЦикла;
	Если Не ЕстьРезультат И Не ЕстьОшибка Тогда
		Возврат Неопределено;
	КонецЕсли;

	Если Не ДопустимоеТелоЗавершенияЗадачиИнструмента(РезультатИнструмента, ЕстьРезультат, ЕстьОшибка) Тогда
		Возврат Неопределено;
	КонецЕсли;

	Если ЕстьРезультат Тогда
		Результат = РезультатИнструмента.result;
		Если Не ЭтоРезультатИнструмента(Результат) Тогда
			Возврат Неопределено;
		КонецЕсли;
		Возврат НовыйПараметрыЗавершенияЗадачи(
			"completed",
			"",
			Новый Структура("result", Результат));
	КонецЕсли;

	Ошибка = РезультатИнструмента.error;
	Код = Мсп_Коллекции.Свойство(Ошибка, "code", Неопределено);
	Если ТипЗнч(Код) <> Тип("Число") Тогда
		Возврат Неопределено;
	КонецЕсли;

	Возврат НовыйПараметрыЗавершенияЗадачи(
		"failed",
		Ошибка.message,
		СформироватьОшибкуЗадачи(Код, Ошибка.message));
КонецФункции

Функция ПодготовитьВнутреннююОшибкуЗавершенияЗадачиИнструмента(Сообщение)
	Возврат НовыйПараметрыЗавершенияЗадачи(
		"failed",
		Сообщение,
		СформироватьОшибкуЗадачи(-32603, Сообщение));
КонецФункции

Функция ДопустимоеТелоЗавершенияЗадачиИнструмента(ТелоОтвета, ЕстьРезультат, ЕстьОшибка)
	Если ЕстьРезультат И ЕстьОшибка Тогда
		Возврат Ложь;
	КонецЕсли;

	Для Каждого Элемент Из ТелоОтвета Цикл
		Если Элемент.Ключ = "jsonrpc"
			ИЛИ Элемент.Ключ = "id" Тогда
			Продолжить;
		КонецЕсли;

		Если ЕстьРезультат И Элемент.Ключ = "result" Тогда
			Продолжить;
		КонецЕсли;

		Если ЕстьОшибка И Элемент.Ключ = "error" Тогда
			Продолжить;
		КонецЕсли;

		Возврат Ложь;
	КонецЦикла;

	Если ЕстьОшибка Тогда
		Ошибка = ТелоОтвета.error;
		Если ТипЗнч(Ошибка) <> Тип("Структура") Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЕсли;

	Возврат Истина;
КонецФункции

Функция ЭтоРезультатИнструмента(Результат)
	Если ТипЗнч(Результат) <> Тип("Структура") Тогда
		Возврат Ложь;
	КонецЕсли;

	Возврат Результат.Свойство("content");
КонецФункции

Функция ЭтоРезультатРесурса(Результат)
	Если ТипЗнч(Результат) <> Тип("Структура") Тогда
		Возврат Ложь;
	КонецЕсли;

	Возврат Результат.Свойство("contents");
КонецФункции

Функция ЭтоРезультатПромпта(Результат)
	Если ТипЗнч(Результат) <> Тип("Структура") Тогда
		Возврат Ложь;
	КонецЕсли;

	Возврат Результат.Свойство("messages");
КонецФункции

#КонецОбласти
