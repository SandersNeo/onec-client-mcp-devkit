#Область СлужебныйПрограммныйИнтерфейс
// Обрабатывает JSON-RPC запрос MCP.
//
// Параметры:
//  Сообщение - Структура - Объект запроса JSON-RPC.
//  Сессия - Строка - Идентификатор сессии.
//
// Возвращаемое значение:
//  Структура:
//  * jsonrpc - Строка - Версия протокола JSON-RPC.
//  * id - Произвольный - Идентификатор запроса.
//  Неопределено - Ответ не требуется.
Функция ОбработатьJSONRPC(Сообщение, Сессия) Экспорт
	Если ТипЗнч(Сообщение) <> Тип("Структура") И ТипЗнч(Сообщение) <> Тип("Соответствие") Тогда
		Возврат СформироватьОшибку(Неопределено, -32600, "Invalid Request");
	КонецЕсли;

	Идентификатор = ПолучитьСвойство(Сообщение, "id", Неопределено);
	Метод = ПолучитьСвойство(Сообщение, "method", "");
	Параметры = ПолучитьСвойство(Сообщение, "params", Новый Структура);

	Если Не ЗначениеЗаполнено(Метод) Тогда
		Если Идентификатор = Неопределено Тогда
			Возврат Неопределено;
		КонецЕсли;
		Возврат СформироватьОшибку(Идентификатор, -32600, "Invalid Request");
	КонецЕсли;

	Если Идентификатор = Неопределено Тогда
		// уведомление, ответа не требуется
		Возврат Неопределено;
	КонецЕсли;

	Если Метод = "initialize" Тогда
		Возврат ОтветИнициализация(Идентификатор, Параметры, Сессия);
	КонецЕсли;
	Если Метод = "ping" Тогда
		Возврат СформироватьОтвет(Идентификатор, Новый Структура);
	КонецЕсли;
	Если Метод = "tools/list" Тогда
		Возврат ОтветСписокИнструментов(Идентификатор);
	КонецЕсли;
	Если Метод = "tools/call" Тогда
		Возврат ОтветВызовИнструмента(Идентификатор, Параметры, Сессия);
	КонецЕсли;
	Если Метод = "resources/list" Тогда
		Возврат ОтветСписокРесурсов(Идентификатор);
	КонецЕсли;
	Если Метод = "resources/read" Тогда
		Возврат ОтветПрочитатьРесурс(Идентификатор, Параметры, Сессия);
	КонецЕсли;
	Если Метод = "prompts/list" Тогда
		Возврат ОтветСписокПромптов(Идентификатор);
	КонецЕсли;
	Если Метод = "prompts/get" Тогда
		Возврат ОтветПолучитьПромпт(Идентификатор, Параметры, Сессия);
	КонецЕсли;

	Возврат СформироватьОшибку(Идентификатор, -32601, "Method not found");
КонецФункции

// Формирует и отправляет уведомление логирования MCP.
//
// Параметры:
//  Уровень - Строка - Уровень логирования.
//  Текст - Строка - Текст сообщения.
//  Контекст - Структура - Дополнительный контекст (если есть).
//
// Возвращаемое значение:
//  Булево - Истина, если уведомление обработано.
Асинх Функция ЛогСообщение(Уровень, Текст, Контекст = Неопределено) Экспорт
	Параметры = Новый Структура("level,message", Уровень, Текст);
	Если Контекст <> Неопределено Тогда
		Параметры.Вставить("context", Контекст);
	КонецЕсли;
	Уведомление = СформироватьУведомление("notifications/logMessage", Параметры);
	Возврат Ждать Мсп_СерверКлиент.ОтправитьУведомление(Уведомление);
КонецФункции

// Читает JSON-строку и возвращает объект.
//
// Параметры:
//  ТекстJSON - Строка - JSON-строка.
//
// Возвращаемое значение:
//  Произвольный - Прочитанный объект.
Функция ПрочитатьJSONСтроку(ТекстJSON) Экспорт
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(ТекстJSON);
	Возврат ПрочитатьJSON(ЧтениеJSON, Истина);
КонецФункции

// Читает JSON-строку с подстановкой значения по умолчанию при ошибке.
//
// Параметры:
//  ТекстJSON - Строка - JSON-строка.
//  ЗначениеПоУмолчанию - Произвольный, Неопределено - Значение при ошибке чтения.
//
// Возвращаемое значение:
//  Произвольный - Прочитанный объект или значение по умолчанию.
//  Неопределено - Нет значения по умолчанию или не удалось прочитать JSON.
Функция ПрочитатьJSONСтрокуБезОшибок(ТекстJSON, ЗначениеПоУмолчанию = Неопределено) Экспорт
	Попытка
		Возврат ПрочитатьJSONСтроку(ТекстJSON);
	Исключение
		Возврат ЗначениеПоУмолчанию;
	КонецПопытки;
КонецФункции

// Записывает объект в JSON-строку.
//
// Параметры:
//  Данные - Структура - Объект для сериализации.
//
// Возвращаемое значение:
//  Строка - JSON-представление данных.
Функция Сериализовать(Данные) Экспорт
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, Данные);
	Возврат ЗаписьJSON.Закрыть();
КонецФункции

// Получает свойство из структуры/соответствия с поддержкой значения по умолчанию.
//
// Параметры:
//  Данные - Структура - Структура или соответствие.
//  Имя - Строка - Имя свойства.
//  ЗначениеПоУмолчанию - Произвольный, Неопределено - Значение по умолчанию.
//
// Возвращаемое значение:
//  Произвольный - Значение свойства или значение по умолчанию.
//  Неопределено - Свойство не найдено и значение по умолчанию не задано.
Функция ПолучитьСвойство(Данные, Имя, ЗначениеПоУмолчанию) Экспорт
	Если ТипЗнч(Данные) = Тип("Структура") Тогда
		Значение = ЗначениеПоУмолчанию;
		Если Данные.Свойство(Имя, Значение) Тогда
			Возврат Значение;
		КонецЕсли;
	КонецЕсли;
	Если ТипЗнч(Данные) = Тип("Соответствие") Тогда
		Значение = Данные.Получить(Имя);
		Если Значение <> Неопределено Тогда
			Возврат Значение;
		КонецЕсли;
	КонецЕсли;
	Возврат ЗначениеПоУмолчанию;
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Формирует описание инструмента MCP.
//
// Параметры:
//  Имя - Строка - Имя инструмента.
//  Описание - Строка - Описание инструмента.
//  Схема - Структура, Соответствие - JSON-схема входных параметров.
//
// Возвращаемое значение:
//  Структура - Описание инструмента.
Функция НовыйОписаниеИнструмента(Имя, Описание, Схема)
	Описание = Новый Структура("name,description,inputSchema", Имя, Описание, Схема);
	
	Возврат Описание;
КонецФункции

// Формирует описание ресурса MCP.
//
// Параметры:
//  URI - Строка - Идентификатор ресурса.
//  Имя - Строка - Имя ресурса.
//  Описание - Строка - Описание ресурса.
//  MimeType - Строка - MIME-тип ресурса.
//
// Возвращаемое значение:
//  Структура - Описание ресурса.
Функция НовыйОписаниеРесурса(URI, Имя, Описание, MimeType)
	Данные = Новый Структура("uri,name,description,mimeType");
	Данные.uri = URI;
	Данные.name = Имя;
	Данные.description = Описание;
	Данные.mimeType = MimeType;
	
	Возврат Данные;
КонецФункции

// Формирует описание промпта MCP.
//
// Параметры:
//  Имя - Строка - Имя промпта.
//  Описание - Строка - Описание промпта.
//  Аргументы - Структура - Описание аргументов промпта.
//
// Возвращаемое значение:
//  Структура - Описание промпта.
Функция НовыйОписаниеПромпта(Имя, Описание, Аргументы)
	Данные = Новый Структура("name,description,arguments");
	Данные.name = Имя;
	Данные.description = Описание;
	Данные.arguments = Аргументы;
	
	Возврат Данные;
КонецФункции

// Формирует описание клиента MCP.
//
// Параметры:
//  Параметры - Структура, Соответствие - Параметры клиента.
//
// Возвращаемое значение:
//  Структура - Описание клиента.
//  Неопределено - Параметры не являются объектом.
Функция НовыйОписаниеКлиента(Параметры)
	Если ТипЗнч(Параметры) <> Тип("Структура")
		И ТипЗнч(Параметры) <> Тип("Соответствие") Тогда
		Возврат Неопределено;
	КонецЕсли;

	Клиент = Новый Структура;
	ЗначениеКлиента = ПолучитьСвойство(Параметры, "clientInfo", Неопределено);
	Если ЗначениеКлиента <> Неопределено Тогда
		Клиент.Вставить("clientInfo", ЗначениеКлиента);
	КонецЕсли;
	ВерсияПротокола = ПолучитьСвойство(Параметры, "protocolVersion", "");
	Если ЗначениеЗаполнено(ВерсияПротокола) Тогда
		Клиент.Вставить("protocolVersion", ВерсияПротокола);
	КонецЕсли;

	Возврат Клиент;
КонецФункции

// Формирует описание возможностей сервера MCP.
//
// Возвращаемое значение:
//  Структура - Описание возможностей сервера.
Функция НовыйОписаниеВозможностейСервера()
	Возможности = Новый Структура;
	Возможности.Вставить("tools", Новый Структура("listChanged", Ложь));
	Возможности.Вставить("resources", Новый Структура("subscribe,listChanged", Ложь, Ложь));
	Возможности.Вставить("prompts", Новый Структура("listChanged", Ложь));
	Возврат Возможности;
КонецФункции

// Формирует результат инициализации MCP.
//
// Возвращаемое значение:
//  Структура - Результат инициализации.
Функция НовыйРезультатИнициализации()
	Результат = Новый Структура;
	Результат.Вставить("protocolVersion", "2025-11-25");
	Результат.Вставить("serverInfo", Новый Структура("name,version", "1C MCP Server", "0.1.0"));
	Результат.Вставить("capabilities", НовыйОписаниеВозможностейСервера());
	Возврат Результат;
КонецФункции

// Формирует ответ инициализации MCP.
//
// Параметры:
//  Идентификатор - Произвольный - Идентификатор запроса.
//  Параметры - Структура - Параметры запроса initialize.
//  Сессия - Строка - Идентификатор сессии.
//
// Возвращаемое значение:
//  Структура:
//  * jsonrpc - Строка - Версия протокола JSON-RPC.
//  * id - Произвольный - Идентификатор запроса.
//  * result - Структура - Данные инициализации.
Функция ОтветИнициализация(Идентификатор, Параметры, Сессия)
	Мсп_РеестрКлиент.ИнициализироватьРеестры();
	Клиент = НовыйОписаниеКлиента(Параметры);
	Если Клиент <> Неопределено И ЗначениеЗаполнено(Сессия) Тогда
		Сессии = Мсп_РеестрКлиент.Сессии();
		Сессии.Вставить(Сессия, Клиент);
	КонецЕсли;

	Возврат СформироватьОтвет(Идентификатор, НовыйРезультатИнициализации());
КонецФункции

// Формирует ответ со списком инструментов MCP.
//
// Параметры:
//  Идентификатор - Произвольный - Идентификатор запроса.
//
// Возвращаемое значение:
//  Структура:
//  * jsonrpc - Строка - Версия протокола JSON-RPC.
//  * id - Произвольный - Идентификатор запроса.
//  * result - Структура - Данные списка инструментов.
Функция ОтветСписокИнструментов(Идентификатор)
	Мсп_РеестрКлиент.ИнициализироватьРеестры();
	Инструменты = Новый Массив;
	ИнструментыРеестр = Мсп_РеестрКлиент.РеестрИнструментов();
	Для Каждого Элемент Из ИнструментыРеестр Цикл
		Дескриптор = Элемент.Значение;
		Инструменты.Добавить(НовыйОписаниеИнструмента(Дескриптор.Имя, Дескриптор.Описание, Дескриптор.СхемаПараметров));
	КонецЦикла;
	Возврат СформироватьОтвет(Идентификатор, Новый Структура("tools", Инструменты));
КонецФункции

// Формирует ответ на вызов инструмента MCP.
//
// Параметры:
//  Идентификатор - Произвольный - Идентификатор запроса.
//  Параметры - Структура - Параметры вызова инструмента.
//  Сессия - Строка - Идентификатор сессии.
//
// Возвращаемое значение:
//  Структура:
//  * jsonrpc - Строка - Версия протокола JSON-RPC.
//  * id - Произвольный - Идентификатор запроса.
Функция ОтветВызовИнструмента(Идентификатор, Параметры, Сессия)
	Мсп_РеестрКлиент.ИнициализироватьРеестры();
	ИмяИнструмента = ПолучитьСвойство(Параметры, "name", "");
	Аргументы = ПолучитьСвойство(Параметры, "arguments", Новый Структура);
	Если Не ЗначениеЗаполнено(ИмяИнструмента) Тогда
		Возврат СформироватьОшибку(Идентификатор, -32602, "Invalid params");
	КонецЕсли;

	ИнструментыРеестр = Мсп_РеестрКлиент.РеестрИнструментов();
	Дескриптор = ИнструментыРеестр.Получить(ИмяИнструмента);
	Если Дескриптор = Неопределено Тогда
		Возврат СформироватьОшибку(Идентификатор, -32601, "Tool not found");
	КонецЕсли;

	Контекст = СформироватьКонтекст("tools", ИмяИнструмента, Аргументы, Сессия, Идентификатор, Параметры);
	Запрос = Новый Структура("Аргументы, Контекст", Аргументы, Контекст);
	Результат = ВыполнитьОповещение(Дескриптор.notify, Запрос);
	Если Результат = Неопределено Тогда
		Возврат СформироватьОшибку(Идентификатор, -32603, "Tool execution error");
	КонецЕсли;

	Нормализовано = НормализоватьРезультатИнструмента(Результат);
	Если Нормализовано = Неопределено Тогда
		Возврат СформироватьОшибку(Идентификатор, -32603, "Tool result is invalid");
	КонецЕсли;

	Возврат СформироватьОтвет(Идентификатор, Нормализовано);
КонецФункции

// Формирует ответ со списком ресурсов MCP.
//
// Параметры:
//  Идентификатор - Произвольный - Идентификатор запроса.
//
// Возвращаемое значение:
//  Структура:
//  * jsonrpc - Строка - Версия протокола JSON-RPC.
//  * id - Произвольный - Идентификатор запроса.
//  * result - Структура - Данные списка ресурсов.
Функция ОтветСписокРесурсов(Идентификатор)
	Мсп_РеестрКлиент.ИнициализироватьРеестры();
	Ресурсы = Новый Массив;
	РесурсыРеестр = Мсп_РеестрКлиент.РеестрРесурсов();
	Для Каждого Элемент Из РесурсыРеестр Цикл
		Дескриптор = Элемент.Значение;
		Ресурсы.Добавить(НовыйОписаниеРесурса(Дескриптор.uri, Дескриптор.name, Дескриптор.description, Дескриптор.mimeType));
	КонецЦикла;
	Возврат СформироватьОтвет(Идентификатор, Новый Структура("resources", Ресурсы));
КонецФункции

// Формирует ответ на чтение ресурса MCP.
//
// Параметры:
//  Идентификатор - Произвольный - Идентификатор запроса.
//  Параметры - Структура - Параметры чтения ресурса.
//  Сессия - Строка - Идентификатор сессии.
//
// Возвращаемое значение:
//  Структура:
//  * jsonrpc - Строка - Версия протокола JSON-RPC.
//  * id - Произвольный - Идентификатор запроса.
Функция ОтветПрочитатьРесурс(Идентификатор, Параметры, Сессия)
	Мсп_РеестрКлиент.ИнициализироватьРеестры();
	URI = ПолучитьСвойство(Параметры, "uri", "");
	Если Не ЗначениеЗаполнено(URI) Тогда
		Возврат СформироватьОшибку(Идентификатор, -32602, "Invalid params");
	КонецЕсли;

	РесурсыРеестр = Мсп_РеестрКлиент.РеестрРесурсов();
	Дескриптор = РесурсыРеестр.Получить(URI);
	Если Дескриптор = Неопределено Тогда
		Возврат СформироватьОшибку(Идентификатор, -32601, "Resource not found");
	КонецЕсли;

	Контекст = СформироватьКонтекст("resources", URI, Параметры, Сессия, Идентификатор, Параметры);
	Запрос = Новый Структура("Аргументы, Контекст", Параметры, Контекст);
	Результат = ВыполнитьОповещение(Дескриптор.notify, Запрос);
	Если Результат = Неопределено Тогда
		Возврат СформироватьОшибку(Идентификатор, -32603, "Resource execution error");
	КонецЕсли;

	Нормализовано = НормализоватьРезультатРесурса(Результат, Дескриптор);
	Если Нормализовано = Неопределено Тогда
		Возврат СформироватьОшибку(Идентификатор, -32603, "Resource result is invalid");
	КонецЕсли;

	Возврат СформироватьОтвет(Идентификатор, Нормализовано);
КонецФункции

// Формирует ответ со списком промптов MCP.
//
// Параметры:
//  Идентификатор - Произвольный - Идентификатор запроса.
//
// Возвращаемое значение:
//  Структура:
//  * jsonrpc - Строка - Версия протокола JSON-RPC.
//  * id - Произвольный - Идентификатор запроса.
//  * result - Структура - Данные списка промптов.
Функция ОтветСписокПромптов(Идентификатор)
	Мсп_РеестрКлиент.ИнициализироватьРеестры();
	Промпты = Новый Массив;
	ПромптыРеестр = Мсп_РеестрКлиент.РеестрПромптов();
	Для Каждого Элемент Из ПромптыРеестр Цикл
		Дескриптор = Элемент.Значение;
		Промпты.Добавить(НовыйОписаниеПромпта(Дескриптор.name, Дескриптор.description, Дескриптор.arguments));
	КонецЦикла;
	Возврат СформироватьОтвет(Идентификатор, Новый Структура("prompts", Промпты));
КонецФункции

// Формирует ответ на получение промпта MCP.
//
// Параметры:
//  Идентификатор - Произвольный - Идентификатор запроса.
//  Параметры - Структура - Параметры получения промпта.
//  Сессия - Строка - Идентификатор сессии.
//
// Возвращаемое значение:
//  Структура:
//  * jsonrpc - Строка - Версия протокола JSON-RPC.
//  * id - Произвольный - Идентификатор запроса.
Функция ОтветПолучитьПромпт(Идентификатор, Параметры, Сессия)
	Мсп_РеестрКлиент.ИнициализироватьРеестры();
	ИмяПромпта = ПолучитьСвойство(Параметры, "name", "");
	Аргументы = ПолучитьСвойство(Параметры, "arguments", Новый Структура);
	Если Не ЗначениеЗаполнено(ИмяПромпта) Тогда
		Возврат СформироватьОшибку(Идентификатор, -32602, "Invalid params");
	КонецЕсли;

	ПромптыРеестр = Мсп_РеестрКлиент.РеестрПромптов();
	Дескриптор = ПромптыРеестр.Получить(ИмяПромпта);
	Если Дескриптор = Неопределено Тогда
		Возврат СформироватьОшибку(Идентификатор, -32601, "Prompt not found");
	КонецЕсли;

	Контекст = СформироватьКонтекст("prompts", ИмяПромпта, Аргументы, Сессия, Идентификатор, Параметры);
	Запрос = Новый Структура("Аргументы, Контекст", Аргументы, Контекст);
	Результат = ВыполнитьОповещение(Дескриптор.notify, Запрос);
	Если Результат = Неопределено Тогда
		Возврат СформироватьОшибку(Идентификатор, -32603, "Prompt execution error");
	КонецЕсли;

	Нормализовано = НормализоватьРезультатПромпта(Результат);
	Если Нормализовано = Неопределено Тогда
		Возврат СформироватьОшибку(Идентификатор, -32603, "Prompt result is invalid");
	КонецЕсли;

	Возврат СформироватьОтвет(Идентификатор, Нормализовано);
КонецФункции

// Формирует JSON-RPC ответ с результатом.
//
// Параметры:
//  Идентификатор - Произвольный - Идентификатор запроса.
//  Результат - Структура - Результат выполнения.
//
// Возвращаемое значение:
//  Структура:
//  * jsonrpc - Строка - Версия протокола JSON-RPC.
//  * id - Произвольный - Идентификатор запроса.
//  * result - Структура - Результат выполнения.
Функция СформироватьОтвет(Идентификатор, Результат)
	Ответ = Новый Структура("jsonrpc,id", "2.0", Идентификатор);
	Ответ.Вставить("result", Результат);
	Возврат Ответ;
КонецФункции

// Формирует JSON-RPC ответ с ошибкой.
//
// Параметры:
//  Идентификатор - Произвольный - Идентификатор запроса.
//  Код - Число - Код ошибки.
//  Сообщение - Строка - Сообщение об ошибке.
//
// Возвращаемое значение:
//  Структура:
//  * jsonrpc - Строка - Версия протокола JSON-RPC.
//  * id - Произвольный - Идентификатор запроса.
//  * error - Структура - Данные ошибки (code, message).
Функция СформироватьОшибку(Идентификатор, Код, Сообщение)
	Ответ = Новый Структура("jsonrpc,id", "2.0", Идентификатор);
	Ошибка = Новый Структура("code,message", Код, Сообщение);
	Ответ.Вставить("error", Ошибка);
	Возврат Ответ;
КонецФункции

// Формирует JSON-RPC уведомление.
//
// Параметры:
//  Метод - Строка - Имя метода уведомления.
//  Параметры - Произвольный, Неопределено - Параметры уведомления.
//
// Возвращаемое значение:
//  Строка - JSON-представление уведомления.
Функция СформироватьУведомление(Метод, Параметры)
	Данные = Новый Структура("jsonrpc,method", "2.0", Метод);
	Если Параметры <> Неопределено Тогда
		Данные.Вставить("params", Параметры);
	КонецЕсли;
	Возврат Сериализовать(Данные);
КонецФункции

// Формирует контекст вызова для обработчиков MCP.
//
// Параметры:
//  Kind - Строка - Тип контекста (tools/resources/prompts).
//  ИмяИлиURI - Строка - Имя инструмента/промпта или URI ресурса.
//  Аргументы - Структура - Аргументы вызова.
//  Сессия - Строка - Идентификатор сессии.
//  Идентификатор - Произвольный - Идентификатор запроса.
//  Raw - Произвольный - Исходные данные запроса.
//
// Возвращаемое значение:
//  Структура:
//  * kind - Строка - Тип контекста.
//  * arguments - Структура - Аргументы вызова.
//  * sessionId - Строка - Идентификатор сессии.
//  * requestId - Произвольный - Идентификатор запроса.
//  * raw - Произвольный - Исходные данные запроса.
//  * meta - Структура - Метаданные сессии.
Функция СформироватьКонтекст(Kind, ИмяИлиURI, Аргументы, Сессия, Идентификатор, Raw)
	Meta = Новый Структура;
	Сессии = Мсп_РеестрКлиент.Сессии();
	Если Сессии <> Неопределено И ЗначениеЗаполнено(Сессия) Тогда
		СессионныеДанные = Сессии.Получить(Сессия);
		Если ТипЗнч(СессионныеДанные) = Тип("Структура") Тогда
			Для Каждого Пара Из СессионныеДанные Цикл
				Meta.Вставить(Пара.Ключ, Пара.Значение);
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;

	Контекст = Новый Структура;
	Контекст.Вставить("kind", Kind);
	Если Kind = "resources" Тогда
		Контекст.Вставить("uri", ИмяИлиURI);
	Иначе
		Контекст.Вставить("name", ИмяИлиURI);
	КонецЕсли;
	Контекст.Вставить("arguments", Аргументы);
	Контекст.Вставить("sessionId", Сессия);
	Контекст.Вставить("requestId", Идентификатор);
	Контекст.Вставить("raw", Raw);
	Контекст.Вставить("meta", Meta);
	Возврат Контекст;
КонецФункции

// Выполняет обработчик оповещения MCP.
//
// Параметры:
//  Оповещение - ОписаниеОповещения - Описание оповещения.
//  Запрос - Структура - Запрос вызова:
//   * Аргументы - Структура - Аргументы вызова.
//   * Контекст - Структура - Контекст вызова.
//
// Возвращаемое значение:
//  Произвольный - Результат выполнения обработчика.
//  Неопределено - Обработчик не задан или завершился с ошибкой.
Функция ВыполнитьОповещение(Оповещение, Запрос)
	Если Оповещение = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	Попытка
		Возврат ВыполнитьОбработкуОповещения(Оповещение, Запрос);
	Исключение
		Возврат Неопределено;
	КонецПопытки;
КонецФункции

// Нормализует результат выполнения инструмента MCP.
//
// Параметры:
//  Результат - Произвольный - Результат обработчика инструмента.
//
// Возвращаемое значение:
//  Структура:
//  * content - Произвольный - Контент результата.
//  Неопределено - Результат не удалось нормализовать.
Функция НормализоватьРезультатИнструмента(Результат)
	Если ТипЗнч(Результат) = Тип("Структура") Тогда
		Если Результат.Свойство("content") Тогда
			Возврат Результат;
		КонецЕсли;
	КонецЕсли;
	Если ТипЗнч(Результат) = Тип("Массив") Тогда
		Возврат Новый Структура("content", Результат);
	КонецЕсли;
	Если ТипЗнч(Результат) = Тип("Строка") Тогда
		Контент = Новый Массив;
		Контент.Добавить(Новый Структура("type,text", "text", Результат));
		Возврат Новый Структура("content", Контент);
	КонецЕсли;
	Возврат Неопределено;
КонецФункции

// Нормализует результат чтения ресурса MCP.
//
// Параметры:
//  Результат - Произвольный - Результат обработчика ресурса.
//  Дескриптор - Структура - Описание ресурса.
//
// Возвращаемое значение:
//  Структура:
//  * contents - Произвольный - Контент ресурса.
//  Неопределено - Результат не удалось нормализовать.
Функция НормализоватьРезультатРесурса(Результат, Дескриптор)
	Если ТипЗнч(Результат) = Тип("Структура") Тогда
		Если Результат.Свойство("contents") Тогда
			Возврат Результат;
		КонецЕсли;
	КонецЕсли;
	Если ТипЗнч(Результат) = Тип("Массив") Тогда
		Возврат Новый Структура("contents", Результат);
	КонецЕсли;
	Если ТипЗнч(Результат) = Тип("Строка") Тогда
		Контент = Новый Структура("uri,text", Дескриптор.uri, Результат);
		Если ЗначениеЗаполнено(Дескриптор.mimeType) Тогда
			Контент.Вставить("mimeType", Дескриптор.mimeType);
		КонецЕсли;
		МассивКонтента = Новый Массив;
		МассивКонтента.Добавить(Контент);
		Возврат Новый Структура("contents", МассивКонтента);
	КонецЕсли;
	Возврат Неопределено;
КонецФункции

// Нормализует результат получения промпта MCP.
//
// Параметры:
//  Результат - Произвольный - Результат обработчика промпта.
//
// Возвращаемое значение:
//  Структура:
//  * messages - Произвольный - Список сообщений.
//  Неопределено - Результат не удалось нормализовать.
Функция НормализоватьРезультатПромпта(Результат)
	Если ТипЗнч(Результат) = Тип("Структура") Тогда
		Если Результат.Свойство("messages") Тогда
			Возврат Результат;
		КонецЕсли;
	КонецЕсли;
	Если ТипЗнч(Результат) = Тип("Массив") Тогда
		Возврат Новый Структура("messages", Результат);
	КонецЕсли;
	Если ТипЗнч(Результат) = Тип("Строка") Тогда
		Контент = Новый Массив;
		Контент.Добавить(Новый Структура("type,text", "text", Результат));
		Сообщение = Новый Структура("role,content", "user", Контент);
		Сообщения = Новый Массив;
		Сообщения.Добавить(Сообщение);
		Возврат Новый Структура("messages", Сообщения);
	КонецЕсли;
	Возврат Неопределено;
КонецФункции

#КонецОбласти
