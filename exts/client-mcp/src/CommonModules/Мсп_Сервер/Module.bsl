#Область ПрограммныйИнтерфейс

// Инициализирует реестры MCP в состоянии клиента.
// И регистрирует провайдеров MCP из подсистемы Мсп_Провайдеры.
Процедура Инициализировать() Экспорт

	Мсп_РеестрКлиент.ИнициализироватьРеестры();
	Мсп_ПровайдерыКлиент.ЗарегистрироватьПровайдеров();

КонецПроцедуры

// Создает описание инструмента для регистрации.
//
// Параметры:
//  Имя - Строка - Идентификатор инструмента.
//  Описание - Строка - Описание инструмента.
//  СхемаПараметров - Структура - JSON-схема входных параметров.
//  Обработчик - ОписаниеОповещения - Обработчик вызова.
//  РежимВыполнения - Строка - Режим выполнения инструмента (sync | task).
//
// Возвращаемое значение:
//  Структура - Описание инструмента.
Функция НовыйИнструмент(Имя, Описание, СхемаПараметров, Обработчик, РежимВыполнения = "sync") Экспорт
	Результат = Новый Структура;
	Результат.Вставить("Имя", Имя);
	Результат.Вставить("Описание", Описание);
	Результат.Вставить("СхемаПараметров", СхемаПараметров);
	Результат.Вставить("Обработчик", Обработчик);
	ПроверитьРежимВыполненияИнструмента(РежимВыполнения);
	Результат.Вставить("РежимВыполнения", РежимВыполнения);
	Результат.Вставить("Включён", Истина);
	Результат.Вставить("Асинхронный", РежимВыполнения = "task");
	Результат.Вставить("ИсточникРегистрации", "");
	Возврат Результат;
КонецФункции

// Возвращает описание ресурса для регистрации в реестре.
//
// Параметры:
//  URI - Строка - URI ресурса.
//  Имя - Строка - Читаемое имя ресурса.
//  Описание - Строка - Описание ресурса.
//  MimeType - Строка - MIME-тип контента ресурса.
//  Обработчик - ОписаниеОповещения - Обработчик чтения ресурса.
//
// Возвращаемое значение:
//  Структура - Описание ресурса.
Функция НовыйРесурс(URI, Имя, Описание, MimeType, Обработчик) Экспорт
	ОписаниеРесурса = Новый Структура;
	ОписаниеРесурса.Вставить("URI", URI);
	ОписаниеРесурса.Вставить("Имя", Имя);
	ОписаниеРесурса.Вставить("Описание", Описание);
	ОписаниеРесурса.Вставить("MimeType", MimeType);
	ОписаниеРесурса.Вставить("Обработчик", Обработчик);
	ОписаниеРесурса.Вставить("Провайдер", "");
	ОписаниеРесурса.Вставить("Включён", Истина);
	ОписаниеРесурса.Вставить("ИсточникРегистрации", "");
	Возврат ОписаниеРесурса;
КонецФункции

// Возвращает описание шаблона ресурса для регистрации в реестре.
//
// Параметры:
//  URIШаблон - Строка - URI-шаблон ресурса.
//  Имя - Строка - Читаемое имя шаблона ресурса.
//  Описание - Строка - Описание шаблона ресурса.
//  MimeType - Строка - MIME-тип контента ресурса.
//  Обработчик - ОписаниеОповещения - Обработчик чтения ресурса.
//
// Возвращаемое значение:
//  Структура - Описание шаблона ресурса.
Функция НовыйШаблонРесурса(URIШаблон, Имя, Описание, MimeType, Обработчик) Экспорт
	ОписаниеШаблонаРесурса = Новый Структура;
	ОписаниеШаблонаРесурса.Вставить("URIШаблон", URIШаблон);
	ОписаниеШаблонаРесурса.Вставить("Имя", Имя);
	ОписаниеШаблонаРесурса.Вставить("Описание", Описание);
	ОписаниеШаблонаРесурса.Вставить("MimeType", MimeType);
	ОписаниеШаблонаРесурса.Вставить("Обработчик", Обработчик);
	ОписаниеШаблонаРесурса.Вставить("Провайдер", "");
	ОписаниеШаблонаРесурса.Вставить("Включён", Истина);
	ОписаниеШаблонаРесурса.Вставить("ИсточникРегистрации", "");
	Возврат ОписаниеШаблонаРесурса;
КонецФункции

// Возвращает описание промпта для регистрации в реестре.
//
// Параметры:
//  Имя - Строка - Идентификатор промпта.
//  Описание - Строка - Описание промпта.
//  Аргументы - Массив - Описание аргументов промпта.
//  Обработчик - ОписаниеОповещения - Обработчик получения промпта.
//
// Возвращаемое значение:
//  Структура - Описание промпта.
Функция НовыйПромпт(Имя, Описание, Аргументы, Обработчик) Экспорт
	ПроверитьАргументыПромпта(Аргументы);
	ОписаниеПромпта = Новый Структура;
	ОписаниеПромпта.Вставить("Имя", Имя);
	ОписаниеПромпта.Вставить("Описание", Описание);
	ОписаниеПромпта.Вставить("Аргументы", Аргументы);
	ОписаниеПромпта.Вставить("Обработчик", Обработчик);
	ОписаниеПромпта.Вставить("Провайдер", "");
	ОписаниеПромпта.Вставить("Включён", Истина);
	ОписаниеПромпта.Вставить("ИсточникРегистрации", "");
	Возврат ОписаниеПромпта;
КонецФункции

// Формирует параметры запуска MCP-сервера.
Функция НовыйПараметрыСервера(Порт, РазрешенныеOrigins = "", ТаймаутСек = 30, ИнформацияОСервере = Неопределено) Экспорт
	ПараметрыСервера = Новый Структура;
	ПараметрыСервера.Вставить("Порт", Порт);
	ПараметрыСервера.Вставить("РазрешенныеOrigins", РазрешенныеOrigins);
	ПараметрыСервера.Вставить("ТаймаутСек", ТаймаутСек);
	ПараметрыСервера.Вставить("ИнформацияОСервере", ИнформацияОСервере);
	Возврат ПараметрыСервера;
КонецФункции

// Формирует описание MCP-сервера для initialize.
Функция НоваяИнформацияОСервере(Имя, Версия, Заголовок = "", Описание = "", Инструкции = "") Экспорт
	ИнформацияОСервере = Новый Структура;
	ИнформацияОСервере.Вставить("name", Имя);
	ИнформацияОСервере.Вставить("version", Версия);
	ИнформацияОСервере.Вставить("title", Заголовок);
	ИнформацияОСервере.Вставить("description", Описание);
	ИнформацияОСервере.Вставить("instructions", Инструкции);
	Возврат ИнформацияОСервере;
КонецФункции

// Запускает MCP-сервер с параметрами.
Асинх Функция Запустить(ПараметрыСервера) Экспорт
	РезультатЗапуска = Ждать Мсп_ТранспортКлиент.ЗапуститьСервер(
		ПараметрыСервера.Порт,
		ПараметрыСервера.РазрешенныеOrigins,
		ПараметрыСервера.ТаймаутСек);

	ИнформацияОСервере = Неопределено;
	Если ПараметрыСервера.Свойство("ИнформацияОСервере", ИнформацияОСервере)
		И ИнформацияОСервере <> Неопределено Тогда
		Ждать Мсп_ТранспортКлиент.УстановитьИнформациюОСервере(
			Мсп_СериализацияКлиент.Сериализовать(ИнформацияОСервере));
	КонецЕсли;

	Возврат РезультатЗапуска;
КонецФункции

// Останавливает MCP-сервер.
Асинх Функция Остановить() Экспорт
	Возврат Ждать Мсп_ТранспортКлиент.ОстановитьСервер();
КонецФункции

// Запускает MCP-сервер и инициализирует состояние.
//
// Параметры:
//  Порт - Число - Номер порта для прослушивания.
//  РазрешенныеOrigins - Строка - Допустимые origins ("" | "*" | JSON-массив строк).
//  ТаймаутСек - Число - Таймаут ожидания ответа от 1С.
//
// Возвращаемое значение:
//  Булево - Истина, если запрос на запуск отправлен.
Асинх Функция ЗапуститьСервер(Порт, РазрешенныеOrigins = "*", ТаймаутСек = 30) Экспорт

	Возврат Ждать Запустить(НовыйПараметрыСервера(Порт, РазрешенныеOrigins, ТаймаутСек));

КонецФункции

// Регистрирует описание инструмента в клиентском реестре.
//
// Параметры:
//  ОписаниеИнструмента - см. НовыйОписаниеИнструмента
Процедура ЗарегистрироватьИнструмент(ОписаниеИнструмента, ИсточникРегистрации = Неопределено) Экспорт

	Если ИсточникРегистрации <> Неопределено Тогда
		ОписаниеИнструмента.Вставить("ИсточникРегистрации", ИсточникРегистрации);
	КонецЕсли;
	Мсп_РеестрКлиент.ЗарегистрироватьИнструмент(ОписаниеИнструмента);

КонецПроцедуры

// Регистрирует описание ресурса в клиентском реестре.
//
// Параметры:
//  ОписаниеРесурса - Структура - Описание ресурса:
//   * URI - Строка - URI ресурса.
//   * Имя - Строка - Читаемое имя ресурса.
//   * Описание - Строка - Описание ресурса.
//   * MimeType - Строка - MIME-тип контента ресурса.
//   * Обработчик - ОписаниеОповещения - Обработчик чтения ресурса.
//   * Провайдер - Строка - Имя провайдера, зарегистрировавшего ресурс.
//   * Включён - Булево - Признак активности ресурса.
Процедура ЗарегистрироватьРесурс(ОписаниеРесурса, ИсточникРегистрации = "") Экспорт

	ОписаниеРесурса.Вставить("ИсточникРегистрации", ИсточникРегистрации);
	Мсп_РеестрКлиент.ЗарегистрироватьРесурс(ОписаниеРесурса);

КонецПроцедуры

// Регистрирует описание шаблона ресурса в клиентском реестре.
//
// Параметры:
//  ОписаниеШаблонаРесурса - Структура - Описание шаблона ресурса:
//   * URIШаблон - Строка - URI-шаблон ресурса.
//   * Имя - Строка - Читаемое имя шаблона ресурса.
//   * Описание - Строка - Описание шаблона ресурса.
//   * MimeType - Строка - MIME-тип контента ресурса.
//   * Обработчик - ОписаниеОповещения - Обработчик чтения ресурса.
//   * Провайдер - Строка - Имя провайдера, зарегистрировавшего шаблон ресурса.
//   * Включён - Булево - Признак активности шаблона ресурса.
Процедура ЗарегистрироватьШаблонРесурса(ОписаниеШаблонаРесурса, ИсточникРегистрации = "") Экспорт

	ОписаниеШаблонаРесурса.Вставить("ИсточникРегистрации", ИсточникРегистрации);
	Мсп_РеестрКлиент.ЗарегистрироватьШаблонРесурса(ОписаниеШаблонаРесурса);

КонецПроцедуры

// Регистрирует описание промпта в клиентском реестре.
//
// Параметры:
//  ОписаниеПромпта - см. НовыйПромпт
//  ИсточникРегистрации - Строка - Источник регистрации.
Процедура ЗарегистрироватьПромпт(ОписаниеПромпта, ИсточникРегистрации = "") Экспорт

	ОписаниеПромпта.Вставить("ИсточникРегистрации", ИсточникРегистрации);
	Мсп_РеестрКлиент.ЗарегистрироватьПромпт(ОписаниеПромпта);

КонецПроцедуры

// Отменяет регистрацию всех объектов указанного источника регистрации во всех реестрах.
//
// Параметры:
//  ИсточникРегистрации - Строка - Источник регистрации.
Процедура ОтменитьРегистрацию(ИсточникРегистрации) Экспорт

	Мсп_РеестрКлиент.ОтменитьРегистрацию(ИсточникРегистрации);

КонецПроцедуры

// Отменяет регистрацию всех объектов указанного провайдера во всех реестрах.
//
// Параметры:
//  ИмяПровайдера - Строка - Имя провайдера.
Процедура ОтменитьРегистрациюПровайдера(ИмяПровайдера) Экспорт

	Мсп_РеестрКлиент.ОтменитьРегистрациюПровайдера(ИмяПровайдера);

КонецПроцедуры

// Создает описание инструмента для регистрации.
//
// Параметры:
//  Имя - Строка - Идентификатор инструмента.
//  Описание - Строка - Описание инструмента.
//  СхемаПараметров - Структура - JSON-схема входных параметров.
//  Оповещение - ОписаниеОповещения - Обработчик вызова.
//  ИсточникРегистрации - Строка - Источник регистрации.
//  Асинхронный - Булево - Признак, что инструмент поддерживает task-based выполнение
//   и может завершаться после ответа на tools/call.
//
// Возвращаемое значение:
//  Структура - Описание инструмента.
Функция НовыйОписаниеИнструмента(Имя, Описание, СхемаПараметров, Оповещение, ИсточникРегистрации = "", Асинхронный = Ложь) Экспорт
	Результат = Мсп_РеестрКлиент.НовыйОписаниеИнструмента();
	Результат.Имя = Имя;
	Результат.Описание = Описание;
	Результат.СхемаПараметров = СхемаПараметров;
	Результат.Обработчик = Оповещение;
	Результат.ИсточникРегистрации = ИсточникРегистрации;
	Результат.Асинхронный = Асинхронный;

	Возврат Результат;
КонецФункции

// Формирует ошибочный результат для асинхронного завершения инструмента.
//
// Параметры:
//  КодОшибки - Строка - Код ошибки.
//  Ошибка - Строка - Описание ошибки.
//
// Возвращаемое значение:
//  Структура - Ошибочный результат инструмента.
Функция ОшибкаИнструмента(КодОшибки, Ошибка) Экспорт
	Возврат Новый Структура("КодОшибки,Ошибка", КодОшибки, Ошибка);
КонецФункции

// Завершает отложенный tools/call успешным результатом.
//
// Параметры:
//  ИдентификаторЗапроса - Произвольный - Идентификатор JSON-RPC запроса.
//  Результат - Произвольный - Результат инструмента.
Асинх Процедура ЗавершитьВызовИнструментаУспешно(ИдентификаторЗапроса, Результат) Экспорт
	Если Не ЗначениеЗаполнено(ИдентификаторЗапроса) Тогда
		Возврат;
	КонецЕсли;

	Ответ = Мсп_ПротоколКлиент.ПодготовитьОтветЗапросаИнструмента(ИдентификаторЗапроса, Результат);
	Ждать Мсп_ТранспортКлиент.ОтправитьОтвет(ИдентификаторЗапроса, Ответ);
КонецПроцедуры

// Завершает отложенный tools/call ошибкой.
//
// Параметры:
//  ИдентификаторЗапроса - Произвольный - Идентификатор JSON-RPC запроса.
//  КодОшибки - Строка - Код ошибки инструмента.
//  Ошибка - Строка - Описание ошибки.
Асинх Процедура ЗавершитьВызовИнструментаСОшибкой(ИдентификаторЗапроса, КодОшибки, Ошибка) Экспорт
	Если Не ЗначениеЗаполнено(ИдентификаторЗапроса) Тогда
		Возврат;
	КонецЕсли;

	Ответ = Мсп_ПротоколКлиент.ПодготовитьОшибкуЗапросаИнструмента(ИдентификаторЗапроса, КодОшибки, Ошибка);
	Ждать Мсп_ТранспортКлиент.ОтправитьОтвет(ИдентификаторЗапроса, Ответ);
КонецПроцедуры

// Завершает task-based выполнение инструмента успешным результатом.
//
// Параметры:
//  ИдентификаторЗадачи - Строка - Идентификатор MCP-задачи.
//  Результат - Произвольный - Результат инструмента.
Процедура ЗавершитьЗадачуУспешно(ИдентификаторЗадачи, Результат) Экспорт
	Мсп_ЗадачиКлиент.ЗавершитьЗадачуУспешно(ИдентификаторЗадачи, Результат);
КонецПроцедуры

// Завершает task-based выполнение инструмента ошибкой.
//
// Параметры:
//  ИдентификаторЗадачи - Строка - Идентификатор MCP-задачи.
//  КодОшибки - Строка - Код ошибки.
//  Ошибка - Строка - Описание ошибки.
Процедура ЗавершитьЗадачуСОшибкой(ИдентификаторЗадачи, КодОшибки, Ошибка) Экспорт
	Мсп_ЗадачиКлиент.ЗавершитьЗадачуСОшибкой(ИдентификаторЗадачи, КодОшибки, Ошибка);
КонецПроцедуры

// Устанавливает статус MCP-задачи.
//
// Параметры:
//  ИдентификаторЗадачи - Строка - Идентификатор MCP-задачи.
//  Статус - Строка - Статус задачи.
//  Сообщение - Строка - Человекочитаемое описание.
Процедура УстановитьСтатусЗадачи(ИдентификаторЗадачи, Статус, Сообщение = "") Экспорт
	Мсп_ЗадачиКлиент.УстановитьСтатусЗадачи(ИдентификаторЗадачи, Статус, Сообщение);
КонецПроцедуры

// Отправляет progress для MCP-задачи.
//
// Параметры:
//  ИдентификаторЗадачи - Строка - Идентификатор MCP-задачи.
//  Прогресс - Число - Текущее значение progress.
//  Всего - Число - Общее количество шагов.
//  Сообщение - Строка - Описание progress.
Процедура УведомитьОПрогрессеЗадачи(ИдентификаторЗадачи, Прогресс, Всего = Неопределено, Сообщение = "") Экспорт
	Мсп_ЗадачиКлиент.УведомитьОПрогрессеЗадачи(ИдентификаторЗадачи, Прогресс, Всего, Сообщение);
КонецПроцедуры

