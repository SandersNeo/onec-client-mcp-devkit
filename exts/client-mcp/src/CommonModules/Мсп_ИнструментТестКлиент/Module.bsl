		"open_form",
		"Открывает форму через ExecuteCommand активного окна.",
		СхемаВходныхПараметровОткрытиеФормы(),
		Новый ОписаниеОповещения("ОбработчикКомандыОткрытияФормы", Мсп_ИнструментТестКлиент)));
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Запускает тест-клиент 1С и устанавливает соединение.
//
// Параметры:
//  Запрос - Структура - Запрос инструмента:
//   * Аргументы - Структура - Аргументы вызова.
//   * Контекст - Структура - Контекст вызова.
//  ДополнительныеПараметры - Произвольный - Дополнительные параметры вызова.
//
// Возвращаемое значение:
//  Произвольный - Результат инструмента.
Функция ОбработчикКомандыЗапуска(Запрос, ДополнительныеПараметры) Экспорт
	Аргументы = Новый Структура;
	Если Запрос <> Неопределено Тогда
		Аргументы = Запрос.Аргументы;
	КонецЕсли;
	
	Порт = Мсп_Коллекции.ПолучитьСвойство(Аргументы, "port", 0);
	РезультатЗапуска = Мсп_УправлениеТестКлиентом.Запустить(Порт);
	
	Данные = НовыйДанныеЗапуска(РезультатЗапуска.Запущен, РезультатЗапуска.Подключен);
	
	Возврат НовыйРезультатИнструмента(РезультатЗапуска.Подключен, Данные, РезультатЗапуска.Ошибка);
КонецФункции

// Останавливает тест-клиент 1С и разрывает соединение.
//
// Параметры:
//  Запрос - Структура - Запрос инструмента:
//   * Аргументы - Структура - Аргументы вызова.
//   * Контекст - Структура - Контекст вызова.
//  ДополнительныеПараметры - Произвольный - Дополнительные параметры вызова.
//
// Возвращаемое значение:
//  Произвольный - Результат инструмента.
Функция ОбработчикКомандыОстановки(Запрос, ДополнительныеПараметры) Экспорт
	РезультатОстановки = Мсп_УправлениеТестКлиентом.Остановить();
	Данные = НовыйДанныеОстановки(РезультатОстановки.Остановлен);
	Возврат НовыйРезультатИнструмента(РезультатОстановки.Остановлен, Данные, РезультатОстановки.Ошибка);
КонецФункции

// Выполняет поиск объектов интерфейса тест-клиента.
//
// Параметры:
//  Запрос - Структура - Запрос инструмента:
//   * Аргументы - Структура - Аргументы вызова.
//   * Контекст - Структура - Контекст вызова.
//  ДополнительныеПараметры - Произвольный - Дополнительные параметры вызова.
//
// Возвращаемое значение:
//  Произвольный - Результат инструмента.
Функция ОбработчикКомандыПоиска(Запрос, ДополнительныеПараметры) Экспорт
	Аргументы = АргументыИнструмента(Запрос);
	РезультатRootURI = СтроковыйАргумент(Аргументы, "root_uri");
	Если ЗначениеЗаполнено(РезультатRootURI.КодОшибки) Тогда
		Возврат НовыйРезультатОшибкиИнструмента(РезультатRootURI.КодОшибки, РезультатRootURI.Ошибка);
	КонецЕсли;
	РезультатТипа = СтроковыйАргумент(Аргументы, "type");
	Если ЗначениеЗаполнено(РезультатТипа.КодОшибки) Тогда
		Возврат НовыйРезультатОшибкиИнструмента(РезультатТипа.КодОшибки, РезультатТипа.Ошибка);
	КонецЕсли;
	РезультатЗаголовка = СтроковыйАргумент(Аргументы, "title");
	Если ЗначениеЗаполнено(РезультатЗаголовка.КодОшибки) Тогда
		Возврат НовыйРезультатОшибкиИнструмента(РезультатЗаголовка.КодОшибки, РезультатЗаголовка.Ошибка);
	КонецЕсли;
	РезультатИмени = СтроковыйАргумент(Аргументы, "name");
	Если ЗначениеЗаполнено(РезультатИмени.КодОшибки) Тогда
		Возврат НовыйРезультатОшибкиИнструмента(РезультатИмени.КодОшибки, РезультатИмени.Ошибка);
	КонецЕсли;
	РезультатТаймаута = ЧисловойАргумент(Аргументы, "timeout_sec", 0);
	Если ЗначениеЗаполнено(РезультатТаймаута.КодОшибки) Тогда
		Возврат НовыйРезультатОшибкиИнструмента(РезультатТаймаута.КодОшибки, РезультатТаймаута.Ошибка);
	КонецЕсли;

	РезультатПоиска = Мсп_ФормыКлиент.НайтиОбъекты(
		РезультатRootURI.Значение,
		РезультатТипа.Значение,
		РезультатЗаголовка.Значение,
		РезультатИмени.Значение,
		РезультатТаймаута.Значение);

	Если ЗначениеЗаполнено(РезультатПоиска.КодОшибки) Тогда
		Возврат НовыйРезультатОшибкиИнструмента(РезультатПоиска.КодОшибки, РезультатПоиска.Ошибка);
	КонецЕсли;

	Возврат НовыйРезультатИнструмента(Истина, РезультатПоиска.Объекты);
КонецФункции

// Активизирует объект интерфейса по URI.
//
// Параметры:
//  Запрос - Структура - Запрос инструмента:
//   * Аргументы - Структура - Аргументы вызова.
//   * Контекст - Структура - Контекст вызова.
//  ДополнительныеПараметры - Произвольный - Дополнительные параметры вызова.
//
// Возвращаемое значение:
//  Произвольный - Результат инструмента.
Функция ОбработчикКомандыАктивации(Запрос, ДополнительныеПараметры) Экспорт
	Аргументы = АргументыИнструмента(Запрос);
	РезультатURI = СтроковыйАргумент(Аргументы, "uri", Истина);
	Если ЗначениеЗаполнено(РезультатURI.КодОшибки) Тогда
		Возврат НовыйРезультатОшибкиИнструмента(РезультатURI.КодОшибки, РезультатURI.Ошибка);
	КонецЕсли;

	РезультатАктивации = Мсп_ФормыКлиент.АктивизироватьПоURI(РезультатURI.Значение);
	Если ЗначениеЗаполнено(РезультатАктивации.КодОшибки) Тогда
		Возврат НовыйРезультатОшибкиИнструмента(РезультатАктивации.КодОшибки, РезультатАктивации.Ошибка);
	КонецЕсли;

	Возврат НовыйРезультатИнструмента(РезультатАктивации.Успех, РезультатАктивации.Описание);
КонецФункции

// Закрывает окно или форму по URI.
//
// Параметры:
//  Запрос - Структура - Запрос инструмента:
//   * Аргументы - Структура - Аргументы вызова.
//   * Контекст - Структура - Контекст вызова.
//  ДополнительныеПараметры - Произвольный - Дополнительные параметры вызова.
//
// Возвращаемое значение:
//  Произвольный - Результат инструмента.
Функция ОбработчикКомандыЗакрытия(Запрос, ДополнительныеПараметры) Экспорт
	Аргументы = АргументыИнструмента(Запрос);
	РезультатURI = СтроковыйАргумент(Аргументы, "uri", Истина);
	Если ЗначениеЗаполнено(РезультатURI.КодОшибки) Тогда
		Возврат НовыйРезультатОшибкиИнструмента(РезультатURI.КодОшибки, РезультатURI.Ошибка);
	КонецЕсли;

	РезультатЗакрытия = Мсп_ФормыКлиент.ЗакрытьПоURI(РезультатURI.Значение);
	Если ЗначениеЗаполнено(РезультатЗакрытия.КодОшибки) Тогда
		Возврат НовыйРезультатОшибкиИнструмента(РезультатЗакрытия.КодОшибки, РезультатЗакрытия.Ошибка);
	КонецЕсли;

	Возврат НовыйРезультатИнструмента(РезультатЗакрытия.Успех, РезультатЗакрытия.Описание);
КонецФункции

// Открывает форму через ExecuteCommand активного окна.
//
// Параметры:
//  Запрос - Структура - Запрос инструмента:
//   * Аргументы - Структура - Аргументы вызова.
//   * Контекст - Структура - Контекст вызова.
//  ДополнительныеПараметры - Произвольный - Дополнительные параметры вызова.
//
// Возвращаемое значение:
//  Произвольный - Результат инструмента.
Функция ОбработчикКомандыОткрытияФормы(Запрос, ДополнительныеПараметры) Экспорт
	Аргументы = АргументыИнструмента(Запрос);
	РезультатTarget = СтроковыйАргумент(Аргументы, "target", Истина);
	Если ЗначениеЗаполнено(РезультатTarget.КодОшибки) Тогда
		Возврат НовыйРезультатОшибкиИнструмента(РезультатTarget.КодОшибки, РезультатTarget.Ошибка);
	КонецЕсли;

	РезультатОткрытия = Мсп_ФормыКлиент.ОткрытьФормуПоКоманде(РезультатTarget.Значение);
	Если ЗначениеЗаполнено(РезультатОткрытия.КодОшибки) Тогда
		Возврат НовыйРезультатОшибкиИнструмента(РезультатОткрытия.КодОшибки, РезультатОткрытия.Ошибка);
	КонецЕсли;

	Возврат НовыйРезультатИнструмента(РезультатОткрытия.Успех, НовыйДанныеОткрытияФормы(
		РезультатОткрытия.Target,
		РезультатОткрытия.WindowURI,
		РезультатОткрытия.FormURI));
КонецФункции

// Возвращает JSON-схему входных параметров запуска.
Функция СхемаВходныхПараметровЗапуск()
	Схема = Новый Структура;
	Схема.Вставить("type", "object");
	Свойства = Новый Структура;
	Свойства.Вставить("port", Новый Структура("type", "number"));
	Схема.Вставить("properties", Свойства);
	Схема.Вставить("additionalProperties", Ложь);
	Возврат Схема;
КонецФункции

// Возвращает JSON-схему входных параметров остановки.
Функция СхемаВходныхПараметровОстановка()
	Схема = Новый Структура;
	Схема.Вставить("type", "object");
	Схема.Вставить("properties", Новый Структура);
	Схема.Вставить("additionalProperties", Ложь);
	Возврат Схема;
КонецФункции

// Возвращает JSON-схему входных параметров поиска.
Функция СхемаВходныхПараметровПоиск()
	Схема = Новый Структура;
	Схема.Вставить("type", "object");
	Свойства = Новый Структура;
	Свойства.Вставить("root_uri", Новый Структура("type", "string"));
	Свойства.Вставить("type", Новый Структура("type", "string"));
	Свойства.Вставить("title", Новый Структура("type", "string"));
	Свойства.Вставить("name", Новый Структура("type", "string"));
	Свойства.Вставить("timeout_sec", Новый Структура("type", "number"));
	Схема.Вставить("properties", Свойства);
	Схема.Вставить("additionalProperties", Ложь);
	Возврат Схема;
КонецФункции

// Возвращает JSON-схему входных параметров инструмента по URI.
Функция СхемаВходныхПараметровURI()
	Схема = Новый Структура;
	Схема.Вставить("type", "object");
	Свойства = Новый Структура;
	Свойства.Вставить("uri", Новый Структура("type", "string"));
	Схема.Вставить("properties", Свойства);
	ТребуемыеПоля = Новый Массив;
	ТребуемыеПоля.Добавить("uri");
	Схема.Вставить("required", ТребуемыеПоля);
	Схема.Вставить("additionalProperties", Ложь);
	Возврат Схема;
КонецФункции

// Возвращает JSON-схему входных параметров открытия формы.
Функция СхемаВходныхПараметровОткрытиеФормы()
	Схема = Новый Структура;
	Схема.Вставить("type", "object");
	Свойства = Новый Структура;
	Свойства.Вставить("target", Новый Структура("type", "string"));
	Схема.Вставить("properties", Свойства);
	ТребуемыеПоля = Новый Массив;
	ТребуемыеПоля.Добавить("target");
	Схема.Вставить("required", ТребуемыеПоля);
	Схема.Вставить("additionalProperties", Ложь);
	Возврат Схема;
КонецФункции

Функция НовыйДанныеЗапуска(Запущен, Подключен)
	Возврат Новый Структура("started, connected", Запущен, Подключен);
КонецФункции

Функция НовыйДанныеОстановки(Остановлен)
	Возврат Новый Структура("stopped", Остановлен);
КонецФункции

Функция НовыйДанныеОткрытияФормы(Target, WindowURI, FormURI)
	Данные = Новый Структура("target,window_uri", Target, WindowURI);
	Если ЗначениеЗаполнено(FormURI) Тогда
		Данные.Вставить("form_uri", FormURI);
	КонецЕсли;
	Возврат Данные;
КонецФункции

Функция АргументыИнструмента(Запрос)
	Если Запрос = Неопределено Тогда
		Возврат Новый Структура;
	КонецЕсли;

	Возврат Мсп_Коллекции.ПолучитьСвойство(Запрос, "Аргументы", Новый Структура);
КонецФункции

Функция СтроковыйАргумент(Аргументы, ИмяАргумента, Обязательный = Ложь, ЗначениеПоУмолчанию = "")
	ЗначениеАргумента = Неопределено;
	Если Не Аргументы.Свойство(ИмяАргумента, ЗначениеАргумента) Тогда
		Если Обязательный Тогда
			Возврат НовыйРезультатАргумента(ЗначениеПоУмолчанию, "INVALID_PARAMS", ИмяАргумента + " is required");
		КонецЕсли;
		Возврат НовыйРезультатАргумента(ЗначениеПоУмолчанию);
	КонецЕсли;
	Если ТипЗнч(ЗначениеАргумента) <> Тип("Строка") Тогда
		Возврат НовыйРезультатАргумента(ЗначениеПоУмолчанию, "INVALID_PARAMS", ИмяАргумента + " must be string");
	КонецЕсли;

	Возврат НовыйРезультатАргумента(ЗначениеАргумента);
КонецФункции

Функция ЧисловойАргумент(Аргументы, ИмяАргумента, ЗначениеПоУмолчанию)
	ЗначениеАргумента = Неопределено;
	Если Не Аргументы.Свойство(ИмяАргумента, ЗначениеАргумента) Тогда
		Возврат НовыйРезультатАргумента(ЗначениеПоУмолчанию);
	КонецЕсли;
	Если ТипЗнч(ЗначениеАргумента) <> Тип("Число") Тогда
		Возврат НовыйРезультатАргумента(ЗначениеПоУмолчанию, "INVALID_PARAMS", ИмяАргумента + " must be number");
	КонецЕсли;

	Возврат НовыйРезультатАргумента(ЗначениеАргумента);
КонецФункции

Функция НовыйРезультатОшибкиИнструмента(КодОшибки, Ошибка)
	ПубличныйКод = ПубличныйКодОшибки(КодОшибки);
	Детали = ДеталиОшибкиИнструмента(КодОшибки, Ошибка, ПубличныйКод);
	Возврат НовыйРезультатИнструмента(Ложь, Неопределено, ПубличныйКод, Детали);
КонецФункции

Функция ПубличныйКодОшибки(КодОшибки)
	Если КодОшибки = "INVALID_URI"
		ИЛИ КодОшибки = "INVALID_PARAMS" Тогда
		Возврат "-32602";
	ИначеЕсли КодОшибки = "ACTION_FAILED" Тогда
		Возврат "-32603";
	КонецЕсли;

	Возврат КодОшибки;
КонецФункции

Функция ДеталиОшибкиИнструмента(КодОшибки, Ошибка, ПубличныйКод)
	Если Не ЗначениеЗаполнено(Ошибка) Тогда
		Возврат КодОшибки;
	КонецЕсли;
	Если КодОшибки = ПубличныйКод Тогда
		Возврат Ошибка;
	КонецЕсли;

	Возврат КодОшибки + ": " + Ошибка;
КонецФункции

Функция НовыйРезультатАргумента(Значение, КодОшибки = "", Ошибка = "")
	Возврат Новый Структура("Значение,КодОшибки,Ошибка", Значение, КодОшибки, Ошибка);
КонецФункции

Функция НовыйРезультатИнструмента(Успех, Данные, Ошибка = "", Детали = "")
	Результат = Новый Структура("ok", Успех);
	Если Данные <> Неопределено Тогда
		Результат.Вставить("data", Данные);
	КонецЕсли;
	Если ЗначениеЗаполнено(Ошибка) Тогда
		Результат.Вставить("error", Ошибка);
	КонецЕсли;
	Если ЗначениеЗаполнено(Детали) Тогда
		Результат.Вставить("details", Детали);
	КонецЕсли;
	Возврат Результат;
КонецФункции

#КонецОбласти
