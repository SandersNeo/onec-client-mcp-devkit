// Запускает тест-клиент 1С и устанавливает соединение.
//
// Параметры:
//  Запрос - Структура - Запрос инструмента:
//   * Аргументы - Структура - Аргументы вызова.
//   * Контекст - Структура - Контекст вызова.
//  ДополнительныеПараметры - Произвольный - Дополнительные параметры вызова.
//
// Возвращаемое значение:
//  Произвольный - Результат инструмента.
Функция ОбработчикКомандыЗапуска(Запрос, ДополнительныеПараметры) Экспорт
	Порт = Мсп_Коллекции.Свойство(Запрос.Аргументы, "port");
	РезультатЗапуска = Мсп_УправлениеТестКлиентом.Запустить(Порт);
	
	Данные = НовыйДанныеЗапуска(РезультатЗапуска.Запущен, РезультатЗапуска.Подключен);
	
	Возврат НовыйРезультатИнструмента(РезультатЗапуска.Успех, Данные, РезультатЗапуска.Ошибка);
КонецФункции

// Останавливает тест-клиент 1С и разрывает соединение.
//
// Параметры:
//  Запрос - Структура - Запрос инструмента:
//   * Аргументы - Структура - Аргументы вызова.
//   * Контекст - Структура - Контекст вызова.
//  ДополнительныеПараметры - Произвольный - Дополнительные параметры вызова.
//
// Возвращаемое значение:
//  Произвольный - Результат инструмента.
Функция ОбработчикКомандыОстановки(Запрос, ДополнительныеПараметры) Экспорт
	ЗакрытьКлиент = Мсп_Коллекции.Свойство(Запрос.Аргументы, "close", Ложь);
	
	Если ЗакрытьКлиент Тогда
		РезультатОстановки = Мсп_УправлениеТестКлиентом.Закрыть();
	Иначе
		РезультатОстановки = Мсп_УправлениеТестКлиентом.Остановить();
	КонецЕсли;
	
	Данные = НовыйДанныеОстановки(РезультатОстановки.Остановлен);
	Возврат НовыйРезультатИнструмента(РезультатОстановки.Успех, Данные, РезультатОстановки.Ошибка);
КонецФункции

// Выполняет поиск объектов интерфейса тест-клиента.
//
// Параметры:
//  Запрос - Структура - Запрос инструмента:
//   * Аргументы - Структура - Аргументы вызова.
//   * Контекст - Структура - Контекст вызова.
//  ДополнительныеПараметры - Произвольный - Дополнительные параметры вызова.
//
// Возвращаемое значение:
//  Произвольный - Результат инструмента.
Функция ОбработчикКомандыПоиска(Запрос, ДополнительныеПараметры) Экспорт
	Адрес = СтроковыйАргумент(Запрос.Аргументы, "root_uri");
	Тип = СтроковыйАргумент(Запрос.Аргументы, "type");
	Заголовок = СтроковыйАргумент(Запрос.Аргументы, "title");
	Имя = СтроковыйАргумент(Запрос.Аргументы, "name");
	Таймаут = ЧисловойАргумент(Запрос.Аргументы, "timeout_sec", , 0);
	
	РезультатПоиска = Мсп_ФормыКлиент.НайтиОбъекты(Адрес, Тип, Заголовок, Имя, Таймаут);
	
	ОшибкаИнструмента = РезультатОшибкиИнструмента(РезультатПоиска);
	Если ОшибкаИнструмента <> Неопределено Тогда
		Возврат ОшибкаИнструмента;
	КонецЕсли;
	
	Возврат НовыйРезультатИнструмента(Истина, РезультатПоиска.Объекты);
КонецФункции

