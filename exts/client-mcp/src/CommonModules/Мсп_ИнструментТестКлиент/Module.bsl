#Область ПрограммныйИнтерфейс

// Возвращает описание инструментов провайдера.
Процедура ЗарегистрироватьИнструменты() Экспорт
	Мсп_РеестрКлиент.ЗарегистрироватьИнструмент(Мсп_ИнструментыКлиент.НовыйОписаниеИнструмента(
		"test_client_start",
		"Запускает тест-клиент 1С и устанавливает соединение.",
		СхемаВходныхПараметровЗапуск(),
		Новый ОписаниеОповещения("ОбработчикКомандыЗапуска", Мсп_ИнструментТестКлиент)));
	Мсп_РеестрКлиент.ЗарегистрироватьИнструмент(Мсп_ИнструментыКлиент.НовыйОписаниеИнструмента(
		"test_client_stop",
		"Останавливает тест-клиент 1С и разрывает соединение.",
		СхемаВходныхПараметровОстановка(),
		Новый ОписаниеОповещения("ОбработчикКомандыОстановки", Мсп_ИнструментТестКлиент)));
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Запускает тест-клиент 1С и устанавливает соединение.
//
// Параметры:
//  Запрос - Структура - Запрос инструмента:
//   * Аргументы - Структура - Аргументы вызова.
//   * Контекст - Структура - Контекст вызова.
//  ДополнительныеПараметры - Произвольный - Дополнительные параметры вызова.
//
// Возвращаемое значение:
//  см. НовыйРезультатИнструмента
Функция ОбработчикКомандыЗапуска(Запрос, ДополнительныеПараметры) Экспорт
	Аргументы = Новый Структура;
	Если Запрос <> Неопределено Тогда
		Аргументы = Запрос.Аргументы;
	КонецЕсли;
	
	Порт = Мсп_Коллекции.ПолучитьСвойство(Аргументы, "port", 0);
	РезультатЗапуска = Мсп_УправлениеТестКлиентом.Запустить(Порт);
	
	Данные = НовыйДанныеЗапуска(РезультатЗапуска.Запущен, РезультатЗапуска.Подключен);
	
	Возврат НовыйРезультатИнструмента(РезультатЗапуска.Подключен, Данные, РезультатЗапуска.Ошибка);
КонецФункции

// Останавливает тест-клиент 1С и разрывает соединение.
//
// Параметры:
//  Запрос - Структура - Запрос инструмента:
//   * Аргументы - Структура - Аргументы вызова.
//   * Контекст - Структура - Контекст вызова.
//  ДополнительныеПараметры - Произвольный - Дополнительные параметры вызова.
//
// Возвращаемое значение:
//  см. НовыйРезультатИнструмента
Функция ОбработчикКомандыОстановки(Запрос, ДополнительныеПараметры) Экспорт
	РезультатОстановки = Мсп_УправлениеТестКлиентом.Остановить();
	Данные = НовыйДанныеОстановки(РезультатОстановки.Остановлен);
	Возврат НовыйРезультатИнструмента(РезультатОстановки.Остановлен, Данные, РезультатОстановки.Ошибка);
КонецФункции

// Возвращает JSON-схему входных параметров запуска.
Функция СхемаВходныхПараметровЗапуск()
	Схема = Новый Структура;
	Схема.Вставить("type", "object");
	Свойства = Новый Структура;
	Свойства.Вставить("port", Новый Структура("type", "number"));
	Схема.Вставить("properties", Свойства);
	Схема.Вставить("additionalProperties", Ложь);
	Возврат Схема;
КонецФункции

// Возвращает JSON-схему входных параметров остановки.
Функция СхемаВходныхПараметровОстановка()
	Схема = Новый Структура;
	Схема.Вставить("type", "object");
	Схема.Вставить("properties", Новый Структура);
	Схема.Вставить("additionalProperties", Ложь);
	Возврат Схема;
КонецФункции

Функция НовыйДанныеЗапуска(Запущен, Подключен)
	Возврат Новый Структура("started, connected", Запущен, Подключен);
КонецФункции

Функция НовыйДанныеОстановки(Остановлен)
	Возврат Новый Структура("stopped", Остановлен);
КонецФункции

Функция НовыйРезультатИнструмента(Успех, Данные, Ошибка)
	Результат = Новый Структура("ok", Успех);
	Если Данные <> Неопределено Тогда
		Результат.Вставить("data", Данные);
	КонецЕсли;
	Если ЗначениеЗаполнено(Ошибка) Тогда
		Результат.Вставить("error", Ошибка);
	КонецЕсли;
	Возврат Результат;
КонецФункции

#КонецОбласти
