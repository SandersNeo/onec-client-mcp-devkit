// Выполняет выбор значения в поле формы по URI.
//
// Параметры:
//  Запрос - Структура - Запрос инструмента:
//   * Аргументы - Структура - Аргументы вызова.
//   * Контекст - Структура - Контекст вызова.
//  ДополнительныеПараметры - Произвольный - Дополнительные параметры вызова.
//
// Возвращаемое значение:
//  Произвольный - Результат инструмента.
Функция ОбработчикКомандыВыбора(Запрос, ДополнительныеПараметры) Экспорт
	Адрес = СтроковыйАргумент(Запрос.Аргументы, "uri", Истина);

	ЕстьPresent = ЕстьАргумент(Запрос.Аргументы, "present");
	ЕстьIndex = ЕстьАргумент(Запрос.Аргументы, "index");
	Если ЕстьPresent = ЕстьIndex Тогда
		Возврат Мсп_Ошибки.НекорректныеПараметры("exactly one of present or index is required");
	КонецЕсли;

	ЗначениеВыбора = Мсп_Коллекции.Свойство(Запрос.Аргументы, "present", Неопределено);
	Если ЕстьIndex Тогда
		ЗначениеВыбора = ЧисловойАргумент(Запрос.Аргументы, "index", Истина).Значение;
	КонецЕсли;

	РезультатВыбора = Мсп_ФормыКлиент.ВыбратьПоURI(Адрес, ЗначениеВыбора);
	ОшибкаИнструмента = РезультатОшибкиИнструмента(РезультатВыбора);
	Если ОшибкаИнструмента <> Неопределено Тогда
		Возврат ОшибкаИнструмента;
	КонецЕсли;
	
	Возврат НовыйРезультатИнструмента(РезультатВыбора.Успех, РезультатВыбора.Данные);
КонецФункции

