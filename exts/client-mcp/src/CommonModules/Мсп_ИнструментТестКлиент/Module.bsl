#Область ПрограммныйИнтерфейс

// Возвращает описание инструментов провайдера.
Процедура ЗарегистрироватьИнструменты() Экспорт
	Мсп_РеестрКлиент.ЗарегистрироватьИнструмент(Мсп_ИнструментыКлиент.НовыйОписаниеИнструмента(
		"test_client_start",
		"Запускает тест-клиент 1С и устанавливает соединение.",
		СхемаВходныхПараметровЗапуск(),
		Новый ОписаниеОповещения("ОбработатьИнструментЗапуск", Мсп_ИнструментТестКлиент)));
	Мсп_РеестрКлиент.ЗарегистрироватьИнструмент(Мсп_ИнструментыКлиент.НовыйОписаниеИнструмента(
		"test_client_stop",
		"Останавливает тест-клиент 1С и разрывает соединение.",
		СхемаВходныхПараметровОстановка(),
		Новый ОписаниеОповещения("ОбработатьИнструментОстановка", Мсп_ИнструментТестКлиент)));
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Запускает тест-клиент 1С и устанавливает соединение.
//
// Параметры:
//  Запрос - Структура - Запрос инструмента:
//   * Аргументы - Структура - Аргументы вызова.
//   * Контекст - Структура - Контекст вызова.
//  ДополнительныеПараметры - Произвольный - Дополнительные параметры вызова.
//
// Возвращаемое значение:
//  Структура - Результат выполнения.
Функция ОбработатьИнструментЗапуск(Запрос, ДополнительныеПараметры) Экспорт
	Аргументы = Новый Структура;
	Если Запрос <> Неопределено Тогда
		Аргументы = Запрос.Аргументы;
	КонецЕсли;

	КомандаЗапуска = Мсп_Коллекции.ПолучитьСвойство(Аргументы, "command_line", "");
	Если Не ЗначениеЗаполнено(КомандаЗапуска) Тогда
		Возврат СформироватьРезультат(Ложь, Неопределено, "command_line is required");
	КонецЕсли;

	РабочийКаталог = Мсп_Коллекции.ПолучитьСвойство(Аргументы, "working_dir", "");
	ИнтервалПаузы = Мсп_Коллекции.ПолучитьСвойство(Аргументы, "startup_delay_sec", 0);
	Хост = Мсп_Коллекции.ПолучитьСвойство(Аргументы, "host", "");
	Порт = Мсп_Коллекции.ПолучитьСвойство(Аргументы, "port", 0);
	ИдентификаторКлиента = Мсп_Коллекции.ПолучитьСвойство(Аргументы, "client_id", "");

	Порт = НормализоватьПорт(Порт, КомандаЗапуска);
	КомандаЗапуска = ОбеспечитьКлючТестКлиента(КомандаЗапуска, Порт);

	РезультатЗапуска = ЗапуститьПроцессТестКлиента(КомандаЗапуска, РабочийКаталог);
	Если Не РезультатЗапуска.Успех Тогда
		Возврат СформироватьРезультат(Ложь, Неопределено, РезультатЗапуска.Ошибка);
	КонецЕсли;

	ВыполнитьПауза(ИнтервалПаузы);

	ТестКлиент = СоздатьТестируемоеПриложение(Хост, Порт, ИдентификаторКлиента);
	РезультатПодключения = ПодключитьсяКТестКлиенту(ТестКлиент, 60);

	Память = ПолучитьПамятьТестКлиент();
	Память.Вставить("КомандаЗапуска", КомандаЗапуска);
	Память.Вставить("ТестКлиент", ТестКлиент);
	Память.Вставить("Подключен", РезультатПодключения.Подключен);
	Память.Вставить("ПоследняяОшибка", РезультатПодключения.Ошибка);
	Память.Вставить("Порт", Порт);
	Память.Вставить("Хост", Хост);
	Память.Вставить("ИдентификаторКлиента", ИдентификаторКлиента);
	СохранитьПамятьТестКлиент(Память);

	Данные = Новый Структура("started,connected,port", Истина, РезультатПодключения.Подключен, Порт);
	Возврат СформироватьРезультат(РезультатПодключения.Подключен, Данные, РезультатПодключения.Ошибка);
КонецФункции

// Останавливает тест-клиент 1С и разрывает соединение.
//
// Параметры:
//  Запрос - Структура - Запрос инструмента:
//   * Аргументы - Структура - Аргументы вызова.
//   * Контекст - Структура - Контекст вызова.
//  ДополнительныеПараметры - Произвольный - Дополнительные параметры вызова.
//
// Возвращаемое значение:
//  Структура - Результат выполнения.
Функция ОбработатьИнструментОстановка(Запрос, ДополнительныеПараметры) Экспорт
	Память = ПолучитьПамятьТестКлиент();
	ТестКлиент = ПолучитьЗначениеПамяти(Память, "ТестКлиент", Неопределено);
	Если ТестКлиент = Неопределено Тогда
		Возврат СформироватьРезультат(Ложь, Новый Структура("stopped", Ложь), "test client not started");
	КонецЕсли;

	Ошибка = "";
	Попытка
		Окно = Неопределено;
		Попытка
			Окно = ТестКлиент.ПолучитьАктивноеОкно();
		Исключение
		КонецПопытки;
		Если Окно <> Неопределено Тогда
			Попытка
				Окно.Закрыть();
			Исключение
			КонецПопытки;
		КонецЕсли;
		Попытка
			ТестКлиент.РазорватьСоединение();
		Исключение
			Ошибка = ОписаниеОшибки();
		КонецПопытки;
	Исключение
		Ошибка = ОписаниеОшибки();
	КонецПопытки;

	Память.Вставить("ТестКлиент", Неопределено);
	Память.Вставить("Подключен", Ложь);
	Память.Вставить("ПоследняяОшибка", Ошибка);
	СохранитьПамятьТестКлиент(Память);

	Данные = Новый Структура("stopped", Не ЗначениеЗаполнено(Ошибка));
	Возврат СформироватьРезультат(Не ЗначениеЗаполнено(Ошибка), Данные, Ошибка);
КонецФункции

// Возвращает JSON-схему входных параметров запуска.
Функция СхемаВходныхПараметровЗапуск()
	Схема = Новый Структура;
	Схема.Вставить("type", "object");
	Свойства = Новый Структура;
	Свойства.Вставить("command_line", Новый Структура("type", "string"));
	Свойства.Вставить("working_dir", Новый Структура("type", "string"));
	Свойства.Вставить("startup_delay_sec", Новый Структура("type", "number"));
	Свойства.Вставить("host", Новый Структура("type", "string"));
	Свойства.Вставить("port", Новый Структура("type", "number"));
	Свойства.Вставить("client_id", Новый Структура("type", "string"));
	Схема.Вставить("properties", Свойства);
	Требуемые = Новый Массив;
	Требуемые.Добавить("command_line");
	Схема.Вставить("required", Требуемые);
	Схема.Вставить("additionalProperties", Ложь);
	Возврат Схема;
КонецФункции

// Возвращает JSON-схему входных параметров остановки.
Функция СхемаВходныхПараметровОстановка()
	Схема = Новый Структура;
	Схема.Вставить("type", "object");
	Схема.Вставить("properties", Новый Структура);
	Схема.Вставить("additionalProperties", Ложь);
	Возврат Схема;
КонецФункции

Функция СформироватьРезультат(Успех, Данные, Ошибка)
	Результат = Новый Структура("ok", Успех);
	Если Данные <> Неопределено Тогда
		Результат.Вставить("data", Данные);
	КонецЕсли;
	Если ЗначениеЗаполнено(Ошибка) Тогда
		Результат.Вставить("error", Ошибка);
	КонецЕсли;
	Возврат Результат;
КонецФункции

Функция ПолучитьПамятьТестКлиент()
	Память = Мсп_СостояниеКлиент.ПолучитьСостояниеЗначение(КлючПамятиТестКлиент(), Неопределено);
	Если Память = Неопределено Тогда
		Память = Новый Структура;
		СохранитьПамятьТестКлиент(Память);
	КонецЕсли;
	Возврат Память;
КонецФункции

Процедура СохранитьПамятьТестКлиент(Память)
	Мсп_СостояниеКлиент.УстановитьСостояниеЗначение(КлючПамятиТестКлиент(), Память);
КонецПроцедуры

Функция КлючПамятиТестКлиент()
	Возврат "ПамятьТестКлиент";
КонецФункции

Функция ПолучитьЗначениеПамяти(Память, Имя, ЗначениеПоУмолчанию)
	Если Память = Неопределено Тогда
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;
	Значение = ЗначениеПоУмолчанию;
	Если Память.Свойство(Имя, Значение) Тогда
		Возврат Значение;
	КонецЕсли;
	Возврат ЗначениеПоУмолчанию;
КонецФункции

Функция ЗапуститьПроцессТестКлиента(КомандаЗапуска, РабочийКаталог)
	Попытка
		Если ЗначениеЗаполнено(РабочийКаталог) Тогда
			ЗапуститьПриложение(КомандаЗапуска, РабочийКаталог);
		Иначе
			ЗапуститьПриложение(КомандаЗапуска);
		КонецЕсли;
		Возврат Новый Структура("Успех, Ошибка", Истина, "");
	Исключение
		Возврат Новый Структура("Успех, Ошибка", Ложь, ОписаниеОшибки());
	КонецПопытки;
КонецФункции

Процедура ВыполнитьПауза(ИнтервалПаузы)
	Если ТипЗнч(ИнтервалПаузы) <> Тип("Число") Тогда
		Попытка
			ИнтервалПаузы = Число(ИнтервалПаузы);
		Исключение
			Возврат;
		КонецПопытки;
	КонецЕсли;
	Если ИнтервалПаузы <= 0 Тогда
		Возврат;
	КонецЕсли;
	Попытка
		Пауза(ИнтервалПаузы);
	Исключение
	КонецПопытки;
КонецПроцедуры

Функция СоздатьТестируемоеПриложение(Хост, Порт, ИдентификаторКлиента)
	Если ЗначениеЗаполнено(Хост) Или Порт > 0 Или ЗначениеЗаполнено(ИдентификаторКлиента) Тогда
		Возврат Новый ТестируемоеПриложение(Хост, Порт, ИдентификаторКлиента);
	КонецЕсли;
	Возврат Новый ТестируемоеПриложение();
КонецФункции

Функция ПодключитьсяКТестКлиенту(ТестКлиент, МаксИтераций)
	Подключен = Ложь;
	ПоследняяОшибка = "";
	Для Счетчик = 1 По МаксИтераций Цикл
		Попытка
			ТестКлиент.УстановитьСоединение();
			Подключен = Истина;
			Прервать;
		Исключение
			ПоследняяОшибка = ОписаниеОшибки();
		КонецПопытки;
	КонецЦикла;
	Возврат Новый Структура("Подключен, Ошибка", Подключен, ПоследняяОшибка);
КонецФункции

Функция НормализоватьПорт(Порт, КомандаЗапуска)
	ЧислоПорта = 0;
	Если ТипЗнч(Порт) = Тип("Число") Тогда
		ЧислоПорта = Порт;
	ИначеЕсли ТипЗнч(Порт) = Тип("Строка") И ЗначениеЗаполнено(Порт) Тогда
		Попытка
			ЧислоПорта = Число(Порт);
		Исключение
			ЧислоПорта = 0;
		КонецПопытки;
	КонецЕсли;
	Если ЧислоПорта <= 0 Тогда
		ЧислоПорта = ПолучитьПортИзКоманднойСтроки(КомандаЗапуска);
	КонецЕсли;
	Если ЧислоПорта <= 0 Тогда
		ЧислоПорта = 1538;
	КонецЕсли;
	Возврат ЧислоПорта;
КонецФункции

Функция ПолучитьПортИзКоманднойСтроки(КомандаЗапуска)
	ВерхнийРегистр = ВРег(КомандаЗапуска);
	Позиция = СтрНайти(ВерхнийРегистр, "-TPORT");
	Если Позиция = 0 Тогда
		Возврат 0;
	КонецЕсли;
	Позиция = Позиция + СтрДлина("-TPORT");
	СтрокаПорта = "";
	Для Индекс = Позиция По СтрДлина(КомандаЗапуска) Цикл
		Символ = Сред(КомандаЗапуска, Индекс, 1);
		Если СтрНайти("0123456789", Символ) > 0 Тогда
			СтрокаПорта = СтрокаПорта + Символ;
		Иначе
			Прервать;
		КонецЕсли;
	КонецЦикла;
	Если ЗначениеЗаполнено(СтрокаПорта) Тогда
		Попытка
			Возврат Число(СтрокаПорта);
		Исключение
			Возврат 0;
		КонецПопытки;
	КонецЕсли;
	Возврат 0;
КонецФункции

Функция ОбеспечитьКлючТестКлиента(КомандаЗапуска, Порт)
	ВерхнийРегистр = ВРег(КомандаЗапуска);
	Если СтрНайти(ВерхнийРегистр, "/TESTCLIENT") = 0 Тогда
		КомандаЗапуска = КомандаЗапуска + " /TESTCLIENT";
		ВерхнийРегистр = ВРег(КомандаЗапуска);
	КонецЕсли;
	Если Порт > 0 И СтрНайти(ВерхнийРегистр, "-TPORT") = 0 Тогда
		КомандаЗапуска = КомандаЗапуска + " -TPort" + Строка(Порт);
	КонецЕсли;
	Возврат КомандаЗапуска;
КонецФункции

#КонецОбласти
