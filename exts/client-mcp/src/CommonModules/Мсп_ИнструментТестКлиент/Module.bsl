// Отправляет клавиатурное событие элементу по URI или активному элементу.
//
// Параметры:
//  Запрос - Структура - Запрос инструмента.
//  ДополнительныеПараметры - Произвольный - Дополнительные параметры вызова.
//
// Возвращаемое значение:
//  Произвольный - Результат инструмента.
Функция ОбработчикКомандыКлавиатуры(Запрос, ДополнительныеПараметры) Экспорт
	Аргументы = АргументыИнструмента(Запрос);
	РезультатКлавиши = СтроковыйАргумент(Аргументы, "key", Истина);
	ОшибкаИнструмента = РезультатОшибкиИнструмента(РезультатКлавиши);
	Если ОшибкаИнструмента <> Неопределено Тогда
		Возврат ОшибкаИнструмента;
	КонецЕсли;

	РезультатURI = СтроковыйАргумент(Аргументы, "uri");
	ОшибкаИнструмента = РезультатОшибкиИнструмента(РезультатURI);
	Если ОшибкаИнструмента <> Неопределено Тогда
		Возврат ОшибкаИнструмента;
	КонецЕсли;

	Модификаторы = Мсп_Коллекции.Свойство(Аргументы, "modifiers", Новый Массив);

	РезультатНажатия = Мсп_ФормыКлиент.НажатьКлавишуПоURI(РезультатURI.Значение, РезультатКлавиши.Значение, Модификаторы);
	ОшибкаИнструмента = РезультатОшибкиИнструмента(РезультатНажатия);
	Если ОшибкаИнструмента <> Неопределено Тогда
		Возврат ОшибкаИнструмента;
	КонецЕсли;

	Возврат НовыйРезультатИнструмента(Истина, Новый Структура("success", Истина));
КонецФункции

// Ожидает появления элемента интерфейса по фильтру.
//
// Параметры:
//  Запрос - Структура - Запрос инструмента.
//  ДополнительныеПараметры - Произвольный - Дополнительные параметры вызова.
//
// Возвращаемое значение:
//  Произвольный - Результат инструмента.
Функция ОбработчикКомандыОжидания(Запрос, ДополнительныеПараметры) Экспорт
	Аргументы = АргументыИнструмента(Запрос);
	РезультатRootURI = СтроковыйАргумент(Аргументы, "root_uri");
	ОшибкаИнструмента = РезультатОшибкиИнструмента(РезультатRootURI);
	Если ОшибкаИнструмента <> Неопределено Тогда
		Возврат ОшибкаИнструмента;
	КонецЕсли;
	РезультатТипа = СтроковыйАргумент(Аргументы, "type");
	ОшибкаИнструмента = РезультатОшибкиИнструмента(РезультатТипа);
	Если ОшибкаИнструмента <> Неопределено Тогда
		Возврат ОшибкаИнструмента;
	КонецЕсли;
	РезультатЗаголовка = СтроковыйАргумент(Аргументы, "title");
	ОшибкаИнструмента = РезультатОшибкиИнструмента(РезультатЗаголовка);
	Если ОшибкаИнструмента <> Неопределено Тогда
		Возврат ОшибкаИнструмента;
	КонецЕсли;
	РезультатИмени = СтроковыйАргумент(Аргументы, "name");
	ОшибкаИнструмента = РезультатОшибкиИнструмента(РезультатИмени);
	Если ОшибкаИнструмента <> Неопределено Тогда
		Возврат ОшибкаИнструмента;
	КонецЕсли;
	РезультатТаймаута = ЧисловойАргумент(Аргументы, "timeout_sec", 10);
	ОшибкаИнструмента = РезультатОшибкиИнструмента(РезультатТаймаута);
	Если ОшибкаИнструмента <> Неопределено Тогда
		Возврат ОшибкаИнструмента;
	КонецЕсли;
	РезультатИнтервала = ЧисловойАргумент(Аргументы, "interval_ms", 500);
	ОшибкаИнструмента = РезультатОшибкиИнструмента(РезультатИнтервала);
	Если ОшибкаИнструмента <> Неопределено Тогда
		Возврат ОшибкаИнструмента;
	КонецЕсли;

	ТаймаутСек = РезультатТаймаута.Значение;
	ИнтервалМс = РезультатИнтервала.Значение;
	НачалоОжидания = ТекущаяДата();

	Пока Истина Цикл
		РезультатПоиска = Мсп_ФормыКлиент.НайтиОбъекты(
			РезультатRootURI.Значение,
			РезультатТипа.Значение,
			РезультатЗаголовка.Значение,
			РезультатИмени.Значение,
			0);

		Если Не ЗначениеЗаполнено(РезультатПоиска.КодОшибки)
			И РезультатПоиска.Объекты.Количество() > 0 Тогда
			Первый = РезультатПоиска.Объекты[0];
			URI = Мсп_Коллекции.Свойство(Первый, "uri", "");
			Возврат НовыйРезультатИнструмента(Истина, Новый Структура("uri", URI));
		КонецЕсли;

		Если (ТекущаяДата() - НачалоОжидания) >= ТаймаутСек Тогда
			Прервать;
		КонецЕсли;

		Мсп_ПаузаВызовСервера.СделатьПаузу(ИнтервалМс / 1000);
	КонецЦикла;

	Возврат НовыйРезультатОшибкиИнструмента("ACTION_FAILED", "element not found within timeout");
КонецФункции

// Возвращает строки таблицы формы по URI.
//
// Параметры:
//  Запрос - Структура - Запрос инструмента.
//  ДополнительныеПараметры - Произвольный - Дополнительные параметры вызова.
//
// Возвращаемое значение:
//  Произвольный - Результат инструмента.
Функция ОбработчикКомандыСтрокТаблицы(Запрос, ДополнительныеПараметры) Экспорт
	Аргументы = АргументыИнструмента(Запрос);
	РезультатURI = СтроковыйАргумент(Аргументы, "uri", Истина);
	ОшибкаИнструмента = РезультатОшибкиИнструмента(РезультатURI);
	Если ОшибкаИнструмента <> Неопределено Тогда
		Возврат ОшибкаИнструмента;
	КонецЕсли;
	РезультатLimit = ЧисловойАргумент(Аргументы, "limit", 100);
	ОшибкаИнструмента = РезультатОшибкиИнструмента(РезультатLimit);
	Если ОшибкаИнструмента <> Неопределено Тогда
		Возврат ОшибкаИнструмента;
	КонецЕсли;
	РезультатOffset = ЧисловойАргумент(Аргументы, "offset", 0);
	ОшибкаИнструмента = РезультатОшибкиИнструмента(РезультатOffset);
	Если ОшибкаИнструмента <> Неопределено Тогда
		Возврат ОшибкаИнструмента;
	КонецЕсли;

	РезультатСтрок = Мсп_ФормыКлиент.ПолучитьСтрокиТаблицыПоURI(
		РезультатURI.Значение,
		РезультатLimit.Значение,
		РезультатOffset.Значение);
	ОшибкаИнструмента = РезультатОшибкиИнструмента(РезультатСтрок);
	Если ОшибкаИнструмента <> Неопределено Тогда
		Возврат ОшибкаИнструмента;
	КонецЕсли;

	Возврат НовыйРезультатИнструмента(Истина, РезультатСтрок.Строки);
КонецФункции

// Читает значение ячейки таблицы по URI, строке и колонке.
//
// Параметры:
//  Запрос - Структура - Запрос инструмента.
//  ДополнительныеПараметры - Произвольный - Дополнительные параметры вызова.
//
// Возвращаемое значение:
//  Произвольный - Результат инструмента.
Функция ОбработчикКомандыЗначенияЯчейки(Запрос, ДополнительныеПараметры) Экспорт
	Аргументы = АргументыИнструмента(Запрос);
	РезультатURI = СтроковыйАргумент(Аргументы, "uri", Истина);
	ОшибкаИнструмента = РезультатОшибкиИнструмента(РезультатURI);
	Если ОшибкаИнструмента <> Неопределено Тогда
		Возврат ОшибкаИнструмента;
	КонецЕсли;
	РезультатRow = ЧисловойАргумент(Аргументы, "row", -1);
	ОшибкаИнструмента = РезультатОшибкиИнструмента(РезультатRow);
	Если ОшибкаИнструмента <> Неопределено Тогда
		Возврат ОшибкаИнструмента;
	КонецЕсли;
	Если Не ЕстьАргумент(Аргументы, "row") Тогда
		Возврат НовыйРезультатОшибкиИнструмента("INVALID_PARAMS", "row is required");
	КонецЕсли;
	РезультатColumn = СтроковыйАргумент(Аргументы, "column", Истина);
	ОшибкаИнструмента = РезультатОшибкиИнструмента(РезультатColumn);
	Если ОшибкаИнструмента <> Неопределено Тогда
		Возврат ОшибкаИнструмента;
	КонецЕсли;

	РезультатЗначения = Мсп_ФормыКлиент.ПолучитьЗначениеЯчейкиПоURI(
		РезультатURI.Значение,
		РезультатRow.Значение,
		РезультатColumn.Значение);
	ОшибкаИнструмента = РезультатОшибкиИнструмента(РезультатЗначения);
	Если ОшибкаИнструмента <> Неопределено Тогда
		Возврат ОшибкаИнструмента;
	КонецЕсли;

	Данные = Новый Структура("value,type", РезультатЗначения.Значение, РезультатЗначения.Тип);
	Возврат НовыйРезультатИнструмента(Истина, Данные);
КонецФункции

// Выбирает строку таблицы по индексу или фильтру.
//
// Параметры:
//  Запрос - Структура - Запрос инструмента.
//  ДополнительныеПараметры - Произвольный - Дополнительные параметры вызова.
//
// Возвращаемое значение:
//  Произвольный - Результат инструмента.
Функция ОбработчикКомандыВыбораСтроки(Запрос, ДополнительныеПараметры) Экспорт
	Аргументы = АргументыИнструмента(Запрос);
	РезультатURI = СтроковыйАргумент(Аргументы, "uri", Истина);
	ОшибкаИнструмента = РезультатОшибкиИнструмента(РезультатURI);
	Если ОшибкаИнструмента <> Неопределено Тогда
		Возврат ОшибкаИнструмента;
	КонецЕсли;

	ЕстьRow = ЕстьАргумент(Аргументы, "row");
	ЕстьFilter = ЕстьАргумент(Аргументы, "filter");
	Если ЕстьRow = ЕстьFilter Тогда
		Возврат НовыйРезультатОшибкиИнструмента("INVALID_PARAMS", "exactly one of row or filter is required");
	КонецЕсли;

	РезультатRow = ЧисловойАргумент(Аргументы, "row", 0);
	ОшибкаИнструмента = РезультатОшибкиИнструмента(РезультатRow);
	Если ОшибкаИнструмента <> Неопределено Тогда
		Возврат ОшибкаИнструмента;
	КонецЕсли;

	Фильтр = Мсп_Коллекции.Свойство(Аргументы, "filter", Неопределено);

	РезультатВыбора = Мсп_ФормыКлиент.ВыбратьСтрокуТаблицыПоURI(
		РезультатURI.Значение,
		РезультатRow.Значение,
		ЕстьRow,
		Фильтр);
	ОшибкаИнструмента = РезультатОшибкиИнструмента(РезультатВыбора);
	Если ОшибкаИнструмента <> Неопределено Тогда
		Возврат ОшибкаИнструмента;
	КонецЕсли;

	Данные = Новый Структура("row,uri", РезультатВыбора.Индекс, РезультатВыбора.URI);
	Возврат НовыйРезультатИнструмента(Истина, Данные);
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Возвращает JSON-схему входных параметров запуска.
Функция СхемаВходныхПараметровЗапуск()
	Свойства = Новый Структура;
	Свойства.Вставить("port", НовыйСвойствоСхемы("number", "Номер порта тест-клиента"));
	Возврат НовыйСхемаОбъекта(Свойства);
КонецФункции

// Возвращает JSON-схему входных параметров остановки.
Функция СхемаВходныхПараметровОстановка()
	Свойства = Новый Структура;
	Свойства.Вставить("close", НовыйСвойствоСхемы("boolean", "Закрыть приложение тест-клиента (true) или только разорвать соединение (false)"));
	Возврат НовыйСхемаОбъекта(Свойства);
КонецФункции

// Возвращает JSON-схему входных параметров поиска.
Функция СхемаВходныхПараметровПоиск()
	Свойства = Новый Структура;
	Свойства.Вставить("root_uri", НовыйСвойствоСхемы("string", "URI корневого объекта поиска (window://, form://, control://)"));
	Свойства.Вставить("type", НовыйСвойствоСхемы("string", "Тип искомого объекта: window, form, group, button, table, field, decoration, label"));
	Свойства.Вставить("title", НовыйСвойствоСхемы("string", "Фильтр по заголовку (поддерживаются маски * и ?)"));
	Свойства.Вставить("name", НовыйСвойствоСхемы("string", "Фильтр по имени объекта"));
	Свойства.Вставить("timeout_sec", НовыйСвойствоСхемы("number", "Таймаут ожидания появления объекта в секундах"));
	Возврат НовыйСхемаОбъекта(Свойства);
КонецФункции

// Возвращает JSON-схему входных параметров инструмента по URI.
Функция СхемаВходныхПараметровURI()
	Свойства = Новый Структура;
	Свойства.Вставить("uri", НовыйСвойствоСхемы("string", "URI объекта интерфейса (window://, form://, control://)"));
	ТребуемыеПоля = Новый Массив;
	ТребуемыеПоля.Добавить("uri");
	Возврат НовыйСхемаОбъекта(Свойства, ТребуемыеПоля);
КонецФункции

