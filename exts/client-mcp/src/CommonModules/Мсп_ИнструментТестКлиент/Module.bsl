Функция ЕстьАргумент(Аргументы, ИмяАргумента)
	ЗначениеАргумента = Неопределено;
	Возврат Аргументы.Свойство(ИмяАргумента, ЗначениеАргумента);
КонецФункции

Функция СтроковыйАргумент(Аргументы, ИмяАргумента, Обязательный = Ложь, ЗначениеПоУмолчанию = "")
	ЗначениеАргумента = Неопределено;
	
	Если Не Аргументы.Свойство(ИмяАргумента, ЗначениеАргумента) Тогда
		Если Обязательный Тогда
			Мсп_Ошибки.НекорректныеПараметры(ИмяАргумента + " is required");
		Иначе
			Возврат ЗначениеПоУмолчанию;
		КонецЕсли;
	ИначеЕсли ТипЗнч(ЗначениеАргумента) <> Тип("Строка") Тогда
		Мсп_Ошибки.НекорректныеПараметры(ИмяАргумента + " must be string");
	КонецЕсли;
	
	Возврат ЗначениеАргумента;
КонецФункции

Функция ЧисловойАргумент(Аргументы, ИмяАргумента, Обязательный = Ложь, ЗначениеПоУмолчанию = 0)
	ЗначениеАргумента = Неопределено;
	Если Не Аргументы.Свойство(ИмяАргумента, ЗначениеАргумента) Тогда
		Если Обязательный Тогда
			Мсп_Ошибки.НекорректныеПараметры(ИмяАргумента + " is required");
		Иначе
			Возврат НовыйРезультатАргумента(ЗначениеПоУмолчанию);
		КонецЕсли;
	КонецЕсли;
	Если ТипЗнч(ЗначениеАргумента) <> Тип("Число") Тогда
		Мсп_Ошибки.НекорректныеПараметры(ИмяАргумента + " must be number");
	КонецЕсли;
	
	Возврат НовыйРезультатАргумента(ЗначениеАргумента);
КонецФункции

Функция НовыйРезультатОшибкиИнструмента(КодОшибки, Ошибка)
	ПубличныйКод = ПубличныйКодОшибки(КодОшибки);
	Детали = ДеталиОшибкиИнструмента(КодОшибки, Ошибка, ПубличныйКод);
	Возврат НовыйРезультатИнструмента(Ложь, Неопределено, ПубличныйКод, Детали);
КонецФункции

Функция РезультатОшибкиИнструмента(Результат)
	КодОшибки = Мсп_Коллекции.Свойство(Результат, "КодОшибки", "");
	Если Не ЗначениеЗаполнено(КодОшибки) Тогда
		Возврат Неопределено;
	КонецЕсли;

	Ошибка = Мсп_Коллекции.Свойство(Результат, "Ошибка", "");
	Возврат НовыйРезультатОшибкиИнструмента(КодОшибки, Ошибка);
КонецФункции

Функция ПубличныйКодОшибки(КодОшибки)
	Если КодОшибки = "INVALID_URI"
		ИЛИ КодОшибки = "INVALID_PARAMS" Тогда
		Возврат "-32602";
	ИначеЕсли КодОшибки = "ACTION_FAILED" Тогда
		Возврат "-32603";
	КонецЕсли;

	Возврат КодОшибки;
КонецФункции

Функция ДеталиОшибкиИнструмента(КодОшибки, Ошибка, ПубличныйКод)
	Если Не ЗначениеЗаполнено(Ошибка) Тогда
		Возврат КодОшибки;
	КонецЕсли;
	Если КодОшибки = ПубличныйКод Тогда
		Возврат Ошибка;
	КонецЕсли;

	Возврат КодОшибки + ": " + Ошибка;
КонецФункции

Функция НовыйРезультатАргумента(Значение, КодОшибки = "", Ошибка = "")
	Возврат Новый Структура("Значение,КодОшибки,Ошибка", Значение, КодОшибки, Ошибка);
КонецФункции

Функция НовыйРезультатИнструмента(Успех, Данные, Ошибка = "", Детали = "")
	ТелоРезультата = Новый Структура("ok", Успех);
	Если Данные <> Неопределено Тогда
		ТелоРезультата.Вставить("data", Данные);
	КонецЕсли;
	Если ЗначениеЗаполнено(Ошибка) Тогда
		ТелоРезультата.Вставить("error", Ошибка);
	КонецЕсли;
	Если ЗначениеЗаполнено(Детали) Тогда
		ТелоРезультата.Вставить("details", Детали);
	КонецЕсли;
	Возврат Мсп_Результаты.JSON(ТелоРезультата);
КонецФункции

#КонецОбласти
