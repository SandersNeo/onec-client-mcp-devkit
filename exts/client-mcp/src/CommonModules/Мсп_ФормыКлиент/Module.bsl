#Область ПрограммныйИнтерфейс

// Модуль работы с формами тест-клиента.

// Формирует базовый снимок формы.
//
// Параметры:
//  Заголовок - Строка - Заголовок формы (опционально).
//
// Возвращаемое значение:
//  Структура - Базовый снимок формы.
Функция СформироватьБазовыйСнимокФормы(Заголовок = "") Экспорт
	Снимок = Новый Структура;
	Снимок.Вставить("type", "form");
	Если ЗначениеЗаполнено(Заголовок) Тогда
		Снимок.Вставить("title", Заголовок);
	КонецЕсли;
	Снимок.Вставить("children", Новый Массив);
	Возврат Снимок;
КонецФункции

// Формирует снимок формы в формате контракта UI.
//
// Параметры:
//  Форма - ТестируемаяФорма - Форма тест-клиента.
//
// Возвращаемое значение:
//  Структура - Снимок формы.
Функция СформироватьСнимокФормы(Форма, ДополнительныеПараметры = Неопределено) Экспорт
	ИмяФормы = ИмяФормыЗначение(Форма);
	Снимок = Новый Структура(
		"type,uri,title,name,children",
		"form",
		URIФормы(Форма),
		ЗаголовокФормы(Форма),
		ИмяФормы,
		СнимкиПодчиненныхОбъектов(Форма, ИмяФормы));
	Возврат Снимок;
КонецФункции

// Возвращает URI формы.
//
// Параметры:
//  Форма - ТестируемаяФорма - Форма тест-клиента.
//
// Возвращаемое значение:
//  Строка - URI формы.
Функция URIФормы(Форма) Экспорт
	Возврат Мсп_URIКлиент.URIФормы(ИмяФормыЗначение(Форма));
КонецФункции

// Возвращает URI элемента формы.
//
// Параметры:
//  Форма - ТестируемаяФорма - Форма тест-клиента.
//  Элемент - Произвольный - Элемент формы.
//
// Возвращаемое значение:
//  Строка - URI элемента формы.
Функция URIЭлементаФормы(Форма, Элемент) Экспорт
	Возврат Мсп_URIКлиент.URIЭлементаФормы(ИмяФормыЗначение(Форма), ИмяЭлемента(Элемент));
КонецФункции

// Возвращает описание объекта интерфейса.
//
// Параметры:
//  Объект - Произвольный - Объект интерфейса тест-клиента.
//
// Возвращаемое значение:
//  Структура - Описание объекта:
//   * type - Строка - Тип объекта.
//   * title - Строка - Заголовок объекта.
//   * name - Строка - Имя объекта.
//   * uri - Строка - URI объекта.
//  Неопределено - Объект не поддерживается.
Функция ОписаниеОбъекта(Объект) Экспорт
	ТипОбъекта = ТипОбъектаИнтерфейса(Объект);
	Если Не ЗначениеЗаполнено(ТипОбъекта) Тогда
		Возврат Неопределено;
	КонецЕсли;

	Если ТипОбъекта = "window" Тогда
		Описание = НовоеОписаниеОбъекта(
			ТипОбъекта,
			ЗаголовокОкна(Объект),
			"",
			Мсп_ОкнаКлиент.URIОкна(Объект));
		Возврат Описание;
	КонецЕсли;

	Если ТипОбъекта = "form" Тогда
		Описание = НовоеОписаниеОбъекта(
			ТипОбъекта,
			ЗаголовокФормы(Объект),
			ИмяФормыЗначение(Объект),
			URIФормы(Объект));
		Возврат Описание;
	КонецЕсли;

	РодительскаяФорма = ПолучитьРодительскуюФорму(Объект);
	Описание = НовоеОписаниеОбъекта(
		ТипОбъекта,
		ЗаголовокЭлемента(Объект),
		ИмяЭлемента(Объект),
		?(РодительскаяФорма = Неопределено, "", URIЭлементаФормы(РодительскаяФорма, Объект)));
	Возврат Описание;
КонецФункции

// Возвращает форму по URI.
//
// Параметры:
//  URI - Строка - URI формы.
//
// Возвращаемое значение:
//  Структура - Результат получения объекта:
//   * Объект - ТестируемаяФорма, Неопределено - Найденная форма.
//   * КодОшибки - Строка - Код ошибки.
//   * Ошибка - Строка - Описание ошибки.
Функция ФормаПоURI(URI) Экспорт
	Если Не Мсп_URIКлиент.ЭтоURIФормы(URI) Тогда
		Мсп_Ошибки.НекорректныеПараметры("unsupported form uri");
	КонецЕсли;

	Если Не ЗначениеЗаполнено(Мсп_URIКлиент.СегментФормы(URI)) Тогда
		Мсп_Ошибки.НекорректныеПараметры("form uri segment is empty");
	КонецЕсли;

	РезультатСпискаФорм = ПолучитьСписокФорм();
	Если ЗначениеЗаполнено(РезультатСпискаФорм.КодОшибки) Тогда
		Возврат НовыйРезультатПолученияОбъекта(
			Неопределено,
			РезультатСпискаФорм.КодОшибки,
			РезультатСпискаФорм.Ошибка);
	КонецЕсли;
	
	НайденныеФормы = Новый Массив;
	Для Каждого Форма Из РезультатСпискаФорм.Формы Цикл
		Если URIФормы(Форма) = URI Тогда
			НайденныеФормы.Добавить(Форма);
		КонецЕсли;
	КонецЦикла;

	Если НайденныеФормы.Количество() = 0 Тогда
		Мсп_Ошибки.НеНайдено("form not found");
	КонецЕсли;
	Если НайденныеФормы.Количество() > 1 Тогда
		Мсп_Ошибки.НеоднозначныйРезультат("form uri is ambiguous");
	КонецЕсли;

	Возврат НовыйРезультатПолученияОбъекта(НайденныеФормы[0]);
КонецФункции

// Выполняет поиск объектов интерфейса по фильтру.
//
// Параметры:
//  URIКорня - Строка - URI корневого объекта поиска.
//  Тип - Строка - Тип объекта поиска.
//  Заголовок - Строка - Фильтр по заголовку.
//  Имя - Строка - Фильтр по имени.
//  Таймаут - Число - Таймаут поиска в секундах.
//
// Возвращаемое значение:
//  Структура - Результат поиска:
//   * Объекты - Массив - Найденные описания объектов.
//   * КодОшибки - Строка - Код ошибки.
//   * Ошибка - Строка - Описание ошибки.
Функция НайтиОбъекты(URIКорня = "", Тип = "", Заголовок = "", Имя = "", Таймаут = 0) Экспорт
	Если ЗначениеЗаполнено(Тип)
		И ТипПлатформыПоСтроке(Тип) = Неопределено Тогда
		Мсп_Ошибки.НекорректныеПараметры("unsupported object type");
	КонецЕсли;

	РезультатКорня = ПолучитьКореньПоиска(URIКорня);
	Если ЗначениеЗаполнено(РезультатКорня.КодОшибки) Тогда
		Возврат НовыйРезультатПоиска(Новый Массив, РезультатКорня.КодОшибки, РезультатКорня.Ошибка);
	КонецЕсли;

	РезультатПоиска = НайтиПодчиненныеОбъекты(
		РезультатКорня.Объект,
		ТипПлатформыПоСтроке(Тип),
		Заголовок,
		Имя,
		Таймаут);
	Если ЗначениеЗаполнено(РезультатПоиска.КодОшибки) Тогда
		Возврат НовыйРезультатПоиска(Новый Массив, РезультатПоиска.КодОшибки, РезультатПоиска.Ошибка);
	КонецЕсли;

	ОписанияОбъектов = Новый Массив;
	Для Каждого НайденныйОбъект Из РезультатПоиска.Объекты Цикл
		Описание = ОписаниеОбъекта(НайденныйОбъект);
		Если Описание <> Неопределено Тогда
			ОписанияОбъектов.Добавить(Описание);
		КонецЕсли;
	КонецЦикла;

	Возврат НовыйРезультатПоиска(ОписанияОбъектов);
КонецФункции

// Активизирует объект интерфейса по URI.
//
// Параметры:
//  URI - Строка - URI объекта.
//
// Возвращаемое значение:
//  Структура - Результат активации:
//   * Успех - Булево - Признак успешной активации.
//   * Описание - Структура - Описание объекта.
//   * КодОшибки - Строка - Код ошибки.
//   * Ошибка - Строка - Описание ошибки.
Функция АктивизироватьПоURI(URI) Экспорт
	РезультатПолучения = ПолучитьОбъектПоURI(URI);
	Если ЗначениеЗаполнено(РезультатПолучения.КодОшибки) Тогда
		Возврат НовыйРезультатАктивации(
			Ложь,
			Неопределено,
			РезультатПолучения.КодОшибки,
			РезультатПолучения.Ошибка);
	КонецЕсли;
	
	Попытка
		РезультатПолучения.Объект.Активизировать();
	Исключение
		Мсп_Ошибки.СбойВыполнения("Не удалось активизировать объект интерфейса", ИнформацияОбОшибке());
	КонецПопытки;
	
	Возврат НовыйРезультатАктивации(Истина, ОписаниеОбъекта(РезультатПолучения.Объект));
КонецФункции

// Закрывает объект интерфейса по URI.
//
// Параметры:
//  URI - Строка - URI объекта.
//
// Возвращаемое значение:
//  Структура - Результат закрытия:
//   * Успех - Булево - Признак успешного закрытия.
//   * Описание - Структура - Описание объекта.
//   * КодОшибки - Строка - Код ошибки.
//   * Ошибка - Строка - Описание ошибки.
Функция ЗакрытьПоURI(URI) Экспорт
	Если Мсп_URIКлиент.ЭтоURIЭлементаФормы(URI) Тогда
		Мсп_Ошибки.ДоступЗапрещен("control uri is not closable");
	КонецЕсли;

	Если Мсп_URIКлиент.ЭтоURIОкна(URI) Тогда
		РезультатОкна = Мсп_ОкнаКлиент.ОкноПоURI(URI);
		Если ЗначениеЗаполнено(РезультатОкна.КодОшибки) Тогда
			Возврат НовыйРезультатЗакрытия(
				Ложь,
				Неопределено,
				РезультатОкна.КодОшибки,
				РезультатОкна.Ошибка);
		КонецЕсли;

		Попытка
			РезультатОкна.Окно.Закрыть();
		Исключение
			Мсп_Ошибки.СбойВыполнения("Не удалось закрыть окно", ИнформацияОбОшибке());
		КонецПопытки;

		Возврат НовыйРезультатЗакрытия(Истина, ОписаниеОбъекта(РезультатОкна.Окно));
	КонецЕсли;

	Если Не Мсп_URIКлиент.ЭтоURIФормы(URI) Тогда
		Мсп_Ошибки.НекорректныеПараметры("unsupported close uri");
	КонецЕсли;

	РезультатФормы = ФормаПоURI(URI);
	Если ЗначениеЗаполнено(РезультатФормы.КодОшибки) Тогда
		Возврат НовыйРезультатЗакрытия(
			Ложь,
			Неопределено,
			РезультатФормы.КодОшибки,
			РезультатФормы.Ошибка);
	КонецЕсли;

	Окно = ПолучитьРодительскоеОкно(РезультатФормы.Объект);
	Если Окно = Неопределено Тогда
		Мсп_Ошибки.НеНайдено("parent window not found");
	КонецЕсли;

	Попытка
		Окно.Закрыть();
	Исключение
		Мсп_Ошибки.СбойВыполнения("Не удалось закрыть форму", ИнформацияОбОшибке());
	КонецПопытки;

	Возврат НовыйРезультатЗакрытия(Истина, ОписаниеОбъекта(РезультатФормы.Объект));
КонецФункции

// Открывает форму через команду активного окна.
//
// Параметры:
//  НавигационнаяСсылка - Строка - Навигационная ссылка команды.
//
// Возвращаемое значение:
//  Структура - Результат открытия:
//   * Успех - Булево - Признак успешного открытия.
//   * Target - Строка - Исходная команда.
//   * WindowURI - Строка - URI активного окна после открытия.
//   * FormURI - Строка - URI открытой формы.
//   * КодОшибки - Строка - Код ошибки.
//   * Ошибка - Строка - Описание ошибки.
Функция ОткрытьФормуПоКоманде(НавигационнаяСсылка) Экспорт
	Если Не ЗначениеЗаполнено(НавигационнаяСсылка) Тогда
		Мсп_Ошибки.НекорректныеПараметры("target is required");
	КонецЕсли;

	РезультатАктивногоОкна = Мсп_ОкнаКлиент.АктивноеОкноПриложения();
	Если ЗначениеЗаполнено(РезультатАктивногоОкна.КодОшибки) Тогда
		Возврат НовыйРезультатОткрытия(
			Ложь,
			НавигационнаяСсылка,
			"",
			"",
			РезультатАктивногоОкна.КодОшибки,
			РезультатАктивногоОкна.Ошибка);
	КонецЕсли;

	РезультатФормДо = ПолучитьСписокФорм();
	Если ЗначениеЗаполнено(РезультатФормДо.КодОшибки) Тогда
		Возврат НовыйРезультатОткрытия(
			Ложь,
			НавигационнаяСсылка,
			"",
			"",
			РезультатФормДо.КодОшибки,
			РезультатФормДо.Ошибка);
	КонецЕсли;

	Попытка
		РезультатАктивногоОкна.Окно.ВыполнитьКоманду(НавигационнаяСсылка);
	Исключение
		Мсп_Ошибки.СбойВыполнения("Не удалось открыть форму по команде", ИнформацияОбОшибке());
	КонецПопытки;

	РезультатОкнаПосле = Мсп_ОкнаКлиент.АктивноеОкноПриложения();
	Если ЗначениеЗаполнено(РезультатОкнаПосле.КодОшибки) Тогда
		Возврат НовыйРезультатОткрытия(
			Ложь,
			НавигационнаяСсылка,
			"",
			"",
			РезультатОкнаПосле.КодОшибки,
			РезультатОкнаПосле.Ошибка);
	КонецЕсли;
	РезультатФормПосле = ПолучитьСписокФорм();
	Если ЗначениеЗаполнено(РезультатФормПосле.КодОшибки) Тогда
		Возврат НовыйРезультатОткрытия(
			Ложь,
			НавигационнаяСсылка,
			"",
			"",
			РезультатФормПосле.КодОшибки,
			РезультатФормПосле.Ошибка);
	КонецЕсли;

	Возврат НовыйРезультатОткрытия(
		Истина,
		НавигационнаяСсылка,
		?(РезультатОкнаПосле.Окно = Неопределено, "", Мсп_ОкнаКлиент.URIОкна(РезультатОкнаПосле.Окно)),
		URIНовойФормы(РезультатФормДо.Формы, РезультатФормПосле.Формы));
КонецФункции

// Нажимает на объект интерфейса по URI.
//
// Параметры:
//  URI - Строка - URI объекта.
//
// Возвращаемое значение:
//  Структура - Результат действия:
//   * Успех - Булево - Признак успешного выполнения.
//   * Данные - Структура - Данные действия.
//   * КодОшибки - Строка - Код ошибки.
//   * Ошибка - Строка - Описание ошибки.
Функция НажатьПоURI(URI) Экспорт
	Подготовка = ПодготовитьДействиеПоURI(URI, "button", "object is not clickable");
	Если ЗначениеЗаполнено(Подготовка.КодОшибки) Тогда
		Возврат НовыйРезультатДействия(Ложь, Неопределено, Подготовка.КодОшибки, Подготовка.Ошибка);
	КонецЕсли;

	Попытка
		Подготовка.Объект.Нажать();
	Исключение
		Мсп_Ошибки.СбойВыполнения("Не удалось нажать на элемент интерфейса", ИнформацияОбОшибке());
	КонецПопытки;

	Возврат ЗавершитьДействие(Подготовка.Объект, Подготовка.КонтекстДо);
КонецФункции

// Вводит текст в поле по URI.
//
// Параметры:
//  URI - Строка - URI поля.
//  Текст - Строка - Вводимый текст.
//
// Возвращаемое значение:
//  Структура - Результат действия:
//   * Успех - Булево - Признак успешного выполнения.
//   * Данные - Структура - Данные действия.
//   * КодОшибки - Строка - Код ошибки.
//   * Ошибка - Строка - Описание ошибки.
Функция ВвестиТекстПоURI(URI, Текст) Экспорт
	Подготовка = ПодготовитьДействиеПоURI(URI, "field", "object is not input field", Истина);
	Если ЗначениеЗаполнено(Подготовка.КодОшибки) Тогда
		Возврат НовыйРезультатДействия(Ложь, Неопределено, Подготовка.КодОшибки, Подготовка.Ошибка);
	КонецЕсли;

	Попытка
		Подготовка.Объект.ВвестиТекст(Текст);
	Исключение
		Мсп_Ошибки.СбойВыполнения("Не удалось ввести текст в поле", ИнформацияОбОшибке());
	КонецПопытки;

	Возврат ЗавершитьДействие(
		Подготовка.Объект,
		Подготовка.КонтекстДо,
		ТекущееЗначениеПоля(Подготовка.Объект));
КонецФункции

// Выполняет выбор значения поля по URI.
//
// Параметры:
//  URI - Строка - URI поля.
//  ЗначениеВыбора - Строка, Число - Представление выбираемого значения списка
//                                  или индекс строки списка выбора.
//
// Возвращаемое значение:
//  Структура - Результат действия:
//   * Успех - Булево - Признак успешного выполнения.
//   * Данные - Структура - Данные действия.
//   * КодОшибки - Строка - Код ошибки.
//   * Ошибка - Строка - Описание ошибки.
Функция ВыбратьПоURI(URI, ЗначениеВыбора) Экспорт
	Подготовка = ПодготовитьДействиеПоURI(URI, "field", "object is not selectable field", Истина);
	Если ЗначениеЗаполнено(Подготовка.КодОшибки) Тогда
		Возврат НовыйРезультатДействия(Ложь, Неопределено, Подготовка.КодОшибки, Подготовка.Ошибка);
	КонецЕсли;
	
	Форма = ПолучитьРодительскуюФорму(Подготовка.Объект);
	Если Форма = Неопределено Тогда
		Мсп_Ошибки.НеНайдено("parent form not found");
	КонецЕсли;
	
	Попытка
		Подготовка.Объект.Активизировать();
	Исключение
		Мсп_Ошибки.СбойВыполнения("Не удалось активизировать поле формы", ИнформацияОбОшибке());
	КонецПопытки;
	
	Попытка
		Подготовка.Объект.ОткрытьВыпадающийСписок();
	Исключение
		Мсп_ЛогированиеКлиент.Отладка("OpenDropdown skipped: %1", ОписаниеОшибки());
	КонецПопытки;
	
	Попытка
		Подготовка.Объект.ВыполнитьВыборИзСпискаВыбора(ЗначениеВыбора);
	Исключение
		Попытка
			Форма.ВыполнитьВыборИзСписка(ЗначениеВыбора);
		Исключение
			Мсп_Ошибки.СбойВыполнения("Не удалось выбрать из списка", ИнформацияОбОшибке());
		КонецПопытки;
	КонецПопытки;
	
	РезультатДействия = ЗавершитьДействие(
		Подготовка.Объект,
		Подготовка.КонтекстДо,
		ТекущееЗначениеПоля(Подготовка.Объект),
		ЗначениеВыбора);
	Если ЗначениеЗаполнено(РезультатДействия.КодОшибки) Тогда
		Возврат РезультатДействия;
	КонецЕсли;
	
	Возврат РезультатДействия;
КонецФункции

// Возвращает текущее значение элемента управления по URI.
//
// Параметры:
//  URI - Строка - URI элемента управления (control://).
//
// Возвращаемое значение:
//  Структура - Результат:
//   * Значение - Произвольный - Текущее значение элемента.
//   * Тип - Строка - Тип значения (string, number, date, boolean, ref).
//   * КодОшибки - Строка - Код ошибки.
//   * Ошибка - Строка - Описание ошибки.
Функция ПолучитьЗначениеПоURI(URI) Экспорт
	РезультатПолучения = ПолучитьОбъектПоURI(URI);
	Если ЗначениеЗаполнено(РезультатПолучения.КодОшибки) Тогда
		Возврат НовыйРезультатЗначения(Неопределено, "", РезультатПолучения.КодОшибки, РезультатПолучения.Ошибка);
	КонецЕсли;

	Если Не Мсп_URIКлиент.ЭтоURIЭлементаФормы(URI) Тогда
		Мсп_Ошибки.НекорректныеПараметры("only control:// uri is supported");
	КонецЕсли;

	Объект = РезультатПолучения.Объект;
	Попытка
		Значение = Объект.ПолучитьЗначение();
	Исключение
		Попытка
			Значение = ТекущееЗначениеПоля(Объект);
		Исключение
			Мсп_Ошибки.СбойВыполнения("Не удалось получить значение поля", ИнформацияОбОшибке());
		КонецПопытки;
	КонецПопытки;

	Возврат НовыйРезультатЗначения(Значение, ТипЗначенияСтрокой(Значение));
КонецФункции

// Возвращает строки таблицы формы по URI.
//
// Параметры:
//  URI - Строка - URI таблицы (control://).
//  Лимит - Число - Максимальное количество строк.
//  Смещение - Число - Смещение.
//
// Возвращаемое значение:
//  Структура - Результат:
//   * Строки - Массив - Строки таблицы.
//   * КодОшибки - Строка - Код ошибки.
//   * Ошибка - Строка - Описание ошибки.
Функция ПолучитьСтрокиТаблицыПоURI(URI, Лимит = 100, Смещение = 0) Экспорт
	РезультатПолучения = ПолучитьОбъектПоURI(URI);
	Если ЗначениеЗаполнено(РезультатПолучения.КодОшибки) Тогда
		Возврат НовыйРезультатСтрокТаблицы(Новый Массив, РезультатПолучения.КодОшибки, РезультатПолучения.Ошибка);
	КонецЕсли;

	Если ТипОбъектаИнтерфейса(РезультатПолучения.Объект) <> "table" Тогда
		Мсп_Ошибки.ДоступЗапрещен("object is not a table");
	КонецЕсли;

	Таблица = РезультатПолучения.Объект;
	Строки = Новый Массив;

	Попытка
		КоличествоСтрок = Таблица.КоличествоСтрок();
	Исключение
		Мсп_Ошибки.СбойВыполнения("Не удалось получить количество строк таблицы", ИнформацияОбОшибке());
	КонецПопытки;

	КонецИндекс = Мин(Смещение + Лимит, КоличествоСтрок);
	Для Индекс = Смещение По КонецИндекс - 1 Цикл
		Попытка
			СтрокаТаблицы = Таблица.ПолучитьСтроку(Индекс);
			Ячейки = Новый Структура;
			Для Каждого Колонка Из СтрокаТаблицы.ПолучитьКолонки() Цикл
				Попытка
					Ячейки.Вставить(Колонка.Имя, СтрокаТаблицы.ПолучитьЗначение(Колонка.Имя));
				Исключение
				КонецПопытки;
			КонецЦикла;
			Строки.Добавить(Новый Структура("index,cells", Индекс, Ячейки));
		Исключение
		КонецПопытки;
	КонецЦикла;

	Возврат НовыйРезультатСтрокТаблицы(Строки);
КонецФункции

// Возвращает значение ячейки таблицы по URI, индексу строки и имени колонки.
//
// Параметры:
//  URI - Строка - URI таблицы (control://).
//  ИндексСтроки - Число - Индекс строки, 0-based.
//  ИмяКолонки - Строка - Имя колонки.
//
// Возвращаемое значение:
//  Структура - Результат значения.
Функция ПолучитьЗначениеЯчейкиПоURI(URI, ИндексСтроки, ИмяКолонки) Экспорт
	РезультатПолучения = ПолучитьОбъектПоURI(URI);
	Если ЗначениеЗаполнено(РезультатПолучения.КодОшибки) Тогда
		Возврат НовыйРезультатЗначения(Неопределено, "", РезультатПолучения.КодОшибки, РезультатПолучения.Ошибка);
	КонецЕсли;

	Если ТипОбъектаИнтерфейса(РезультатПолучения.Объект) <> "table" Тогда
		Мсп_Ошибки.ДоступЗапрещен("object is not a table");
	КонецЕсли;

	Попытка
		СтрокаТаблицы = РезультатПолучения.Объект.ПолучитьСтроку(ИндексСтроки);
		Значение = СтрокаТаблицы.ПолучитьЗначение(ИмяКолонки);
	Исключение
		Мсп_Ошибки.СбойВыполнения("Не удалось получить значение ячейки таблицы", ИнформацияОбОшибке());
	КонецПопытки;

	Возврат НовыйРезультатЗначения(Значение, ТипЗначенияСтрокой(Значение));
КонецФункции

// Выбирает строку таблицы по индексу или фильтру.
//
// Параметры:
//  URI - Строка - URI таблицы (control://).
//  ИндексСтроки - Число - Индекс строки (используется если ИспользоватьИндекс = Истина).
//  ИспользоватьИндекс - Булево - Признак выбора по индексу.
//  Фильтр - Структура, Неопределено - Фильтр по значениям колонок.
//
// Возвращаемое значение:
//  Структура - Результат:
//   * Индекс - Число - Индекс выбранной строки.
//   * URI - Строка - URI таблицы.
//   * КодОшибки - Строка - Код ошибки.
//   * Ошибка - Строка - Описание ошибки.
Функция ВыбратьСтрокуТаблицыПоURI(URI, ИндексСтроки, ИспользоватьИндекс, Фильтр) Экспорт
	РезультатПолучения = ПолучитьОбъектПоURI(URI);
	Если ЗначениеЗаполнено(РезультатПолучения.КодОшибки) Тогда
		Возврат НовыйРезультатВыбораСтроки(-1, "", РезультатПолучения.КодОшибки, РезультатПолучения.Ошибка);
	КонецЕсли;

	Если ТипОбъектаИнтерфейса(РезультатПолучения.Объект) <> "table" Тогда
		Мсп_Ошибки.ДоступЗапрещен("object is not a table");
	КонецЕсли;

	Таблица = РезультатПолучения.Объект;

	Если Не ИспользоватьИндекс И Фильтр <> Неопределено Тогда
		// Поиск строки по фильтру
		Попытка
			КоличествоСтрок = Таблица.КоличествоСтрок();
		Исключение
			Мсп_Ошибки.СбойВыполнения("Не удалось получить количество строк таблицы", ИнформацияОбОшибке());
		КонецПопытки;

		НайденныйИндекс = -1;
		Для Индекс = 0 По КоличествоСтрок - 1 Цикл
			Попытка
				СтрокаТаблицы = Таблица.ПолучитьСтроку(Индекс);
				Совпадает = Истина;
				Для Каждого КолонкаФильтра Из Фильтр Цикл
					ЗначениеЯчейки = СтрокаТаблицы.ПолучитьЗначение(КолонкаФильтра.Ключ);
					Если Строка(ЗначениеЯчейки) <> Строка(КолонкаФильтра.Значение) Тогда
						Совпадает = Ложь;
						Прервать;
					КонецЕсли;
				КонецЦикла;
				Если Совпадает Тогда
					НайденныйИндекс = Индекс;
					Прервать;
				КонецЕсли;
			Исключение
			КонецПопытки;
		КонецЦикла;

		Если НайденныйИндекс = -1 Тогда
			Мсп_Ошибки.НеНайдено("no row matches filter");
		КонецЕсли;
		ИндексСтроки = НайденныйИндекс;
	КонецЕсли;

	Попытка
		Таблица.ВыбратьСтроку(ИндексСтроки);
	Исключение
		Мсп_Ошибки.СбойВыполнения("Не удалось выбрать строку таблицы", ИнформацияОбОшибке());
	КонецПопытки;

	Возврат НовыйРезультатВыбораСтроки(ИндексСтроки, URI);
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ПолучитьОбъектПоURI(URI)
	Если Мсп_URIКлиент.ЭтоURIОкна(URI) Тогда
		РезультатОкна = Мсп_ОкнаКлиент.ОкноПоURI(URI);
		Возврат НовыйРезультатПолученияОбъекта(
			РезультатОкна.Окно,
			РезультатОкна.КодОшибки,
			РезультатОкна.Ошибка);
	КонецЕсли;

	Если Мсп_URIКлиент.ЭтоURIФормы(URI) Тогда
		Возврат ФормаПоURI(URI);
	КонецЕсли;

	Если Мсп_URIКлиент.ЭтоURIЭлементаФормы(URI) Тогда
		Возврат ПолучитьЭлементПоURI(URI);
	КонецЕсли;

	Мсп_Ошибки.НекорректныеПараметры("unsupported object uri");
КонецФункции

Функция ПолучитьСписокФорм()
	ТестКлиент = Мсп_УправлениеТестКлиентом.ПолучитьТестКлиент();
	Если ТестКлиент = Неопределено Тогда
		Мсп_Ошибки.НеГотово("test client not connected");
	КонецЕсли;

	Попытка
		НайденныеФормы = ТестКлиент.НайтиОбъекты(Тип("ТестируемаяФорма"));
	Исключение
		Мсп_Ошибки.НеГотово(ОписаниеОшибки());
	КонецПопытки;
	Если НайденныеФормы = Неопределено Тогда
		Возврат НовыйРезультатСпискаФорм(Новый Массив);
	КонецЕсли;

	Формы = Новый Массив;
	Для Каждого Форма Из НайденныеФормы Цикл
		Формы.Добавить(Форма);
	КонецЦикла;

	Возврат НовыйРезультатСпискаФорм(Формы);
КонецФункции

Функция ПолучитьЭлементПоURI(URI)
	Сегменты = Мсп_URIКлиент.СегментыЭлементаФормы(URI);
	Если Сегменты = Неопределено Тогда
		Мсп_Ошибки.НекорректныеПараметры("control uri is invalid");
	КонецЕсли;

	URIФормыЭлемента = "form://" + Сегменты.СегментФормы;
	РезультатФормы = ФормаПоURI(URIФормыЭлемента);
	Если ЗначениеЗаполнено(РезультатФормы.КодОшибки) Тогда
		Возврат РезультатФормы;
	КонецЕсли;
	
	ИмяКонтрола = Мсп_URIКлиент.ДекодироватьURL(Сегменты.СегментЭлемента);
	РезультатПоиска = НайтиПодчиненныеОбъекты(РезультатФормы.Объект, Неопределено, , ИмяКонтрола, 0);
	Если ЗначениеЗаполнено(РезультатПоиска.КодОшибки) Тогда
		Возврат НовыйРезультатПолученияОбъекта(
			Неопределено,
			РезультатПоиска.КодОшибки,
			РезультатПоиска.Ошибка);
	КонецЕсли;

	НайденныеЭлементы = Новый Массив;
	Для Каждого Элемент Из РезультатПоиска.Объекты Цикл
		Если URIЭлементаФормы(РезультатФормы.Объект, Элемент) = URI Тогда
			НайденныеЭлементы.Добавить(Элемент);
		КонецЕсли;
	КонецЦикла;

	Если НайденныеЭлементы.Количество() = 0 Тогда
		Мсп_Ошибки.НеНайдено("control not found");
	КонецЕсли;
	Если НайденныеЭлементы.Количество() > 1 Тогда
		Мсп_Ошибки.НеоднозначныйРезультат("control uri is ambiguous");
	КонецЕсли;

	Возврат НовыйРезультатПолученияОбъекта(НайденныеЭлементы[0]);
КонецФункции

Функция ПолучитьКореньПоиска(URIКорня)
	Если Не ЗначениеЗаполнено(URIКорня) Тогда
		ТестКлиент = Мсп_УправлениеТестКлиентом.ПолучитьТестКлиент();
		Если ТестКлиент = Неопределено Тогда
			Мсп_Ошибки.НеГотово("test client not connected");
		КонецЕсли;
		Возврат НовыйРезультатПолученияОбъекта(ТестКлиент);
	КонецЕсли;

	Возврат ПолучитьОбъектПоURI(URIКорня);
КонецФункции

Функция НайтиПодчиненныеОбъекты(Корень, ТипПлатформы, Заголовок, Имя, Таймаут)
	Попытка
		НайденныеОбъекты = Корень.НайтиОбъекты(ТипПлатформы, Заголовок, Имя, Таймаут);
	Исключение
		Если ТипОбъектаИнтерфейса(Корень) = "window" Тогда
			Попытка
				НайденныеОбъекты = Корень.НайтиОбъекты(ТипПлатформы, Имя, Таймаут);
			Исключение
				Мсп_Ошибки.СбойВыполнения("Не удалось выполнить поиск подчиненных объектов окна", ИнформацияОбОшибке());
			КонецПопытки;
			Возврат НовыйРезультатПоиска(ОтфильтрованныеОбъектыПоЗаголовку(НайденныеОбъекты, Заголовок));
		КонецЕсли;
		
		Мсп_Ошибки.СбойВыполнения("Не удалось выполнить поиск подчиненных объектов", ИнформацияОбОшибке());
	КонецПопытки;
	
	Если НайденныеОбъекты = Неопределено Тогда
		Возврат НовыйРезультатПоиска(Новый Массив);
	КонецЕсли;
	
	Возврат НовыйРезультатПоиска(ОтфильтрованныеОбъектыПоЗаголовку(МассивИзКоллекции(НайденныеОбъекты), Заголовок));
КонецФункции

Функция СнимкиПодчиненныхОбъектов(Объект, ИмяФормы)
	Снимки = Новый Массив;
	Для Каждого ПодчиненныйОбъект Из ПодчиненныеОбъектыИнтерфейса(Объект) Цикл
		Снимок = СнимокОбъектаИнтерфейса(ПодчиненныйОбъект, ИмяФормы);
		Если Снимок <> Неопределено Тогда
			Снимки.Добавить(Снимок);
		КонецЕсли;
	КонецЦикла;

	Возврат Снимки;
КонецФункции

Функция СнимокОбъектаИнтерфейса(Объект, ИмяФормы)
	ТипОбъекта = ТипОбъектаИнтерфейса(Объект);
	Если Не ЗначениеЗаполнено(ТипОбъекта) Тогда
		Возврат Неопределено;
	КонецЕсли;

	ИмяФормыОбъекта = ?(ТипОбъекта = "form", ИмяФормыЗначение(Объект), ИмяФормы);
	ИмяОбъекта = ИмяОбъектаСнимка(Объект, ТипОбъекта);
	Снимок = Новый Структура(
		"type,title,name,children",
		ТипОбъекта,
		ЗаголовокОбъектаСнимка(Объект, ТипОбъекта),
		ИмяОбъекта,
		СнимкиПодчиненныхОбъектов(Объект, ИмяФормыОбъекта));

	URI = URIОбъектаСнимка(Объект, ТипОбъекта, ИмяФормыОбъекта);
	Если ЗначениеЗаполнено(URI) Тогда
		Снимок.Вставить("uri", URI);
	КонецЕсли;

	Возврат Снимок;
КонецФункции

Функция ПодчиненныеОбъектыИнтерфейса(Объект)
	Попытка
		ПодчиненныеОбъекты = Объект.ПолучитьПодчиненныеОбъекты();
	Исключение
		ПодчиненныеОбъекты = Мсп_Коллекции.Свойство(Объект, "ПодчиненныеОбъекты", Новый Массив);
	КонецПопытки;

	Если ПодчиненныеОбъекты = Неопределено Тогда
		Возврат Новый Массив;
	КонецЕсли;
	Если ТипЗнч(ПодчиненныеОбъекты) = Тип("Массив") Тогда
		Возврат ПодчиненныеОбъекты;
	КонецЕсли;

	Попытка
		Возврат МассивИзКоллекции(ПодчиненныеОбъекты);
	Исключение
	КонецПопытки;

	Возврат Новый Массив;
КонецФункции

Функция ОтфильтрованныеОбъектыПоЗаголовку(Объекты, Заголовок)
	Если Не ЗначениеЗаполнено(Заголовок) Тогда
		Возврат МассивИзКоллекции(Объекты);
	КонецЕсли;

	ОтфильтрованныеОбъекты = Новый Массив;
	Для Каждого Объект Из Объекты Цикл
		Если СоответствуетМаске(ЗаголовокЭлементаИлиОкна(Объект), Заголовок) Тогда
			ОтфильтрованныеОбъекты.Добавить(Объект);
		КонецЕсли;
	КонецЦикла;

	Возврат ОтфильтрованныеОбъекты;
КонецФункции

Функция МассивИзКоллекции(Коллекция)
	Результат = Новый Массив;
	Для Каждого Элемент Из Коллекция Цикл
		Результат.Добавить(Элемент);
	КонецЦикла;
	Возврат Результат;
КонецФункции

Функция ПолучитьРодительскуюФорму(Объект)
