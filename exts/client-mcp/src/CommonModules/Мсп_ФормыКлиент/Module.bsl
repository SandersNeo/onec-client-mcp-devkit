	КонецЕсли;
	Соответствие = СоответствиеСтрокТипамПлатформы();
	Возврат Соответствие.Получить(Тип);
КонецФункции

Функция ТипОбъектаИнтерфейса(Объект)
	ТипЗначения = ТипЗнч(Объект);
	Соответствие = СоответствиеТиповПлатформыСтрокам();
	Результат = Соответствие.Получить(ТипЗначения);
	Если Результат <> Неопределено Тогда
		Возврат Результат;
	КонецЕсли;

	Возврат Мсп_Коллекции.Свойство(Объект, "ТипИнтерфейса", "");
КонецФункции

Функция СоответствиеСтрокТипамПлатформы()
	Соответствие = Новый Соответствие;
	Соответствие.Вставить("window", Тип("ТестируемоеОкноКлиентскогоПриложения"));
	Соответствие.Вставить("form", Тип("ТестируемаяФорма"));
	Соответствие.Вставить("group", Тип("ТестируемаяГруппаФормы"));
	Соответствие.Вставить("button", Тип("ТестируемаяКнопкаФормы"));
	Соответствие.Вставить("table", Тип("ТестируемаяТаблицаФормы"));
	Соответствие.Вставить("field", Тип("ТестируемоеПолеФормы"));
	Соответствие.Вставить("decoration", Тип("ТестируемаяДекорацияФормы"));
	Возврат Соответствие;
КонецФункции

Функция СоответствиеТиповПлатформыСтрокам()
	Соответствие = Новый Соответствие;
	Соответствие.Вставить(Тип("ТестируемоеОкноКлиентскогоПриложения"), "window");
	Соответствие.Вставить(Тип("ТестируемаяФорма"), "form");
	Соответствие.Вставить(Тип("ТестируемаяГруппаФормы"), "group");
	Соответствие.Вставить(Тип("ТестируемаяКнопкаФормы"), "button");
	Соответствие.Вставить(Тип("ТестируемаяТаблицаФормы"), "table");
	Соответствие.Вставить(Тип("ТестируемоеПолеФормы"), "field");
	Соответствие.Вставить(Тип("ТестируемаяДекорацияФормы"), "decoration");
	Возврат Соответствие;
КонецФункции

