Функция СоответствуетМаске(Текст, Маска)
	Если Не ЗначениеЗаполнено(Маска) Тогда
		Возврат Истина;
	КонецЕсли;

	ПозицияТекста = 1;
	ПозицияМаски = 1;
	ПозицияЗвезды = 0;
	СовпадениеПослеЗвезды = 0;

	Пока ПозицияТекста <= СтрДлина(Текст) Цикл
		Если ПозицияМаски <= СтрДлина(Маска)
			И (Сред(Маска, ПозицияМаски, 1) = "?"
			ИЛИ Сред(Маска, ПозицияМаски, 1) = Сред(Текст, ПозицияТекста, 1)) Тогда
			ПозицияТекста = ПозицияТекста + 1;
			ПозицияМаски = ПозицияМаски + 1;
		ИначеЕсли ПозицияМаски <= СтрДлина(Маска)
			И Сред(Маска, ПозицияМаски, 1) = "*" Тогда
			ПозицияЗвезды = ПозицияМаски;
			СовпадениеПослеЗвезды = ПозицияТекста;
			ПозицияМаски = ПозицияМаски + 1;
		ИначеЕсли ПозицияЗвезды > 0 Тогда
			ПозицияМаски = ПозицияЗвезды + 1;
			СовпадениеПослеЗвезды = СовпадениеПослеЗвезды + 1;
			ПозицияТекста = СовпадениеПослеЗвезды;
		Иначе
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;

	Пока ПозицияМаски <= СтрДлина(Маска)
		И Сред(Маска, ПозицияМаски, 1) = "*" Цикл
		ПозицияМаски = ПозицияМаски + 1;
	КонецЦикла;

	Возврат ПозицияМаски > СтрДлина(Маска);
КонецФункции

Функция URIНовойФормы(ФормыДо, ФормыПосле)
	ОстаткиURI = Новый Соответствие;
	Для Каждого Форма Из ФормыДо Цикл
		URI = URIФормы(Форма);
		Если Не ЗначениеЗаполнено(URI) Тогда
			Продолжить;
		КонецЕсли;

		ОстаткиURI.Вставить(URI, Мсп_Коллекции.ПолучитьСвойство(ОстаткиURI, URI, 0) + 1);
	КонецЦикла;

	НовыеURI = Новый Массив;
	Для Каждого Форма Из ФормыПосле Цикл
		URI = URIФормы(Форма);
		Если Не ЗначениеЗаполнено(URI) Тогда
			Продолжить;
		КонецЕсли;

		КоличествоОстатков = Мсп_Коллекции.ПолучитьСвойство(ОстаткиURI, URI, 0);
		Если КоличествоОстатков = 0 Тогда
			НовыеURI.Добавить(URI);
		Иначе
			ОстаткиURI.Вставить(URI, КоличествоОстатков - 1);
		КонецЕсли;
	КонецЦикла;

	Если НовыеURI.Количество() = 1 Тогда
		Возврат НовыеURI[0];
	КонецЕсли;

	Возврат "";
КонецФункции

Функция ЗаголовокОбъектаСнимка(Объект, ТипОбъекта)
