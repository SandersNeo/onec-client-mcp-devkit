Функция URIАктивнойФормы(Окно)
	Если Окно = Неопределено Тогда
		Возврат "";
	КонецЕсли;

	ФормыОкна = Новый Массив;
	Для Каждого ПодчиненныйОбъект Из ПодчиненныеОбъектыИнтерфейса(Окно) Цикл
		Если ТипОбъектаИнтерфейса(ПодчиненныйОбъект) = "form" Тогда
			ФормыОкна.Добавить(ПодчиненныйОбъект);
		КонецЕсли;
	КонецЦикла;

	Если ФормыОкна.Количество() = 1 Тогда
		Возврат URIФормы(ФормыОкна[0]);
	КонецЕсли;

	Возврат "";
КонецФункции

Функция URIОкнаДляРезультата(Окно)
	Если Окно = Неопределено Тогда
		Возврат Мсп_URIКлиент.URIАктивногоОкна();
	КонецЕсли;

	URI = Мсп_ОкнаКлиент.URIОкна(Окно);
	Если ЗначениеЗаполнено(URI) Тогда
		Возврат URI;
	КонецЕсли;

	Возврат Мсп_URIКлиент.URIАктивногоОкна();
КонецФункции

Функция ЭтоНовоеАктивноеОкно(ОкнаДо, ОкнаПосле, АктивноеОкноПосле)
	Если АктивноеОкноПосле = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;

	КлючАктивногоОкна = КлючОкна(АктивноеОкноПосле);
	Возврат КоличествоОконПоКлючу(ОкнаПосле, КлючАктивногоОкна) > КоличествоОконПоКлючу(ОкнаДо, КлючАктивногоОкна);
КонецФункции

Функция КоличествоОконПоКлючу(Окна, Ключ)
	Количество = 0;
	Для Каждого Окно Из Окна Цикл
		Если КлючОкна(Окно) = Ключ Тогда
			Количество = Количество + 1;
		КонецЕсли;
	КонецЦикла;

	Возврат Количество;
КонецФункции

Функция КлючОкна(Окно)
	URI = Мсп_ОкнаКлиент.URIОкна(Окно);
	Если ЗначениеЗаполнено(URI) Тогда
		Возврат "uri:" + URI;
	КонецЕсли;

	Возврат "title:" + ЗаголовокОкна(Окно);
КонецФункции

Функция ТипПлатформыПоСтроке(Тип)
