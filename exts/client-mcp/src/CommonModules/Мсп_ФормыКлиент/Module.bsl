		Если ТипОбъектаИнтерфейса(ТекущийОбъект) = "window" Тогда
			Возврат ТекущийОбъект;
		КонецЕсли;

		Попытка
			ТекущийОбъект = ТекущийОбъект.ПолучитьРодителя();
		Исключение
			Возврат Неопределено;
		КонецПопытки;
	КонецЦикла;

	Возврат Неопределено;
КонецФункции

// Подготавливает действие над объектом по URI: получение, проверка типа, доступности и контекста.
//
// Параметры:
//  URI - Строка - URI объекта.
//  ОжидаемыйТип - Строка - Ожидаемый тип объекта интерфейса ("button", "field" и т.д.).
//  СообщениеОшибкиТипа - Строка - Сообщение при несовпадении типа.
//  ПроверятьТолькоПросмотр - Булево - Проверять ли режим "только просмотр".
//
// Возвращаемое значение:
//  Структура - Результат подготовки:
//   * Объект - Произвольный - Найденный объект интерфейса.
//   * КонтекстДо - Структура - Контекст до действия.
//   * КодОшибки - Строка - Код ошибки.
//   * Ошибка - Строка - Описание ошибки.
Функция ПодготовитьДействиеПоURI(URI, ОжидаемыйТип, СообщениеОшибкиТипа, ПроверятьТолькоПросмотр = Ложь)
	РезультатПолучения = ПолучитьОбъектПоURI(URI);
	Если ЗначениеЗаполнено(РезультатПолучения.КодОшибки) Тогда
		Возврат НовыйРезультатПодготовкиДействия(Неопределено, Неопределено, РезультатПолучения.КодОшибки, РезультатПолучения.Ошибка);
	КонецЕсли;
	
	Если ТипОбъектаИнтерфейса(РезультатПолучения.Объект) <> ОжидаемыйТип Тогда
		Мсп_Ошибки.ДоступЗапрещен(СообщениеОшибкиТипа);
	КонецЕсли;
	
	РезультатПроверки = ПроверитьОбъектДляДействия(РезультатПолучения.Объект, ПроверятьТолькоПросмотр);
	Если ЗначениеЗаполнено(РезультатПроверки.КодОшибки) Тогда
		Возврат НовыйРезультатПодготовкиДействия(Неопределено, Неопределено, РезультатПроверки.КодОшибки, РезультатПроверки.Ошибка);
	КонецЕсли;
	
	КонтекстДо = ПолучитьКонтекстДействия();
	Если ЗначениеЗаполнено(КонтекстДо.КодОшибки) Тогда
		Возврат НовыйРезультатПодготовкиДействия(Неопределено, Неопределено, КонтекстДо.КодОшибки, КонтекстДо.Ошибка);
	КонецЕсли;
	
	Возврат НовыйРезультатПодготовкиДействия(РезультатПолучения.Объект, КонтекстДо);
КонецФункции

Функция НовыйРезультатПодготовкиДействия(Объект, КонтекстДо, КодОшибки = "", Ошибка = "")
	Результат = Новый Структура;
	Результат.Вставить("Объект", Объект);
	Результат.Вставить("КонтекстДо", КонтекстДо);
	Результат.Вставить("КодОшибки", КодОшибки);
	Результат.Вставить("Ошибка", Ошибка);
	Возврат Результат;
КонецФункции

// Завершает действие: собирает данные после действия и формирует результат.
//
// Параметры:
//  Объект - Произвольный - Объект интерфейса.
//  КонтекстДо - Структура - Контекст до действия.
//  Значение - Произвольный - Значение после действия.
//  Индекс - Число - Индекс выбранного значения.
//
// Возвращаемое значение:
//  Структура - см. НовыйРезультатДействия.
Функция ЗавершитьДействие(Объект, КонтекстДо, Значение = Неопределено, Индекс = Неопределено)
	РезультатКонтекста = ДанныеПослеДействия(Объект, КонтекстДо, Значение, Индекс);
	Если ЗначениеЗаполнено(РезультатКонтекста.КодОшибки) Тогда
		Возврат НовыйРезультатДействия(Ложь, Неопределено, РезультатКонтекста.КодОшибки, РезультатКонтекста.Ошибка);
	КонецЕсли;

	Возврат НовыйРезультатДействия(Истина, РезультатКонтекста.Данные);
КонецФункции

Функция ПолучитьКонтекстДействия()
	РезультатОкна = Мсп_ОкнаКлиент.АктивноеОкноПриложения();
	Если ЗначениеЗаполнено(РезультатОкна.КодОшибки) Тогда
		Возврат НовыйРезультатКонтекстаДействия(
			Неопределено,
			"",
			Новый Массив,
			Новый Массив,
			РезультатОкна.КодОшибки,
			РезультатОкна.Ошибка);
	КонецЕсли;

	РезультатСпискаОкон = Мсп_ОкнаКлиент.СписокОконПриложения();
	Если ЗначениеЗаполнено(РезультатСпискаОкон.КодОшибки) Тогда
		Возврат НовыйРезультатКонтекстаДействия(
			Неопределено,
			"",
			Новый Массив,
			Новый Массив,
			РезультатСпискаОкон.КодОшибки,
			РезультатСпискаОкон.Ошибка);
	КонецЕсли;

	РезультатСпискаФорм = ПолучитьСписокФорм();
	Если ЗначениеЗаполнено(РезультатСпискаФорм.КодОшибки) Тогда
		Возврат НовыйРезультатКонтекстаДействия(
			Неопределено,
			"",
			Новый Массив,
			Новый Массив,
			РезультатСпискаФорм.КодОшибки,
			РезультатСпискаФорм.Ошибка);
	КонецЕсли;

	Возврат НовыйРезультатКонтекстаДействия(
		РезультатОкна.Окно,
		URIАктивнойФормы(РезультатОкна.Окно),
		РезультатСпискаОкон.Окна,
		РезультатСпискаФорм.Формы);
КонецФункции

Функция ДанныеПослеДействия(Объект, КонтекстДо, Значение = Неопределено, Индекс = Неопределено)
	РезультатКонтекста = ПолучитьКонтекстДействия();
	Если ЗначениеЗаполнено(РезультатКонтекста.КодОшибки) Тогда
		Возврат НовыйРезультатДействия(Ложь, Неопределено, РезультатКонтекста.КодОшибки, РезультатКонтекста.Ошибка);
	КонецЕсли;

	Описание = ОписаниеОбъекта(Объект);
	Если Описание = Неопределено Тогда
		Мсп_Ошибки.СбойВыполнения("action object is unsupported");
	КонецЕсли;

	Данные = Новый Структура(
		"type,title,name,uri,window_uri,modal_opened",
		Описание.type,
		Описание.title,
		Описание.name,
		Описание.uri,
		URIОкнаДляРезультата(РезультатКонтекста.Окно),
		ЭтоНовоеАктивноеОкно(КонтекстДо.Окна, РезультатКонтекста.Окна, РезультатКонтекста.Окно));

	URIФормыПосле = URIНовойФормы(КонтекстДо.Формы, РезультатКонтекста.Формы);
	Если Не ЗначениеЗаполнено(URIФормыПосле) Тогда
		URIФормыПосле = URIАктивнойФормы(РезультатКонтекста.Окно);
	КонецЕсли;
	Если Не ЗначениеЗаполнено(URIФормыПосле) Тогда
		URIФормыПосле = КонтекстДо.URIФормы;
	КонецЕсли;
	Если ЗначениеЗаполнено(URIФормыПосле) Тогда
		Данные.Вставить("form_uri", URIФормыПосле);
	КонецЕсли;

	Если Значение <> Неопределено Тогда
		Данные.Вставить("value", Значение);
	КонецЕсли;
	Если Индекс <> Неопределено Тогда
		Данные.Вставить("index", Индекс);
	КонецЕсли;

	Возврат НовыйРезультатДействия(Истина, Данные);
КонецФункции

Функция ПроверитьОбъектДляДействия(Объект, ПроверятьТолькоПросмотр = Ложь)
	Если Не ОбъектВиден(Объект) Тогда
		Мсп_Ошибки.ДоступЗапрещен("object is hidden");
	КонецЕсли;
	Если Не ОбъектДоступен(Объект) Тогда
		Мсп_Ошибки.ДоступЗапрещен("object is disabled");
	КонецЕсли;
	Если ПроверятьТолькоПросмотр
		И ОбъектТолькоДляПросмотра(Объект) Тогда
		Мсп_Ошибки.ДоступЗапрещен("object is read only");
	КонецЕсли;

	Возврат НовыйРезультатПроверкиДействия();
КонецФункции

