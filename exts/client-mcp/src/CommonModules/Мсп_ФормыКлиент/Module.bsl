Функция ЗначениеСпискаПоИндексу(Форма, Индекс)
	Попытка
		СписокВыбора = Форма.ПолучитьПредставлениеСпискаВыбора();
	Исключение
		Возврат НовыйРезультатВыбора("", "ACTION_FAILED", ОписаниеОшибки());
	КонецПопытки;

	Если СписокВыбора = Неопределено Тогда
		Возврат НовыйРезультатВыбора("", "ACTION_FAILED", "choice list is empty");
	КонецЕсли;
	Если Индекс < 0
		ИЛИ Индекс >= СписокВыбора.Количество() Тогда
		Возврат НовыйРезультатВыбора("", "ACTION_FAILED", "choice index is out of range");
	КонецЕсли;

	Возврат НовыйРезультатВыбора(СписокВыбора[Индекс]);
КонецФункции

Функция ТипПлатформыПоСтроке(Тип)
	Если Не ЗначениеЗаполнено(Тип) Тогда
		Возврат Неопределено;
	ИначеЕсли Тип = "window" Тогда
		Возврат Тип("ТестируемоеОкноКлиентскогоПриложения");
	ИначеЕсли Тип = "form" Тогда
		Возврат Тип("ТестируемаяФорма");
	ИначеЕсли Тип = "group" Тогда
		Возврат Тип("ТестируемаяГруппаФормы");
	ИначеЕсли Тип = "button" Тогда
		Возврат Тип("ТестируемаяКнопкаФормы");
	ИначеЕсли Тип = "table" Тогда
		Возврат Тип("ТестируемаяТаблицаФормы");
	ИначеЕсли Тип = "field" Тогда
		Возврат Тип("ТестируемоеПолеФормы");
	ИначеЕсли Тип = "decoration" Тогда
		Возврат Тип("ТестируемаяДекорацияФормы");
	КонецЕсли;

	Возврат Неопределено;
КонецФункции

Функция ТипОбъектаИнтерфейса(Объект)
	ТипЗначения = ТипЗнч(Объект);
	Если ТипЗначения = Тип("ТестируемоеОкноКлиентскогоПриложения") Тогда
		Возврат "window";
	ИначеЕсли ТипЗначения = Тип("ТестируемаяФорма") Тогда
		Возврат "form";
	ИначеЕсли ТипЗначения = Тип("ТестируемаяГруппаФормы") Тогда
		Возврат "group";
	ИначеЕсли ТипЗначения = Тип("ТестируемаяКнопкаФормы") Тогда
		Возврат "button";
	ИначеЕсли ТипЗначения = Тип("ТестируемаяТаблицаФормы") Тогда
		Возврат "table";
	ИначеЕсли ТипЗначения = Тип("ТестируемоеПолеФормы") Тогда
		Возврат "field";
	ИначеЕсли ТипЗначения = Тип("ТестируемаяДекорацияФормы") Тогда
		Возврат "decoration";
	КонецЕсли;

	Возврат Мсп_Коллекции.ПолучитьСвойство(Объект, "ТипИнтерфейса", "");
КонецФункции

