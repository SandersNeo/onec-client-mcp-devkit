// Синхронизирует реестр инструментов с компонентой и отправляет уведомление клиентам MCP.
//
// Возвращаемое значение:
//  Булево - Истина.
Асинх Функция СинхронизироватьИнструменты() Экспорт
	Компонента = ЭкземплярСервера();
	Если Компонента = Неопределено Тогда
		Возврат Истина;
	КонецЕсли;

	Попытка
		Ждать Компонента.ОчиститьИнструментыАсинх();
	Исключение
		Мсп_ЛогированиеКлиент.Ошибка(ИнформацияОбОшибке());
		Возврат Истина;
	КонецПопытки;

	Для Каждого Элемент Из Мсп_РеестрКлиент.РеестрИнструментов(Истина) Цикл
		Дескриптор = Элемент.Значение;
		Если Дескриптор.РежимВыполнения = "task" Тогда
			Описание = Мсп_ПротоколКлиент.НовыйОписаниеИнструмента(
				Дескриптор.Имя,
				Дескриптор.Описание,
				Дескриптор.СхемаПараметров,
				"task");
		Иначе
			Описание = Мсп_ПротоколКлиент.НовыйОписаниеИнструмента(
				Дескриптор.Имя,
				Дескриптор.Описание,
				Дескриптор.СхемаПараметров);
		КонецЕсли;
		Попытка
			РезультатРегистрации = Ждать Компонента.ЗарегистрироватьИнструментАсинх(
				Мсп_СериализацияКлиент.Сериализовать(Описание));
			Если РезультатРегистрации.Значение = Ложь Тогда
				Мсп_ЛогированиеКлиент.Важно("Tool register failed name=%1", Дескриптор.Имя);
			КонецЕсли;
		Исключение
			Мсп_ЛогированиеКлиент.Ошибка(ИнформацияОбОшибке());
		КонецПопытки;
	КонецЦикла;

	Ждать УведомитьОбИзмененииИнструментов();
	Возврат Истина;
КонецФункции

// Синхронизирует реестры ресурсов и шаблонов с компонентой и отправляет уведомление клиентам MCP.
//
// Возвращаемое значение:
//  Булево - Истина.
Асинх Функция СинхронизироватьРесурсы() Экспорт
	Компонента = ЭкземплярСервера();
	Если Компонента = Неопределено Тогда
		Возврат Истина;
	КонецЕсли;

	Попытка
		Ждать Компонента.ОчиститьРесурсыАсинх();
		Ждать Компонента.ОчиститьШаблоныРесурсовАсинх();
	Исключение
		Мсп_ЛогированиеКлиент.Ошибка(ИнформацияОбОшибке());
		Возврат Истина;
	КонецПопытки;

	Для Каждого Элемент Из Мсп_РеестрКлиент.РеестрРесурсов(Истина) Цикл
		Дескриптор = Элемент.Значение;
		Описание = Мсп_ПротоколКлиент.НовыйОписаниеРесурса(
			Дескриптор.URI,
			Дескриптор.Имя,
			Дескриптор.Описание,
			Дескриптор.MimeType);
		Попытка
			Ждать Компонента.ЗарегистрироватьРесурсАсинх(Мсп_СериализацияКлиент.Сериализовать(Описание));
		Исключение
			Мсп_ЛогированиеКлиент.Ошибка(ИнформацияОбОшибке());
		КонецПопытки;
	КонецЦикла;

	Для Каждого Элемент Из Мсп_РеестрКлиент.РеестрШаблоновРесурсов(Истина) Цикл
		Дескриптор = Элемент.Значение;
		Описание = Мсп_ПротоколКлиент.НовыйОписаниеШаблонаРесурса(
			Дескриптор.URIШаблон,
			Дескриптор.Имя,
			Дескриптор.Описание,
			Дескриптор.MimeType);
		Попытка
			Ждать Компонента.ЗарегистрироватьШаблонРесурсаАсинх(
				Мсп_СериализацияКлиент.Сериализовать(Описание));
		Исключение
			Мсп_ЛогированиеКлиент.Ошибка(ИнформацияОбОшибке());
		КонецПопытки;
	КонецЦикла;

	Ждать УведомитьОбИзмененииРесурсов();
	Возврат Истина;
КонецФункции

