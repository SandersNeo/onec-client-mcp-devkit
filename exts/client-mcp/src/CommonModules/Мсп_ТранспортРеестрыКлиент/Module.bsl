#Область ПрограммныйИнтерфейс

// Планирует синхронизацию реестра инструментов с компонентой MCP.
Процедура ЗапланироватьСинхронизациюИнструментов() Экспорт
	Если Не ЗапланироватьСинхронизацию("ТребуетсяСинхронизацияИнструментов") Тогда
		Возврат;
	КонецЕсли;
КонецПроцедуры

// Планирует синхронизацию реестров ресурсов с компонентой MCP.
Процедура ЗапланироватьСинхронизациюРесурсов() Экспорт
	Если Не ЗапланироватьСинхронизацию("ТребуетсяСинхронизацияРесурсов") Тогда
		Возврат;
	КонецЕсли;
КонецПроцедуры

// Планирует синхронизацию реестра промптов с компонентой MCP.
Процедура ЗапланироватьСинхронизациюПромптов() Экспорт
	Если Не ЗапланироватьСинхронизацию("ТребуетсяСинхронизацияПромптов") Тогда
		Возврат;
	КонецЕсли;
КонецПроцедуры

// Планирует синхронизацию всех реестров с компонентой MCP.
Процедура ЗапланироватьСинхронизациюРеестров() Экспорт
	ЗапланироватьСинхронизациюИнструментов();
	ЗапланироватьСинхронизациюРесурсов();
	ЗапланироватьСинхронизациюПромптов();
КонецПроцедуры

// Отправляет notifications/tools/list_changed всем подключённым клиентам.
//
// Возвращаемое значение:
//  Булево - Истина.
Асинх Функция УведомитьОбИзмененииИнструментов() Экспорт
	Компонента = ЭкземплярСервера();
	Если Компонента = Неопределено Тогда
		Мсп_ЛогированиеКлиент.Важно("УведомитьОбИзмененииИнструментов ignored: Компонента is undefined");
		Возврат Истина;
	КонецЕсли;

	Попытка
		Ждать Компонента.УведомитьОбИзмененииИнструментовАсинх();
	Исключение
		Мсп_ЛогированиеКлиент.Ошибка(ИнформацияОбОшибке());
	КонецПопытки;

	Возврат Истина;
КонецФункции

