#Область ПрограммныйИнтерфейс

// Отправляет notifications/tools/list_changed всем подключённым клиентам.
//
// Возвращаемое значение:
//  Булево - Истина.
Асинх Функция УведомитьОбИзмененииИнструментов() Экспорт
	Компонента = ЭкземплярСервера();
	Если Компонента = Неопределено Тогда
		Мсп_ЛогированиеКлиент.Важно("УведомитьОбИзмененииИнструментов ignored: Компонента is undefined");
		Возврат Истина;
	КонецЕсли;

	Попытка
		Ждать Компонента.УведомитьОбИзмененииИнструментовАсинх();
	Исключение
		Мсп_ЛогированиеКлиент.Ошибка(ИнформацияОбОшибке());
	КонецПопытки;

	Возврат Истина;
КонецФункции

