// Отправляет notifications/resources/updated подписчикам ресурса.
//
// Параметры:
//  URI - Строка - URI обновлённого ресурса.
Асинх Процедура УведомитьОбОбновленииРесурса(URI) Экспорт
	Компонента = ЭкземплярСервера();
	Если Компонента = Неопределено Тогда
		Мсп_ЛогированиеКлиент.Важно("УведомитьОбОбновленииРесурса ignored: Компонента is undefined");
		Возврат;
	КонецЕсли;

	Попытка
		Ждать Компонента.УведомитьОбОбновленииРесурсаАсинх(URI);
	Исключение
		Мсп_ЛогированиеКлиент.Ошибка(ИнформацияОбОшибке());
	КонецПопытки;
КонецПроцедуры

// Инициализирует реестры сервера и синхронизирует их с компонентой.
//
// Возвращаемое значение:
//  Булево - Истина.
Асинх Функция ИнициализироватьРеестрыСервера() Экспорт
	Мсп_ЛогированиеКлиент.Информация("Server startup: initialize registries");

	Если НЕ ЗначениеЗаполнено(Мсп_СостояниеКлиент.СостояниеСервера().Реестры) Тогда
		Мсп_РеестрКлиент.ИнициализироватьРеестры();
		Мсп_ПровайдерыКлиент.ЗарегистрироватьПровайдеров();
	КонецЕсли;

	Возврат Ждать СинхронизироватьРеестрыСКомпонентой();
КонецФункции

// Синхронизирует все реестры с компонентой.
//
// Возвращаемое значение:
//  Булево - Истина, если синхронизация выполнена.
Асинх Функция СинхронизироватьРеестрыСКомпонентой() Экспорт
	Компонента = ЭкземплярСервера();
	Если Компонента = Неопределено Тогда
		Мсп_ЛогированиеКлиент.Важно("Registry sync skipped: Компонента is undefined");
		Возврат Ложь;
	КонецЕсли;

	Ждать СинхронизироватьИнструменты();
	Ждать СинхронизироватьРесурсы();
	Ждать СинхронизироватьПромпты();

	Возврат Истина;
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ЭкземплярСервера()
	Возврат Мсп_СостояниеКлиент.ЗначениеСостоянияСервера("Компонента", Неопределено);
КонецФункции

#КонецОбласти
