// Отправляет notifications/resources/updated подписчикам ресурса.
//
// Параметры:
//  URI - Строка - URI обновлённого ресурса.
//
// Возвращаемое значение:
//  Булево - Истина.
Асинх Функция УведомитьОбОбновленииРесурса(URI) Экспорт
	Компонента = ЭкземплярСервера();
	Если Компонента = Неопределено Тогда
		Мсп_ЛогированиеКлиент.Важно("УведомитьОбОбновленииРесурса ignored: Компонента is undefined");
		Возврат Ложь;
	КонецЕсли;
	Попытка
		Возврат Ждать Компонента.УведомитьОбОбновленииРесурсаАсинх(URI);
	Исключение
		Мсп_ЛогированиеКлиент.Ошибка(ИнформацияОбОшибке());
	КонецПопытки;
КонецФункции

// Инициализирует реестры сервера и синхронизирует их с компонентой.
//
// Возвращаемое значение:
//  Булево - Истина.
Асинх Функция ИнициализироватьРеестрыСервера() Экспорт
	Мсп_ЛогированиеКлиент.Информация("Server startup: initialize registries");

	Если НЕ ЗначениеЗаполнено(Мсп_СостояниеКлиент.СостояниеСервера().Реестры) Тогда
		Мсп_РеестрКлиент.ИнициализироватьРеестры();
		Мсп_СостояниеКлиент.УстановитьЗначениеСостоянияСервера("ИнициализацияРеестровСервера", Истина);
		Мсп_ПровайдерыКлиент.ЗарегистрироватьПровайдеров();
		Мсп_СостояниеКлиент.УстановитьЗначениеСостоянияСервера("ИнициализацияРеестровСервера", Ложь);
	КонецЕсли;

	Возврат Ждать СинхронизироватьРеестрыСКомпонентой();
КонецФункции

// Синхронизирует все реестры с компонентой.
//
// Возвращаемое значение:
//  Булево - Истина, если синхронизация выполнена.
Асинх Функция СинхронизироватьРеестрыСКомпонентой() Экспорт
	Компонента = ЭкземплярСервера();
	Если Компонента = Неопределено Тогда
		Мсп_ЛогированиеКлиент.Важно("Registry sync skipped: Компонента is undefined");
		Возврат Ложь;
	КонецЕсли;

	Ждать СинхронизироватьИнструменты();
	Ждать СинхронизироватьРесурсы();
	Ждать СинхронизироватьПромпты();

	Возврат Истина;
КонецФункции

Асинх Функция ВыполнитьЗапланированныеСинхронизации() Экспорт
	Мсп_СостояниеКлиент.УстановитьЗначениеСостоянияСервера("ЗапланированОбработчикСинхронизацииРеестров", Ложь);
	Если Не ЕстьЗапланированныеСинхронизации() Тогда
		Возврат Истина;
	КонецЕсли;
	Если Мсп_СостояниеКлиент.ЗначениеСостоянияСервера("ВыполняетсяСинхронизацияРеестров", Ложь) Тогда
		Возврат Истина;
	КонецЕсли;
	Если ЭкземплярСервера() = Неопределено Тогда
		Возврат Истина;
	КонецЕсли;

	Мсп_СостояниеКлиент.УстановитьЗначениеСостоянияСервера("ВыполняетсяСинхронизацияРеестров", Истина);
	Попытка
		Пока ЕстьЗапланированныеСинхронизации() Цикл
			Ждать ВыполнитьЗапланированныйПроходСинхронизации();
		КонецЦикла;
	Исключение
		Мсп_ЛогированиеКлиент.Ошибка(ИнформацияОбОшибке());
	КонецПопытки;
	Мсп_СостояниеКлиент.УстановитьЗначениеСостоянияСервера("ВыполняетсяСинхронизацияРеестров", Ложь);
	Возврат Истина;
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Асинх Функция ВыполнитьЗапланированныйПроходСинхронизации()
	Если Мсп_СостояниеКлиент.ЗначениеСостоянияСервера("ТребуетсяСинхронизацияИнструментов", Ложь) Тогда
		Мсп_СостояниеКлиент.УстановитьЗначениеСостоянияСервера("ТребуетсяСинхронизацияИнструментов", Ложь);
		Ждать СинхронизироватьИнструменты();
	КонецЕсли;
	Если Мсп_СостояниеКлиент.ЗначениеСостоянияСервера("ТребуетсяСинхронизацияРесурсов", Ложь) Тогда
		Мсп_СостояниеКлиент.УстановитьЗначениеСостоянияСервера("ТребуетсяСинхронизацияРесурсов", Ложь);
		Ждать СинхронизироватьРесурсы();
	КонецЕсли;
	Если Мсп_СостояниеКлиент.ЗначениеСостоянияСервера("ТребуетсяСинхронизацияПромптов", Ложь) Тогда
		Мсп_СостояниеКлиент.УстановитьЗначениеСостоянияСервера("ТребуетсяСинхронизацияПромптов", Ложь);
		Ждать СинхронизироватьПромпты();
	КонецЕсли;
	Возврат Истина;
КонецФункции

Функция ЗапланироватьСинхронизацию(ИмяФлага)
	Если Не Мсп_ТранспортСерверКлиент.СерверЗапущен() Тогда
		Возврат Ложь;
	КонецЕсли;
	Если Мсп_СостояниеКлиент.ЗначениеСостоянияСервера("ИнициализацияРеестровСервера", Ложь)
		Или Мсп_СостояниеКлиент.ЗначениеСостоянияСервера("РегистрацияПровайдераВыполняется", Ложь) Тогда
		Возврат Ложь;
	КонецЕсли;
	Мсп_СостояниеКлиент.УстановитьЗначениеСостоянияСервера(ИмяФлага, Истина);
	ЗапланироватьОбработчикСинхронизации();
	Возврат Истина;
КонецФункции

Процедура ЗапланироватьОбработчикСинхронизации()
	Если Мсп_СостояниеКлиент.ЗначениеСостоянияСервера("ВыполняетсяСинхронизацияРеестров", Ложь)
		Или Мсп_СостояниеКлиент.ЗначениеСостоянияСервера("ЗапланированОбработчикСинхронизацииРеестров", Ложь) Тогда
		Возврат;
	КонецЕсли;

	Мсп_СостояниеКлиент.УстановитьЗначениеСостоянияСервера("ЗапланированОбработчикСинхронизацииРеестров", Истина);
	ПодключитьОбработчикОжидания("Мсп_ВыполнитьЗапланированныеСинхронизацииРеестров", 1, Истина);
КонецПроцедуры

Функция ЕстьЗапланированныеСинхронизации()
	Возврат Мсп_СостояниеКлиент.ЗначениеСостоянияСервера("ТребуетсяСинхронизацияИнструментов", Ложь)
		Или Мсп_СостояниеКлиент.ЗначениеСостоянияСервера("ТребуетсяСинхронизацияРесурсов", Ложь)
		Или Мсп_СостояниеКлиент.ЗначениеСостоянияСервера("ТребуетсяСинхронизацияПромптов", Ложь);
КонецФункции

Функция ЭкземплярСервера()
	Возврат Мсп_СостояниеКлиент.ЗначениеСостоянияСервера("Компонента", Неопределено);
КонецФункции

#КонецОбласти
