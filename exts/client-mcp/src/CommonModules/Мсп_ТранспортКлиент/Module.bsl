#Область СлужебныеПроцедурыИФункции

Процедура СохранитьПараметрыПодключения(НомерПорта, РазрешенныеOrigins, ТаймаутСек)
	Мсп_СостояниеКлиент.УстановитьЗначениеСостоянияСервера("Порт", НомерПорта);
	Мсп_СостояниеКлиент.УстановитьЗначениеСостоянияСервера("РазрешенныеOrigins", РазрешенныеOrigins);
	Мсп_СостояниеКлиент.УстановитьЗначениеСостоянияСервера("ТаймаутСек", ТаймаутСек);
КонецПроцедуры

// Подключает внешнюю компоненту WebTransport.
//
// Возвращаемое значение:
//  Булево - Истина при успешном подключении.
Асинх Функция ПодключитьКомпоненту()
	МакетКомпоненты = "ОбщийМакет.Мсп_webTransport";
	ИмяКомпоненты = "WebTransport";
	Мсп_ЛогированиеКлиент.Информация("Component connect: begin name=%1 layout=%2", ИмяКомпоненты, МакетКомпоненты);
	
	Попытка
		Мсп_ЛогированиеКлиент.Информация("Component connect: try connect");
		Подключено = Ждать ПодключитьВнешнююКомпонентуАсинх(
			МакетКомпоненты,
			ИмяКомпоненты,
			ТипВнешнейКомпоненты.Native,
			ТипПодключенияВнешнейКомпоненты.НеИзолированно);
			
		Если Не Подключено Тогда
			Мсп_ЛогированиеКлиент.Информация("Component connect: install component from layout");
			Ждать УстановитьВнешнююКомпонентуАсинх(МакетКомпоненты);
			Мсп_ЛогированиеКлиент.Информация("Component connect: retry connect");
			Подключено = Ждать ПодключитьВнешнююКомпонентуАсинх(
				МакетКомпоненты,
				ИмяКомпоненты,
				ТипВнешнейКомпоненты.Native,
				ТипПодключенияВнешнейКомпоненты.НеИзолированно);
		КонецЕсли;
	Исключение
		ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		Мсп_ЛогированиеКлиент.Ошибка("Component connect error: %1", ТекстОшибки);
		ВызватьИсключение СтрШаблон(
			"Не удалось подключить внешнюю компоненту %1 (%2): %3",
			ИмяКомпоненты,
			МакетКомпоненты,
			ТекстОшибки);
	КонецПопытки;
	
	Если Не Подключено Тогда
		Мсп_ЛогированиеКлиент.Ошибка("Component connect failed: no connection established");
		ВызватьИсключение СтрШаблон(
			"Не удалось подключить внешнюю компоненту %1 (%2).",
			ИмяКомпоненты,
			МакетКомпоненты);
	КонецЕсли;
	
	Мсп_ЛогированиеКлиент.Информация("Component connect: success");
	
	Возврат Истина;
КонецФункции

Асинх Процедура ОстановитьКомпоненту(Компонента)
	Попытка
		РезультатОстановки = Ждать Компонента.ОстановитьMCPАсинх();
		ОбработатьОстановкуMCP(РезультатОстановки.Значение, РезультатОстановки.Параметры, Компонента);
	Исключение
		Мсп_ЛогированиеКлиент.Ошибка(ИнформацияОбОшибке());
		ОбработатьОстановкуMCP(Ложь, Неопределено, Компонента);
	КонецПопытки;
КонецПроцедуры

Асинх Процедура ЗапуститьКомпоненту(Компонента, РазрешенныеOrigins, ТаймаутСек)
	Попытка
		РезультатЗапуска = Ждать Компонента.ЗапуститьMCPАсинх(
			АдресПрослушивания(),
			РазрешенныеOrigins,
			ТаймаутСек);
		ОбработатьЗапускMCP(РезультатЗапуска.Значение, РезультатЗапуска.Параметры, Компонента);
	Исключение
		Мсп_ЛогированиеКлиент.Ошибка(ИнформацияОбОшибке());
		ОбработатьЗапускMCP(Ложь, Неопределено, Компонента);
	КонецПопытки;
КонецПроцедуры

Асинх Функция ИнициализироватьРеестрыСервера(Компонента)
	Мсп_ЛогированиеКлиент.Информация("Server startup: initialize registries");
	
	Мсп_РеестрКлиент.ИнициализироватьРеестры();
	Мсп_ПровайдерыКлиент.ЗарегистрироватьПровайдеров();
	
	Возврат Ждать СинхронизироватьРеестрыСКомпонентой(Компонента);
КонецФункции

Функция АдресПрослушивания()
	Порт = Мсп_СостояниеКлиент.ЗначениеСостоянияСервера("Порт", 0);
	Возврат "127.0.0.1:" + Формат(Порт, "ЧГ=0");
КонецФункции

Функция ПолучитьСводкуДанных(Данные)
	ДлинаПревью = 200;
	
	ЕстьДанные = ЗначениеЗаполнено(Данные);
	ДлинаДанных = 0;
	ПревьюДанных = "";
	
	Если ЕстьДанные Тогда
		ДлинаДанных = СтрДлина(Данные);
		ПревьюДанных = Лев(Данные, ДлинаПревью);
		ПревьюДанных = СтрЗаменить(ПревьюДанных, Символы.ПС, " ");
		ПревьюДанных = СтрЗаменить(ПревьюДанных, Символы.ВК, " ");
		ПревьюДанных = СтрЗаменить(ПревьюДанных, Символы.Таб, " ");
		Если ДлинаДанных > ДлинаПревью Тогда
			ПревьюДанных = ПревьюДанных + "...";
		КонецЕсли;
	КонецЕсли;
	
	Возврат НовыйСводкаДанных(ЕстьДанные, ДлинаДанных, ПревьюДанных);
КонецФункции

Функция НовыйСводкаДанных(ЕстьДанные, ДлинаДанных, ПревьюДанных)
	Сводка = Новый Структура;
	Сводка.Вставить("ЕстьДанные", ЕстьДанные);
	Сводка.Вставить("ДлинаДанных", ДлинаДанных);
	Сводка.Вставить("ПревьюДанных", ПревьюДанных);
	Возврат Сводка;
КонецФункции

Процедура ЗаписатьПропускСобытия(ИмяСобытия, Причина)
	Мсп_ЛогированиеКлиент.Важно(ИмяСобытия + " ignored: " + Причина);
КонецПроцедуры

Функция ПодготовитьЗапросСобытия(ИмяСобытия, ЗапросJSON)
	Если Не ЗначениеЗаполнено(ЗапросJSON) Тогда
		ЗаписатьПропускСобытия(ИмяСобытия, "empty request JSON");
		Возврат Неопределено;
	КонецЕсли;
	Запрос = Мсп_СериализацияКлиент.ПрочитатьJSONСтрокуБезОшибок(ЗапросJSON, Неопределено);
	Если ТипЗнч(Запрос) <> Тип("Структура")
		И ТипЗнч(Запрос) <> Тип("Соответствие") Тогда
		ЗаписатьПропускСобытия(ИмяСобытия, "request is not object");
		Возврат Неопределено;
	КонецЕсли;
	Идентификатор = Мсп_Коллекции.Свойство(Запрос, "id", "");
	Если Не ЗначениеЗаполнено(Идентификатор) Тогда
		ЗаписатьПропускСобытия(ИмяСобытия, "missing id");
		Возврат Неопределено;
	КонецЕсли;

	Возврат НовыйКонтекстЗапроса(Запрос, Идентификатор);
КонецФункции

Функция НовыйКонтекстЗапроса(Запрос, Идентификатор)
	Контекст = Новый Структура;
	Контекст.Вставить("Запрос", Запрос);
	Контекст.Вставить("Идентификатор", Идентификатор);
	Возврат Контекст;
КонецФункции

Асинх Функция ОбработатьToolCall(ЗапросJSON)
	Мсп_ЛогированиеКлиент.Отладка("MCP_TOOL_CALL received has_data=%1", ЗначениеЗаполнено(ЗапросJSON));
	КонтекстЗапроса = ПодготовитьЗапросСобытия("MCP_TOOL_CALL", ЗапросJSON);
	Если КонтекстЗапроса = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Запрос = КонтекстЗапроса.Запрос;
	Идентификатор = КонтекстЗапроса.Идентификатор;
	ИмяИнструмента = Мсп_Коллекции.Свойство(Запрос, "name", "");
	Аргументы = Мсп_Коллекции.Свойство(Запрос, "arguments", Неопределено);
	Если ТипЗнч(Аргументы) <> Тип("Структура")
		И ТипЗнч(Аргументы) <> Тип("Соответствие") Тогда
		Аргументы = Новый Структура;
	КонецЕсли;
	Параметры = Новый Структура("name,arguments", ИмяИнструмента, Аргументы);
	Ответ = Мсп_ПротоколКлиент.ВызоватьИнструмент(Идентификатор, Параметры, "");
	Возврат Ждать ОтправитьОтвет(Идентификатор, Ответ);
КонецФункции

Асинх Функция ОбработатьResourceRead(ЗапросJSON)
	Мсп_ЛогированиеКлиент.Отладка("MCP_RESOURCE_READ received has_data=%1", ЗначениеЗаполнено(ЗапросJSON));
	КонтекстЗапроса = ПодготовитьЗапросСобытия("MCP_RESOURCE_READ", ЗапросJSON);
	Если КонтекстЗапроса = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;

	Запрос = КонтекстЗапроса.Запрос;
	Идентификатор = КонтекстЗапроса.Идентификатор;
	URI = Мсп_Коллекции.Свойство(Запрос, "uri", "");
	URIШаблон = Мсп_Коллекции.Свойство(Запрос, "uriTemplate", "");
	Аргументы = Мсп_Коллекции.Свойство(Запрос, "arguments", Неопределено);
	Если ТипЗнч(Аргументы) <> Тип("Структура")
		И ТипЗнч(Аргументы) <> Тип("Соответствие") Тогда
		Аргументы = Новый Структура;
	КонецЕсли;
	Параметры = Новый Структура("uri", URI);
	Если ЗначениеЗаполнено(URIШаблон) Тогда
		Параметры.Вставить("uriTemplate", URIШаблон);
	КонецЕсли;
	Если Аргументы <> Неопределено Тогда
		Параметры.Вставить("arguments", Аргументы);
	КонецЕсли;
	Ответ = Мсп_ПротоколКлиент.ПрочитатьРесурс(Идентификатор, Параметры, "");
	Возврат Ждать ОтправитьОтвет(Идентификатор, Ответ);
КонецФункции

Асинх Функция ОбработатьPromptGet(ЗапросJSON)
	Мсп_ЛогированиеКлиент.Отладка("MCP_PROMPT_GET received has_data=%1", ЗначениеЗаполнено(ЗапросJSON));
	КонтекстЗапроса = ПодготовитьЗапросСобытия("MCP_PROMPT_GET", ЗапросJSON);
	Если КонтекстЗапроса = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;

	Запрос = КонтекстЗапроса.Запрос;
	Идентификатор = КонтекстЗапроса.Идентификатор;
	ИмяПромпта = Мсп_Коллекции.Свойство(Запрос, "name", "");
	Аргументы = Мсп_Коллекции.Свойство(Запрос, "arguments", Неопределено);
	Если ТипЗнч(Аргументы) <> Тип("Структура")
		И ТипЗнч(Аргументы) <> Тип("Соответствие") Тогда
		Аргументы = Новый Структура;
	КонецЕсли;
	Параметры = Новый Структура("name", ИмяПромпта);
	Если Аргументы <> Неопределено Тогда
		Параметры.Вставить("arguments", Аргументы);
	КонецЕсли;
	Ответ = Мсп_ПротоколКлиент.ПолучитьПромпт(Идентификатор, Параметры, "");
	Возврат Ждать ОтправитьОтвет(Идентификатор, Ответ);
КонецФункции

Процедура ОбработатьNotification(ЗапросJSON)
	Если Не ЗначениеЗаполнено(ЗапросJSON) Тогда
		Возврат;
	КонецЕсли;
	Запрос = Мсп_СериализацияКлиент.ПрочитатьJSONСтрокуБезОшибок(ЗапросJSON, Неопределено);
	Если ТипЗнч(Запрос) <> Тип("Структура")
		И ТипЗнч(Запрос) <> Тип("Соответствие") Тогда
		Возврат;
	КонецЕсли;
	Метод = Мсп_Коллекции.Свойство(Запрос, "method", "");
	Если ЗначениеЗаполнено(Метод) Тогда
		Мсп_ЛогированиеКлиент.Отладка("MCP notify: %1", Метод);
	КонецЕсли;
КонецПроцедуры

Асинх Функция ОтправитьОтвет(Идентификатор, Данные)
	Компонента = ЭкземплярСервера();
	Если Компонента = Неопределено Тогда
		Мсп_ЛогированиеКлиент.Важно("MCP response ignored: Компонента is undefined");
		Возврат Ложь;
	КонецЕсли;
	ОтветJSON = Мсп_СериализацияКлиент.Сериализовать(Данные);
	Попытка
		РезультатОтправки = Ждать Компонента.ОтправитьMCPОтветАсинх(
			Идентификатор,
			200,
			"{""Content-Type"":""application/json; charset=utf-8""}",
			ОтветJSON);
		Если РезультатОтправки.Значение = Ложь Тогда
			Мсп_ЛогированиеКлиент.Ошибка("MCP response send error id=%1", Идентификатор);
			Возврат Ложь;
		КонецЕсли;
		Мсп_ЛогированиеКлиент.Отладка("MCP response send ok id=%1", Идентификатор);
	Исключение
		Мсп_ЛогированиеКлиент.Ошибка(ИнформацияОбОшибке());
		Возврат Ложь;
	КонецПопытки;
	Возврат Истина;
КонецФункции

Асинх Функция СинхронизироватьРеестрыСКомпонентой(Компонента)
	Если Компонента = Неопределено Тогда
		Мсп_ЛогированиеКлиент.Важно("Registry sync skipped: Компонента is undefined");
		Возврат Ложь;
	КонецЕсли;

	Попытка
		Ждать Компонента.ОчиститьИнструментыАсинх();
		Ждать Компонента.ОчиститьРесурсыАсинх();
		Ждать Компонента.ОчиститьШаблоныРесурсовАсинх();
		Ждать Компонента.ОчиститьПромптыАсинх();
	Исключение
		Мсп_ЛогированиеКлиент.Ошибка(ИнформацияОбОшибке());
		Возврат Ложь;
	КонецПопытки;

	Для Каждого Элемент Из Мсп_РеестрКлиент.РеестрИнструментов() Цикл
		Дескриптор = Элемент.Значение;
		Описание = Мсп_ПротоколКлиент.НовыйОписаниеИнструмента(
			Дескриптор.Имя,
			Дескриптор.Описание,
			Дескриптор.СхемаПараметров);
		Попытка
			РезультатРегистрации = Ждать Компонента.ЗарегистрироватьИнструментАсинх(
				Мсп_СериализацияКлиент.Сериализовать(Описание));
			
			Если РезультатРегистрации.Значение = Ложь Тогда
				Мсп_ЛогированиеКлиент.Важно("Tool register failed name=%1", Дескриптор.Имя);
			КонецЕсли;
		Исключение
			Мсп_ЛогированиеКлиент.Ошибка(ИнформацияОбОшибке());
		КонецПопытки;
	КонецЦикла;

	Для Каждого Элемент Из Мсп_РеестрКлиент.РеестрРесурсов() Цикл
		Дескриптор = Элемент.Значение;
		Описание = Мсп_ПротоколКлиент.НовыйОписаниеРесурса(
			Дескриптор.URI,
			Дескриптор.Имя,
			Дескриптор.Описание,
			Дескриптор.MimeType);
		Попытка
			РезультатРегистрации = Ждать Компонента.ЗарегистрироватьРесурсАсинх(
				Мсп_СериализацияКлиент.Сериализовать(Описание));
			Если РезультатРегистрации.Значение = Ложь Тогда
				Мсп_ЛогированиеКлиент.Важно("Resource register failed uri=%1", Дескриптор.URI);
			КонецЕсли;
		Исключение
			Мсп_ЛогированиеКлиент.Ошибка(ИнформацияОбОшибке());
		КонецПопытки;
	КонецЦикла;

	Для Каждого Элемент Из Мсп_РеестрКлиент.РеестрШаблоновРесурсов() Цикл
		Дескриптор = Элемент.Значение;
		Описание = Мсп_ПротоколКлиент.НовыйОписаниеШаблонаРесурса(
			Дескриптор.URIШаблон,
			Дескриптор.Имя,
			Дескриптор.Описание,
			Дескриптор.MimeType);
		Попытка
			РезультатРегистрации = Ждать Компонента.ЗарегистрироватьШаблонРесурсаАсинх(
				Мсп_СериализацияКлиент.Сериализовать(Описание));
			Если РезультатРегистрации.Значение = Ложь Тогда
				Мсп_ЛогированиеКлиент.Важно("Resource template register failed uri_template=%1", Дескриптор.URIШаблон);
			КонецЕсли;
		Исключение
			Мсп_ЛогированиеКлиент.Ошибка(ИнформацияОбОшибке());
		КонецПопытки;
	КонецЦикла;

	Для Каждого Элемент Из Мсп_РеестрКлиент.РеестрПромптов() Цикл
		Дескриптор = Элемент.Значение;
		Описание = Мсп_ПротоколКлиент.НовыйОписаниеПромпта(
			Дескриптор.Имя,
			Дескриптор.Описание,
			Дескриптор.Аргументы);
		Попытка
			РезультатРегистрации = Ждать Компонента.ЗарегистрироватьПромптАсинх(
				Мсп_СериализацияКлиент.Сериализовать(Описание));
			Если РезультатРегистрации.Значение = Ложь Тогда
				Мсп_ЛогированиеКлиент.Важно("Prompt register failed name=%1", Дескриптор.Имя);
			КонецЕсли;
		Исключение
			Мсп_ЛогированиеКлиент.Ошибка(ИнформацияОбОшибке());
		КонецПопытки;
	КонецЦикла;
	
	Возврат Истина;
КонецФункции

Процедура ОбработатьЗапускMCP(РезультатВызова, ПараметрыВызова, Компонента = Неопределено)
	Если РезультатВызова = Ложь Тогда
		Мсп_ЛогированиеКлиент.Ошибка("MCP start error: component returned false");
		Если Компонента <> Неопределено Тогда
			Если ЭкземплярСервера() = Компонента Тогда
				Мсп_СостояниеКлиент.УстановитьЗначениеСостоянияСервера("Компонента", Неопределено);
			КонецЕсли;
		КонецЕсли;
		Если Компонента = Неопределено Или ЭкземплярСервера() = Компонента Тогда
			Мсп_СостояниеКлиент.УстановитьЗначениеСостоянияСервера("СерверЗапущен", Ложь);
		КонецЕсли;
		Возврат;
	КонецЕсли;

	Если Компонента = Неопределено Или ЭкземплярСервера() = Компонента Тогда
		Мсп_СостояниеКлиент.УстановитьЗначениеСостоянияСервера("СерверЗапущен", Истина);
	КонецЕсли;
КонецПроцедуры

Процедура ОбработатьОстановкуMCP(РезультатВызова, ПараметрыВызова, Компонента = Неопределено)
	Если РезультатВызова = Ложь Тогда
		Мсп_ЛогированиеКлиент.Ошибка("MCP stop error: component returned false");
		Если Компонента = Неопределено Или ЭкземплярСервера() = Компонента Тогда
			Мсп_СостояниеКлиент.УстановитьЗначениеСостоянияСервера("СерверЗапущен", Истина);
		КонецЕсли;
		Возврат;
	КонецЕсли;

	Если Компонента = Неопределено Или ЭкземплярСервера() = Компонента Тогда
		Мсп_СостояниеКлиент.УстановитьЗначениеСостоянияСервера("Компонента", Неопределено);
		Мсп_СостояниеКлиент.УстановитьЗначениеСостоянияСервера("СерверЗапущен", Ложь);
		Мсп_ЛогированиеКлиент.Информация("Server stopped");
	КонецЕсли;
КонецПроцедуры

Процедура ОбработатьResourceSubscribe(ЗапросJSON)
	Если Не ЗначениеЗаполнено(ЗапросJSON) Тогда
		Возврат;
	КонецЕсли;
	Запрос = Мсп_СериализацияКлиент.ПрочитатьJSONСтрокуБезОшибок(ЗапросJSON, Неопределено);
	URI = Мсп_Коллекции.Свойство(Запрос, "uri", "");
	Мсп_ЛогированиеКлиент.Информация("Client subscribed to resource uri=%1", URI);
КонецПроцедуры

Процедура ОбработатьResourceUnsubscribe(ЗапросJSON)
	Если Не ЗначениеЗаполнено(ЗапросJSON) Тогда
		Возврат;
	КонецЕсли;
	Запрос = Мсп_СериализацияКлиент.ПрочитатьJSONСтрокуБезОшибок(ЗапросJSON, Неопределено);
	URI = Мсп_Коллекции.Свойство(Запрос, "uri", "");
	Мсп_ЛогированиеКлиент.Информация("Client unsubscribed from resource uri=%1", URI);
КонецПроцедуры

#КонецОбласти
