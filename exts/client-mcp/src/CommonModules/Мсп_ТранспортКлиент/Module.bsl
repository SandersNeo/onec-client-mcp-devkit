#Область ПрограммныйИнтерфейс

// Запускает MCP-сервер и инициализирует состояние.
//
// Параметры:
//  НомерПорта - Число - Номер порта для прослушивания.
//  РазрешенныеOrigins - Строка - Допустимые origins ("" | "*" | JSON-массив строк).
//  ТаймаутСек - Число - Таймаут ожидания ответа от 1С.
//
// Возвращаемое значение:
//  Булево - Истина, если запрос на запуск отправлен.
Асинх Функция ЗапуститьСервер(НомерПорта, РазрешенныеOrigins = "", ТаймаутСек = 30) Экспорт
	Возврат Ждать Мсп_ТранспортСерверКлиент.ЗапуститьСервер(НомерПорта, РазрешенныеOrigins, ТаймаутСек);
КонецФункции

// Останавливает MCP-сервер.
//
// Возвращаемое значение:
//  Булево - Истина, если запрос на остановку обработан.
Асинх Функция ОстановитьСервер() Экспорт
	Возврат Ждать Мсп_ТранспортСерверКлиент.ОстановитьСервер();
КонецФункции

// Возвращает экземпляр внешней компоненты MCP (если инициализирована).
//
// Возвращаемое значение:
//  ВнешнийОбъект - Экземпляр внешней компоненты или Неопределено.
Функция ЭкземплярСервера() Экспорт
	Возврат Мсп_ТранспортСерверКлиент.ЭкземплярСервера();
КонецФункции

// Проверяет, запущен ли MCP-сервер.
//
// Возвращаемое значение:
//  Булево - Истина, если сервер запущен.
Функция СерверЗапущен() Экспорт
	Возврат Мсп_ТранспортСерверКлиент.СерверЗапущен();
КонецФункции

// Возвращает порт MCP-сервера.
//
// Возвращаемое значение:
//  Число - Порт сервера или 0, если не задан.
Функция ПолучитьПортСервера() Экспорт
	Возврат Мсп_ТранспортСерверКлиент.ПолучитьПортСервера();
КонецФункции

// Возвращает адрес прослушивания MCP-сервера.
//
// Возвращаемое значение:
//  Строка - Адрес прослушивания или пустая строка.
Функция ПолучитьАдресПрослушивания() Экспорт
	Возврат Мсп_ТранспортСерверКлиент.ПолучитьАдресПрослушивания();
КонецФункции

// Возвращает разрешенные origins MCP-сервера.
//
// Возвращаемое значение:
//  Строка - Строковое представление allow-list.
Функция ПолучитьРазрешенныеOrigins() Экспорт
	Возврат Мсп_ТранспортСерверКлиент.ПолучитьРазрешенныеOrigins();
КонецФункции

// Возвращает таймаут ответа от обработчиков MCP.
//
// Возвращаемое значение:
//  Число - Таймаут в секундах.
Функция ПолучитьТаймаутСек() Экспорт
	Возврат Мсп_ТранспортСерверКлиент.ПолучитьТаймаутСек();
КонецФункции

// Устанавливает метаданные MCP-сервера, возвращаемые клиенту при initialize.
//
// Параметры:
//  ОписаниеJSON - Строка - JSON с полями name, version, title, description, instructions.
Асинх Процедура УстановитьИнформациюОСервере(ОписаниеJSON) Экспорт
	Ждать Мсп_ТранспортСерверКлиент.УстановитьИнформациюОСервере(ОписаниеJSON);
КонецПроцедуры

