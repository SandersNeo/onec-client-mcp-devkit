#Область ПрограммныйИнтерфейс

// Запускает MCP-сервер и инициализирует состояние.
//
// Параметры:
//  НомерПорта - Число - Номер порта для прослушивания.
//  РазрешенныеOrigins - Строка - Допустимые origins ("" | "*" | JSON-массив строк).
//  ТаймаутСек - Число - Таймаут ожидания ответа от 1С.
//
// Возвращаемое значение:
//  Булево - Истина, если запрос на запуск отправлен.
Асинх Функция ЗапуститьСервер(НомерПорта, РазрешенныеOrigins = "", ТаймаутСек = 30) Экспорт
	СохранитьПараметрыПодключения(НомерПорта, РазрешенныеOrigins, ТаймаутСек);
	
	Мсп_ЛогированиеКлиент.Информация("Server startup:
									 |  port=%1
									 |  timeout=%2
									 |  origins=%3", НомерПорта, РазрешенныеOrigins, ТаймаутСек);
	
	Ждать ПодключитьКомпоненту();
	
	Компонента = ЭкземплярСервера();
	Если Компонента <> Неопределено Тогда
		Мсп_ЛогированиеКлиент.Информация("Server startup: stopping previous MCP server");
		ОстановитьКомпоненту(Компонента);
		Мсп_ЛогированиеКлиент.Информация("Server startup: stop requested for previous server");
	КонецЕсли;
	
	Мсп_ЛогированиеКлиент.Информация("Server startup: create addin AddIn.WebTransport.mcp");
	Компонента = Новый("AddIn.WebTransport.mcp");
	Мсп_ЛогированиеКлиент.Информация("Server startup: MCP start requested address=%1", АдресПрослушивания());
	Мсп_СостояниеКлиент.УстановитьЗначениеСостоянияСервера("Компонента", Компонента);
	
	ЗапуститьКомпоненту(Компонента, РазрешенныеOrigins, ТаймаутСек);
	
	Ждать ИнициализироватьРеестрыСервера(Компонента);
	Мсп_ЛогированиеКлиент.Информация("Server start requested on %1", АдресПрослушивания());
	
	Возврат Истина;
КонецФункции

// Останавливает MCP-сервер.
//
// Возвращаемое значение:
//  Булево - Истина, если запрос на остановку обработан.
Асинх Функция ОстановитьСервер() Экспорт
	Компонента = ЭкземплярСервера();
	Мсп_СостояниеКлиент.УстановитьЗначениеСостоянияСервера("СерверЗапущен", Ложь);
	Если Компонента <> Неопределено Тогда
		ОстановитьКомпоненту(Компонента);
	КонецЕсли;
	Мсп_ЛогированиеКлиент.Информация("Server stop requested");
	Возврат Истина;
КонецФункции

// Обрабатывает события внешней компоненты MCP.
//
// Параметры:
//  Источник - Строка - Имя источника события.
//  Событие - Строка - Имя события.
//  Данные - Строка - Данные события.
//
// Возвращаемое значение:
//  Булево - Истина, если событие обработано.
Асинх Функция ОбработатьВнешнееСобытие(Источник, Событие, Данные) Экспорт
	
	Если Источник <> "WebTransport" Тогда
		Возврат Ложь;
	КонецЕсли;
	
	СводкаДанных = ПолучитьСводкуДанных(Данные);
	
	Мсп_ЛогированиеКлиент.Отладка(
		"External event received source=%1 event=%2 has_data=%3 data_len=%4 data_preview=%5",
		Источник,
		Событие,
		СводкаДанных.ЕстьДанные,
		СводкаДанных.ДлинаДанных,
		СводкаДанных.ПревьюДанных);
	
	Если Событие = "MCP_TOOL_CALL" Тогда
		
		Мсп_ЛогированиеКлиент.Отладка("External event MCP_TOOL_CALL: begin");
		Результат = Ждать ОбработатьToolCall(Данные);
		Мсп_ЛогированиеКлиент.Отладка("External event MCP_TOOL_CALL: end result=%1", Результат);
		Возврат Результат;
		
	ИначеЕсли Событие = "MCP_RESOURCE_READ" Тогда
		
		Мсп_ЛогированиеКлиент.Отладка("External event MCP_RESOURCE_READ: begin");
		Результат = Ждать ОбработатьResourceRead(Данные);
		Мсп_ЛогированиеКлиент.Отладка("External event MCP_RESOURCE_READ: end result=%1", Результат);
		Возврат Результат;
		
	ИначеЕсли Событие = "MCP_PROMPT_GET" Тогда
		
		Мсп_ЛогированиеКлиент.Отладка("External event MCP_PROMPT_GET: begin");
		Результат = Ждать ОбработатьPromptGet(Данные);
		Мсп_ЛогированиеКлиент.Отладка("External event MCP_PROMPT_GET: end result=%1", Результат);
		Возврат Результат;
		
	ИначеЕсли Событие = "MCP_NOTIFICATION" Тогда

		Мсп_ЛогированиеКлиент.Отладка("External event MCP_NOTIFICATION: begin");
		ОбработатьNotification(Данные);
		Мсп_ЛогированиеКлиент.Отладка("External event MCP_NOTIFICATION: end");
		Возврат Истина;

	ИначеЕсли Событие = "MCP_RESOURCE_SUBSCRIBE" Тогда

		Мсп_ЛогированиеКлиент.Отладка("External event MCP_RESOURCE_SUBSCRIBE: begin");
		ОбработатьResourceSubscribe(Данные);
		Мсп_ЛогированиеКлиент.Отладка("External event MCP_RESOURCE_SUBSCRIBE: end");
		Возврат Истина;

	ИначеЕсли Событие = "MCP_RESOURCE_UNSUBSCRIBE" Тогда

		Мсп_ЛогированиеКлиент.Отладка("External event MCP_RESOURCE_UNSUBSCRIBE: begin");
		ОбработатьResourceUnsubscribe(Данные);
		Мсп_ЛогированиеКлиент.Отладка("External event MCP_RESOURCE_UNSUBSCRIBE: end");
		Возврат Истина;

	Иначе
		
		Мсп_ЛогированиеКлиент.Отладка(
			"External event ignored: unknown event=%1 source=%2 has_data=%3 data_len=%4 data_preview=%5",
			Событие,
			Источник,
			СводкаДанных.ЕстьДанные,
			СводкаДанных.ДлинаДанных,
			СводкаДанных.ПревьюДанных);
		Возврат Ложь;
		
	КонецЕсли;
	
КонецФункции

// Возвращает экземпляр внешней компоненты MCP (если инициализирована).
//
// Возвращаемое значение:
//  ВнешнийОбъект - Экземпляр внешней компоненты или Неопределено.
Функция ЭкземплярСервера() Экспорт
	Возврат Мсп_СостояниеКлиент.ЗначениеСостоянияСервера("Компонента", Неопределено);
КонецФункции

// Проверяет, запущен ли MCP-сервер.
//
// Возвращаемое значение:
//  Булево - Истина, если сервер запущен.
Функция СерверЗапущен() Экспорт
	Возврат Мсп_СостояниеКлиент.ЗначениеСостоянияСервера(
		"СерверЗапущен",
		ЭкземплярСервера() <> Неопределено);
КонецФункции

// Возвращает порт MCP-сервера.
//
// Возвращаемое значение:
//  Число - Порт сервера или 0, если не задан.
Функция ПолучитьПортСервера() Экспорт
	Возврат Мсп_СостояниеКлиент.ЗначениеСостоянияСервера("Порт", 0);
КонецФункции

// Возвращает адрес прослушивания MCP-сервера.
//
// Возвращаемое значение:
//  Строка - Адрес прослушивания или пустая строка.
Функция ПолучитьАдресПрослушивания() Экспорт
	Если Мсп_СостояниеКлиент.ЗначениеСостоянияСервера("Порт", 0) <= 0 Тогда
		Возврат "";
	КонецЕсли;
	Возврат АдресПрослушивания();
КонецФункции

// Возвращает разрешенные origins MCP-сервера.
//
// Возвращаемое значение:
