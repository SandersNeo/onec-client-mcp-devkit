#Область ПрограммныйИнтерфейс

// Запускает MCP-сервер и инициализирует состояние.
//
// Параметры:
//  НомерПорта - Число - Номер порта для прослушивания.
//  РазрешенныеOrigins - Строка - Допустимые origins ("" | "*" | JSON-массив строк).
//  ТаймаутСек - Число - Таймаут ожидания ответа от 1С.
//
// Возвращаемое значение:
//  Булево - Истина, если запрос на запуск отправлен.
Асинх Функция ЗапуститьСервер(НомерПорта, РазрешенныеOrigins = "", ТаймаутСек = 30) Экспорт
	Мсп_СостояниеКлиент.УстановитьСостояниеЗначение("Порт", НомерПорта);
	Мсп_СостояниеКлиент.УстановитьСостояниеЗначение("РазрешенныеOrigins", РазрешенныеOrigins);
	Мсп_СостояниеКлиент.УстановитьСостояниеЗначение("ТаймаутСек", ТаймаутСек);
	
	Мсп_ЛогированиеКлиент.Информация("Server startup: begin port=%1", НомерПорта);
	Мсп_ЛогированиеКлиент.Информация(
		"Server startup: params origins=%1 timeout=%2",
		РазрешенныеOrigins,
		ТаймаутСек);
	
	Мсп_ЛогированиеКлиент.Информация("Server startup: connect external component");
	Ждать ПодключитьКомпоненту();
	Мсп_ЛогированиеКлиент.Информация("Server startup: external component connected");
	
	Компонента = ЭкземплярСервера();
	Если Компонента <> Неопределено Тогда
		Мсп_ЛогированиеКлиент.Информация("Server startup: stopping previous MCP server");
		Попытка
			РезультатОстановки = Ждать Компонента.ОстановитьMCPАсинх();
			ОбработкаОстановкиMCP(РезультатОстановки.Значение, РезультатОстановки.Параметры, Компонента);
		Исключение
			Мсп_ЛогированиеКлиент.Ошибка(ИнформацияОбОшибке());
			ОбработкаОстановкиMCP(Ложь, Неопределено, Компонента);
		КонецПопытки;
		Мсп_ЛогированиеКлиент.Информация("Server startup: stop requested for previous server");
	КонецЕсли;
	
	Мсп_ЛогированиеКлиент.Информация("Server startup: create addin AddIn.WebTransport.mcp");
	Компонента = Новый("AddIn.WebTransport.mcp");
	Мсп_ЛогированиеКлиент.Информация("Server startup: MCP start requested address=%1", АдресПрослушивания());
	Мсп_СостояниеКлиент.УстановитьСостояниеЗначение("Компонента", Компонента);
	
	Попытка
		РезультатЗапуска = Ждать Компонента.ЗапуститьMCPАсинх(
			АдресПрослушивания(),
			РазрешенныеOrigins,
			ТаймаутСек);
		ОбработкаЗапускаMCP(РезультатЗапуска.Значение, РезультатЗапуска.Параметры, Компонента);
	Исключение
		Мсп_ЛогированиеКлиент.Ошибка(ИнформацияОбОшибке());
		ОбработкаЗапускаMCP(Ложь, Неопределено, Компонента);
	КонецПопытки;
	
	Мсп_ЛогированиеКлиент.Информация("Server startup: initialize registries");
	Мсп_РеестрКлиент.ИнициализироватьРеестры();
	Мсп_ПровайдерыКлиент.ЗарегистрироватьПровайдеров();
	Компонента = ЭкземплярСервера();
	Если Компонента <> Неопределено Тогда
		СинхронизироватьРеестрыСКомпонентой(Компонента);
	КонецЕсли;
	Мсп_ЛогированиеКлиент.Информация("Server start requested on %1", АдресПрослушивания());
	
	Возврат Истина;
КонецФункции

// Останавливает MCP-сервер.
//
// Возвращаемое значение:
//  Булево - Истина, если запрос на остановку обработан.
Асинх Функция ОстановитьСервер() Экспорт
	Компонента = ЭкземплярСервера();
	Мсп_СостояниеКлиент.УстановитьСостояниеЗначение("СерверЗапущен", Ложь);
	Если Компонента <> Неопределено Тогда
		Попытка
			РезультатОстановки = Ждать Компонента.ОстановитьMCPАсинх();
			ОбработкаОстановкиMCP(РезультатОстановки.Значение, РезультатОстановки.Параметры, Компонента);
		Исключение
			Мсп_ЛогированиеКлиент.Ошибка(ИнформацияОбОшибке());
			ОбработкаОстановкиMCP(Ложь, Неопределено, Компонента);
		КонецПопытки;
	КонецЕсли;
	Мсп_ЛогированиеКлиент.Информация("Server stop requested");
	Возврат Истина;
КонецФункции

// Обрабатывает события внешней компоненты MCP.
//
// Параметры:
//  Источник - Строка - Имя источника события.
//  Событие - Строка - Имя события.
//  Данные - Строка - Данные события.
//
// Возвращаемое значение:
//  Булево - Истина, если событие обработано.
Асинх Функция ОбработатьВнешнееСобытие(Источник, Событие, Данные) Экспорт
	ДлинаПревью = 200;
	ЕстьДанные = ЗначениеЗаполнено(Данные);
	ДлинаДанных = 0;
	ПревьюДанных = "";
	Если ЕстьДанные Тогда
		ДлинаДанных = СтрДлина(Данные);
		ПревьюДанных = Лев(Данные, ДлинаПревью);
		ПревьюДанных = СтрЗаменить(ПревьюДанных, Символы.ПС, " ");
		ПревьюДанных = СтрЗаменить(ПревьюДанных, Символы.ВК, " ");
		ПревьюДанных = СтрЗаменить(ПревьюДанных, Символы.Таб, " ");
		Если ДлинаДанных > ДлинаПревью Тогда
			ПревьюДанных = ПревьюДанных + "...";
		КонецЕсли;
	КонецЕсли;

	Мсп_ЛогированиеКлиент.Отладка(
		"External event received source=%1 event=%2 has_data=%3 data_len=%4 data_preview=%5",
		Источник,
		Событие,
		ЕстьДанные,
		ДлинаДанных,
		ПревьюДанных);
	Если Источник <> "WebTransport" Тогда
		Мсп_ЛогированиеКлиент.Отладка("External event ignored: source=%1", Источник);
		Возврат Ложь;
	КонецЕсли;

	Если Событие = "MCP_TOOL_CALL" Тогда
		Мсп_ЛогированиеКлиент.Отладка("External event MCP_TOOL_CALL: begin");
		Результат = Ждать ОбработатьToolCall(Данные);
		Мсп_ЛогированиеКлиент.Отладка("External event MCP_TOOL_CALL: end result=%1", Результат);
		Возврат Результат;
	ИначеЕсли Событие = "MCP_RESOURCE_READ" Тогда
		Мсп_ЛогированиеКлиент.Отладка("External event MCP_RESOURCE_READ: begin");
		Результат = Ждать ОбработатьResourceRead(Данные);
		Мсп_ЛогированиеКлиент.Отладка("External event MCP_RESOURCE_READ: end result=%1", Результат);
		Возврат Результат;
	ИначеЕсли Событие = "MCP_PROMPT_GET" Тогда
		Мсп_ЛогированиеКлиент.Отладка("External event MCP_PROMPT_GET: begin");
		Результат = Ждать ОбработатьPromptGet(Данные);
		Мсп_ЛогированиеКлиент.Отладка("External event MCP_PROMPT_GET: end result=%1", Результат);
		Возврат Результат;
	ИначеЕсли Событие = "MCP_NOTIFICATION" Тогда
		Мсп_ЛогированиеКлиент.Отладка("External event MCP_NOTIFICATION: begin");
		ОбработатьNotification(Данные);
		Мсп_ЛогированиеКлиент.Отладка("External event MCP_NOTIFICATION: end");
		Возврат Истина;
	КонецЕсли;

	Мсп_ЛогированиеКлиент.Отладка(
		"External event ignored: unknown event=%1 source=%2 has_data=%3 data_len=%4 data_preview=%5",
		Событие,
		Источник,
		ЕстьДанные,
		ДлинаДанных,
		ПревьюДанных);
	Возврат Ложь;
КонецФункции

// Возвращает экземпляр внешней компоненты MCP (если инициализирована).
//
// Возвращаемое значение:
//  ВнешнийОбъект - Экземпляр внешней компоненты или Неопределено.
Функция ЭкземплярСервера() Экспорт
	Возврат Мсп_СостояниеКлиент.ПолучитьСостояниеЗначение("Компонента", Неопределено);
КонецФункции

// Проверяет, запущен ли MCP-сервер.
//
// Возвращаемое значение:
//  Булево - Истина, если сервер запущен.
Функция СерверЗапущен() Экспорт
	Возврат Мсп_СостояниеКлиент.ПолучитьСостояниеЗначение(
		"СерверЗапущен",
		ЭкземплярСервера() <> Неопределено);
КонецФункции

// Возвращает порт MCP-сервера.
//
// Возвращаемое значение:
//  Число - Порт сервера или 0, если не задан.
Функция ПолучитьПортСервера() Экспорт
	Возврат Мсп_СостояниеКлиент.ПолучитьСостояниеЗначение("Порт", 0);
КонецФункции

// Возвращает адрес прослушивания MCP-сервера.
//
// Возвращаемое значение:
//  Строка - Адрес прослушивания или пустая строка.
Функция ПолучитьАдресПрослушивания() Экспорт
	Если Мсп_СостояниеКлиент.ПолучитьСостояниеЗначение("Порт", 0) <= 0 Тогда
		Возврат "";
	КонецЕсли;
	Возврат АдресПрослушивания();
КонецФункции

// Возвращает разрешенные origins MCP-сервера.
//
// Возвращаемое значение:
//  Строка - Строковое представление allow-list.
Функция ПолучитьРазрешенныеOrigins() Экспорт
	Возврат Мсп_СостояниеКлиент.ПолучитьСостояниеЗначение("РазрешенныеOrigins", "");
КонецФункции

// Возвращает таймаут ответа от обработчиков MCP.
//
// Возвращаемое значение:
//  Число - Таймаут в секундах.
Функция ПолучитьТаймаутСек() Экспорт
	Возврат Мсп_СостояниеКлиент.ПолучитьСостояниеЗначение("ТаймаутСек", 30);
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Подключает внешнюю компоненту WebTransport.
//
// Возвращаемое значение:
//  Булево - Истина при успешном подключении.
Асинх Функция ПодключитьКомпоненту() Экспорт
	МакетКомпоненты = "ОбщийМакет.Мсп_webTransport";
	ИмяКомпоненты = "WebTransport";
	Мсп_ЛогированиеКлиент.Информация("Component connect: begin name=%1 layout=%2", ИмяКомпоненты, МакетКомпоненты);

	Попытка
		Мсп_ЛогированиеКлиент.Информация("Component connect: try connect");
		Подключено = Ждать ПодключитьВнешнююКомпонентуАсинх(
			МакетКомпоненты,
			ИмяКомпоненты,
			ТипВнешнейКомпоненты.Native,
			ТипПодключенияВнешнейКомпоненты.НеИзолированно);

		Если Не Подключено Тогда
			Мсп_ЛогированиеКлиент.Информация("Component connect: install component from layout");
			Ждать УстановитьВнешнююКомпонентуАсинх(МакетКомпоненты);
			Мсп_ЛогированиеКлиент.Информация("Component connect: retry connect");
			Подключено = Ждать ПодключитьВнешнююКомпонентуАсинх(
				МакетКомпоненты,
				ИмяКомпоненты,
				ТипВнешнейКомпоненты.Native,
				ТипПодключенияВнешнейКомпоненты.НеИзолированно);
		КонецЕсли;
	Исключение
		ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		Мсп_ЛогированиеКлиент.Ошибка("Component connect error: %1", ТекстОшибки);
		ВызватьИсключение СтрШаблон(
			"Не удалось подключить внешнюю компоненту %1 (%2): %3",
			ИмяКомпоненты,
			МакетКомпоненты,
			ТекстОшибки);
	КонецПопытки;

	Если Не Подключено Тогда
		Мсп_ЛогированиеКлиент.Ошибка("Component connect failed: no connection established");
		ВызватьИсключение СтрШаблон(
			"Не удалось подключить внешнюю компоненту %1 (%2).",
			ИмяКомпоненты,
			МакетКомпоненты);
	КонецЕсли;

	Мсп_ЛогированиеКлиент.Информация("Component connect: success");
	Возврат Истина;
КонецФункции

Функция АдресПрослушивания()
	Порт = Мсп_СостояниеКлиент.ПолучитьСостояниеЗначение("Порт", 0);
	Возврат "127.0.0.1:" + Формат(Порт, "ЧГ=0");
КонецФункции

Асинх Функция ОбработатьToolCall(ЗапросJSON)
	Мсп_ЛогированиеКлиент.Отладка("MCP_TOOL_CALL received has_data=%1", ЗначениеЗаполнено(ЗапросJSON));
	Компонента = ЭкземплярСервера();
	Если Компонента = Неопределено Тогда
		Мсп_ЛогированиеКлиент.Важно("MCP_TOOL_CALL ignored: Компонента is undefined");
		Возврат Ложь;
	КонецЕсли;
	Если Не ЗначениеЗаполнено(ЗапросJSON) Тогда
		Мсп_ЛогированиеКлиент.Важно("MCP_TOOL_CALL ignored: empty request JSON");
		Возврат Ложь;
	КонецЕсли;
	Запрос = Мсп_ИнструментыКлиент.ПрочитатьJSONСтрокуБезОшибок(ЗапросJSON, Неопределено);
	Если ТипЗнч(Запрос) <> Тип("Структура")
		И ТипЗнч(Запрос) <> Тип("Соответствие") Тогда
		Мсп_ЛогированиеКлиент.Важно("MCP_TOOL_CALL ignored: request is not object");
		Возврат Ложь;
	КонецЕсли;
	Идентификатор = Мсп_ИнструментыКлиент.ПолучитьСвойство(Запрос, "id", "");
	Если Не ЗначениеЗаполнено(Идентификатор) Тогда
		Мсп_ЛогированиеКлиент.Важно("MCP_TOOL_CALL ignored: missing id");
		Возврат Ложь;
	КонецЕсли;
	ИмяИнструмента = Мсп_ИнструментыКлиент.ПолучитьСвойство(Запрос, "name", "");
	Аргументы = Мсп_ИнструментыКлиент.ПолучитьСвойство(Запрос, "arguments", Неопределено);
	Если ТипЗнч(Аргументы) <> Тип("Структура")
		И ТипЗнч(Аргументы) <> Тип("Соответствие") Тогда
		Аргументы = Новый Структура;
	КонецЕсли;
	Параметры = Новый Структура("name,arguments", ИмяИнструмента, Аргументы);
	Ответ = Мсп_ПротоколКлиент.ОтветВызовИнструмента(Идентификатор, Параметры, "");
	Возврат Ждать ОтправитьОтвет(Идентификатор, Ответ);
КонецФункции

Асинх Функция ОбработатьResourceRead(ЗапросJSON)
	Мсп_ЛогированиеКлиент.Отладка("MCP_RESOURCE_READ received has_data=%1", ЗначениеЗаполнено(ЗапросJSON));
	Компонента = ЭкземплярСервера();
	Если Компонента = Неопределено Тогда
		Мсп_ЛогированиеКлиент.Важно("MCP_RESOURCE_READ ignored: Компонента is undefined");
		Возврат Ложь;
	КонецЕсли;
	Если Не ЗначениеЗаполнено(ЗапросJSON) Тогда
		Мсп_ЛогированиеКлиент.Важно("MCP_RESOURCE_READ ignored: empty request JSON");
		Возврат Ложь;
	КонецЕсли;
	Запрос = Мсп_ИнструментыКлиент.ПрочитатьJSONСтрокуБезОшибок(ЗапросJSON, Неопределено);
	Если ТипЗнч(Запрос) <> Тип("Структура")
		И ТипЗнч(Запрос) <> Тип("Соответствие") Тогда
		Мсп_ЛогированиеКлиент.Важно("MCP_RESOURCE_READ ignored: request is not object");
		Возврат Ложь;
	КонецЕсли;
	Идентификатор = Мсп_ИнструментыКлиент.ПолучитьСвойство(Запрос, "id", "");
	Если Не ЗначениеЗаполнено(Идентификатор) Тогда
		Мсп_ЛогированиеКлиент.Важно("MCP_RESOURCE_READ ignored: missing id");
		Возврат Ложь;
	КонецЕсли;
	URI = Мсп_ИнструментыКлиент.ПолучитьСвойство(Запрос, "uri", "");
	Параметры = Новый Структура("uri", URI);
	Ответ = Мсп_ПротоколКлиент.ОтветПрочитатьРесурс(Идентификатор, Параметры, "");
	Возврат Ждать ОтправитьОтвет(Идентификатор, Ответ);
КонецФункции

Асинх Функция ОбработатьPromptGet(ЗапросJSON)
	Мсп_ЛогированиеКлиент.Отладка("MCP_PROMPT_GET received has_data=%1", ЗначениеЗаполнено(ЗапросJSON));
	Компонента = ЭкземплярСервера();
	Если Компонента = Неопределено Тогда
		Мсп_ЛогированиеКлиент.Важно("MCP_PROMPT_GET ignored: Компонента is undefined");
		Возврат Ложь;
	КонецЕсли;
	Если Не ЗначениеЗаполнено(ЗапросJSON) Тогда
		Мсп_ЛогированиеКлиент.Важно("MCP_PROMPT_GET ignored: empty request JSON");
		Возврат Ложь;
	КонецЕсли;
	Запрос = Мсп_ИнструментыКлиент.ПрочитатьJSONСтрокуБезОшибок(ЗапросJSON, Неопределено);
	Если ТипЗнч(Запрос) <> Тип("Структура")
		И ТипЗнч(Запрос) <> Тип("Соответствие") Тогда
		Мсп_ЛогированиеКлиент.Важно("MCP_PROMPT_GET ignored: request is not object");
		Возврат Ложь;
	КонецЕсли;
	Идентификатор = Мсп_ИнструментыКлиент.ПолучитьСвойство(Запрос, "id", "");
	Если Не ЗначениеЗаполнено(Идентификатор) Тогда
		Мсп_ЛогированиеКлиент.Важно("MCP_PROMPT_GET ignored: missing id");
		Возврат Ложь;
	КонецЕсли;
	ИмяПромпта = Мсп_ИнструментыКлиент.ПолучитьСвойство(Запрос, "name", "");
	Аргументы = Мсп_ИнструментыКлиент.ПолучитьСвойство(Запрос, "arguments", Неопределено);
	Если ТипЗнч(Аргументы) <> Тип("Структура")
		И ТипЗнч(Аргументы) <> Тип("Соответствие") Тогда
		Аргументы = Новый Структура;
	КонецЕсли;
	Параметры = Новый Структура("name", ИмяПромпта);
	Если Аргументы <> Неопределено Тогда
		Параметры.Вставить("arguments", Аргументы);
	КонецЕсли;
	Ответ = Мсп_ПротоколКлиент.ОтветПолучитьПромпт(Идентификатор, Параметры, "");
	Возврат Ждать ОтправитьОтвет(Идентификатор, Ответ);
КонецФункции

Процедура ОбработатьNotification(ЗапросJSON)
	Если Не ЗначениеЗаполнено(ЗапросJSON) Тогда
		Возврат;
	КонецЕсли;
	Запрос = Мсп_ИнструментыКлиент.ПрочитатьJSONСтрокуБезОшибок(ЗапросJSON, Неопределено);
	Если ТипЗнч(Запрос) <> Тип("Структура")
		И ТипЗнч(Запрос) <> Тип("Соответствие") Тогда
		Возврат;
	КонецЕсли;
	Метод = Мсп_ИнструментыКлиент.ПолучитьСвойство(Запрос, "method", "");
	Если ЗначениеЗаполнено(Метод) Тогда
		Мсп_ЛогированиеКлиент.Отладка("MCP notify: %1", Метод);
	КонецЕсли;
КонецПроцедуры

Асинх Функция ОтправитьОтвет(Идентификатор, Данные)
	Компонента = ЭкземплярСервера();
	Если Компонента = Неопределено Тогда
		Мсп_ЛогированиеКлиент.Важно("MCP response ignored: Компонента is undefined");
		Возврат Ложь;
	КонецЕсли;
	ОтветJSON = Мсп_ПротоколКлиент.Сериализовать(Данные);
	Попытка
		РезультатОтправки = Ждать Компонента.ОтправитьMCPОтветАсинх(
			Идентификатор,
			200,
			"{""Content-Type"":""application/json; charset=utf-8""}",
			ОтветJSON);
		Если РезультатОтправки.Значение = Ложь Тогда
			Мсп_ЛогированиеКлиент.Ошибка("MCP response send error id=%1", Идентификатор);
			Возврат Ложь;
		КонецЕсли;
		Мсп_ЛогированиеКлиент.Отладка("MCP response send ok id=%1", Идентификатор);
	Исключение
		Мсп_ЛогированиеКлиент.Ошибка(ИнформацияОбОшибке());
		Возврат Ложь;
	КонецПопытки;
	Возврат Истина;
КонецФункции

Асинх Процедура СинхронизироватьРеестрыСКомпонентой(Компонента)
	Если Компонента = Неопределено Тогда
		Мсп_ЛогированиеКлиент.Важно("Registry sync skipped: Компонента is undefined");
		Возврат;
	КонецЕсли;

	Попытка
		Ждать Компонента.ОчиститьИнструментыАсинх();
		Ждать Компонента.ОчиститьРесурсыАсинх();
		Ждать Компонента.ОчиститьПромптыАсинх();
	Исключение
		Мсп_ЛогированиеКлиент.Ошибка(ИнформацияОбОшибке());
		Возврат;
	КонецПопытки;

	Для Каждого Элемент Из Мсп_РеестрКлиент.РеестрИнструментов() Цикл
		Дескриптор = Элемент.Значение;
		Описание = Мсп_ПротоколКлиент.НовыйОписаниеИнструмента(
			Дескриптор.Имя,
			Дескриптор.Описание,
			Дескриптор.СхемаПараметров);
		Попытка
			РезультатРегистрации = Ждать Компонента.ЗарегистрироватьИнструментАсинх(
				Мсп_ПротоколКлиент.Сериализовать(Описание));
			Если РезультатРегистрации.Значение = Ложь Тогда
				Мсп_ЛогированиеКлиент.Важно("Tool register failed name=%1", Дескриптор.Имя);
			КонецЕсли;
		Исключение
			Мсп_ЛогированиеКлиент.Ошибка(ИнформацияОбОшибке());
		КонецПопытки;
	КонецЦикла;

	Для Каждого Элемент Из Мсп_РеестрКлиент.РеестрРесурсов() Цикл
		Дескриптор = Элемент.Значение;
		Описание = Мсп_ПротоколКлиент.НовыйОписаниеРесурса(
			Дескриптор.URI,
			Дескриптор.Имя,
			Дескриптор.Описание,
			Дескриптор.MimeType);
		Попытка
			РезультатРегистрации = Ждать Компонента.ЗарегистрироватьРесурсАсинх(
				Мсп_ПротоколКлиент.Сериализовать(Описание));
			Если РезультатРегистрации.Значение = Ложь Тогда
				Мсп_ЛогированиеКлиент.Важно("Resource register failed uri=%1", Дескриптор.URI);
			КонецЕсли;
		Исключение
			Мсп_ЛогированиеКлиент.Ошибка(ИнформацияОбОшибке());
		КонецПопытки;
	КонецЦикла;

	Для Каждого Элемент Из Мсп_РеестрКлиент.РеестрПромптов() Цикл
		Дескриптор = Элемент.Значение;
		Описание = Мсп_ПротоколКлиент.НовыйОписаниеПромпта(
			Дескриптор.Имя,
			Дескриптор.Описание,
			Дескриптор.Аргументы);
		Попытка
			РезультатРегистрации = Ждать Компонента.ЗарегистрироватьПромптАсинх(
				Мсп_ПротоколКлиент.Сериализовать(Описание));
			Если РезультатРегистрации.Значение = Ложь Тогда
				Мсп_ЛогированиеКлиент.Важно("Prompt register failed name=%1", Дескриптор.Имя);
			КонецЕсли;
		Исключение
			Мсп_ЛогированиеКлиент.Ошибка(ИнформацияОбОшибке());
		КонецПопытки;
	КонецЦикла;
КонецПроцедуры

Процедура ОбработкаЗапускаMCP(РезультатВызова, ПараметрыВызова, Компонента = Неопределено) Экспорт
	Если РезультатВызова = Ложь Тогда
		Мсп_ЛогированиеКлиент.Ошибка("MCP start error err=%1", ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		Если Компонента <> Неопределено Тогда
			Если ЭкземплярСервера() = Компонента Тогда
				Мсп_СостояниеКлиент.УстановитьСостояниеЗначение("Компонента", Неопределено);
			КонецЕсли;
		КонецЕсли;
		Если Компонента = Неопределено Или ЭкземплярСервера() = Компонента Тогда
			Мсп_СостояниеКлиент.УстановитьСостояниеЗначение("СерверЗапущен", Ложь);
		КонецЕсли;
		Возврат;
	КонецЕсли;

	Если Компонента = Неопределено Или ЭкземплярСервера() = Компонента Тогда
		Мсп_СостояниеКлиент.УстановитьСостояниеЗначение("СерверЗапущен", Истина);
	КонецЕсли;
КонецПроцедуры

Процедура ОбработкаОстановкиMCP(РезультатВызова, ПараметрыВызова, Компонента = Неопределено) Экспорт
	Если РезультатВызова = Ложь Тогда
		Мсп_ЛогированиеКлиент.Ошибка("MCP stop error err=%1", ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		Если Компонента = Неопределено Или ЭкземплярСервера() = Компонента Тогда
			Мсп_СостояниеКлиент.УстановитьСостояниеЗначение("СерверЗапущен", Истина);
		КонецЕсли;
		Возврат;
	КонецЕсли;

	Если Компонента = Неопределено Или ЭкземплярСервера() = Компонента Тогда
		Мсп_СостояниеКлиент.УстановитьСостояниеЗначение("Компонента", Неопределено);
		Мсп_СостояниеКлиент.УстановитьСостояниеЗначение("СерверЗапущен", Ложь);
		Мсп_ЛогированиеКлиент.Информация("Server stopped");
	КонецЕсли;
КонецПроцедуры

#КонецОбласти
