// Отправляет JSON-RPC ответ по ранее принятому запросу.
//
// Параметры:
//  Идентификатор - Произвольный - Идентификатор запроса.
//  Данные - Структура - JSON-RPC ответ.
//
// Возвращаемое значение:
//  Булево - Истина, если ответ отправлен.
Асинх Функция ОтправитьОтвет(Идентификатор, Данные) Экспорт
	Возврат Ждать Мсп_ТранспортСобытияКлиент.ОтправитьОтвет(Идентификатор, Данные);
КонецФункции

Асинх Процедура УведомитьОПрогрессе(ТокенПрогресса, Прогресс, Всего = Неопределено, Сообщение = "") Экспорт
	Если ТокенПрогресса = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Компонента = ЭкземплярСервера();
	Если Компонента = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Попытка
		Попытка
			РезультатОтправки = Ждать Компонента.УведомитьОПрогрессеАсинх(ТокенПрогресса, Прогресс, Всего, Сообщение);
		Исключение
			РезультатОтправки = Компонента.УведомитьОПрогрессе(ТокенПрогресса, Прогресс, Всего, Сообщение);
		КонецПопытки;
		Если Не ВызовКомпонентыУспешен(РезультатОтправки) Тогда
			Мсп_ЛогированиеКлиент.Ошибка("MCP progress send error");
		КонецЕсли;
	Исключение
		Мсп_ЛогированиеКлиент.Ошибка(ИнформацияОбОшибке());
	КонецПопытки;
КонецПроцедуры

Функция ВызовКомпонентыУспешен(РезультатВызова) Экспорт
	Если РезультатВызова = Неопределено Тогда
		ВызватьИсключение "Результат вызова компоненты не определен.";
	КонецЕсли;

	Если ТипЗнч(РезультатВызова) = Тип("Булево") Тогда
		Возврат РезультатВызова;
	КонецЕсли;

	Если ТипЗнч(РезультатВызова) = Тип("Структура") Тогда
		Значение = Мсп_Коллекции.Свойство(РезультатВызова, "Значение", Неопределено);
		Если ТипЗнч(Значение) <> Тип("Булево") Тогда
			ВызватьИсключение "Результат вызова компоненты должен содержать булево поле Значение.";
		КонецЕсли;
		Возврат Значение;
	КонецЕсли;

	ВызватьИсключение "Результат вызова компоненты имеет недопустимый тип.";
КонецФункции

#КонецОбласти
