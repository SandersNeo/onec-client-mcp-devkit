#Область ПрограммныйИнтерфейс

// Завершает task-based выполнение инструмента успешным результатом.
//
// Параметры:
//  ИдентификаторЗадачи - Строка - Идентификатор MCP-задачи.
//  РезультатИнструмента - Произвольный - Результат инструмента.
Асинх Процедура ЗавершитьЗадачуУспешно(ИдентификаторЗадачи, РезультатИнструмента) Экспорт
	Если Не ЗначениеЗаполнено(ИдентификаторЗадачи) Тогда
		Возврат;
	КонецЕсли;

	Компонента = ЭкземплярСервера();
	Если Компонента = Неопределено Тогда
		Мсп_ЛогированиеКлиент.Важно("Task completion ignored: Компонента is undefined");
		Возврат;
	КонецЕсли;

	Подготовлено = Мсп_ПротоколКлиент.ПодготовитьУспешноеЗавершениеЗадачиИнструмента(РезультатИнструмента);
	ЗавершитьЗадачу(Компонента, ИдентификаторЗадачи, Подготовлено);
КонецПроцедуры

// Завершает task-based выполнение инструмента ошибкой.
//
// Параметры:
//  ИдентификаторЗадачи - Строка - Идентификатор MCP-задачи.
//  КодОшибки - Строка - Код ошибки инструмента.
//  Ошибка - Строка - Описание ошибки.
Асинх Процедура ЗавершитьЗадачуСОшибкой(ИдентификаторЗадачи, КодОшибки, Ошибка) Экспорт
	Если Не ЗначениеЗаполнено(ИдентификаторЗадачи) Тогда
		Возврат;
	КонецЕсли;

	Компонента = ЭкземплярСервера();
	Если Компонента = Неопределено Тогда
		Мсп_ЛогированиеКлиент.Важно("Task completion ignored: Компонента is undefined");
		Возврат;
	КонецЕсли;

	Подготовлено = Мсп_ПротоколКлиент.ПодготовитьОшибочноеЗавершениеЗадачиИнструмента(КодОшибки, Ошибка);
	ЗавершитьЗадачу(Компонента, ИдентификаторЗадачи, Подготовлено);
КонецПроцедуры

// Завершает task-based выполнение по ответу обработчика.
//
// Параметры:
//  ИдентификаторЗадачи - Строка - Идентификатор MCP-задачи.
//  РезультатИнструмента - Произвольный - Ответ обработчика.
Асинх Процедура ЗавершитьЗадачуПоОтветуИнструмента(ИдентификаторЗадачи, РезультатИнструмента) Экспорт
	Если Не ЗначениеЗаполнено(ИдентификаторЗадачи) Тогда
		Возврат;
	КонецЕсли;

	Компонента = ЭкземплярСервера();
	Если Компонента = Неопределено Тогда
		Мсп_ЛогированиеКлиент.Важно("Task completion ignored: Компонента is undefined");
		Возврат;
	КонецЕсли;

	Подготовлено = Мсп_ПротоколКлиент.ПодготовитьЗавершениеЗадачиИнструмента(РезультатИнструмента);
	ЗавершитьЗадачу(Компонента, ИдентификаторЗадачи, Подготовлено);
КонецПроцедуры

// Устанавливает статус task-based задачи.
//
// Параметры:
//  ИдентификаторЗадачи - Строка - Идентификатор MCP-задачи.
//  Статус - Строка - Статус задачи.
//  Сообщение - Строка - Человекочитаемое описание.
Асинх Процедура УстановитьСтатусЗадачи(ИдентификаторЗадачи, Статус, Сообщение = "") Экспорт
	Если Не ЗначениеЗаполнено(ИдентификаторЗадачи) Тогда
		Возврат;
	КонецЕсли;

	Компонента = ЭкземплярСервера();
	Если Компонента = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Попытка
		Попытка
			Ждать Компонента.УстановитьСтатусMCPЗадачиАсинх(ИдентификаторЗадачи, Статус, Сообщение);
		Исключение
			Компонента.УстановитьСтатусMCPЗадачи(ИдентификаторЗадачи, Статус, Сообщение);
		КонецПопытки;
	Исключение
		Мсп_ЛогированиеКлиент.Ошибка(ИнформацияОбОшибке());
	КонецПопытки;
КонецПроцедуры

// Отправляет progress task-based задачи.
//
// Параметры:
//  ИдентификаторЗадачи - Строка - Идентификатор MCP-задачи.
//  Прогресс - Число - Текущее значение progress.
//  Всего - Число - Общее количество шагов.
//  Сообщение - Строка - Описание progress.
Асинх Процедура УведомитьОПрогрессеЗадачи(ИдентификаторЗадачи, Прогресс, Всего = Неопределено, Сообщение = "") Экспорт
	Если Не ЗначениеЗаполнено(ИдентификаторЗадачи) Тогда
		Возврат;
	КонецЕсли;

	Компонента = ЭкземплярСервера();
	Если Компонента = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Попытка
		Попытка
			Ждать Компонента.УведомитьОПрогрессеMCPЗадачиАсинх(ИдентификаторЗадачи, Прогресс, Всего, Сообщение);
		Исключение
			Компонента.УведомитьОПрогрессеMCPЗадачи(ИдентификаторЗадачи, Прогресс, Всего, Сообщение);
		КонецПопытки;
	Исключение
		Мсп_ЛогированиеКлиент.Ошибка(ИнформацияОбОшибке());
	КонецПопытки;
КонецПроцедуры

// Возвращает признак отмены задачи.
//
// Параметры:
//  ИдентификаторЗадачи - Строка - Идентификатор MCP-задачи.
//
// Возвращаемое значение:
//  Булево - Истина, если задача отменена.
Функция ЗадачаОтменена(ИдентификаторЗадачи) Экспорт
	Если Не ЗначениеЗаполнено(ИдентификаторЗадачи) Тогда
		Возврат Ложь;
	КонецЕсли;

	Возврат ОтмененныеЗадачи().Получить(ИдентификаторЗадачи) = Истина;
КонецФункции

// Снимает признак отмены задачи.
//
// Параметры:
//  ИдентификаторЗадачи - Строка - Идентификатор MCP-задачи.
Процедура ОчиститьОтменуЗадачи(ИдентификаторЗадачи) Экспорт
	Если Не ЗначениеЗаполнено(ИдентификаторЗадачи) Тогда
		Возврат;
	КонецЕсли;

	ОтмененныеЗадачи().Удалить(ИдентификаторЗадачи);
КонецПроцедуры

// Выполняет async-инструмент в task-based режиме.
//
// Параметры:
//  Дескриптор - Структура - Описание инструмента.
//  Запрос - Структура - Нормализованный запрос обработчика.
//  ИдентификаторЗадачи - Строка - Идентификатор MCP-задачи.
Асинх Процедура ВызватьАсинхронныйОбработчик(Дескриптор, Запрос, ИдентификаторЗадачи) Экспорт
	УстановитьСтатусЗадачи(ИдентификаторЗадачи, "working");
	Попытка
		Результат = ВыполнитьОповещение(Дескриптор.Обработчик, Запрос);
	Исключение
		ЗавершитьЗадачуСОшибкой(
			ИдентификаторЗадачи,
			"ACTION_FAILED",
			ИнформацияОбОшибке().Описание);
		Возврат;
	КонецПопытки;

	Если Результат <> Неопределено Тогда
		ЗавершитьЗадачуПоОтветуИнструмента(ИдентификаторЗадачи, Результат);
	КонецЕсли;
КонецПроцедуры

// Обрабатывает уведомление об отмене MCP-задачи.
//
// Параметры:
//  ЗапросJSON - Строка - JSON с полем taskId.
Процедура ОбработатьTaskCancelled(ЗапросJSON) Экспорт
	Если Не ЗначениеЗаполнено(ЗапросJSON) Тогда
		Возврат;
	КонецЕсли;

	Запрос = Мсп_СериализацияКлиент.ПрочитатьJSONСтрокуБезОшибок(ЗапросJSON, Неопределено);
	Если ТипЗнч(Запрос) <> Тип("Структура")
		И ТипЗнч(Запрос) <> Тип("Соответствие") Тогда
		Возврат;
	КонецЕсли;

	ИдентификаторЗадачи = Мсп_Коллекции.Свойство(Запрос, "taskId", "");
	Если Не ЗначениеЗаполнено(ИдентификаторЗадачи) Тогда
		Возврат;
	КонецЕсли;

	ОтмененныеЗадачи().Вставить(ИдентификаторЗадачи, Истина);
	Мсп_ЛогированиеКлиент.Информация("Task cancelled taskId=%1", ИдентификаторЗадачи);
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Асинх Процедура ЗавершитьЗадачу(Компонента, ИдентификаторЗадачи, Подготовлено)
	Если Подготовлено = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Попытка
		Если ЗначениеЗаполнено(Подготовлено.Статус) Тогда
			Попытка
				Ждать Компонента.УстановитьСтатусMCPЗадачиАсинх(ИдентификаторЗадачи, Подготовлено.Статус, Подготовлено.Сообщение);
			Исключение
				Компонента.УстановитьСтатусMCPЗадачи(ИдентификаторЗадачи, Подготовлено.Статус, Подготовлено.Сообщение);
			КонецПопытки;
		КонецЕсли;
		Попытка
			Ждать Компонента.ЗавершитьMCPЗадачуАсинх(
				ИдентификаторЗадачи,
				200,
				"{""Content-Type"":""application/json; charset=utf-8""}",
				Мсп_СериализацияКлиент.Сериализовать(Подготовлено.Тело));
		Исключение
			Компонента.ЗавершитьMCPЗадачу(
				ИдентификаторЗадачи,
				200,
				"{""Content-Type"":""application/json; charset=utf-8""}",
				Мсп_СериализацияКлиент.Сериализовать(Подготовлено.Тело));
		КонецПопытки;
		ОчиститьОтменуЗадачи(ИдентификаторЗадачи);
	Исключение
		Мсп_ЛогированиеКлиент.Ошибка(ИнформацияОбОшибке());
	КонецПопытки;
КонецПроцедуры

Функция ЭкземплярСервера()
	Возврат Мсп_СостояниеКлиент.ЗначениеСостоянияСервера("Компонента", Неопределено);
КонецФункции

Функция ОтмененныеЗадачи()
	Отмененные = Мсп_СостояниеКлиент.ЗначениеСостоянияСервера("ОтмененныеЗадачи", Неопределено);
	Если Отмененные = Неопределено Тогда
		Отмененные = Новый Соответствие;
		Мсп_СостояниеКлиент.УстановитьЗначениеСостоянияСервера("ОтмененныеЗадачи", Отмененные);
	КонецЕсли;

	Возврат Отмененные;
КонецФункции

Функция ВыполнитьОповещение(Оповещение, Запрос)
	Если Оповещение = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;

	Возврат ВыполнитьОбработкуОповещения(Оповещение, Запрос);
КонецФункции

#КонецОбласти
