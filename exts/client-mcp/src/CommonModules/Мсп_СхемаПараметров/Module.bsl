#Область ПрограммныйИнтерфейс

// Конструктор JSON-схемы объекта.
//
// Параметры:
//  Свойства - Структура - Свойства схемы.
//  ТребуемыеПоля - Массив, Неопределено - Список обязательных полей.
//
// Возвращаемое значение:
//  Структура - JSON-схема объекта.
Функция НовыйСхемаОбъекта(Свойства, ТребуемыеПоля = Неопределено) Экспорт
	Схема = Новый Структура;
	Схема.Вставить("type", "object");
	Схема.Вставить("properties", Свойства);
	Если ТребуемыеПоля <> Неопределено Тогда
		Схема.Вставить("required", ТребуемыеПоля);
	КонецЕсли;
	Схема.Вставить("additionalProperties", Ложь);
	Возврат Схема;
КонецФункции

// Конструктор свойства JSON-схемы.
//
// Параметры:
//  Тип - Строка - Тип свойства (string, number и т.д.).
//  Описание - Строка - Описание свойства.
//
// Возвращаемое значение:
//  Структура - Описание свойства схемы.
Функция НовыйСвойствоСхемы(Тип, Описание = "") Экспорт
	Свойство = Новый Структура;
	Свойство.Вставить("type", Тип);
	Если ЗначениеЗаполнено(Описание) Тогда
		Свойство.Вставить("description", Описание);
	КонецЕсли;
	Возврат Свойство;
КонецФункции

// Конструктор свойства JSON-схемы с перечислением допустимых значений.
//
// Параметры:
//  Тип - Строка - Тип свойства.
//  Описание - Строка - Описание свойства.
//  ДопустимыеЗначения - Массив - Список допустимых значений (enum).
//
// Возвращаемое значение:
//  Структура - Описание свойства схемы.
Функция НовыйСвойствоСхемыСEnum(Тип, Описание, ДопустимыеЗначения) Экспорт
	Свойство = НовыйСвойствоСхемы(Тип, Описание);
	Свойство.Вставить("enum", ДопустимыеЗначения);
	Возврат Свойство;
КонецФункции

#КонецОбласти
