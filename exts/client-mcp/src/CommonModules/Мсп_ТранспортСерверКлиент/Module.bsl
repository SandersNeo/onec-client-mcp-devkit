#Область ПрограммныйИнтерфейс

// Запускает MCP-сервер и инициализирует состояние.
//
// Параметры:
//  НомерПорта - Число - Номер порта для прослушивания.
//  РазрешенныеOrigins - Строка - Допустимые origins ("" | "*" | JSON-массив строк).
//  ТаймаутСек - Число - Таймаут ожидания ответа от 1С.
//
// Возвращаемое значение:
//  Булево - Истина, если запрос на запуск отправлен.
Асинх Функция ЗапуститьСервер(НомерПорта, РазрешенныеOrigins = "", ТаймаутСек = 900) Экспорт
	СохранитьПараметрыПодключения(НомерПорта, РазрешенныеOrigins, ТаймаутСек);

	Мсп_ЛогированиеКлиент.Информация("Server startup:
								 |  port=%1
								 |  timeout=%2
								 |  origins=%3", НомерПорта, ТаймаутСек, РазрешенныеOrigins);

	Ждать ПодключитьКомпоненту();

	Компонента = ЭкземплярСервера();
	Если Компонента <> Неопределено Тогда
		Мсп_ЛогированиеКлиент.Информация("Server startup: stopping previous MCP server");
		ОстановитьКомпоненту(Компонента);
		Мсп_ЛогированиеКлиент.Информация("Server startup: stop requested for previous server");
	КонецЕсли;

	Мсп_ЛогированиеКлиент.Информация("Server startup: create addin AddIn.WebTransport.mcp");
	Компонента = Новый("AddIn.WebTransport.mcp");
	Мсп_ЛогированиеКлиент.Информация("Server startup: MCP start requested address=%1", АдресПрослушивания());
	Мсп_СостояниеКлиент.УстановитьЗначениеСостоянияСервера("Компонента", Компонента);

	Ждать ЗапуститьКомпоненту(Компонента, РазрешенныеOrigins, ТаймаутСек);
	Ждать Мсп_ТранспортРеестрыКлиент.ИнициализироватьРеестрыСервера();
	Мсп_ЛогированиеКлиент.Информация("Server start requested on %1", АдресПрослушивания());

	Возврат Истина;
КонецФункции

// Останавливает MCP-сервер.
//
// Возвращаемое значение:
//  Булево - Истина, если запрос на остановку обработан.
Асинх Функция ОстановитьСервер() Экспорт
	Компонента = ЭкземплярСервера();
	Мсп_СостояниеКлиент.УстановитьЗначениеСостоянияСервера("СерверЗапущен", Ложь);
	Если Компонента <> Неопределено Тогда
		ОстановитьКомпоненту(Компонента);
	КонецЕсли;
	Мсп_ЛогированиеКлиент.Информация("Server stop requested");
	Возврат Истина;
КонецФункции

// Возвращает экземпляр внешней компоненты MCP (если инициализирована).
//
// Возвращаемое значение:
//  ВнешнийОбъект - Экземпляр внешней компоненты или Неопределено.
Функция ЭкземплярСервера() Экспорт
	Возврат Мсп_СостояниеКлиент.ЗначениеСостоянияСервера("Компонента", Неопределено);
КонецФункции

// Проверяет, запущен ли MCP-сервер.
//
// Возвращаемое значение:
//  Булево - Истина, если сервер запущен.
Функция СерверЗапущен() Экспорт
	Возврат Мсп_СостояниеКлиент.ЗначениеСостоянияСервера(
		"СерверЗапущен",
		ЭкземплярСервера() <> Неопределено);
КонецФункции

// Возвращает порт MCP-сервера.
//
// Возвращаемое значение:
//  Число - Порт сервера или 0, если не задан.
Функция ПолучитьПортСервера() Экспорт
	Возврат Мсп_СостояниеКлиент.ЗначениеСостоянияСервера("Порт", 0);
КонецФункции

// Возвращает адрес прослушивания MCP-сервера.
//
// Возвращаемое значение:
//  Строка - Адрес прослушивания или пустая строка.
Функция ПолучитьАдресПрослушивания() Экспорт
	Если Мсп_СостояниеКлиент.ЗначениеСостоянияСервера("Порт", 0) <= 0 Тогда
		Возврат "";
	КонецЕсли;

	Возврат АдресПрослушивания();
КонецФункции

// Возвращает разрешенные origins MCP-сервера.
//
// Возвращаемое значение:
//  Строка - Строковое представление allow-list.
Функция ПолучитьРазрешенныеOrigins() Экспорт
	Возврат Мсп_СостояниеКлиент.ЗначениеСостоянияСервера("РазрешенныеOrigins", "");
КонецФункции

// Возвращает таймаут ответа от обработчиков MCP.
//
// Возвращаемое значение:
//  Число - Таймаут в секундах.
Функция ПолучитьТаймаутСек() Экспорт
	Возврат Мсп_СостояниеКлиент.ЗначениеСостоянияСервера("ТаймаутСек", 900);
КонецФункции

// Устанавливает метаданные MCP-сервера, возвращаемые клиенту при initialize.
//
// Параметры:
//  ОписаниеJSON - Строка - JSON с полями name, version, title, description, instructions.
//
// Возвращаемое значение:
//  Булево - Истина, если метаданные обработаны без ошибок.
Асинх Функция УстановитьИнформациюОСервере(ОписаниеJSON) Экспорт
	Компонента = ЭкземплярСервера();
	Если Компонента = Неопределено Тогда
		Мсп_ЛогированиеКлиент.Важно("УстановитьИнформациюОСервере ignored: Компонента is undefined");
		Возврат Ложь;
	КонецЕсли;

	Попытка
		Ждать Компонента.УстановитьИнформациюОСервереАсинх(ОписаниеJSON);
	Исключение
		Мсп_ЛогированиеКлиент.Ошибка(ИнформацияОбОшибке());
		Возврат Ложь;
	КонецПопытки;

	Возврат Истина;
КонецФункции

// Отправляет progress-notification для обычного tools/call.
//
// Параметры:
//  ТокенПрогресса - Произвольный - Токен progress notifications из запроса.
//  Прогресс - Число - Текущее значение progress.
//  Всего - Число - Общее количество шагов.
//  Сообщение - Строка - Описание progress.
//
// Возвращаемое значение:
//  Булево - Истина, если уведомление отправлено.
Функция УведомитьОПрогрессе(ТокенПрогресса, Прогресс, Всего = Неопределено, Сообщение = "") Экспорт
	Если ТокенПрогресса = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;

	Компонента = ЭкземплярСервера();
	Если Компонента = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;

	Попытка
		Возврат Компонента.УведомитьОПрогрессе(ТокенПрогресса, Прогресс, Всего, Сообщение);
	Исключение
		Мсп_ЛогированиеКлиент.Ошибка(ИнформацияОбОшибке());
	КонецПопытки;
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура СохранитьПараметрыПодключения(НомерПорта, РазрешенныеOrigins, ТаймаутСек)
	Мсп_СостояниеКлиент.УстановитьЗначениеСостоянияСервера("Порт", НомерПорта);
	Мсп_СостояниеКлиент.УстановитьЗначениеСостоянияСервера("РазрешенныеOrigins", РазрешенныеOrigins);
	Мсп_СостояниеКлиент.УстановитьЗначениеСостоянияСервера("ТаймаутСек", ТаймаутСек);
КонецПроцедуры

Асинх Функция ПодключитьКомпоненту()
	МакетКомпоненты = "ОбщийМакет.Мсп_webTransport";
	ИмяКомпоненты = "WebTransport";
	Мсп_ЛогированиеКлиент.Информация("Component connect: begin name=%1 layout=%2", ИмяКомпоненты, МакетКомпоненты);

	Попытка
		Мсп_ЛогированиеКлиент.Информация("Component connect: try connect");
		Подключено = Ждать ПодключитьКомпонентуАсинх(МакетКомпоненты, ИмяКомпоненты);

		Если Не Подключено Тогда
			Мсп_ЛогированиеКлиент.Информация("Component connect: install component from layout");
			Ждать УстановитьВнешнююКомпонентуАсинх(МакетКомпоненты);
			Мсп_ЛогированиеКлиент.Информация("Component connect: retry connect");
			Подключено = Ждать ПодключитьКомпонентуАсинх(МакетКомпоненты, ИмяКомпоненты);
		КонецЕсли;
	Исключение
		ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		Мсп_ЛогированиеКлиент.Ошибка("Component connect error: %1", ТекстОшибки);
		ВызватьИсключение СтрШаблон(
			"Не удалось подключить внешнюю компоненту %1 (%2): %3",
			ИмяКомпоненты,
			МакетКомпоненты,
			ТекстОшибки);
	КонецПопытки;

	Если Не Подключено Тогда
		Мсп_ЛогированиеКлиент.Ошибка("Component connect failed: no connection established");
		ВызватьИсключение СтрШаблон(
			"Не удалось подключить внешнюю компоненту %1 (%2).",
			ИмяКомпоненты,
			МакетКомпоненты);
	КонецЕсли;

	Мсп_ЛогированиеКлиент.Информация("Component connect: success");

	Возврат Истина;
КонецФункции

Асинх Функция ПодключитьКомпонентуАсинх(МакетКомпоненты, ИмяКомпоненты)
	ИспользоватьТипПодключения = Ложь;

	Попытка
		ТипПодключения = Вычислить("ТипПодключенияВнешнейКомпоненты.НеИзолированно");
		ИспользоватьТипПодключения = Истина;
	Исключение
	КонецПопытки;

	Если ИспользоватьТипПодключения Тогда
		Возврат Ждать Вычислить(
			"ПодключитьВнешнююКомпонентуАсинх(МакетКомпоненты, ИмяКомпоненты, ТипВнешнейКомпоненты.Native, ТипПодключения)");
	КонецЕсли;

	Возврат Ждать ПодключитьВнешнююКомпонентуАсинх(
		МакетКомпоненты,
		ИмяКомпоненты,
		ТипВнешнейКомпоненты.Native);
КонецФункции

Асинх Процедура ОстановитьКомпоненту(Компонента)
	Попытка
		РезультатОстановки = Ждать Компонента.ОстановитьАсинх();
		ОбработатьОстановкуMCP(РезультатОстановки.Значение, Компонента);
	Исключение
		Мсп_ЛогированиеКлиент.Ошибка(ИнформацияОбОшибке());
		ОбработатьОстановкуMCP(Ложь, Компонента);
	КонецПопытки;
КонецПроцедуры

Асинх Функция ЗапуститьКомпоненту(Компонента, РазрешенныеOrigins, ТаймаутСек)
	Попытка
		РезультатЗапуска = Ждать Компонента.ЗапуститьАсинх(
			АдресПрослушивания(),
			РазрешенныеOrigins,
			ТаймаутСек);
		ОбработатьЗапускMCP(РезультатЗапуска.Значение, Компонента);
	Исключение
		Мсп_ЛогированиеКлиент.Ошибка(ИнформацияОбОшибке());
		ОбработатьЗапускMCP(Ложь, Компонента);
	КонецПопытки;

	Возврат Истина;
КонецФункции

Функция АдресПрослушивания()
	Порт = Мсп_СостояниеКлиент.ЗначениеСостоянияСервера("Порт", 0);
	Возврат "127.0.0.1:" + Формат(Порт, "ЧГ=0");
КонецФункции

Процедура ОбработатьЗапускMCP(РезультатВызова, Компонента = Неопределено)
	Если РезультатВызова = Ложь Тогда
		Мсп_ЛогированиеКлиент.Ошибка("MCP start error: component returned false");
		Если Компонента <> Неопределено Тогда
			Если ЭкземплярСервера() = Компонента Тогда
				Мсп_СостояниеКлиент.УстановитьЗначениеСостоянияСервера("Компонента", Неопределено);
			КонецЕсли;
		КонецЕсли;
		Если Компонента = Неопределено Или ЭкземплярСервера() = Компонента Тогда
			Мсп_СостояниеКлиент.УстановитьЗначениеСостоянияСервера("СерверЗапущен", Ложь);
		КонецЕсли;
		Возврат;
	КонецЕсли;

	Если Компонента = Неопределено Или ЭкземплярСервера() = Компонента Тогда
		Мсп_СостояниеКлиент.УстановитьЗначениеСостоянияСервера("СерверЗапущен", Истина);
	КонецЕсли;
КонецПроцедуры

Процедура ОбработатьОстановкуMCP(РезультатВызова, Компонента = Неопределено)
	Если РезультатВызова = Ложь Тогда
		Мсп_ЛогированиеКлиент.Ошибка("MCP stop error: component returned false");
		Если Компонента = Неопределено Или ЭкземплярСервера() = Компонента Тогда
			Мсп_СостояниеКлиент.УстановитьЗначениеСостоянияСервера("СерверЗапущен", Истина);
		КонецЕсли;
		Возврат;
	КонецЕсли;

	Если Компонента = Неопределено Или ЭкземплярСервера() = Компонента Тогда
		Мсп_СостояниеКлиент.УстановитьЗначениеСостоянияСервера("Компонента", Неопределено);
		Мсп_СостояниеКлиент.УстановитьЗначениеСостоянияСервера("СерверЗапущен", Ложь);
		Мсп_ЛогированиеКлиент.Информация("Server stopped");
	КонецЕсли;
КонецПроцедуры

#КонецОбласти
