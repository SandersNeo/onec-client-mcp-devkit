#Область ПрограммныйИнтерфейс

// Запускает тест-клиент 1С и устанавливает соединение.
//
// Параметры:
//  Порт - Произвольный - Номер порта тест-клиента.
//
// Возвращаемое значение:
//  см. НовыйРезультатЗапуска
Функция Запустить(Порт = 1538) Экспорт
	Мсп_ЛогированиеКлиент.Информация("Test client start requested port=%1", Порт);
	
	РезультатПодключения = Подключиться(Порт, 2);
	
	Если РезультатПодключения.Подключен Тогда
		Возврат НовыйРезультатЗапуска(Ложь, Истина);
	КонецЕсли;
	
	РезультатЗапуск = ЗапуститьТестКлиент(Порт);
	Если НЕ РезультатЗапуск.Успех Тогда
		Возврат НовыйРезультатЗапуска(
			Ложь, Ложь, РезультатЗапуск.Ошибка);
	КонецЕсли;
	
	РезультатПодключения = Подключиться(Порт, 5);
	
	Возврат НовыйРезультатЗапуска(
		Истина,
		РезультатПодключения.Подключен,
		РезультатПодключения.Ошибка);
КонецФункции

// Подключается к тест-клиенту по порту.
//
// Параметры:
//  Порт - Произвольный - Номер порта тест-клиента.
//  МаксИтераций - Число - Количество попыток подключения.
//
// Возвращаемое значение:
//  см. НовыйРезультатПодключения
Функция Подключиться(Порт = 1538, МаксИтераций = 5) Экспорт
	
	Порт = НормализованныйПорт(Порт);
	Мсп_ЛогированиеКлиент.Информация("Test client connect requested port=%1", Порт);
	
	ТестКлиент = СоздатьТестируемоеПриложение(Порт);
	РезультатПодключения = ПодключитьсяКТестКлиенту(ТестКлиент, МаксИтераций);
	Если РезультатПодключения.Успех Тогда
		Мсп_ЛогированиеКлиент.Информация("Test client connected port=%1", Порт);
	Иначе
		Мсп_ЛогированиеКлиент.Важно("Test client connect failed: %1", РезультатПодключения.Ошибка);
	КонецЕсли;
	
	Память = ПолучитьПамятьТестКлиент();
	Память.Вставить("ТестКлиент", ТестКлиент);
	Память.Вставить("Подключен", РезультатПодключения.Успех);
	Память.Вставить("ПоследняяОшибка", РезультатПодключения.Ошибка);
	Память.Вставить("Порт", Порт);
	СохранитьПамятьТестКлиент(Память);
	
	Возврат НовыйРезультатПодключения(
		РезультатПодключения.Успех,
		РезультатПодключения.Ошибка);
	
КонецФункции

// Останавливает тест-клиент 1С и разрывает соединение.
//
// Возвращаемое значение:
//  см. НовыйРезультатОстановки
Функция Остановить() Экспорт
	Память = ПолучитьПамятьТестКлиент();
	ТестКлиент = ПолучитьЗначениеПамяти(Память, "ТестКлиент", Неопределено);
	Если ТестКлиент = Неопределено Тогда
		Мсп_ЛогированиеКлиент.Важно("Test client stop requested but no active client");
		Возврат НовыйРезультатОстановки(Ложь, "test client not started");
	КонецЕсли;
	
	Мсп_ЛогированиеКлиент.Информация("Test client stop requested");
	Ошибка = "";
	Попытка
		ТестКлиент.РазорватьСоединение();
	Исключение
		Ошибка = ОписаниеОшибки();
	КонецПопытки;
	
	Если ЗначениеЗаполнено(Ошибка) Тогда
		Мсп_ЛогированиеКлиент.Ошибка("Test client stop error: %1", Ошибка);
	Иначе
		Мсп_ЛогированиеКлиент.Информация("Test client stopped");
	КонецЕсли;
	
	Память.Вставить("ТестКлиент", Неопределено);
	Память.Вставить("Подключен", Ложь);
	Память.Вставить("ПоследняяОшибка", Ошибка);
	СохранитьПамятьТестКлиент(Память);
	
	Возврат НовыйРезультатОстановки(Не ЗначениеЗаполнено(Ошибка), Ошибка);
КонецФункции

// Закрывает тест-клиент 1С (закрывает приложение, не только отключает).
//
// Параметры:
//  ТаймаутОжидания - Число - Таймаут ожидания закрытия процесса в секундах.
//  Принудительно - Булево - Признак принудительного завершения процесса.
//
// Возвращаемое значение:
//  см. НовыйРезультатЗакрытия
Функция Закрыть(ТаймаутОжидания = 10, Принудительно = Ложь) Экспорт
	Память = ПолучитьПамятьТестКлиент();
	ТестКлиент = ПолучитьЗначениеПамяти(Память, "ТестКлиент", Неопределено);
	Если ТестКлиент = Неопределено Тогда
		Мсп_ЛогированиеКлиент.Важно("Test client close requested but no active client");
		Возврат НовыйРезультатЗакрытия(Ложь, "test client not started");
	КонецЕсли;

	Мсп_ЛогированиеКлиент.Информация("Test client close requested");

	Ошибка = "";

	Попытка
		ЗакрытьВсеОкнаТестКлиента(ТестКлиент);
	Исключение
		Ошибка = ОписаниеОшибки();
		Мсп_ЛогированиеКлиент.Ошибка("Test client close windows error: %1", Ошибка);
	КонецПопытки;

	Попытка
		ОбработатьДиалогЗавершенияРаботы(ТестКлиент);
	Исключение
		Мсп_ЛогированиеКлиент.Информация("No exit dialog found or already closed");
	КонецПопытки;

	Попытка
		ТестКлиент.РазорватьСоединение();
	Исключение
		Ошибка = ОписаниеОшибки();
		Мсп_ЛогированиеКлиент.Ошибка("Test client disconnect error: %1", Ошибка);
	КонецПопытки;

	Память = НоваяПамятьТестКлиента();
	СохранитьПамятьТестКлиент(Память);

	Мсп_ЛогированиеКлиент.Информация("Test client closed");

	Возврат НовыйРезультатЗакрытия(Не ЗначениеЗаполнено(Ошибка), Ошибка);
КонецФункции

// Возвращает объект тест-клиента из состояния.
//
// Возвращаемое значение:
//  ТестируемоеПриложение, Неопределено - Объект тест-клиента.
Функция ПолучитьТестКлиент() Экспорт
	Память = ПолучитьПамятьТестКлиент();
	Возврат ПолучитьЗначениеПамяти(Память, "ТестКлиент", Неопределено);
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ЗапуститьТестКлиент(Знач Порт)
	Порт = НормализованныйПорт(Порт);
	
	КомандаЗапуска = СформироватьКомандуЗапуска(Порт);
	Мсп_ЛогированиеКлиент.Информация("Test client command line: %1", КомандаЗапуска);
	Если Не ЗначениеЗаполнено(КомандаЗапуска) Тогда
		Мсп_ЛогированиеКлиент.Ошибка("Test client start error: command line is empty");
		Возврат НовыйРезультатОшибка("Не удалось сформировать команду запуска");
	КонецЕсли;
	
	РезультатЗапуска = ЗапуститьПроцессТестКлиента(КомандаЗапуска);
	Если Не РезультатЗапуска.Успех Тогда
		Мсп_ЛогированиеКлиент.Ошибка("Test client start error: %1", РезультатЗапуска.Ошибка);
	КонецЕсли;
	
	Память = ПолучитьПамятьТестКлиент();
	Память.Вставить("КомандаЗапуска", КомандаЗапуска);
	СохранитьПамятьТестКлиент(Память);
	
	Возврат РезультатЗапуска;
	
КонецФункции

// Возвращает структуру результата запуска тест-клиента.
//
// Параметры:
//  Запущен - Булево - Признак успешного запуска процесса тест-клиента.
//  Подключен - Булево - Признак успешного подключения к тест-клиенту.
//  Ошибка - Строка - Описание ошибки запуска или подключения.
//         - Неопределено - Ошибка отсутствует.
//
// Возвращаемое значение:
//  Структура - Результат запуска:
//   * Успех - Булево - Признак успешного запуска тест-клиента.
//   * Запущен - Булево - Признак успешного запуска процесса тест-клиента.
//   * Подключен - Булево - Признак успешного подключения к тест-клиенту.
//   * Ошибка - Строка - Описание ошибки запуска или подключения.
//              - Неопределено - Ошибка отсутствует.
Функция НовыйРезультатЗапуска(Запущен, Подключен, Ошибка = Неопределено)
	Возврат Новый Структура(
		"Успех, Запущен, Подключен, Ошибка",
		Подключен,
		Запущен,
		Подключен,
		Ошибка);
КонецФункции

// Возвращает структуру неуспешного результата операции.
//
// Параметры:
//  Ошибка - Строка - Описание ошибки операции.
//
// Возвращаемое значение:
//  Структура - Результат операции:
//   * Успех - Булево - Всегда Ложь.
//   * Ошибка - Строка - Описание ошибки операции.
Функция НовыйРезультатОшибка(Ошибка)
	
	Возврат Новый Структура("Успех, Ошибка", Ложь, Ошибка);
	
КонецФункции

// Возвращает структуру успешного результата операции.
//
// Возвращаемое значение:
//  Структура - Результат операции:
//   * Успех - Булево - Всегда Истина.
//   * Ошибка - Неопределено - Ошибка отсутствует.
Функция НовыйУспешныйРезультат()
	
	Возврат Новый Структура("Успех, Ошибка", Истина, Неопределено);
	
КонецФункции

// Возвращает структуру результата остановки тест-клиента.
//
// Параметры:
//  Остановлен - Булево - Признак успешной остановки тест-клиента.
//  Ошибка - Строка - Описание ошибки остановки.
//
// Возвращаемое значение:
//  Структура - Результат остановки:
//   * Успех - Булево - Признак успешной остановки тест-клиента.
//   * Остановлен - Булево - Признак успешной остановки тест-клиента.
//   * Ошибка - Строка - Описание ошибки остановки.
Функция НовыйРезультатОстановки(Остановлен, Ошибка)
	Возврат Новый Структура("Успех, Остановлен, Ошибка", Остановлен, Остановлен, Ошибка);
КонецФункции

// Возвращает структуру результата закрытия тест-клиента.
//
// Параметры:
//  Закрыт - Булево - Признак успешного закрытия тест-клиента.
//  Ошибка - Строка - Описание ошибки закрытия.
//
// Возвращаемое значение:
//  Структура - Результат закрытия:
//   * Успех - Булево - Признак успешного закрытия тест-клиента.
//   * Закрыт - Булево - Признак успешного закрытия тест-клиента.
//   * Ошибка - Строка - Описание ошибки закрытия.
Функция НовыйРезультатЗакрытия(Закрыт, Ошибка)
	Возврат Новый Структура("Успех, Закрыт, Ошибка", Закрыт, Закрыт, Ошибка);
КонецФункции

// Закрывает все окна тест-клиента.
//
// Параметры:
//  ТестКлиент - ТестируемоеПриложение - Объект тест-клиента.
Процедура ЗакрытьВсеОкнаТестКлиента(ТестКлиент)
	
	Пока Истина Цикл
		ГлавноеОкно = ТестКлиент.ПолучитьАктивноеОкно();
		Если ГлавноеОкно = Неопределено Тогда
			Возврат;
		КонецЕсли;
		
		ПодчиненныеОкна = ГлавноеОкно.ПолучитьПодчиненныеОбъекты();
		Для Каждого Окно Из ПодчиненныеОкна Цикл
			Попытка
				Окно.Закрыть();
			Исключение
				Мсп_ЛогированиеКлиент.Ошибка("Test client close windows error: %1", ОписаниеОшибки());
			КонецПопытки;
		КонецЦикла;
	
		ГлавноеОкно.Закрыть();
		
		Если ГлавноеОкно.Основное Тогда
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

// Обрабатывает диалог завершения работы приложения.
//
// Параметры:
//  ТестКлиент - ТестируемоеПриложение - Объект тест-клиента.
Процедура ОбработатьДиалогЗавершенияРаботы(ТестКлиент)
	Окна = ТестКлиент.ПолучитьОкна();
	Для Каждого Окно Из Окна Цикл
		Заголовок = Окно.ПолучитьЗаголовок();
		Если СтрНайти(Заголовок, "Завершить работу") > 0
			ИЛИ СтрНайти(Заголовок, "End session") > 0 Тогда
			Кнопки = Окно.ПолучитьПодчиненныеОбъекты();
			Для Каждого Кнопка Из Кнопки Цикл
				ТипЭлемента = Кнопка.ПолучитьТип();
				Если СтрНайти(ТипЭлемента, "Button") > 0
					ИЛИ СтрНайти(ТипЭлемента, "Кнопка") > 0 Тогда
					ТекстКнопки = "";
					Попытка
						ТекстКнопки = Кнопка.ПолучитьЗаголовок();
					Исключение
						ТекстКнопки = "";
					КонецПопытки;
					Если СтрНайти(НРег(ТекстКнопки), "завершить") > 0
						ИЛИ СтрНайти(НРег(ТекстКнопки), "end") > 0 Тогда
						Кнопка.Нажать();
						Прервать;
					КонецЕсли;
				КонецЕсли;
			КонецЦикла;
			Прервать;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

// Возвращает структуру результата подключения к тест-клиенту.
// 
// Параметры:
//  Подключен - Булево - Признак успешного подключения к тест-клиенту.
//  Ошибка - Строка - Описание ошибки подключения.
//         - Неопределено - Ошибка отсутствует.
// 
// Возвращаемое значение:
//  Структура - Результат подключения:
//   * Успех - Булево - Признак успешного подключения к тест-клиенту.
//   * Подключен - Булево - Признак успешного подключения к тест-клиенту.
//   * Ошибка - Строка - Описание ошибки подключения.
//              - Неопределено - Ошибка отсутствует.
Функция НовыйРезультатПодключения(Подключен, Ошибка)
	Возврат Новый Структура("Успех, Подключен, Ошибка", Подключен, Подключен, Ошибка);
КонецФункции

// Возвращает структуру результата подключения к тест-клиенту по порту.
// 
// Параметры:
//  Подключен - Булево - Признак успешного подключения к тест-клиенту.
//  Ошибка - Строка - Описание ошибки подключения.
//         - Неопределено - Ошибка отсутствует.
//  Порт - Число - Порт тест-клиента.
// 
// Возвращаемое значение:
//  Структура - Результат подключения по порту:
//   * Успех - Булево - Признак успешного подключения к тест-клиенту.
//   * Подключен - Булево - Признак успешного подключения к тест-клиенту.
//   * Ошибка - Строка - Описание ошибки подключения.
//              - Неопределено - Ошибка отсутствует.
//   * Порт - Число - Порт тест-клиента.
Функция НовыйРезультатПодключенияПоПорту(Подключен, Ошибка, Порт)
	Результат = НовыйРезультатПодключения(Подключен, Ошибка);
	Результат.Вставить("Порт", Порт);
	Возврат Результат;
КонецФункции

// Возвращает структуру результата запуска процесса тест-клиента.
// 
// Параметры:
//  Успех - Булево - Признак успешного запуска процесса тест-клиента.
//  Ошибка - Строка - Описание ошибки запуска процесса.
// 
// Возвращаемое значение:
//  Структура - Результат запуска процесса:
//   * Успех - Булево - Признак успешного запуска процесса тест-клиента.
//   * Ошибка - Строка - Описание ошибки запуска процесса.
Функция НовыйРезультатЗапускаПроцесса(Успех, Ошибка)
	Возврат Новый Структура("Успех, Ошибка", Успех, Ошибка);
КонецФункции

// Возвращает структуру памяти тест-клиента.
// 
// Возвращаемое значение:
//  Структура - Пустая структура памяти тест-клиента.
//            Поля состояния добавляются по мере работы модуля.
Функция НоваяПамятьТестКлиента()
	Возврат Новый Структура;
КонецФункции

Функция ПолучитьПамятьТестКлиент()
	Память = Мсп_СостояниеКлиент.ПолучитьСостояниеЗначение(КлючПамятиТестКлиент(), Неопределено);
	Если Память = Неопределено Тогда
		Память = НоваяПамятьТестКлиента();
		СохранитьПамятьТестКлиент(Память);
	КонецЕсли;
	Возврат Память;
КонецФункции

Процедура СохранитьПамятьТестКлиент(Память)
	Мсп_СостояниеКлиент.УстановитьСостояниеЗначение(КлючПамятиТестКлиент(), Память);
КонецПроцедуры

Функция КлючПамятиТестКлиент()
	Возврат "ПамятьТестКлиент";
КонецФункции

Функция ПолучитьЗначениеПамяти(Память, Имя, ЗначениеПоУмолчанию)
	Если Память = Неопределено Тогда
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;
	Значение = ЗначениеПоУмолчанию;
	Если Память.Свойство(Имя, Значение) Тогда
		Возврат Значение;
	КонецЕсли;
	Возврат ЗначениеПоУмолчанию;
КонецФункции

Функция СоздатьТестируемоеПриложение(Порт)
	Если Порт > 0 Тогда
		Возврат Новый ТестируемоеПриложение("127.0.0.1", Порт);
	КонецЕсли;
	
	Возврат Новый ТестируемоеПриложение();
КонецФункции

Функция ПодключитьсяКТестКлиенту(ТестКлиент, МаксИтераций)
	ПоследняяОшибка = "";
	
	Для Счетчик = 1 По МаксИтераций Цикл
		Попытка
			ТестКлиент.УстановитьСоединение();
			Возврат НовыйУспешныйРезультат();
		Исключение
			ПоследняяОшибка = ОписаниеОшибки();
		КонецПопытки;
		Мсп_ПаузаВызовСервера.СделатьПаузу(1);
	КонецЦикла;
	
	Возврат НовыйРезультатОшибка(ПоследняяОшибка);
КонецФункции

Функция НормализованныйПорт(Порт)
	ЧислоПорта = 0;
	Если ТипЗнч(Порт) = Тип("Число") Тогда
		ЧислоПорта = Порт;
	ИначеЕсли ТипЗнч(Порт) = Тип("Строка") И ЗначениеЗаполнено(Порт) Тогда
		Попытка
			ЧислоПорта = Число(Порт);
		Исключение
			ЧислоПорта = 0;
		КонецПопытки;
	КонецЕсли;
	Если ЧислоПорта <= 0 Тогда
		ЧислоПорта = 1538;
	КонецЕсли;
	Возврат ЧислоПорта;
КонецФункции

Функция ЗапуститьПроцессТестКлиента(КомандаЗапуска)
	Попытка
		ЗапуститьПриложение(КомандаЗапуска, , Ложь);
		Возврат НовыйУспешныйРезультат();
	Исключение
		Возврат НовыйРезультатОшибка(ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;
КонецФункции

Функция СформироватьКомандуЗапуска(Порт)
	КаталогПрограммыПути = КаталогПрограммы();
	Если Не ЗначениеЗаполнено(КаталогПрограммыПути) Тогда
		Возврат "";
	КонецЕсли;
	ПутьКПрограмме = ПодготовитьПутьКПрограмме(КаталогПрограммыПути);
	Если Не ЗначениеЗаполнено(ПутьКПрограмме) Тогда
		Возврат "";
	КонецЕсли;
	СтрокаПодключения = СтрокаСоединенияИнформационнойБазы();
	Если Не ЗначениеЗаполнено(СтрокаПодключения) Тогда
		Возврат "";
	КонецЕсли;
	КомандаЗапуска = ПутьКПрограмме + " ENTERPRISE /IBConnectionString '" + СтрокаПодключения + "' /TESTCLIENT";
	КомандаЗапуска = КомандаЗапуска + " -TPort " + Формат(Порт, "ЧГ=0;");
	Возврат КомандаЗапуска;
КонецФункции

Функция ПодготовитьПутьКПрограмме(КаталогПрограммыПути)
	Если Не ЗначениеЗаполнено(КаталогПрограммыПути) Тогда
		Возврат "";
	КонецЕсли;
	
	ПутьКПрограмме = КаталогПрограммыПути + "1cv8c";
	Если СтрНайти(ПутьКПрограмме, " ") > 0 Тогда
		ПутьКПрограмме = """" + ПутьКПрограмме + """";
	КонецЕсли;
	Возврат ПутьКПрограмме;
КонецФункции

#КонецОбласти
