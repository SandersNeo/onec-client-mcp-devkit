#Область ПрограммныйИнтерфейс

Функция Текст(ТекстРезультата) Экспорт
	Контент = Новый Массив;
	Контент.Добавить(Новый Структура("type,text", "text", ТекстРезультата));
	Возврат Новый Структура("content", Контент);
КонецФункции

Функция JSON(Данные) Экспорт
	Возврат Текст(Мсп_СериализацияКлиент.Сериализовать(Данные));
КонецФункции

Функция Ресурс(URI, Данные, MimeType = "application/json") Экспорт
	Контент = Новый Массив;
	ТекстКонтента = ТекстРесурса(Данные, MimeType);
	Контент.Добавить(
		Новый Структура(
			"uri,text,mimeType",
			URI,
			ТекстКонтента,
			MimeType));
	Возврат Новый Структура("contents", Контент);
КонецФункции

Функция Промпт(Сообщения) Экспорт
	Возврат Новый Структура("messages", Сообщения);
КонецФункции

Функция ТекстовыйПромпт(ТекстПромпта, Роль = "user") Экспорт
	Сообщения = Новый Массив;
	Сообщения.Добавить(Новый Структура("role,content", Роль, Новый Структура("type,text", "text", ТекстПромпта)));
	Возврат Промпт(Сообщения);
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ТекстРесурса(Данные, MimeType)
	Если ЭтоJSONMimeType(MimeType) Тогда
		Возврат Мсп_СериализацияКлиент.Сериализовать(Данные);
	КонецЕсли;

	Если ТипЗнч(Данные) = Тип("Строка") Тогда
		Возврат Данные;
	КонецЕсли;

	Если Данные = Неопределено Тогда
		Возврат "";
	КонецЕсли;

	Возврат Строка(Данные);
КонецФункции

Функция ЭтоJSONMimeType(MimeType)
	СтрокаMimeType = СокрЛП(Строка(MimeType));
	НижнийMimeType = НРег(СтрокаMimeType);
	ПрефиксJSON = "application/json";

	Если Лев(НижнийMimeType, СтрДлина(ПрефиксJSON)) <> ПрефиксJSON Тогда
		Возврат Ложь;
	КонецЕсли;

	Если СтрДлина(НижнийMimeType) = СтрДлина(ПрефиксJSON) Тогда
		Возврат Истина;
	КонецЕсли;

	Возврат Сред(НижнийMimeType, СтрДлина(ПрефиксJSON) + 1, 1) = ";";
КонецФункции

#КонецОбласти
