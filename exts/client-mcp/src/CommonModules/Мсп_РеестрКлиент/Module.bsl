#Область ПрограммныйИнтерфейс

// Инициализирует реестры MCP в состоянии клиента.
Процедура ИнициализироватьРеестры() Экспорт
	РеестрИнструментов();
	РеестрРесурсов();
	РеестрПромптов();
	Сессии();
КонецПроцедуры

Процедура ЗарегистрироватьИнструмент(ОписаниеИнструмента) Экспорт
	Если Не ЗначениеЗаполнено(ОписаниеИнструмента.Имя) Тогда
		ВызватьИсключение "Имя инструмента не задано.";
	КонецЕсли;
	РеестрИнструментов().Вставить(ОписаниеИнструмента.Имя, ОписаниеИнструмента);
КонецПроцедуры

Функция НовыйОписаниеИнструмента() Экспорт
	Возврат Новый Структура("Имя, Описание, СхемаПараметров, Обработчик", "", "", "", Новый ОписаниеОповещения());
КонецФункции

Процедура ЗарегистрироватьРесурс(ОписаниеРесурса) Экспорт
	Если Не ЗначениеЗаполнено(ОписаниеРесурса.URI) Тогда
		ВызватьИсключение "URI ресурса не задан.";
	КонецЕсли;
	РеестрРесурсов().Вставить(ОписаниеРесурса.URI, ОписаниеРесурса);
КонецПроцедуры

Функция НовыйОписаниеРесурса() Экспорт
	Возврат Новый Структура("URI, Имя, Описание, MimeType, Обработчик", "", "", "", "", Новый ОписаниеОповещения());
КонецФункции

Процедура ЗарегистрироватьПромпт(ОписаниеПромпта) Экспорт
	Если Не ЗначениеЗаполнено(ОписаниеПромпта.Имя) Тогда
		ВызватьИсключение "Имя промпта не задано.";
	КонецЕсли;
	РеестрПромптов().Вставить(ОписаниеПромпта.Имя, ОписаниеПромпта);
КонецПроцедуры

Функция НовыйОписаниеПромпта() Экспорт
	Возврат Новый Структура("Имя, Описание, Аргументы, Обработчик", "", "", Новый Структура, Новый ОписаниеОповещения());
КонецФункции

Функция РеестрИнструментов() Экспорт
	Возврат ПолучитьРеестр("Инструменты");
КонецФункции

Функция РеестрРесурсов() Экспорт
	Возврат ПолучитьРеестр("Ресурсы");
КонецФункции

Функция РеестрПромптов() Экспорт
	Возврат ПолучитьРеестр("Промпты");
КонецФункции

Функция Сессии() Экспорт
	Возврат ПолучитьРеестр("Сессии");
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Возвращает реестр по имени из состояния MCP.
//
// Параметры:
//  Имя - Строка - Имя реестра.
//
// Возвращаемое значение:
//  Соответствие из Произвольный - Реестр, ключи - строки, значения - элементы реестра.
Функция ПолучитьРеестр(Имя)
	Состояние = Мсп_СостояниеКлиент.ПолучитьСостояние();
	Если Не Состояние.Свойство(Имя) Тогда
		Состояние.Вставить(Имя, Новый Соответствие);
	КонецЕсли;
	Возврат Состояние[Имя];
КонецФункции

#КонецОбласти
