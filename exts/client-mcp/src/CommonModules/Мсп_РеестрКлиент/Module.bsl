#Область ПрограммныйИнтерфейс

// Инициализирует реестры MCP в состоянии клиента.
Процедура ИнициализироватьРеестры() Экспорт
	Реестры = Мсп_СостояниеКлиент.СостояниеСервера().Реестры;
	Реестры.Вставить("Инструменты", Новый Соответствие);
	Реестры.Вставить("Ресурсы", Новый Соответствие);
	Реестры.Вставить("ШаблоныРесурсов", Новый Соответствие);
	Реестры.Вставить("Промпты", Новый Соответствие);
КонецПроцедуры

// Регистрирует описание инструмента в клиентском реестре.
//
// Параметры:
//  ОписаниеИнструмента - Структура - Описание инструмента:
//   * Имя - Строка - Идентификатор инструмента.
//   * Описание - Строка - Описание инструмента.
//   * СхемаПараметров - Структура, Строка - JSON-схема входных параметров или пустое значение до заполнения описания.
//   * Обработчик - ОписаниеОповещения - Обработчик вызова инструмента.
Процедура ЗарегистрироватьИнструмент(ОписаниеИнструмента) Экспорт
	Если Не ЗначениеЗаполнено(ОписаниеИнструмента.Имя) Тогда
		ВызватьИсключение "Имя инструмента не задано.";
	КонецЕсли;
	ПроверитьПоляОписанияИнструмента(ОписаниеИнструмента);
	РеестрИнструментов().Вставить(ОписаниеИнструмента.Имя, ОписаниеИнструмента);
КонецПроцедуры

// Возвращает пустое описание инструмента для заполнения и регистрации.
//
// Возвращаемое значение:
//  Структура - Описание инструмента:
//   * Имя - Строка - Идентификатор инструмента.
//   * Описание - Строка - Описание инструмента.
//   * СхемаПараметров - Структура, Строка - JSON-схема входных параметров или пустое значение до заполнения описания.
//   * Обработчик - ОписаниеОповещения - Обработчик вызова инструмента.
//   * РежимВыполнения - Строка - Режим выполнения инструмента (sync | task).
//   * Включён - Булево - Признак активности инструмента.
//   * ОтложенныйОтвет - Булево - Признак, что sync tools/call может завершиться позже.
//   * ИсточникРегистрации - Строка - Источник регистрации.
Функция НовыйОписаниеИнструмента() Экспорт
	ОписаниеИнструмента = Новый Структура;
	ОписаниеИнструмента.Вставить("Имя", "");
	ОписаниеИнструмента.Вставить("Описание", "");
	ОписаниеИнструмента.Вставить("СхемаПараметров", "");
	ОписаниеИнструмента.Вставить("Обработчик", Новый ОписаниеОповещения());
	ОписаниеИнструмента.Вставить("РежимВыполнения", "sync");
	ОписаниеИнструмента.Вставить("Включён", Истина);
	ОписаниеИнструмента.Вставить("ОтложенныйОтвет", Ложь);
	ОписаниеИнструмента.Вставить("ИсточникРегистрации", "");
	Возврат ОписаниеИнструмента;
КонецФункции

// Регистрирует описание ресурса в клиентском реестре.
//
// Параметры:
//  ОписаниеРесурса - Структура - Описание ресурса:
//   * URI - Строка - URI ресурса.
//   * Имя - Строка - Читаемое имя ресурса.
//   * Описание - Строка - Описание ресурса.
//   * MimeType - Строка - MIME-тип контента ресурса.
//   * Обработчик - ОписаниеОповещения - Обработчик чтения ресурса.
//   * Провайдер - Строка - Имя провайдера, зарегистрировавшего ресурс.
//   * Включён - Булево - Признак активности ресурса.
Процедура ЗарегистрироватьРесурс(ОписаниеРесурса) Экспорт
	Если Не ЗначениеЗаполнено(ОписаниеРесурса.URI) Тогда
		ВызватьИсключение "URI ресурса не задан.";
	КонецЕсли;
	ПроверитьПоляОписания(ОписаниеРесурса);
	РеестрРесурсов().Вставить(ОписаниеРесурса.URI, ОписаниеРесурса);
КонецПроцедуры

// Возвращает пустое описание ресурса для заполнения и регистрации.
//
// Возвращаемое значение:
//  Структура - Описание ресурса:
//   * URI - Строка - URI ресурса.
//   * Имя - Строка - Читаемое имя ресурса.
//   * Описание - Строка - Описание ресурса.
//   * MimeType - Строка - MIME-тип контента ресурса.
//   * Обработчик - ОписаниеОповещения - Обработчик чтения ресурса.
//   * Провайдер - Строка - Имя провайдера, зарегистрировавшего ресурс.
//   * Включён - Булево - Признак активности ресурса.
Функция НовыйОписаниеРесурса() Экспорт
	ОписаниеРесурса = Новый Структура;
	ОписаниеРесурса.Вставить("URI", "");
	ОписаниеРесурса.Вставить("Имя", "");
	ОписаниеРесурса.Вставить("Описание", "");
	ОписаниеРесурса.Вставить("MimeType", "");
	ОписаниеРесурса.Вставить("Обработчик", Новый ОписаниеОповещения());
	ОписаниеРесурса.Вставить("Провайдер", "");
	ОписаниеРесурса.Вставить("Включён", Истина);
	ОписаниеРесурса.Вставить("ИсточникРегистрации", "");
	Возврат ОписаниеРесурса;
КонецФункции

