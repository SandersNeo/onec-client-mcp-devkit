// Регистрирует описание промпта в клиентском реестре.
//
// Параметры:
//  ОписаниеПромпта - Структура - Описание промпта:
//   * Имя - Строка - Идентификатор промпта.
//   * Описание - Строка - Описание промпта.
//   * Аргументы - Массив - Описание аргументов промпта.
//   * Обработчик - ОписаниеОповещения - Обработчик получения промпта.
//   * Провайдер - Строка - Имя провайдера, зарегистрировавшего промпт.
//   * Включён - Булево - Признак активности промпта.
Процедура ЗарегистрироватьПромпт(ОписаниеПромпта) Экспорт
	Если Не ЗначениеЗаполнено(ОписаниеПромпта.Имя) Тогда
		ВызватьИсключение "Имя промпта не задано.";
	КонецЕсли;
	ПроверитьАргументыПромпта(ОписаниеПромпта);
	ПроверитьПоляОписания(ОписаниеПромпта);
	РеестрПромптов().Вставить(ОписаниеПромпта.Имя, ОписаниеПромпта);
КонецПроцедуры

// Отменяет регистрацию всех объектов с указанным источником регистрации во всех реестрах.
//
// Параметры:
//  ИсточникРегистрации - Строка - Источник регистрации.
Процедура ОтменитьРегистрацию(ИсточникРегистрации) Экспорт
	ПроверитьТипИсточникРегистрации(ИсточникРегистрации);
	УдалитьИзРеестраПоИсточникуРегистрации(РеестрИнструментов(), ИсточникРегистрации);
	УдалитьИзРеестраПоИсточникуРегистрации(РеестрРесурсов(), ИсточникРегистрации);
	УдалитьИзРеестраПоИсточникуРегистрации(РеестрШаблоновРесурсов(), ИсточникРегистрации);
	УдалитьИзРеестраПоИсточникуРегистрации(РеестрПромптов(), ИсточникРегистрации);
КонецПроцедуры

// Возвращает пустое описание промпта для заполнения и регистрации.
//
// Возвращаемое значение:
//  Структура - Описание промпта:
//   * Имя - Строка - Идентификатор промпта.
//   * Описание - Строка - Описание промпта.
//   * Аргументы - Массив - Описание аргументов промпта.
//   * Обработчик - ОписаниеОповещения - Обработчик получения промпта.
//   * Провайдер - Строка - Имя провайдера, зарегистрировавшего промпт.
//   * Включён - Булево - Признак активности промпта.
Функция НовыйОписаниеПромпта() Экспорт
	ОписаниеПромпта = Новый Структура;
	ОписаниеПромпта.Вставить("Имя", "");
	ОписаниеПромпта.Вставить("Описание", "");
	ОписаниеПромпта.Вставить("Аргументы", Новый Массив);
	ОписаниеПромпта.Вставить("Обработчик", Новый ОписаниеОповещения());
	ОписаниеПромпта.Вставить("Провайдер", "");
	ОписаниеПромпта.Вставить("Включён", Истина);
	ОписаниеПромпта.Вставить("ИсточникРегистрации", "");
	Возврат ОписаниеПромпта;
КонецФункции

// Отменяет регистрацию всех объектов указанного провайдера во всех реестрах.
//
// Параметры:
//  ИмяПровайдера - Строка - Имя провайдера.
Процедура ОтменитьРегистрациюПровайдера(ИмяПровайдера) Экспорт
	УдалитьИзРеестраПоПровайдеру(РеестрРесурсов(), ИмяПровайдера);
	УдалитьИзРеестраПоПровайдеру(РеестрШаблоновРесурсов(), ИмяПровайдера);
	УдалитьИзРеестраПоПровайдеру(РеестрПромптов(), ИмяПровайдера);
КонецПроцедуры

// Устанавливает признак активности объекта в реестре.
//
// Параметры:
//  Реестр - Соответствие - Реестр объектов (инструменты, ресурсы, промпты и т.д.).
//  Идентификатор - Строка - Ключ объекта в реестре (имя или URI).
//  Включён - Булево - Признак активности.
Процедура УстановитьВключён(Реестр, Идентификатор, Включён) Экспорт
	Дескриптор = Реестр.Получить(Идентификатор);
	Если Дескриптор <> Неопределено Тогда
		Дескриптор.Включён = Включён;
	КонецЕсли;
КонецПроцедуры

// Возвращает реестр зарегистрированных инструментов.
//
// Параметры:
//  ТолькоВключённые - Булево - Если Истина, возвращает только активные инструменты.
//
// Возвращаемое значение:
//  Соответствие из Произвольный - Реестр инструментов, ключи - имена инструментов.
Функция РеестрИнструментов(ТолькоВключённые = Ложь) Экспорт
	Возврат ПолучитьРеестр("Инструменты", ТолькоВключённые);
КонецФункции

// Возвращает реестр зарегистрированных ресурсов.
//
// Параметры:
//  ТолькоВключённые - Булево - Если Истина, возвращает только активные ресурсы.
//
// Возвращаемое значение:
//  Соответствие из Произвольный - Реестр ресурсов, ключи - URI ресурсов.
Функция РеестрРесурсов(ТолькоВключённые = Ложь) Экспорт
	Возврат ПолучитьРеестр("Ресурсы", ТолькоВключённые);
КонецФункции

// Возвращает реестр зарегистрированных шаблонов ресурсов.
//
// Параметры:
//  ТолькоВключённые - Булево - Если Истина, возвращает только активные шаблоны ресурсов.
//
// Возвращаемое значение:
//  Соответствие из Произвольный - Реестр шаблонов ресурсов, ключи - URI-шаблоны ресурсов.
Функция РеестрШаблоновРесурсов(ТолькоВключённые = Ложь) Экспорт
	Возврат ПолучитьРеестр("ШаблоныРесурсов", ТолькоВключённые);
КонецФункции

// Возвращает реестр зарегистрированных промптов.
//
// Параметры:
//  ТолькоВключённые - Булево - Если Истина, возвращает только активные промпты.
//
// Возвращаемое значение:
//  Соответствие из Произвольный - Реестр промптов, ключи - имена промптов.
Функция РеестрПромптов(ТолькоВключённые = Ложь) Экспорт
	Возврат ПолучитьРеестр("Промпты", ТолькоВключённые);
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Проверяет описание аргументов промпта.
//
// Параметры:
//  ОписаниеПромпта - Структура - Описание промпта.
Процедура ПроверитьАргументыПромпта(ОписаниеПромпта)
	АргументыПромпта = Неопределено;
	Если Не ОписаниеПромпта.Свойство("Аргументы", АргументыПромпта) Тогда
		ВызватьИсключение "Аргументы промпта должны быть массивом.";
	КонецЕсли;
	Если ТипЗнч(АргументыПромпта) <> Тип("Массив") Тогда
		ВызватьИсключение "Аргументы промпта должны быть массивом.";
	КонецЕсли;
КонецПроцедуры

Процедура ПроверитьПоляОписания(ОписаниеОбъекта)
	Провайдер = Неопределено;
	Включён = Неопределено;
	ИсточникРегистрации = Неопределено;

	Если Не ОписаниеОбъекта.Свойство("Провайдер", Провайдер)
		Или ТипЗнч(Провайдер) <> Тип("Строка") Тогда
		ВызватьИсключение "Провайдер должен быть строкой.";
	КонецЕсли;
	Если Не ОписаниеОбъекта.Свойство("Включён", Включён)
		Или ТипЗнч(Включён) <> Тип("Булево") Тогда
		ВызватьИсключение "Включён должен быть булевым.";
	КонецЕсли;
	Если Не ОписаниеОбъекта.Свойство("ИсточникРегистрации", ИсточникРегистрации) Тогда
		ВызватьИсключение "ИсточникРегистрации должен быть строкой.";
	КонецЕсли;
	ПроверитьТипИсточникРегистрации(ИсточникРегистрации);
КонецПроцедуры

Процедура ПроверитьПоляОписанияИнструмента(ОписаниеИнструмента)
	РежимВыполнения = Неопределено;
	Включён = Неопределено;
	ОтложенныйОтвет = Неопределено;
	ИсточникРегистрации = Неопределено;

	Если Не ОписаниеИнструмента.Свойство("РежимВыполнения", РежимВыполнения)
		Или ТипЗнч(РежимВыполнения) <> Тип("Строка") Тогда
		ВызватьИсключение "РежимВыполнения должен быть строкой sync или task.";
	КонецЕсли;
	Если РежимВыполнения <> "sync"
		И РежимВыполнения <> "task" Тогда
		ВызватьИсключение "РежимВыполнения должен быть sync или task.";
	КонецЕсли;
	Если Не ОписаниеИнструмента.Свойство("Включён", Включён)
		Или ТипЗнч(Включён) <> Тип("Булево") Тогда
		ВызватьИсключение "Включён должен быть булевым.";
	КонецЕсли;
	Если Не ОписаниеИнструмента.Свойство("ОтложенныйОтвет", ОтложенныйОтвет)
		Или ТипЗнч(ОтложенныйОтвет) <> Тип("Булево") Тогда
		ВызватьИсключение "ОтложенныйОтвет должен быть булевым.";
	КонецЕсли;
	Если ОтложенныйОтвет
		И РежимВыполнения <> "sync" Тогда
		ВызватьИсключение "ОтложенныйОтвет доступен только для sync.";
	КонецЕсли;
	Если Не ОписаниеИнструмента.Свойство("ИсточникРегистрации", ИсточникРегистрации) Тогда
		ВызватьИсключение "ИсточникРегистрации должен быть строкой.";
	КонецЕсли;
	ПроверитьТипИсточникРегистрации(ИсточникРегистрации);
КонецПроцедуры

// Проверяет, что источник регистрации имеет строковый тип.
//
// Параметры:
//  ИсточникРегистрации - Произвольный - Проверяемое значение.
Процедура ПроверитьТипИсточникРегистрации(ИсточникРегистрации)
	Если ТипЗнч(ИсточникРегистрации) <> Тип("Строка") Тогда
		ВызватьИсключение "ИсточникРегистрации должен быть строкой.";
	КонецЕсли;
КонецПроцедуры

// Удаляет из реестра все записи указанного провайдера.
//
// Параметры:
//  Реестр - Соответствие - Реестр объектов.
//  ИмяПровайдера - Строка - Имя провайдера.
Процедура УдалитьИзРеестраПоПровайдеру(Реестр, ИмяПровайдера)
	КлючиУдаления = Новый Массив;
	Для Каждого Элемент Из Реестр Цикл
		ПровайдерЗаписи = "";
		Если ТипЗнч(Элемент.Значение) = Тип("Структура")
			И Элемент.Значение.Свойство("Провайдер", ПровайдерЗаписи)
			И ПровайдерЗаписи = ИмяПровайдера Тогда
			КлючиУдаления.Добавить(Элемент.Ключ);
		КонецЕсли;
	КонецЦикла;
	Для Каждого Ключ Из КлючиУдаления Цикл
		Реестр.Удалить(Ключ);
	КонецЦикла;
КонецПроцедуры

// Удаляет из реестра все записи с указанным источником регистрации.
//
// Параметры:
//  Реестр - Соответствие - Реестр объектов.
//  ИсточникРегистрации - Строка - Источник регистрации.
Процедура УдалитьИзРеестраПоИсточникуРегистрации(Реестр, ИсточникРегистрации)
	КлючиУдаления = Новый Массив;
	Для Каждого Элемент Из Реестр Цикл
		ИсточникЗаписи = "";
		Если Элемент.Значение.Свойство("ИсточникРегистрации", ИсточникЗаписи) Тогда
			Если ТипЗнч(ИсточникЗаписи) <> Тип("Строка") Тогда
				Продолжить;
			КонецЕсли;
		КонецЕсли;
		Если ИсточникЗаписи = ИсточникРегистрации Тогда
			КлючиУдаления.Добавить(Элемент.Ключ);
		КонецЕсли;
	КонецЦикла;
	Для Каждого Ключ Из КлючиУдаления Цикл
		Реестр.Удалить(Ключ);
	КонецЦикла;
КонецПроцедуры

// Возвращает реестр по имени из состояния MCP.
//
// Параметры:
//  Имя - Строка - Имя реестра.
//  ТолькоВключённые - Булево - Если Истина, возвращает только активные элементы.
//
// Возвращаемое значение:
//  Соответствие из Произвольный - Реестр, ключи - строки, значения - элементы реестра.
Функция ПолучитьРеестр(Имя, ТолькоВключённые = Ложь)
	Реестры = Мсп_СостояниеКлиент.СостояниеСервера().Реестры;
	Если Не Реестры.Свойство(Имя) Тогда
		Реестры.Вставить(Имя, Новый Соответствие);
	КонецЕсли;
	Реестр = Реестры[Имя];
	Если Не ТолькоВключённые Тогда
		Возврат Реестр;
	КонецЕсли;
	Отфильтрованный = Новый Соответствие;
	Для Каждого Элемент Из Реестр Цикл
		Если Элемент.Значение.Включён Тогда
			Отфильтрованный.Вставить(Элемент.Ключ, Элемент.Значение);
		КонецЕсли;
	КонецЦикла;
	Возврат Отфильтрованный;
КонецФункции

#КонецОбласти
