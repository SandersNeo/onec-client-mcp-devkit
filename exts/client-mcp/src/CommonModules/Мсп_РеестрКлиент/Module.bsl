#Область ПрограммныйИнтерфейс

// Инициализирует реестры MCP в состоянии клиента.
Процедура ИнициализироватьРеестры() Экспорт
	ПолучитьРеестр("Инструменты");
	ПолучитьРеестр("Ресурсы");
	ПолучитьРеестр("Промпты");
	ПолучитьРеестр("Сессии");
КонецПроцедуры

// Возвращает реестр по имени из состояния MCP.
//
// Параметры:
//  Имя - Строка - Имя реестра.
//
// Возвращаемое значение:
//  Соответствие из Произвольный - Реестр, ключи - строки, значения - элементы реестра.
Функция ПолучитьРеестр(Имя) Экспорт
	Состояние = ПолучитьСостояние();
	Если Не Состояние.Свойство(Имя) Тогда
		Состояние.Вставить(Имя, Новый Соответствие);
	КонецЕсли;
	Возврат Состояние[Имя];
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Возвращает структуру состояния MCP.
//
// Возвращаемое значение:
//  Структура - Состояние MCP.
Функция ПолучитьСостояние()
	Возврат Мсп_СостояниеКлиент.ПолучитьСостояние();
КонецФункции

#КонецОбласти
