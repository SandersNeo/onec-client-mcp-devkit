#Область ПрограммныйИнтерфейс

// Регистрирует инструмент суммирования двух чисел.
Процедура ЗарегистрироватьИнструментСложение() Экспорт
	Описание = "Складывает два числа.";
	СхемаJSON = СхемаВходныхПараметров();
	Оповещение = Новый ОписаниеОповещения("ОбработатьИнструментСложение", Мсп_ИнструментСложениеКлиент);
	Мсп_ИнструментыКлиент.ЗарегистрироватьИнструмент("math.add", Описание, СхемаJSON, Оповещение);
	
	Оповещение = Новый ОписаниеОповещения("ОбработатьИнструментВычитание", Мсп_ИнструментСложениеКлиент);
	Мсп_ИнструментыКлиент.ЗарегистрироватьИнструмент("math.sub", "Вычитает два числа", СхемаJSON, Оповещение);
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Обрабатывает вызов инструмента суммирования.
//
// Параметры:
//  Контекст - Структура - Контекст вызова инструмента.
//
// Возвращаемое значение:
//  Структура - Результат инструмента MCP:
//   * content - Массив из Структура - Контент результата.
Функция ОбработатьИнструментВычитание(Контекст, ДополнительныеПараметры) Экспорт
	Если Контекст = Неопределено Тогда
		Контекст = Новый Структура;
	КонецЕсли;

	Попытка
		Аргументы = Мсп_ИнструментыКлиент.ПолучитьСвойство(Контекст, "arguments", Новый Структура);
		ЧислоA = ПолучитьАргументЧисло(Аргументы, "a", Неопределено);
		ЧислоB = ПолучитьАргументЧисло(Аргументы, "b", Неопределено);
		Если ЧислоA = Неопределено Или ЧислоB = Неопределено Тогда
			Возврат СформироватьТекстовыйОтвет("Invalid params: a, b must be numbers.");
		КонецЕсли;

		Результат = Новый Структура("a,b,sub", ЧислоA, ЧислоB, ЧислоA - ЧислоB);
		Возврат СформироватьТекстовыйОтвет(Мсп_ПротоколКлиент.Сериализовать(Результат));
	Исключение
		СообщениеОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		Мсп_ЛогированиеКлиент.ОшибкаЛога(СтрШаблон("Tool math.add failed: %1", СообщениеОшибки));
		Возврат СформироватьТекстовыйОтвет(СообщениеОшибки);
	КонецПопытки;
КонецФункции

// Обрабатывает вызов инструмента суммирования.
//
// Параметры:
//  Контекст - Структура - Контекст вызова инструмента.
//
// Возвращаемое значение:
//  Структура - Результат инструмента MCP:
//   * content - Массив из Структура - Контент результата.
Функция ОбработатьИнструментСложение(Контекст, ДополнительныеПараметры) Экспорт
	Если Контекст = Неопределено Тогда
		Контекст = Новый Структура;
	КонецЕсли;

	Попытка
		Аргументы = Мсп_ИнструментыКлиент.ПолучитьСвойство(Контекст, "arguments", Новый Структура);
		ЧислоA = ПолучитьАргументЧисло(Аргументы, "a", Неопределено);
		ЧислоB = ПолучитьАргументЧисло(Аргументы, "b", Неопределено);
		Если ЧислоA = Неопределено Или ЧислоB = Неопределено Тогда
			Возврат СформироватьТекстовыйОтвет("Invalid params: a, b must be numbers.");
		КонецЕсли;

		Результат = Новый Структура("a,b,sum", ЧислоA, ЧислоB, ЧислоA + ЧислоB);
		Возврат СформироватьТекстовыйОтвет(Мсп_ПротоколКлиент.Сериализовать(Результат));
	Исключение
		СообщениеОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		Мсп_ЛогированиеКлиент.ОшибкаЛога(СтрШаблон("Tool math.add failed: %1", СообщениеОшибки));
		Возврат СформироватьТекстовыйОтвет(СообщениеОшибки);
	КонецПопытки;
КонецФункции

// Возвращает JSON-схему входных параметров.
Функция СхемаВходныхПараметров()
	Схема = Новый Структура;
	Схема.Вставить("type", "object");
	Свойства = Новый Структура;
	Свойства.Вставить("a", Новый Структура("type", "number"));
	Свойства.Вставить("b", Новый Структура("type", "number"));
	Схема.Вставить("properties", Свойства);
	Требуемые = Новый Массив;
	Требуемые.Добавить("a");
	Требуемые.Добавить("b");
	Схема.Вставить("required", Требуемые);
	Схема.Вставить("additionalProperties", Ложь);
	Возврат Мсп_ПротоколКлиент.Сериализовать(Схема);
КонецФункции

Функция ПолучитьАргументЧисло(Аргументы, Имя, ЗначениеПоУмолчанию)
	Значение = Мсп_ИнструментыКлиент.ПолучитьСвойство(Аргументы, Имя, Неопределено);
	Если Значение = Неопределено Тогда
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;
	Если ТипЗнч(Значение) = Тип("Число") Тогда
		Возврат Значение;
	КонецЕсли;
	Попытка
		Возврат Число(Значение);
	Исключение
		Возврат ЗначениеПоУмолчанию;
	КонецПопытки;
КонецФункции

Функция СформироватьТекстовыйОтвет(Текст)
	Контент = Новый Массив;
	Контент.Добавить(Новый Структура("type,text", "text", Текст));
	Возврат Новый Структура("content", Контент);
КонецФункции

#КонецОбласти
