#Область ПрограммныйИнтерфейс

// Возвращает описание инструментов провайдера.
Процедура ЗарегистрироватьИнструменты() Экспорт
	Мсп_РеестрКлиент.ЗарегистрироватьИнструмент(Мсп_ИнструментыКлиент.ОписаниеИнструмента(
		"math_add",
		"Складывает два числа.",
		СхемаВходныхПараметров(),
		Новый ОписаниеОповещения("ОбработатьИнструментСложение", Мсп_ИнструментСложениеКлиент)));
	Мсп_РеестрКлиент.ЗарегистрироватьИнструмент(Мсп_ИнструментыКлиент.ОписаниеИнструмента(
		"math_sub",
		"Вычитает два числа",
		СхемаВходныхПараметров(),
		Новый ОписаниеОповещения("ОбработатьИнструментВычитание", Мсп_ИнструментСложениеКлиент)));
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Обрабатывает вызов инструмента суммирования.
//
// Параметры:
//  Запрос - Структура - Запрос инструмента:
//   * Аргументы - Структура - Аргументы вызова.
//   * Контекст - Структура - Контекст вызова.
//  ДополнительныеПараметры - Произвольный - Дополнительные параметры вызова.
//
// Возвращаемое значение:
//  Произвольный - Результат вычисления или текст ошибки.
Функция ОбработатьИнструментВычитание(Запрос, ДополнительныеПараметры) Экспорт
	Если Запрос = Неопределено Тогда
		Запрос = Новый Структура;
	КонецЕсли;

	Попытка
		Аргументы = Мсп_ИнструментыКлиент.ПолучитьСвойство(Запрос, "Аргументы", Новый Структура);
		ЧислоA = ПолучитьАргументЧисло(Аргументы, "a", Неопределено);
		ЧислоB = ПолучитьАргументЧисло(Аргументы, "b", Неопределено);
		Если ЧислоA = Неопределено Или ЧислоB = Неопределено Тогда
			Возврат "Invalid params: a, b must be numbers.";
		КонецЕсли;

		Результат = Новый Структура("a,b,sub", ЧислоA, ЧислоB, ЧислоA - ЧислоB);
		Возврат Результат;
	Исключение
		СообщениеОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		Мсп_ЛогированиеКлиент.Ошибка(СтрШаблон("Tool math_sub failed: %1", СообщениеОшибки));
		Возврат СообщениеОшибки;
	КонецПопытки;
КонецФункции

// Обрабатывает вызов инструмента суммирования.
//
// Параметры:
//  Запрос - Структура - Запрос инструмента:
//   * Аргументы - Структура - Аргументы вызова.
//   * Контекст - Структура - Контекст вызова.
//  ДополнительныеПараметры - Произвольный - Дополнительные параметры вызова.
//
// Возвращаемое значение:
//  Произвольный - Результат вычисления или текст ошибки.
Функция ОбработатьИнструментСложение(Запрос, ДополнительныеПараметры) Экспорт
	Если Запрос = Неопределено Тогда
		Запрос = Новый Структура;
	КонецЕсли;

	Аргументы = Мсп_ИнструментыКлиент.ПолучитьСвойство(Запрос, "Аргументы", Новый Структура);
	ЧислоA = ПолучитьАргументЧисло(Аргументы, "a", Неопределено);
	ЧислоB = ПолучитьАргументЧисло(Аргументы, "b", Неопределено);
	Если ЧислоA = Неопределено Или ЧислоB = Неопределено Тогда
		Возврат "Invalid params: a, b must be numbers.";
	КонецЕсли;

	Возврат Новый Структура("a,b,add", ЧислоA, ЧислоB, ЧислоA + ЧислоB);
КонецФункции

// Возвращает JSON-схему входных параметров.
Функция СхемаВходныхПараметров()
	Схема = Новый Структура;
	Схема.Вставить("type", "object");
	Свойства = Новый Структура;
	Свойства.Вставить("a", Новый Структура("type", "number"));
	Свойства.Вставить("b", Новый Структура("type", "number"));
	Схема.Вставить("properties", Свойства);
	Требуемые = Новый Массив;
	Требуемые.Добавить("a");
	Требуемые.Добавить("b");
	Схема.Вставить("required", Требуемые);
	Схема.Вставить("additionalProperties", Ложь);
	Возврат Схема;
КонецФункции

Функция ПолучитьАргументЧисло(Аргументы, Имя, ЗначениеПоУмолчанию)
	Значение = Мсп_ИнструментыКлиент.ПолучитьСвойство(Аргументы, Имя, Неопределено);
	Если Значение = Неопределено Тогда
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;
	Если ТипЗнч(Значение) = Тип("Число") Тогда
		Возврат Значение;
	КонецЕсли;
	Попытка
		Возврат Число(Значение);
	Исключение
		Возврат ЗначениеПоУмолчанию;
	КонецПопытки;
КонецФункции

#КонецОбласти
