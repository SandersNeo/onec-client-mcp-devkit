#Область ПрограммныйИнтерфейс

// Регистрирует инструмент суммирования двух чисел.
Процедура ЗарегистрироватьИнструментСложение() Экспорт
	Описание = "Складывает два числа.";
	СхемаJSON = СхемаВходныхПараметров();
	Оповещение = Новый ОписаниеОповещения("ОбработатьИнструментСложение", Мсп_ИнструментСложениеКлиент);
	Мсп_ИнструментыКлиент.ЗарегистрироватьИнструмент("math.add", Описание, СхемаJSON, Оповещение);
	
	Оповещение = Новый ОписаниеОповещения("ОбработатьИнструментВычитание", Мсп_ИнструментСложениеКлиент);
	Мсп_ИнструментыКлиент.ЗарегистрироватьИнструмент("math.sub", "Вычитает два числа", СхемаJSON, Оповещение);
КонецПроцедуры

// Возвращает описание инструментов провайдера.
//
// Возвращаемое значение:
//  Массив из Структура - Описания инструментов.
Функция ОписаниеИнструментов() Экспорт
	Описания = Новый Массив;
	ОповещениеСложения = Новый ОписаниеОповещения("ОбработатьИнструментСложение", Мсп_ИнструментСложениеКлиент);
	ОповещениеВычитания = Новый ОписаниеОповещения("ОбработатьИнструментВычитание", Мсп_ИнструментСложениеКлиент);
	Описания.Добавить(ОписаниеИнструмента(
		"math.add",
		"Складывает два числа.",
		СхемаВходныхПараметров(),
		ОповещениеСложения));
	Описания.Добавить(ОписаниеИнструмента(
		"math.sub",
		"Вычитает два числа",
		СхемаВходныхПараметров(),
		ОповещениеВычитания));
	Возврат Описания;
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Обрабатывает вызов инструмента суммирования.
//
// Параметры:
//  Запрос - Структура - Запрос инструмента:
//   * Аргументы - Структура - Аргументы вызова.
//   * Контекст - Структура - Контекст вызова.
//  ДополнительныеПараметры - Произвольный - Дополнительные параметры вызова.
//
// Возвращаемое значение:
//  Структура - Результат инструмента MCP:
//   * content - Массив из Структура - Контент результата.
Функция ОбработатьИнструментВычитание(Запрос, ДополнительныеПараметры) Экспорт
	Если Запрос = Неопределено Тогда
		Запрос = Новый Структура;
	КонецЕсли;

	Попытка
		Аргументы = Мсп_ИнструментыКлиент.ПолучитьСвойство(Запрос, "Аргументы", Новый Структура);
		ЧислоA = ПолучитьАргументЧисло(Аргументы, "a", Неопределено);
		ЧислоB = ПолучитьАргументЧисло(Аргументы, "b", Неопределено);
		Если ЧислоA = Неопределено Или ЧислоB = Неопределено Тогда
			Возврат СформироватьТекстовыйОтвет("Invalid params: a, b must be numbers.");
		КонецЕсли;

		Результат = Новый Структура("a,b,sub", ЧислоA, ЧислоB, ЧислоA - ЧислоB);
		Возврат СформироватьТекстовыйОтвет(Мсп_ПротоколКлиент.Сериализовать(Результат));
	Исключение
		СообщениеОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		Мсп_ЛогированиеКлиент.Ошибка(СтрШаблон("Tool math.add failed: %1", СообщениеОшибки));
		Возврат СформироватьТекстовыйОтвет(СообщениеОшибки);
	КонецПопытки;
КонецФункции

// Обрабатывает вызов инструмента суммирования.
//
// Параметры:
//  Запрос - Структура - Запрос инструмента:
//   * Аргументы - Структура - Аргументы вызова.
//   * Контекст - Структура - Контекст вызова.
//  ДополнительныеПараметры - Произвольный - Дополнительные параметры вызова.
//
// Возвращаемое значение:
//  Структура - Результат инструмента MCP:
