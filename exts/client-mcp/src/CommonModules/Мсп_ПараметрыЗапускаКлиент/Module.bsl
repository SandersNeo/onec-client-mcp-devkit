#Область ПрограммныйИнтерфейс

// Запускает MCP-сервер по параметру запуска приложения.
//
// Параметры:
//  ПараметрЗапуска - Строка - Значение параметра запуска 1С из /C.
Асинх Функция ЗапуститьИзПараметраЗапуска(ПараметрЗапуска) Экспорт
	ПараметрыСервера = ПодготовитьПараметрыСервера(ПараметрЗапуска);
	Если ПараметрыСервера = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат Ждать Мсп_Сервер.Запустить(ПараметрыСервера);
КонецФункции

// Подготавливает параметры MCP-сервера по параметру запуска приложения.
//
// Параметры:
//  ПараметрЗапуска - Строка - Значение параметра запуска 1С из /C.
//
// Возвращаемое значение:
//  Структура - Параметры MCP-сервера.
//  Неопределено - В параметре запуска нет команды runMcp.
Функция ПодготовитьПараметрыСервера(ПараметрЗапуска) Экспорт
	ПараметрыКоманднойСтроки = РазобратьПараметрЗапуска(ПараметрЗапуска);
	ПутьКонфигурации = "";
	Если Не ПараметрыКоманднойСтроки.Свойство("runMcp", ПутьКонфигурации) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Порт = 8080;
	Если ЗначениеЗаполнено(ПутьКонфигурации) Тогда
		ПараметрыJSON = ПрочитатьПараметрыJSON(ПутьКонфигурации);
		Если ПараметрыJSON.Свойство("port") Тогда
			Порт = ПроверенныйПорт(ПараметрыJSON.port, "port");
		КонецЕсли;
	КонецЕсли;
	
	Если ПараметрыКоманднойСтроки.Свойство("mcpPort") Тогда
		Порт = ПроверенныйПорт(ПараметрыКоманднойСтроки.mcpPort, "mcpPort");
	КонецЕсли;
	
	Возврат Мсп_Сервер.НовыйПараметрыСервера(Порт);
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция РазобратьПараметрЗапуска(ПараметрЗапуска)
	Результат = Новый Структура;
	Если Не ЗначениеЗаполнено(ПараметрЗапуска) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Для Каждого Параметр Из СтрРазделить(ПараметрЗапуска, ";") Цикл
		ПозицияРавно = СтрНайти(Параметр, "=");
		Если ПозицияРавно = 0 Тогда
			Ключ = Параметр;
			Значение = "";
		Иначе
			Ключ = Лев(Параметр, ПозицияРавно - 1);
			Значение = Сред(Параметр, ПозицияРавно + 1);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Ключ) Тогда
			Результат.Вставить(Ключ, Значение);
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
КонецФункции

Функция ПрочитатьПараметрыJSON(ПутьКонфигурации)
	ФайлКонфигурации = Новый Файл(ПутьКонфигурации);
	Если Не ФайлКонфигурации.Существует() Тогда
		ВызватьИсключение СтрШаблон("Файл конфигурации MCP не найден: %1", ПутьКонфигурации);
	КонецЕсли;
	
	Чтение = Новый ЧтениеТекста;
	Чтение.Открыть(ПутьКонфигурации, КодировкаТекста.UTF8);
	ТекстJSON = Чтение.Прочитать();
	Чтение.Закрыть();
	
	ПараметрыJSON = Мсп_СериализацияКлиент.ПрочитатьJSONСтроку(ТекстJSON);
	
	Возврат ПараметрыJSONВСтруктуру(ПараметрыJSON);
КонецФункции

Функция ПараметрыJSONВСтруктуру(ПараметрыJSON)
	Если ТипЗнч(ПараметрыJSON) = Тип("Структура") Тогда
		Возврат ПараметрыJSON;
	КонецЕсли;
	
	Если ТипЗнч(ПараметрыJSON) <> Тип("Соответствие") Тогда
		ВызватьИсключение "Конфигурация MCP должна быть JSON-объектом.";
	КонецЕсли;
	
	Результат = Новый Структура;
	Для Каждого Пара Из ПараметрыJSON Цикл
		Результат.Вставить(Пара.Ключ, Пара.Значение);
	КонецЦикла;
	
	Возврат Результат;
КонецФункции

Функция ПроверенныйПорт(ЗначениеПорта, ИмяПараметра)
	Попытка
		Порт = Число(ЗначениеПорта);
	Исключение
		ВызватьИсключение СтрШаблон("Параметр %1 должен быть числом больше нуля.", ИмяПараметра);
	КонецПопытки;
	
	Если Порт <= 0 Тогда
		ВызватьИсключение СтрШаблон("Параметр %1 должен быть числом больше нуля.", ИмяПараметра);
	КонецЕсли;
	
	Возврат Порт;
КонецФункции

#КонецОбласти
