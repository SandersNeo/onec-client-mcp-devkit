#Область ПрограммныйИнтерфейс

// Возвращает описание инструментов провайдера.
Процедура ЗарегистрироватьИнструменты() Экспорт
	Мсп_РеестрКлиент.ЗарегистрироватьИнструмент(Мсп_ИнструментыКлиент.ОписаниеИнструмента(
		"demo_long_operation",
		"Эмулирует длительную операцию и отправляет уведомления notifications/progress и notifications/message.",
		СхемаВходныхПараметров(),
		Новый ОписаниеОповещения("ОбработатьИнструментДолгаяОперация", Мсп_ИнструментДолгаяОперацияКлиент)));
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Обрабатывает вызов инструмента длительной операции.
//
// Параметры:
//  Запрос - Структура - Запрос инструмента:
//   * Аргументы - Структура - Аргументы вызова.
//   * Контекст - Структура - Контекст вызова.
//  ДополнительныеПараметры - Произвольный - Дополнительные параметры вызова.
//
// Возвращаемое значение:
//  Структура - Итог выполнения инструмента:
//   * status - Строка - Статус выполнения.
//   * steps - Число - Количество шагов.
//   * delayMs - Число - Запрошенная задержка.
//   * progressToken - Строка - Использованный токен прогресса.
//   * notifications - Массив из Строка - Отправленные уведомления.
Функция ОбработатьИнструментДолгаяОперация(Запрос, ДополнительныеПараметры) Экспорт
	Если Запрос = Неопределено Тогда
		Запрос = Новый Структура;
	КонецЕсли;

	Аргументы = Мсп_ИнструментыКлиент.ПолучитьСвойство(Запрос, "Аргументы", Новый Структура);

	Шаги = ПолучитьАргументЧисло(Аргументы, "steps", 5);
	Если Шаги < 1 Тогда
		Шаги = 1;
	КонецЕсли;

	ЗадержкаМс = ПолучитьАргументЧисло(Аргументы, "delayMs", 250);
	Если ЗадержкаМс < 0 Тогда
		ЗадержкаМс = 0;
	КонецЕсли;

	ОтправлятьСообщения = ПолучитьАргументБулево(Аргументы, "emitMessages", Истина);
	ОтправлятьДопУведомления = ПолучитьАргументБулево(Аргументы, "emitOtherNotifications", Ложь);
	ТекстСообщения = ПолучитьАргументСтрока(Аргументы, "message", "Demo long operation");
	ТокенПрогресса = ПолучитьТокенПрогресса(Запрос, Аргументы);
	Если ЗначениеЗаполнено(ТокенПрогресса) Тогда
		ТокенПрогресса = Строка(ТокенПрогресса);
	Иначе
		ТокенПрогресса = "";
	КонецЕсли;

	Если ОтправлятьСообщения Тогда
		ОтправитьСообщение("info", СтрШаблон("%1: start", ТекстСообщения));
	КонецЕсли;

	Если ЗначениеЗаполнено(ТокенПрогресса) Тогда
		ОтправитьПрогресс(ТокенПрогресса, 0, Шаги, "Started");
	КонецЕсли;

	Для Счетчик = 1 По Шаги Цикл
		Если ОтправлятьСообщения Тогда
			ОтправитьСообщение("info", СтрШаблон("%1: step %2 of %3", ТекстСообщения, Счетчик, Шаги));
		КонецЕсли;
		Если ЗначениеЗаполнено(ТокенПрогресса) Тогда
			ОтправитьПрогресс(ТокенПрогресса, Счетчик, Шаги, СтрШаблон("Step %1", Счетчик));
		КонецЕсли;
		Если ЗадержкаМс > 0 Тогда
			Мсп_ПаузаВызовСервера.Пауза(ЗадержкаМс);
		КонецЕсли;
	КонецЦикла;

	Если ОтправлятьСообщения Тогда
		ОтправитьСообщение("info", СтрШаблон("%1: done", ТекстСообщения));
	КонецЕсли;

	Если ОтправлятьДопУведомления Тогда
		ОтправитьУведомление("notifications/tools/list_changed", Неопределено);
		ОтправитьУведомление("notifications/resources/list_changed", Неопределено);
		ОтправитьУведомление("notifications/prompts/list_changed", Неопределено);
		ОтправитьУведомление("notifications/roots/list_changed", Неопределено);
	КонецЕсли;

	Уведомления = Новый Массив;
	Уведомления.Добавить("notifications/message");
	Если ЗначениеЗаполнено(ТокенПрогресса) Тогда
		Уведомления.Добавить("notifications/progress");
	КонецЕсли;
	Если ОтправлятьДопУведомления Тогда
		Уведомления.Добавить("notifications/tools/list_changed");
		Уведомления.Добавить("notifications/resources/list_changed");
		Уведомления.Добавить("notifications/prompts/list_changed");
		Уведомления.Добавить("notifications/roots/list_changed");
	КонецЕсли;

	Результат = Новый Структура;
	Результат.Вставить("status", "ok");
	Результат.Вставить("steps", Шаги);
	Результат.Вставить("delayMs", ЗадержкаМс);
	Результат.Вставить("progressToken", ТокенПрогресса);
	Результат.Вставить("notifications", Уведомления);
	Возврат Результат;
КонецФункции

// Возвращает JSON-схему входных параметров.
Функция СхемаВходныхПараметров()
	Схема = Новый Структура;
	Схема.Вставить("type", "object");
	Свойства = Новый Структура;
	Свойства.Вставить("steps", Новый Структура("type", "number"));
	Свойства.Вставить("delayMs", Новый Структура("type", "number"));
	Свойства.Вставить("emitMessages", Новый Структура("type", "boolean"));
	Свойства.Вставить("emitOtherNotifications", Новый Структура("type", "boolean"));
	Свойства.Вставить("message", Новый Структура("type", "string"));
	Свойства.Вставить("progressToken", Новый Структура("type", "string"));
	Схема.Вставить("properties", Свойства);
	Схема.Вставить("additionalProperties", Ложь);
	Возврат Схема;
КонецФункции

Процедура ОтправитьПрогресс(ТокенПрогресса, ТекущееЗначение, Всего, Текст)
	Параметры = Новый Структура("progressToken,progress", ТокенПрогресса, ТекущееЗначение);
	Если Всего <> Неопределено Тогда
		Параметры.Вставить("total", Всего);
	КонецЕсли;
	Если ЗначениеЗаполнено(Текст) Тогда
		Параметры.Вставить("message", Текст);
	КонецЕсли;
	ОтправитьУведомление("notifications/progress", Параметры);
КонецПроцедуры

Процедура ОтправитьСообщение(Уровень, Данные)
	Параметры = Новый Структура("level,data", Уровень, Данные);
	ОтправитьУведомление("notifications/message", Параметры);
КонецПроцедуры

Процедура ОтправитьУведомление(Метод, Параметры)
	Уведомление = СформироватьУведомление(Метод, Параметры);
	Мсп_ТранспортКлиент.ОтправитьУведомление(Уведомление);
КонецПроцедуры

Функция СформироватьУведомление(Метод, Параметры)
	Данные = Новый Структура("jsonrpc,method", "2.0", Метод);
	Если Параметры <> Неопределено Тогда
		Данные.Вставить("params", Параметры);
	КонецЕсли;
	Возврат Мсп_ПротоколКлиент.Сериализовать(Данные);
КонецФункции

Функция ПолучитьТокенПрогресса(Запрос, Аргументы)
	Контекст = Мсп_ИнструментыКлиент.ПолучитьСвойство(Запрос, "Контекст", Новый Структура);
	Raw = Мсп_ИнструментыКлиент.ПолучитьСвойство(Контекст, "raw", Новый Структура);
	Meta = Мсп_ИнструментыКлиент.ПолучитьСвойство(Raw, "_meta", Новый Структура);
	ТокенПрогресса = Мсп_ИнструментыКлиент.ПолучитьСвойство(Meta, "progressToken", "");
	Если Не ЗначениеЗаполнено(ТокенПрогресса) Тогда
		ТокенПрогресса = Мсп_ИнструментыКлиент.ПолучитьСвойство(Аргументы, "progressToken", "");
	КонецЕсли;
	Возврат ТокенПрогресса;
КонецФункции

Функция ПолучитьАргументЧисло(Аргументы, Имя, ЗначениеПоУмолчанию)
	Значение = Мсп_ИнструментыКлиент.ПолучитьСвойство(Аргументы, Имя, Неопределено);
	Если Значение = Неопределено Тогда
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;
	Если ТипЗнч(Значение) = Тип("Число") Тогда
		Возврат Значение;
	КонецЕсли;
	Попытка
		Возврат Число(Значение);
	Исключение
		Возврат ЗначениеПоУмолчанию;
	КонецПопытки;
КонецФункции

Функция ПолучитьАргументБулево(Аргументы, Имя, ЗначениеПоУмолчанию)
	Значение = Мсп_ИнструментыКлиент.ПолучитьСвойство(Аргументы, Имя, Неопределено);
	Если Значение = Неопределено Тогда
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;
	Если ТипЗнч(Значение) = Тип("Булево") Тогда
		Возврат Значение;
	КонецЕсли;
	Если ТипЗнч(Значение) = Тип("Число") Тогда
		Возврат Значение <> 0;
	КонецЕсли;
	Если ТипЗнч(Значение) = Тип("Строка") Тогда
		Возврат ВРег(Значение) = "TRUE" Или Значение = "1";
	КонецЕсли;
	Возврат ЗначениеПоУмолчанию;
КонецФункции

Функция ПолучитьАргументСтрока(Аргументы, Имя, ЗначениеПоУмолчанию)
	Значение = Мсп_ИнструментыКлиент.ПолучитьСвойство(Аргументы, Имя, Неопределено);
	Если Значение = Неопределено Тогда
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;
	Если ТипЗнч(Значение) = Тип("Строка") Тогда
		Возврат Значение;
	КонецЕсли;
	Попытка
		Возврат Строка(Значение);
	Исключение
		Возврат ЗначениеПоУмолчанию;
	КонецПопытки;
КонецФункции

#КонецОбласти
