#Область ПрограммныйИнтерфейс

// Инициализирует реестры MCP в состоянии клиента.
Процедура MCP_ИнициализироватьРеестры() Экспорт
	MCP_ПолучитьРеестр("MCP_Инструменты");
	MCP_ПолучитьРеестр("MCP_Ресурсы");
	MCP_ПолучитьРеестр("MCP_Промпты");
	MCP_ПолучитьРеестр("MCP_Сессии");
КонецПроцедуры

// Возвращает реестр по имени из состояния MCP.
//
// Параметры:
//  Имя - Строка - Имя реестра.
//
// Возвращаемое значение:
//  Соответствие из Произвольный - Реестр, ключи - строки, значения - элементы реестра.
Функция MCP_ПолучитьРеестр(Имя) Экспорт
	Состояние = MCP_ПолучитьСостояние();
	Если Не Состояние.Свойство(Имя) Тогда
		Состояние.Вставить(Имя, Новый Соответствие);
	КонецЕсли;
	Возврат Состояние[Имя];
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Возвращает структуру состояния MCP.
//
// Возвращаемое значение:
//  Структура - Состояние MCP.
Функция MCP_ПолучитьСостояние()
	Возврат Мсп_СостояниеКлиент.ПолучитьСостояние();
КонецФункции

#КонецОбласти
