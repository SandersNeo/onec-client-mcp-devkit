#Область ПрограммныйИнтерфейс

Функция ОписаниеИнструмента(Имя, Описание, СхемаПараметров, Оповещение) Экспорт
	Результат = Мсп_РеестрКлиент.НовыйОписаниеИнструмента();
	Результат.Имя = Имя;
	Результат.Описание = Описание;
	Результат.СхемаПараметров = СхемаПараметров;
	Результат.Обработчик = Оповещение;
	
	Возврат Результат;
КонецФункции

// Читает JSON-строку и возвращает объект.
//
// Параметры:
//  ТекстJSON - Строка - JSON-строка.
//
// Возвращаемое значение:
//  Произвольный - Прочитанный объект.
Функция ПрочитатьJSONСтроку(ТекстJSON) Экспорт
	Возврат Мсп_ПротоколКлиент.ПрочитатьJSONСтроку(ТекстJSON);
КонецФункции

// Читает JSON-строку с подстановкой значения по умолчанию при ошибке.
//
// Параметры:
//  ТекстJSON - Строка - JSON-строка.
//  ЗначениеПоУмолчанию - Произвольный, Неопределено - Значение при ошибке чтения.
//
// Возвращаемое значение:
//  Произвольный - Прочитанный объект или значение по умолчанию.
//  Неопределено - Нет значения по умолчанию или не удалось прочитать JSON.
Функция ПрочитатьJSONСтрокуБезОшибок(ТекстJSON, ЗначениеПоУмолчанию = Неопределено) Экспорт
	Возврат Мсп_ПротоколКлиент.ПрочитатьJSONСтрокуБезОшибок(ТекстJSON, ЗначениеПоУмолчанию);
КонецФункции

// Получает свойство из структуры/соответствия с поддержкой значения по умолчанию.
//
// Параметры:
//  Данные - Структура - Структура или соответствие.
//  Имя - Строка - Имя свойства.
//  ЗначениеПоУмолчанию - Произвольный, Неопределено - Значение по умолчанию.
//
// Возвращаемое значение:
//  Произвольный - Значение свойства или значение по умолчанию.
//  Неопределено - Свойство не найдено и значение по умолчанию не задано.
Функция ПолучитьСвойство(Данные, Имя, ЗначениеПоУмолчанию) Экспорт
	Возврат Мсп_ПротоколКлиент.ПолучитьСвойство(Данные, Имя, ЗначениеПоУмолчанию);
КонецФункции

#КонецОбласти
