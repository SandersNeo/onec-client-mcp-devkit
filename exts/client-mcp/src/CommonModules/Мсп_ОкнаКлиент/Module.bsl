#Область ПрограммныйИнтерфейс

// Возвращает активное окно тест-клиента.
//
// Возвращаемое значение:
//  Структура - Результат получения окна:
//   * Окно - ТестируемоеОкноКлиентскогоПриложения, Неопределено - Активное окно.
//   * Ошибка - Строка - Описание ошибки.
Функция ПолучитьАктивноеОкно() Экспорт
	ТестКлиент = Мсп_УправлениеТестКлиентом.ПолучитьТестКлиент();
	Если ТестКлиент = Неопределено Тогда
		Возврат НовыйРезультатПолученияОкна(Неопределено, "test client not connected");
	КонецЕсли;

	Попытка
		Окно = ТестКлиент.ПолучитьАктивноеОкно();
		Возврат НовыйРезультатПолученияОкна(Окно, "");
	Исключение
		Возврат НовыйРезультатПолученияОкна(Неопределено, ОписаниеОшибки());
	КонецПопытки;
КонецФункции

// Возвращает список окон тест-клиента.
//
// Возвращаемое значение:
//  Структура - Результат получения окон:
//   * Окна - Массив - Список окон.
//   * Ошибка - Строка - Описание ошибки.
Функция ПолучитьСписокОкон() Экспорт
	ТестКлиент = Мсп_УправлениеТестКлиентом.ПолучитьТестКлиент();
	Если ТестКлиент = Неопределено Тогда
		Возврат НовыйРезультатСпискаОкон(Новый Массив, "test client not connected");
	КонецЕсли;

	Попытка
		Объекты = ТестКлиент.ПолучитьПодчиненныеОбъекты();
	Исключение
		Возврат НовыйРезультатСпискаОкон(Новый Массив, ОписаниеОшибки());
	КонецПопытки;
	Если Объекты = Неопределено Тогда
		Возврат НовыйРезультатСпискаОкон(Новый Массив, "windows not found");
	КонецЕсли;

	Окна = Новый Массив;
	Для Каждого Объект Из Объекты Цикл
		Если ЭтоТестируемоеОкно(Объект) Тогда
			Окна.Добавить(Объект);
		КонецЕсли;
	КонецЦикла;

	Возврат НовыйРезультатСпискаОкон(Окна, "");
КонецФункции

// Формирует снимок окна в формате контракта UI.
//
// Параметры:
//  Окно - ТестируемоеОкноКлиентскогоПриложения - Окно тест-клиента.
//
// Возвращаемое значение:
//  Структура - Снимок окна.
Функция СформироватьСнимокОкна(Окно) Экспорт
	Снимок = Новый Структура;
	Снимок.Вставить("type", "window");
	Снимок.Вставить("title", Окно.Заголовок);
	Снимок.Вставить("isMain", Окно.Основное);
	Снимок.Вставить("homePage", Окно.НачальнаяСтраница);
	Снимок.Вставить("children", Новый Массив);
	Возврат Снимок;
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция НовыйРезультатПолученияОкна(Окно, Ошибка)
	Возврат Новый Структура("Окно, Ошибка", Окно, Ошибка);
КонецФункции

Функция НовыйРезультатСпискаОкон(Окна, Ошибка)
	Возврат Новый Структура("Окна, Ошибка", Окна, Ошибка);
КонецФункции

Функция ЭтоТестируемоеОкно(Объект)
	Возврат ТипЗнч(Объект) = Тип("ТестируемоеОкноКлиентскогоПриложения");
КонецФункции

#КонецОбласти
