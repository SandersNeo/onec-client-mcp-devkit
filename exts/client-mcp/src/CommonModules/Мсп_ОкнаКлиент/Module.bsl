#Область ПрограммныйИнтерфейс

// Возвращает активное окно тест-клиента.
//
// Возвращаемое значение:
//  Структура - Результат получения окна:
//   * Окно - ТестируемоеОкноКлиентскогоПриложения, Неопределено - Активное окно.
//   * КодОшибки - Строка - Код ошибки.
//   * Ошибка - Строка - Описание ошибки.
Функция АктивноеОкноПриложения() Экспорт
	ТестКлиент = Мсп_УправлениеТестКлиентом.ПолучитьТестКлиент();
	Если ТестКлиент = Неопределено Тогда
		Возврат НовыйРезультатПолученияОкна(Неопределено, "UI_NOT_READY", "test client not connected");
	КонецЕсли;

	Попытка
		Окно = ТестКлиент.ПолучитьАктивноеОкно();
		Возврат НовыйРезультатПолученияОкна(Окно);
	Исключение
		Возврат НовыйРезультатПолученияОкна(Неопределено, "UI_NOT_READY", ОписаниеОшибки());
	КонецПопытки;
КонецФункции

// Возвращает список окон тест-клиента.
//
// Возвращаемое значение:
//  Структура - Результат получения окон:
//   * Окна - Массив - Список окон.
//   * КодОшибки - Строка - Код ошибки.
//   * Ошибка - Строка - Описание ошибки.
Функция СписокОконПриложения() Экспорт
	ТестКлиент = Мсп_УправлениеТестКлиентом.ПолучитьТестКлиент();
	Если ТестКлиент = Неопределено Тогда
		Возврат НовыйРезультатСпискаОкон(Новый Массив, "UI_NOT_READY", "test client not connected");
	КонецЕсли;
	
	Попытка
		Объекты = ТестКлиент.ПолучитьПодчиненныеОбъекты();
	Исключение
		Возврат НовыйРезультатСпискаОкон(Новый Массив, "UI_NOT_READY", ОписаниеОшибки());
	КонецПопытки;
	Если Объекты = Неопределено Тогда
		Возврат НовыйРезультатСпискаОкон(Новый Массив, "UI_NOT_FOUND", "windows not found");
	КонецЕсли;
	
	Окна = Новый Массив;
	Для Каждого Объект Из Объекты Цикл
		Если ЭтоТестируемоеОкно(Объект) Тогда
			Окна.Добавить(Объект);
		КонецЕсли;
	КонецЦикла;
	
	Возврат НовыйРезультатСпискаОкон(Окна);
КонецФункции

// Возвращает URI окна.
//
// Параметры:
//  Окно - ТестируемоеОкноКлиентскогоПриложения - Окно тест-клиента.
//
// Возвращаемое значение:
//  Строка - URI окна.
Функция URIОкна(Окно) Экспорт
	Возврат Мсп_URIКлиент.URIОкна(НавигационнаяСсылкаОкна(Окно));
КонецФункции

// Возвращает окно по URI.
//
// Параметры:
//  URI - Строка - URI окна.
//
// Возвращаемое значение:
//  Структура - Результат получения окна:
//   * Окно - ТестируемоеОкноКлиентскогоПриложения, Неопределено - Найденное окно.
//   * КодОшибки - Строка - Код ошибки.
//   * Ошибка - Строка - Описание ошибки.
Функция ОкноПоURI(URI) Экспорт
	Если Не Мсп_URIКлиент.ЭтоURIОкна(URI) Тогда
		Возврат НовыйРезультатПолученияОкна(Неопределено, "INVALID_URI", "unsupported window uri");
	КонецЕсли;

	Если Мсп_URIКлиент.ЭтоURIАктивногоОкна(URI) Тогда
		Возврат АктивноеОкноПриложения();
	КонецЕсли;

	Если Не ЗначениеЗаполнено(Мсп_URIКлиент.СегментОкна(URI)) Тогда
		Возврат НовыйРезультатПолученияОкна(Неопределено, "INVALID_URI", "window uri path is empty");
	КонецЕсли;

	РезультатСписка = СписокОконПриложения();
	Если ЗначениеЗаполнено(РезультатСписка.КодОшибки) Тогда
		Возврат НовыйРезультатПолученияОкна(Неопределено, РезультатСписка.КодОшибки, РезультатСписка.Ошибка);
	КонецЕсли;

	НайденныеОкна = Новый Массив;
	Для Каждого Окно Из РезультатСписка.Окна Цикл
		Если URIОкна(Окно) = URI Тогда
			НайденныеОкна.Добавить(Окно);
		КонецЕсли;
	КонецЦикла;

	Если НайденныеОкна.Количество() = 0 Тогда
		Возврат НовыйРезультатПолученияОкна(Неопределено, "UI_NOT_FOUND", "window not found");
	КонецЕсли;
	Если НайденныеОкна.Количество() > 1 Тогда
		Возврат НовыйРезультатПолученияОкна(Неопределено, "UI_AMBIGUOUS_OBJECT", "window uri is ambiguous");
	КонецЕсли;

	Возврат НовыйРезультатПолученияОкна(НайденныеОкна[0]);
КонецФункции

// Формирует снимок окна в формате контракта UI.
//
// Параметры:
//  Окно - ТестируемоеОкноКлиентскогоПриложения - Окно тест-клиента.
//
// Возвращаемое значение:
//  Структура - Снимок окна.
Функция СформироватьСнимокОкна(Окно, дополнительныеПараметры) Экспорт
	Снимок = Новый Структура;
	Снимок.Вставить("type", "window");
	Снимок.Вставить("uri", URIОкна(Окно));
	Снимок.Вставить("title", ЗаголовокОкна(Окно));
	Снимок.Вставить("isMain", ЭтоОсновноеОкно(Окно));
	Снимок.Вставить("homePage", ЭтоНачальнаяСтраница(Окно));
	Снимок.Вставить("forms", СписокФормОкна(Окно));
	Возврат Снимок;
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция НовыйРезультатПолученияОкна(Окно, КодОшибки = "", Ошибка = "")
	Возврат Новый Структура("Окно, КодОшибки, Ошибка", Окно, КодОшибки, Ошибка);
КонецФункции

Функция НовыйРезультатСпискаОкон(Окна, КодОшибки = "", Ошибка = "")
	Возврат Новый Структура("Окна, КодОшибки, Ошибка", Окна, КодОшибки, Ошибка);
КонецФункции

Функция ЭтоТестируемоеОкно(Объект)
	Возврат ТипЗнч(Объект) = Тип("ТестируемоеОкноКлиентскогоПриложения");
КонецФункции

Функция ЭтоТестируемаяФорма(Объект)
	Возврат ТипЗнч(Объект) = Тип("ТестируемаяФорма");
КонецФункции

Функция ЗаголовокОкна(Окно)
	Попытка
		Возврат Окно.Заголовок;
	Исключение
	КонецПопытки;
	Возврат Мсп_Коллекции.ПолучитьСвойство(Окно, "Заголовок", "");
КонецФункции

Функция НавигационнаяСсылкаОкна(Окно)
	Попытка
		Возврат Окно.НавигационнаяСсылка;
	Исключение
	КонецПопытки;
	Возврат Мсп_Коллекции.ПолучитьСвойство(Окно, "НавигационнаяСсылка", "");
КонецФункции

Функция ЭтоОсновноеОкно(Окно)
	Попытка
		Возврат Окно.Основное;
	Исключение
	КонецПопытки;
	Возврат Мсп_Коллекции.ПолучитьСвойство(Окно, "Основное", Ложь);
КонецФункции

Функция ЭтоНачальнаяСтраница(Окно)
	Попытка
		Возврат Окно.НачальнаяСтраница;
	Исключение
	КонецПопытки;
	Возврат Мсп_Коллекции.ПолучитьСвойство(Окно, "НачальнаяСтраница", Ложь);
КонецФункции

Функция СписокФормОкна(Окно)
	Результат = Новый Массив;
	Для Каждого Форма Из ПодчиненныеФормыОкна(Окно) Цикл
		Результат.Добавить(ОписаниеФормыОкна(Форма));
	КонецЦикла;

	Возврат Результат;
КонецФункции

Функция ПодчиненныеФормыОкна(Окно)
	Попытка
		ПодчиненныеОбъекты = Окно.ПолучитьПодчиненныеОбъекты();
	Исключение
		Возврат Новый Массив;
	КонецПопытки;
	Если ПодчиненныеОбъекты = Неопределено Тогда
		Возврат Новый Массив;
	КонецЕсли;

	Формы = Новый Массив;
	Для Каждого ПодчиненныйОбъект Из ПодчиненныеОбъекты Цикл
		Если ЭтоТестируемаяФорма(ПодчиненныйОбъект) Тогда
			Формы.Добавить(ПодчиненныйОбъект);
		КонецЕсли;
	КонецЦикла;

	Возврат Формы;
КонецФункции

Функция ОписаниеФормыОкна(Форма)
	Возврат Новый Структура("title,uri", ЗаголовокФормы(Форма), URIФормыОкна(Форма));
КонецФункции

Функция ЗаголовокФормы(Форма)
	Попытка
		Возврат Форма.ТекстЗаголовка;
	Исключение
	КонецПопытки;
	Возврат Мсп_Коллекции.ПолучитьСвойство(Форма, "ТекстЗаголовка", "");
КонецФункции

Функция URIФормыОкна(Форма)
	Возврат Мсп_URIКлиент.URIФормы(ИмяФормыОкна(Форма));
КонецФункции

Функция ИмяФормыОкна(Форма)
	Попытка
		Возврат Форма.ИмяФормы;
	Исключение
	КонецПопытки;
	Возврат Мсп_Коллекции.ПолучитьСвойство(Форма, "ИмяФормы", "");
КонецФункции

#КонецОбласти
