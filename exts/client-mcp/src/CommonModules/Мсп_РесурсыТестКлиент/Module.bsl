#Область ПрограммныйИнтерфейс

// Регистрирует ресурсы тест-клиента MCP.
Процедура ЗарегистрироватьРесурсы() Экспорт
	Мсп_РеестрКлиент.ЗарегистрироватьРесурс(Мсп_РесурсыКлиент.НовыйОписаниеРесурса(
		"window://active",
		"Активное окно",
		"Снимок активного окна тест-клиента",
		Новый ОписаниеОповещения("ОбработатьРесурсОкна", Мсп_РесурсыТестКлиент)));
	Мсп_РеестрКлиент.ЗарегистрироватьШаблонРесурса(Мсп_РесурсыКлиент.НовыйОписаниеШаблонаРесурса(
		"window://{path}",
		"Окно",
		"Снимок окна тест-клиента по навигационной ссылке",
		Новый ОписаниеОповещения("ОбработатьРесурсОкна", Мсп_РесурсыТестКлиент)));
	Мсп_РеестрКлиент.ЗарегистрироватьШаблонРесурса(Мсп_РесурсыКлиент.НовыйОписаниеШаблонаРесурса(
		"form://{name}",
		"Форма",
		"Снимок формы тест-клиента по имени формы",
		Новый ОписаниеОповещения("ОбработатьРесурсФормы", Мсп_РесурсыТестКлиент)));
	Мсп_РеестрКлиент.ЗарегистрироватьРесурс(Мсп_РесурсыКлиент.НовыйОписаниеРесурса(
		"snapshot://active",
		"Снимок активного окна",
		"UI-дерево активного окна тест-клиента в формате JSON",
		Новый ОписаниеОповещения("ОбработатьРесурсСнимка", Мсп_РесурсыТестКлиент)));
	Мсп_РеестрКлиент.ЗарегистрироватьШаблонРесурса(Мсп_РесурсыКлиент.НовыйОписаниеШаблонаРесурса(
		"snapshot://{window_uri}",
		"Снимок окна",
		"UI-дерево окна тест-клиента по URI в формате JSON",
		Новый ОписаниеОповещения("ОбработатьРесурсСнимка", Мсп_РесурсыТестКлиент)));
КонецПроцедуры

// Возвращает снимок окна.
//
// Параметры:
//  Запрос - Структура - Запрос ресурса:
//   * Аргументы - Структура - Аргументы вызова.
//   * Контекст - Структура - Контекст вызова.
//  ДополнительныеПараметры - Произвольный - Дополнительные параметры вызова.
//
// Возвращаемое значение:
//  Произвольный - Результат чтения ресурса или описание ошибки ресурса.
Функция ОбработатьРесурсОкна(Запрос, ДополнительныеПараметры) Экспорт
	URI = URIЗапроса(Запрос);
	РезультатОкна = Мсп_ОкнаКлиент.ОкноПоURI(URI);
	Возврат Мсп_РесурсыКлиент.РезультатРесурсаИзРазрешения(
		URI,
		РезультатОкна,
		"Окно",
		"window",
		Новый ОписаниеОповещения("СформироватьСнимокОкна", Мсп_ОкнаКлиент));
КонецФункции

// Возвращает снимок формы.
//
// Параметры:
//  Запрос - Структура - Запрос ресурса:
//   * Аргументы - Структура - Аргументы вызова.
//   * Контекст - Структура - Контекст вызова.
//  ДополнительныеПараметры - Произвольный - Дополнительные параметры вызова.
//
// Возвращаемое значение:
//  Произвольный - Результат чтения ресурса или описание ошибки ресурса.
Функция ОбработатьРесурсФормы(Запрос, ДополнительныеПараметры) Экспорт
	URI = URIЗапроса(Запрос);
	РезультатФормы = Мсп_ФормыКлиент.ФормаПоURI(URI);
	Возврат Мсп_РесурсыКлиент.РезультатРесурсаИзРазрешения(
		URI,
		РезультатФормы,
		"Объект",
		"form",
		Новый ОписаниеОповещения("СформироватьСнимокФормы", Мсп_ФормыКлиент));
КонецФункции

// Возвращает UI-дерево окна или активного окна в формате JSON.
//
// Параметры:
//  Запрос - Структура - Запрос ресурса:
//   * Аргументы - Структура - Аргументы вызова.
//   * Контекст - Структура - Контекст вызова.
//  ДополнительныеПараметры - Произвольный - Дополнительные параметры вызова.
//
// Возвращаемое значение:
//  Произвольный - Результат чтения ресурса или описание ошибки ресурса.
Функция ОбработатьРесурсСнимка(Запрос, ДополнительныеПараметры) Экспорт
	URI = URIЗапроса(Запрос);

	Если URI = "snapshot://active" Тогда
		РезультатОкна = Мсп_ОкнаКлиент.АктивноеОкноПриложения();
		Если ЗначениеЗаполнено(РезультатОкна.КодОшибки) Тогда
			Возврат Новый Структура("КодОшибки,Ошибка", РезультатОкна.КодОшибки, РезультатОкна.Ошибка);
		КонецЕсли;
		Снимок = Мсп_ОкнаКлиент.СформироватьСнимокОкна(РезультатОкна.Окно);
		Возврат Мсп_РесурсыКлиент.РезультатРесурса(URI, Снимок);
	КонецЕсли;

	// snapshot://{window_uri} — декодируем URI окна из аргументов или пути
	Аргументы = Мсп_Коллекции.ПолучитьСвойство(Запрос.Контекст, "arguments", Новый Структура);
	URIОкна = Мсп_Коллекции.ПолучитьСвойство(Аргументы, "window_uri", "");
	Если Не ЗначениеЗаполнено(URIОкна) Тогда
		URIОкна = Мсп_URIКлиент.ДекодироватьURL(Сред(URI, СтрДлина("snapshot://") + 1));
	КонецЕсли;

	РезультатОкна = Мсп_ОкнаКлиент.ОкноПоURI(URIОкна);
	Если ЗначениеЗаполнено(РезультатОкна.КодОшибки) Тогда
		Возврат Новый Структура("КодОшибки,Ошибка", РезультатОкна.КодОшибки, РезультатОкна.Ошибка);
	КонецЕсли;

	Снимок = Мсп_ОкнаКлиент.СформироватьСнимокОкна(РезультатОкна.Окно);
	Возврат Мсп_РесурсыКлиент.РезультатРесурса(URI, Снимок);
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция URIЗапроса(Запрос)
	Если Запрос = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	Возврат Мсп_Коллекции.ПолучитьСвойство(Запрос.Контекст, "uri", "");
КонецФункции

#КонецОбласти
