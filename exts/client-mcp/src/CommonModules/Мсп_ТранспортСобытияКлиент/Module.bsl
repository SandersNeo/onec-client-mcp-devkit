#Область ПрограммныйИнтерфейс

// Обрабатывает события внешней компоненты MCP.
//
// Параметры:
//  Источник - Строка - Имя источника события.
//  Событие - Строка - Имя события.
//  Данные - Строка - Данные события.
//
// Возвращаемое значение:
//  Булево - Истина, если событие обработано.
Асинх Функция ОбработатьВнешнееСобытие(Источник, Событие, Данные) Экспорт
	Если Источник <> "WebTransport" Тогда
		Возврат Ложь;
	КонецЕсли;

	СводкаДанных = ПолучитьСводкуДанных(Данные);

	Мсп_ЛогированиеКлиент.Отладка(
		"External event received source=%1 event=%2 has_data=%3 data_len=%4 data_preview=%5",
		Источник,
		Событие,
		СводкаДанных.ЕстьДанные,
		СводкаДанных.ДлинаДанных,
		СводкаДанных.ПревьюДанных);

	Если Событие = "MCP_TOOL_CALL" Тогда
		Мсп_ЛогированиеКлиент.Отладка("External event MCP_TOOL_CALL: begin");
		Результат = Ждать ОбработатьToolCall(Данные);
		Мсп_ЛогированиеКлиент.Отладка("External event MCP_TOOL_CALL: end result=%1", Результат);
		Возврат Результат;
	ИначеЕсли Событие = "MCP_RESOURCE_READ" Тогда
		Мсп_ЛогированиеКлиент.Отладка("External event MCP_RESOURCE_READ: begin");
		Результат = Ждать ОбработатьResourceRead(Данные);
		Мсп_ЛогированиеКлиент.Отладка("External event MCP_RESOURCE_READ: end result=%1", Результат);
		Возврат Результат;
	ИначеЕсли Событие = "MCP_PROMPT_GET" Тогда
		Мсп_ЛогированиеКлиент.Отладка("External event MCP_PROMPT_GET: begin");
		Результат = Ждать ОбработатьPromptGet(Данные);
		Мсп_ЛогированиеКлиент.Отладка("External event MCP_PROMPT_GET: end result=%1", Результат);
		Возврат Результат;
	ИначеЕсли Событие = "MCP_NOTIFICATION" Тогда
		Мсп_ЛогированиеКлиент.Отладка("External event MCP_NOTIFICATION: begin");
		ОбработатьNotification(Данные);
		Мсп_ЛогированиеКлиент.Отладка("External event MCP_NOTIFICATION: end");
		Возврат Истина;
	ИначеЕсли Событие = "MCP_RESOURCE_SUBSCRIBE" Тогда
		Мсп_ЛогированиеКлиент.Отладка("External event MCP_RESOURCE_SUBSCRIBE: begin");
		ОбработатьResourceSubscribe(Данные);
		Мсп_ЛогированиеКлиент.Отладка("External event MCP_RESOURCE_SUBSCRIBE: end");
		Возврат Истина;
	ИначеЕсли Событие = "MCP_RESOURCE_UNSUBSCRIBE" Тогда
		Мсп_ЛогированиеКлиент.Отладка("External event MCP_RESOURCE_UNSUBSCRIBE: begin");
		ОбработатьResourceUnsubscribe(Данные);
		Мсп_ЛогированиеКлиент.Отладка("External event MCP_RESOURCE_UNSUBSCRIBE: end");
		Возврат Истина;
	ИначеЕсли Событие = "MCP_TASK_CANCELLED" Тогда
		Мсп_ЛогированиеКлиент.Отладка("External event MCP_TASK_CANCELLED: begin");
		Мсп_ЗадачиКлиент.ОбработатьTaskCancelled(Данные);
		Мсп_ЛогированиеКлиент.Отладка("External event MCP_TASK_CANCELLED: end");
		Возврат Истина;
	Иначе
		Мсп_ЛогированиеКлиент.Отладка(
			"External event ignored: unknown event=%1 source=%2 has_data=%3 data_len=%4 data_preview=%5",
			Событие,
			Источник,
			СводкаДанных.ЕстьДанные,
			СводкаДанных.ДлинаДанных,
			СводкаДанных.ПревьюДанных);
		Возврат Ложь;
	КонецЕсли;
КонецФункции

Функция ПодготовитьЗапросИнструмента(ЗапросJSON) Экспорт
	Если Не ЗначениеЗаполнено(ЗапросJSON) Тогда
		ЗаписатьПропускСобытия("MCP_TOOL_CALL", "empty request JSON");
		Возврат Неопределено;
	КонецЕсли;

	Запрос = Мсп_СериализацияКлиент.ПрочитатьJSONСтрокуБезОшибок(ЗапросJSON, Неопределено);
	Если ТипЗнч(Запрос) <> Тип("Структура")
		И ТипЗнч(Запрос) <> Тип("Соответствие") Тогда
		ЗаписатьПропускСобытия("MCP_TOOL_CALL", "request is not object");
		Возврат Неопределено;
	КонецЕсли;

	РежимВыполнения = Мсп_Коллекции.Свойство(Запрос, "executionMode", "sync");
	Идентификатор = Мсп_Коллекции.Свойство(Запрос, "id", "");
	ИдентификаторЗадачи = Мсп_Коллекции.Свойство(Запрос, "taskId", "");
	Если РежимВыполнения = "task" Тогда
		Если Не ЗначениеЗаполнено(ИдентификаторЗадачи) Тогда
			ЗаписатьПропускСобытия("MCP_TOOL_CALL", "missing taskId");
			Возврат Неопределено;
		КонецЕсли;
	ИначеЕсли Не ЗначениеЗаполнено(Идентификатор) Тогда
		ЗаписатьПропускСобытия("MCP_TOOL_CALL", "missing id");
		Возврат Неопределено;
	КонецЕсли;

	Возврат НовыйКонтекстЗапроса(
		Запрос,
		Идентификатор,
		РежимВыполнения,
		ИдентификаторЗадачи,
		ProgressTokenЗапроса(Запрос));
КонецФункции

// Создаёт единый контекст входящего transport-запроса.
//
// Параметры:
//  Запрос - Структура|Соответствие - Исходный запрос.
//  Идентификатор - Строка - Идентификатор ответа.
//  РежимВыполнения - Строка - Режим вызова инструмента.
//  ИдентификаторЗадачи - Строка - Идентификатор task-вызова.
//  ProgressToken - Произвольный - Token для progress notifications.
//
// Возвращаемое значение:
//  Структура - Контекст transport-запроса.
Функция НовыйКонтекстЗапроса(Запрос, Идентификатор, РежимВыполнения = "sync", ИдентификаторЗадачи = "", ProgressToken = Неопределено) Экспорт
	Контекст = Новый Структура("Запрос, Идентификатор", Запрос, Идентификатор);
	Контекст.Вставить("РежимВыполнения", РежимВыполнения);
	Контекст.Вставить("ИдентификаторЗадачи", ИдентификаторЗадачи);
	Контекст.Вставить("ProgressToken", ProgressToken);
	Возврат Контекст;
КонецФункции

Функция ПараметрыВызоваИнструмента(КонтекстЗапроса) Экспорт
	Если КонтекстЗапроса = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;

	Запрос = КонтекстЗапроса.Запрос;
	ИмяИнструмента = Мсп_Коллекции.Свойство(Запрос, "name", "");
	Аргументы = АргументыЗапроса(Запрос, Новый Структура);

	Параметры = Новый Структура(
		"name,arguments,executionMode",
		ИмяИнструмента,
		Аргументы,
		КонтекстЗапроса.РежимВыполнения);
	Если ЗначениеЗаполнено(КонтекстЗапроса.ИдентификаторЗадачи) Тогда
		Параметры.Вставить("taskId", КонтекстЗапроса.ИдентификаторЗадачи);
	КонецЕсли;
	Если КонтекстЗапроса.ProgressToken <> Неопределено Тогда
		Параметры.Вставить("progressToken", КонтекстЗапроса.ProgressToken);
	КонецЕсли;

	Возврат Параметры;
КонецФункции

Функция ПараметрыЧтенияРесурса(КонтекстЗапроса) Экспорт
	Если КонтекстЗапроса = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;

	Запрос = КонтекстЗапроса.Запрос;
	Параметры = Новый Структура("uri", Мсп_Коллекции.Свойство(Запрос, "uri", ""));
	URIШаблон = Мсп_Коллекции.Свойство(Запрос, "uriTemplate", "");
	Если ЗначениеЗаполнено(URIШаблон) Тогда
		Параметры.Вставить("uriTemplate", URIШаблон);
	КонецЕсли;

	Аргументы = АргументыЗапроса(Запрос);
	Если Аргументы <> Неопределено Тогда
		Параметры.Вставить("arguments", Аргументы);
	КонецЕсли;

	Возврат Параметры;
КонецФункции

Функция ПараметрыПолученияПромпта(КонтекстЗапроса) Экспорт
	Если КонтекстЗапроса = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;

	Запрос = КонтекстЗапроса.Запрос;
	Параметры = Новый Структура("name", Мсп_Коллекции.Свойство(Запрос, "name", ""));
	Аргументы = АргументыЗапроса(Запрос);
	Если Аргументы <> Неопределено Тогда
		Параметры.Вставить("arguments", Аргументы);
	КонецЕсли;

	Возврат Параметры;
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ПолучитьСводкуДанных(Данные)
	ДлинаПревью = 200;

	ЕстьДанные = ЗначениеЗаполнено(Данные);
	ДлинаДанных = 0;
	ПревьюДанных = "";

	Если ЕстьДанные Тогда
		ДлинаДанных = СтрДлина(Данные);
		ПревьюДанных = Лев(Данные, ДлинаПревью);
		ПревьюДанных = СтрЗаменить(ПревьюДанных, Символы.ПС, " ");
		ПревьюДанных = СтрЗаменить(ПревьюДанных, Символы.ВК, " ");
		ПревьюДанных = СтрЗаменить(ПревьюДанных, Символы.Таб, " ");
		Если ДлинаДанных > ДлинаПревью Тогда
			ПревьюДанных = ПревьюДанных + "...";
		КонецЕсли;
	КонецЕсли;

	Возврат НоваяСводкаДанных(ЕстьДанные, ДлинаДанных, ПревьюДанных);
КонецФункции

Функция НоваяСводкаДанных(ЕстьДанные, ДлинаДанных, ПревьюДанных)
	Сводка = Новый Структура;
	Сводка.Вставить("ЕстьДанные", ЕстьДанные);
	Сводка.Вставить("ДлинаДанных", ДлинаДанных);
	Сводка.Вставить("ПревьюДанных", ПревьюДанных);
	Возврат Сводка;
КонецФункции

Процедура ЗаписатьПропускСобытия(ИмяСобытия, Причина)
	Мсп_ЛогированиеКлиент.Важно(ИмяСобытия + " ignored: " + Причина);
КонецПроцедуры

Функция ПодготовитьЗапросСобытия(ИмяСобытия, ЗапросJSON)
	Если Не ЗначениеЗаполнено(ЗапросJSON) Тогда
		ЗаписатьПропускСобытия(ИмяСобытия, "empty request JSON");
		Возврат Неопределено;
	КонецЕсли;

	Запрос = Мсп_СериализацияКлиент.ПрочитатьJSONСтрокуБезОшибок(ЗапросJSON, Неопределено);
	Если ТипЗнч(Запрос) <> Тип("Структура")
		И ТипЗнч(Запрос) <> Тип("Соответствие") Тогда
		ЗаписатьПропускСобытия(ИмяСобытия, "request is not object");
		Возврат Неопределено;
	КонецЕсли;

	Идентификатор = Мсп_Коллекции.Свойство(Запрос, "id", "");
	Если Не ЗначениеЗаполнено(Идентификатор) Тогда
		ЗаписатьПропускСобытия(ИмяСобытия, "missing id");
		Возврат Неопределено;
	КонецЕсли;

	Возврат НовыйКонтекстЗапроса(Запрос, Идентификатор);
КонецФункции

Функция АргументыЗапроса(Запрос, ЗначениеПоУмолчанию = Неопределено)
	Аргументы = Мсп_Коллекции.Свойство(Запрос, "arguments", Неопределено);
	Если ТипЗнч(Аргументы) <> Тип("Структура")
		И ТипЗнч(Аргументы) <> Тип("Соответствие") Тогда
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;

	Возврат Аргументы;
КонецФункции

Функция ProgressTokenЗапроса(Запрос)
	Мета = Мсп_Коллекции.Свойство(Запрос, "_meta", Неопределено);
	Если ТипЗнч(Мета) = Тип("Структура")
		Или ТипЗнч(Мета) = Тип("Соответствие") Тогда
		Возврат Мсп_Коллекции.Свойство(
			Мета,
			"progressToken",
			Мсп_Коллекции.Свойство(Запрос, "progressToken", Неопределено));
	КонецЕсли;

	Возврат Мсп_Коллекции.Свойство(Запрос, "progressToken", Неопределено);
КонецФункции

Асинх Функция ОбработатьToolCall(ЗапросJSON)
	Мсп_ЛогированиеКлиент.Отладка("MCP_TOOL_CALL received has_data=%1", ЗначениеЗаполнено(ЗапросJSON));
	КонтекстЗапроса = ПодготовитьЗапросИнструмента(ЗапросJSON);
	Если КонтекстЗапроса = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;

	Идентификатор = КонтекстЗапроса.Идентификатор;
	РежимВыполнения = КонтекстЗапроса.РежимВыполнения;
	Параметры = ПараметрыВызоваИнструмента(КонтекстЗапроса);
	Ответ = Мсп_ПротоколКлиент.ВызватьИнструмент(Идентификатор, Параметры, "");

	Если РежимВыполнения = "task" Тогда
		Если Ответ <> Неопределено Тогда
			Мсп_ЗадачиКлиент.ЗавершитьЗадачуПоОтветуИнструмента(КонтекстЗапроса.ИдентификаторЗадачи, Ответ);
		КонецЕсли;
		Возврат Истина;
	КонецЕсли;

	Если Ответ = Неопределено Тогда
		Мсп_ЛогированиеКлиент.Отладка("MCP tool call deferred id=%1", Идентификатор);
		Возврат Истина;
	КонецЕсли;

	Возврат Ждать ОтправитьОтвет(Идентификатор, Ответ);
КонецФункции

Асинх Функция ОбработатьResourceRead(ЗапросJSON)
	Мсп_ЛогированиеКлиент.Отладка("MCP_RESOURCE_READ received has_data=%1", ЗначениеЗаполнено(ЗапросJSON));
	КонтекстЗапроса = ПодготовитьЗапросСобытия("MCP_RESOURCE_READ", ЗапросJSON);
	Если КонтекстЗапроса = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;

	Идентификатор = КонтекстЗапроса.Идентификатор;
	Параметры = ПараметрыЧтенияРесурса(КонтекстЗапроса);
	Ответ = Мсп_ПротоколКлиент.ПрочитатьРесурс(Идентификатор, Параметры, "");
	Возврат Ждать ОтправитьОтвет(Идентификатор, Ответ);
КонецФункции

Асинх Функция ОбработатьPromptGet(ЗапросJSON)
	Мсп_ЛогированиеКлиент.Отладка("MCP_PROMPT_GET received has_data=%1", ЗначениеЗаполнено(ЗапросJSON));
	КонтекстЗапроса = ПодготовитьЗапросСобытия("MCP_PROMPT_GET", ЗапросJSON);
	Если КонтекстЗапроса = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;

	Идентификатор = КонтекстЗапроса.Идентификатор;
	Параметры = ПараметрыПолученияПромпта(КонтекстЗапроса);
	Ответ = Мсп_ПротоколКлиент.ПолучитьПромпт(Идентификатор, Параметры, "");
	Возврат Ждать ОтправитьОтвет(Идентификатор, Ответ);
КонецФункции

Процедура ОбработатьNotification(ЗапросJSON)
	Если Не ЗначениеЗаполнено(ЗапросJSON) Тогда
		Возврат;
	КонецЕсли;

	Запрос = Мсп_СериализацияКлиент.ПрочитатьJSONСтрокуБезОшибок(ЗапросJSON, Неопределено);
	Если ТипЗнч(Запрос) <> Тип("Структура")
		И ТипЗнч(Запрос) <> Тип("Соответствие") Тогда
		Возврат;
	КонецЕсли;

	Метод = Мсп_Коллекции.Свойство(Запрос, "method", "");
	Если ЗначениеЗаполнено(Метод) Тогда
		Мсп_ЛогированиеКлиент.Отладка("MCP notify: %1", Метод);
	КонецЕсли;
КонецПроцедуры

Асинх Функция ОтправитьОтвет(Идентификатор, Данные) Экспорт
	Компонента = ЭкземплярСервера();
	Если Компонента = Неопределено Тогда
		Мсп_ЛогированиеКлиент.Важно("MCP response ignored: Компонента is undefined");
		Возврат Ложь;
	КонецЕсли;

	ОтветJSON = Мсп_СериализацияКлиент.Сериализовать(Данные);
	Попытка
		Попытка
			РезультатОтправки = Ждать Компонента.ОтправитьОтветАсинх(
				Идентификатор,
				200,
				"{""Content-Type"":""application/json; charset=utf-8""}",
				ОтветJSON);
		Исключение
			РезультатОтправки = Компонента.ОтправитьОтвет(
				Идентификатор,
				200,
				"{""Content-Type"":""application/json; charset=utf-8""}",
				ОтветJSON);
		КонецПопытки;
		Если Не ВызовКомпонентыУспешен(РезультатОтправки) Тогда
			Мсп_ЛогированиеКлиент.Ошибка("MCP response send error id=%1", Идентификатор);
			Возврат Ложь;
		КонецЕсли;
		Мсп_ЛогированиеКлиент.Отладка("MCP response send ok id=%1", Идентификатор);
	Исключение
		Мсп_ЛогированиеКлиент.Ошибка(ИнформацияОбОшибке());
		Возврат Ложь;
	КонецПопытки;

	Возврат Истина;
КонецФункции

Процедура ОбработатьResourceSubscribe(ЗапросJSON)
	Если Не ЗначениеЗаполнено(ЗапросJSON) Тогда
		Возврат;
	КонецЕсли;

	Запрос = Мсп_СериализацияКлиент.ПрочитатьJSONСтрокуБезОшибок(ЗапросJSON, Неопределено);
	Если ТипЗнч(Запрос) <> Тип("Структура")
		И ТипЗнч(Запрос) <> Тип("Соответствие") Тогда
		Возврат;
	КонецЕсли;

	URI = Мсп_Коллекции.Свойство(Запрос, "uri", "");
	Мсп_ЛогированиеКлиент.Информация("Client subscribed to resource uri=%1", URI);
КонецПроцедуры

Процедура ОбработатьResourceUnsubscribe(ЗапросJSON)
	Если Не ЗначениеЗаполнено(ЗапросJSON) Тогда
		Возврат;
	КонецЕсли;

	Запрос = Мсп_СериализацияКлиент.ПрочитатьJSONСтрокуБезОшибок(ЗапросJSON, Неопределено);
	Если ТипЗнч(Запрос) <> Тип("Структура")
		И ТипЗнч(Запрос) <> Тип("Соответствие") Тогда
		Возврат;
	КонецЕсли;

	URI = Мсп_Коллекции.Свойство(Запрос, "uri", "");
	Мсп_ЛогированиеКлиент.Информация("Client unsubscribed from resource uri=%1", URI);
КонецПроцедуры

Функция ЭкземплярСервера()
	Возврат Мсп_СостояниеКлиент.ЗначениеСостоянияСервера("Компонента", Неопределено);
КонецФункции

Функция ВызовКомпонентыУспешен(РезультатВызова, ЗначениеПоУмолчанию = Истина)
	Если РезультатВызова = Неопределено Тогда
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;

	Если ТипЗнч(РезультатВызова) = Тип("Булево") Тогда
		Возврат РезультатВызова;
	КонецЕсли;

	Если ТипЗнч(РезультатВызова) = Тип("Структура")
		Или ТипЗнч(РезультатВызова) = Тип("Соответствие") Тогда
		Возврат Мсп_Коллекции.Свойство(РезультатВызова, "Значение", ЗначениеПоУмолчанию);
	КонецЕсли;

	Возврат ЗначениеПоУмолчанию;
КонецФункции

#КонецОбласти
