#Область ПрограммныйИнтерфейс

// Возвращает описание инструментов провайдера.
Процедура ЗарегистрироватьИнструменты() Экспорт
	Мсп_РеестрКлиент.ЗарегистрироватьИнструмент(Мсп_ИнструментыКлиент.ОписаниеИнструмента(
		"infobase_info",
		"Возвращает сведения об информационной базе: версия платформы, конфигурации, расширения и др.",
		СхемаВходныхПараметров(),
		Новый ОписаниеОповещения("ОбработатьИнструментИнфоИБ", Мсп_ИнструментИнфоИБКлиент)));
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Обрабатывает вызов инструмента и возвращает сведения об информационной базе.
//
// Параметры:
//  Запрос - Структура - Запрос инструмента:
//   * Аргументы - Структура - Аргументы вызова.
//   * Контекст - Структура - Контекст вызова.
//  ДополнительныеПараметры - Произвольный - Дополнительные параметры вызова.
//
// Возвращаемое значение:
//  Структура - Техническая информация об информационной базе.
Функция ОбработатьИнструментИнфоИБ(Запрос, ДополнительныеПараметры) Экспорт
	Если Запрос = Неопределено Тогда
		Запрос = Новый Структура;
	КонецЕсли;
	
	Информация = СобратьИнформациюИБ();
	Возврат Информация;
КонецФункции

// Возвращает JSON-схему входных параметров.
Функция СхемаВходныхПараметров()
	Схема = Новый Структура;
	Схема.Вставить("type", "object");
	Схема.Вставить("properties", Новый Структура);
	Схема.Вставить("additionalProperties", Ложь);
	Возврат Схема;
КонецФункции

// Собирает техническую информацию об информационной базе.
Функция СобратьИнформациюИБ()
	СистемнаяИнформация = Новый СистемнаяИнформация();

	Информация = Новый Структура;
	Информация.Вставить("Платформа", Новый Структура(
		"Версия, ТипПлатформы",
		СистемнаяИнформация.ВерсияПриложения,
		Строка(СистемнаяИнформация.ТипПлатформы)));
#Если ТонкийКлиент Тогда
	Информация.Вставить("Конфигурация", Новый Структура("Имя, Версия", "", ""));
	Информация.Вставить("ВстроенныйЯзык", "");
#Иначе
	Информация.Вставить("Конфигурация", Новый Структура(
		"Имя, Версия",
		Метаданные.Представление(),
		Метаданные.Версия));
	Информация.Вставить("ВстроенныйЯзык", ВстроенныйЯзык());
#КонецЕсли
	Информация.Вставить("ФайловаяБаза", ЭтоФайловаяБаза());

	Расширения = ПолучитьРасширенияКонфигурации();
	Информация.Вставить("Расширения", Расширения.Список);
	Информация.Вставить("РасширенияДоступны", Расширения.Доступны);

	Возврат Информация;
КонецФункции

Функция ВстроенныйЯзык()
#Если ТонкийКлиент Тогда
	Возврат "";
#Иначе
	ЭтоРусскийВстроенныйЯзык = Метаданные.ВариантВстроенногоЯзыка = Метаданные.СвойстваОбъектов.ВариантВстроенногоЯзыка.Русский;
	Возврат Формат(ЭтоРусскийВстроенныйЯзык, "БЛ=en; БИ=ru;");
#КонецЕсли
КонецФункции

Функция ЭтоФайловаяБаза()
	Возврат СтрНайти(Врег(СтрокаСоединенияИнформационнойБазы()), "FILE=") = 1;
КонецФункции

Функция ПолучитьРасширенияКонфигурации()
	Результат = Новый Структура("Доступны, Список", Истина, Новый Массив);
#Если ТонкийКлиент Тогда
	Результат.Доступны = Ложь;
#Иначе
	Попытка
		Для Каждого Расширение Из РасширенияКонфигурации.Получить() Цикл
			ОписаниеРасширения = Новый Структура;
			ОписаниеРасширения.Вставить("Имя", Расширение.Имя);
			ОписаниеРасширения.Вставить("Версия", Расширение.Версия);
			ОписаниеРасширения.Вставить("БезопасныйРежим", Расширение.БезопасныйРежим);
			ОписаниеРасширения.Вставить("ЗащитаОтОпасныхДействий",
				Строка(Расширение.ЗащитаОтОпасныхДействий.ПредупреждатьОбОпасныхДействиях));
			Результат.Список.Добавить(ОписаниеРасширения);
		КонецЦикла;
	Исключение
		Результат.Доступны = Ложь;
	КонецПопытки;
#КонецЕсли

	Возврат Результат;
КонецФункции

#КонецОбласти
