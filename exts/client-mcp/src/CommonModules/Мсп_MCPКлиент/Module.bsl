#Область ПрограммныйИнтерфейс

// Запускает MCP-сервер на указанном порту.
//
// Параметры:
//  Порт - Число - Номер порта для прослушивания.
//
// Возвращаемое значение:
//  Булево - Истина, если запрос на запуск отправлен.
Асинх Функция ЗапуститьСервер(Порт) Экспорт
	Возврат Ждать Мсп_СерверКлиент.ЗапуститьСервер(Порт);
КонецФункции

// Останавливает MCP-сервер.
//
// Возвращаемое значение:
//  Булево - Истина, если запрос на остановку обработан.
Асинх Функция ОстановитьСервер() Экспорт
	Возврат Ждать Мсп_СерверКлиент.ОстановитьСервер();
КонецФункции

// Регистрирует инструмент MCP и обработчик его вызова.
//
// Параметры:
//  Имя - Строка - Имя инструмента.
//  Описание - Строка - Описание инструмента.
//  СхемаJSON - Строка - JSON-схема входных параметров.
//  Оповещение - ОписаниеОповещения - Описание оповещения для вызова инструмента.
Процедура ЗарегистрироватьИнструмент(Имя, Описание, СхемаJSON, Оповещение) Экспорт
	Мсп_ИнструментыКлиент.MCP_ЗарегистрироватьИнструмент(Имя, Описание, СхемаJSON, Оповещение);
КонецПроцедуры

// Регистрирует ресурс MCP и обработчик чтения.
//
// Параметры:
//  URI - Строка - Идентификатор ресурса.
//  Описание - Строка - Описание ресурса.
//  MimeType - Строка - MIME-тип ресурса.
//  Оповещение - ОписаниеОповещения - Описание оповещения для чтения ресурса.
Процедура ЗарегистрироватьРесурс(URI, Описание, MimeType, Оповещение) Экспорт
	Мсп_ИнструментыКлиент.MCP_ЗарегистрироватьРесурс(URI, Описание, MimeType, Оповещение);
КонецПроцедуры

// Регистрирует промпт MCP и обработчик получения.
//
// Параметры:
//  Имя - Строка - Имя промпта.
//  Описание - Строка - Описание промпта.
//  Аргументы - Структура - Описание аргументов промпта.
//  Оповещение - ОписаниеОповещения - Описание оповещения для получения промпта.
Процедура ЗарегистрироватьПромпт(Имя, Описание, Аргументы, Оповещение) Экспорт
	Мсп_ИнструментыКлиент.MCP_ЗарегистрироватьПромпт(Имя, Описание, Аргументы, Оповещение);
КонецПроцедуры

// Отправляет лог-сообщение в MCP.
//
// Параметры:
//  Уровень - Строка - Уровень логирования.
//  Текст - Строка - Текст сообщения.
//  Контекст - Структура - Дополнительный контекст (если есть).
//
// Возвращаемое значение:
//  Булево - Истина, если логирование обработано.
Асинх Функция ЛогСообщение(Уровень, Текст, Контекст = Неопределено) Экспорт
	Возврат Ждать Мсп_ИнструментыКлиент.MCP_ЛогСообщение(Уровень, Текст, Контекст);
КонецФункции

#КонецОбласти
