#Область ПрограммныйИнтерфейс

// Запускает MCP-сервер и инициализирует состояние.
//
// Параметры:
//  НомерПорта - Число - Номер порта для прослушивания.
//
// Возвращаемое значение:
//  Булево - Истина, если запрос на запуск отправлен.
Асинх Функция ЗапуститьСервер(НомерПорта) Экспорт
	УстановитьСостояниеЗначение("Порт", НомерПорта);
	
	Мсп_ЛогированиеКлиент.Информация(СтрШаблон("Server startup: begin port=%1", НомерПорта));
	Мсп_ЛогированиеКлиент.Информация(СтрШаблон("Server startup: logging params:%1", НомерПорта));
	
	Мсп_ЛогированиеКлиент.Информация("Server startup: connect external component");
	Ждать ПодключитьКомпоненту();
	Мсп_ЛогированиеКлиент.Информация("Server startup: external component connected");
	
	Компонента = ЭкземплярСервера();
	Если Компонента <> Неопределено Тогда
		Мсп_ЛогированиеКлиент.Информация("Server startup: stopping previous HTTP server");
		Попытка
			РезультатОстановки = Ждать Компонента.ОстановитьHTTPАсинх();
			ОбработкаОстановкиHTTP(РезультатОстановки.Значение, РезультатОстановки.Параметры, Компонента);
		Исключение
			ОбработкаОстановкиHTTP(Ложь, Неопределено, Компонента);
		КонецПопытки;
		Мсп_ЛогированиеКлиент.Информация("Server startup: stop requested for previous server");
	КонецЕсли;
	
	Мсп_ЛогированиеКлиент.Информация("Server startup: create addin AddIn.WebTransport.mcp");
	Компонента = Новый("AddIn.WebTransport.mcp");
	Мсп_ЛогированиеКлиент.Информация(СтрШаблон("Server startup: HTTP start requested address=%1", АдресПрослушивания()));
	УстановитьСостояниеЗначение("Компонента", Компонента);
	УстановитьСостояниеЗначение("SSE_Сессии", Новый Соответствие);
	
	Попытка
		РезультатЗапуска = Ждать Компонента.ЗапуститьHTTPАсинх(АдресПрослушивания());
		ОбработкаЗапускаHTTP(РезультатЗапуска.Значение, РезультатЗапуска.Параметры, Компонента);
	Исключение
		ОбработкаЗапускаHTTP(Ложь, Неопределено, Компонента);
	КонецПопытки;
	
	Мсп_ЛогированиеКлиент.Информация("Server startup: initialize registries");
	Мсп_ИнструментыКлиент.ИнициализироватьРеестры();
	Мсп_ИнструментИнфоИБКлиент.ЗарегистрироватьИнструментИнфоИБ();
	Мсп_ИнструментСложениеКлиент.ЗарегистрироватьИнструментСложение();
	Мсп_ЛогированиеКлиент.Информация(СтрШаблон("Server start requested on %1", АдресПрослушивания()));
	
	Возврат Истина;
КонецФункции

// Останавливает MCP-сервер.
//
// Возвращаемое значение:
//  Булево - Истина, если запрос на остановку обработан.
Асинх Функция ОстановитьСервер() Экспорт
	Компонента = ЭкземплярСервера();
	УстановитьСостояниеЗначение("СерверЗапущен", Ложь);
	Если Компонента <> Неопределено Тогда
		Попытка
			РезультатОстановки = Ждать Компонента.ОстановитьHTTPАсинх();
			ОбработкаОстановкиHTTP(РезультатОстановки.Значение, РезультатОстановки.Параметры, Компонента);
		Исключение
			ОбработкаОстановкиHTTP(Ложь, Неопределено, Компонента);
		КонецПопытки;
	КонецЕсли;
	Мсп_ЛогированиеКлиент.Информация("Server stop requested");
	Возврат Истина;
КонецФункции

// Обрабатывает события внешней компоненты MCP.
//
// Параметры:
//  Источник - Строка - Имя источника события.
//  Событие - Строка - Имя события.
//  Данные - Строка - Данные события.
//
// Возвращаемое значение:
//  Булево - Истина, если событие обработано.
Асинх Функция ОбработатьВнешнееСобытие(Источник, Событие, Данные) Экспорт
	Мсп_ЛогированиеКлиент.Отладка(СтрШаблон(
		"External event received source=%1 event=%2 has_data=%3",
		Источник,
		Событие,
		ЗначениеЗаполнено(Данные)));
	Если Источник <> "WebTransport" Тогда
		Мсп_ЛогированиеКлиент.Отладка(СтрШаблон("External event ignored: source=%1", Источник));
		Возврат Ложь;
	КонецЕсли;

	Если Событие = "MCP_MESSAGE" Тогда
		Мсп_ЛогированиеКлиент.Отладка("External event MCP MESSAGE: begin");
		Результат = Ждать ОбработатьMcpСообщение(Данные);
		Мсп_ЛогированиеКлиент.Отладка(СтрШаблон("External event MCP MESSAGE: end result=%1", Результат));
		Возврат Результат;
	ИначеЕсли Событие = "SSE_OPEN" Тогда
		Мсп_ЛогированиеКлиент.Отладка("External event SSE_OPEN: begin");
		ОбработатьSseOpen(Данные);
		Мсп_ЛогированиеКлиент.Отладка("External event SSE_OPEN: end");
		Возврат Истина;
	КонецЕсли;

	Мсп_ЛогированиеКлиент.Отладка(СтрШаблон("External event ignored: unknown event=%1", Событие));
	Возврат Ложь;
КонецФункции

// Отправляет уведомление всем активным SSE-сессиям.
//
// Параметры:
//  СообщениеJSON - Строка - JSON-строка уведомления.
//
// Возвращаемое значение:
//  Булево - Истина, если уведомление обработано.
Асинх Функция ОтправитьУведомление(СообщениеJSON) Экспорт
	Компонента = ЭкземплярСервера();
	Если Компонента = Неопределено Тогда
		Мсп_ЛогированиеКлиент.Отладка("SSE broadcast skipped: MCP Компонента is undefined");
		Возврат Ложь;
	КонецЕсли;
	SSE_Сессии = ПолучитьСостояниеЗначение("SSE_Сессии", Неопределено);
	Если SSE_Сессии = Неопределено Тогда
		SSE_Сессии = Новый Соответствие;
		УстановитьСостояниеЗначение("SSE_Сессии", SSE_Сессии);
	КонецЕсли;
	Мсп_ЛогированиеКлиент.Отладка(СтрШаблон("SSE broadcast: begin sessions=%1", SSE_Сессии.Количество()));
	Успешно = Истина;
	Для Каждого Элемент Из SSE_Сессии Цикл
		Попытка
			РезультатОтправки = Ждать Компонента.ОтправитьSSEАсинх(Элемент.Ключ, СообщениеJSON);
			ОбработкаОтправкиSSE(РезультатОтправки.Значение, РезультатОтправки.Параметры, Элемент.Ключ);
			Если РезультатОтправки.Значение = Ложь Тогда
				Успешно = Ложь;
			КонецЕсли;
		Исключение
			ОбработкаОтправкиSSE(Ложь, Неопределено, Элемент.Ключ);
			Успешно = Ложь;
		КонецПопытки;
	КонецЦикла;
	Мсп_ЛогированиеКлиент.Отладка(СтрШаблон("SSE broadcast: end result=%1", Успешно));
	Возврат Успешно;
КонецФункции

// Возвращает экземпляр внешней компоненты MCP (если инициализирована).
//
// Возвращаемое значение:
//  ВнешнийОбъект - Экземпляр внешней компоненты или Неопределено.
Функция ЭкземплярСервера() Экспорт
	Возврат ПолучитьСостояниеЗначение("Компонента", Неопределено);
КонецФункции

// Проверяет, запущен ли MCP-сервер.
//
// Возвращаемое значение:
//  Булево - Истина, если сервер запущен.
Функция СерверЗапущен() Экспорт
	Возврат ПолучитьСостояниеЗначение(
		"СерверЗапущен",
		ЭкземплярСервера() <> Неопределено);
КонецФункции

// Возвращает порт MCP-сервера.
//
// Возвращаемое значение:
//  Число - Порт сервера или 0, если не задан.
Функция ПолучитьПортСервера() Экспорт
	Возврат ПолучитьСостояниеЗначение("Порт", 0);
КонецФункции

// Возвращает адрес прослушивания MCP-сервера.
//
// Возвращаемое значение:
//  Строка - Адрес прослушивания или пустая строка.
Функция ПолучитьАдресПрослушивания() Экспорт
	Если ПолучитьСостояниеЗначение("Порт", 0) <= 0 Тогда
		Возврат "";
	КонецЕсли;
	Возврат АдресПрослушивания();
КонецФункции

