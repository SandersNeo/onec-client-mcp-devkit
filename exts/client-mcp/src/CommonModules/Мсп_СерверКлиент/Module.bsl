КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Подключает внешнюю компоненту WebTransport.
//
// Возвращаемое значение:
//  Булево - Истина при успешном подключении.
Асинх Функция ПодключитьКомпоненту() Экспорт
	МакетКомпоненты = "ОбщийМакет.Мсп_webTransport";
	ИмяКомпоненты = "WebTransport";
	Мсп_ЛогированиеКлиент.Информация(СтрШаблон("Component connect: begin name=%1 layout=%2", ИмяКомпоненты, МакетКомпоненты));

	Попытка
		Мсп_ЛогированиеКлиент.Информация("Component connect: try connect");
		Подключено = Ждать ПодключитьВнешнююКомпонентуАсинх(
			МакетКомпоненты,
			ИмяКомпоненты,
			ТипВнешнейКомпоненты.Native,
			ТипПодключенияВнешнейКомпоненты.НеИзолированно);

		Если Не Подключено Тогда
			Мсп_ЛогированиеКлиент.Информация("Component connect: install component from layout");
			Ждать УстановитьВнешнююКомпонентуАсинх(МакетКомпоненты);
			Мсп_ЛогированиеКлиент.Информация("Component connect: retry connect");
			Подключено = Ждать ПодключитьВнешнююКомпонентуАсинх(
				МакетКомпоненты,
				ИмяКомпоненты,
				ТипВнешнейКомпоненты.Native,
				ТипПодключенияВнешнейКомпоненты.НеИзолированно);
		КонецЕсли;
	Исключение
		ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		Мсп_ЛогированиеКлиент.Ошибка(СтрШаблон("Component connect error: %1", ТекстОшибки));
		ВызватьИсключение СтрШаблон(
			"Не удалось подключить внешнюю компоненту %1 (%2): %3",
			ИмяКомпоненты,
			МакетКомпоненты,
			ТекстОшибки);
	КонецПопытки;

	Если Не Подключено Тогда
		Мсп_ЛогированиеКлиент.Ошибка("Component connect failed: no connection established");
		ВызватьИсключение СтрШаблон(
			"Не удалось подключить внешнюю компоненту %1 (%2).",
			ИмяКомпоненты,
			МакетКомпоненты);
	КонецЕсли;

	Мсп_ЛогированиеКлиент.Информация("Component connect: success");
	Возврат Истина;
КонецФункции

Функция АдресПрослушивания()
	Порт = ПолучитьСостояниеЗначение("Порт", 0);
	Возврат "127.0.0.1:" + Формат(Порт, "ЧГ=0");
КонецФункции

Процедура ОбработатьSseOpen(ЗапросJSON)
	Мсп_ЛогированиеКлиент.Отладка(СтрШаблон("SSE open: received has_data=%1", ЗначениеЗаполнено(ЗапросJSON)));
	SSE_Сессии = ПолучитьСостояниеЗначение("SSE_Сессии", Неопределено);
	Если SSE_Сессии = Неопределено Тогда
		SSE_Сессии = Новый Соответствие;
		УстановитьСостояниеЗначение("SSE_Сессии", SSE_Сессии);
	КонецЕсли;
	Если Не ЗначениеЗаполнено(ЗапросJSON) Тогда
		Мсп_ЛогированиеКлиент.Отладка("SSE open: empty request");
		Возврат;
	КонецЕсли;
	Данные = Мсп_ИнструментыКлиент.ПрочитатьJSONСтрокуБезОшибок(ЗапросJSON, Неопределено);
	Если ТипЗнч(Данные) <> Тип("Структура")
		И ТипЗнч(Данные) <> Тип("Соответствие") Тогда
		Мсп_ЛогированиеКлиент.Отладка("SSE open: request is not object");
		Возврат;
	КонецЕсли;
	Сессия = Мсп_ИнструментыКлиент.ПолучитьСвойство(Данные, "id", "");
	Если ЗначениеЗаполнено(Сессия) Тогда
		SSE_Сессии.Вставить(Сессия, Истина);
		Мсп_ЛогированиеКлиент.Отладка(СтрШаблон("SSE open session=%1", Сессия));
	Иначе
		Мсп_ЛогированиеКлиент.Отладка("SSE open: session id missing");
	КонецЕсли;
КонецПроцедуры

Асинх Функция ОбработатьMcpСообщение(ЗапросJSON)
	Мсп_ЛогированиеКлиент.Отладка(СтрШаблон("MCP message: received has_data=%1", ЗначениеЗаполнено(ЗапросJSON)));
	Компонента = ЭкземплярСервера();
	Если Компонента = Неопределено Тогда
		Мсп_ЛогированиеКлиент.Важно("MCP MESSAGE ignored: Компонента is undefined");
		Возврат Ложь;
	КонецЕсли;
	Если Не ЗначениеЗаполнено(ЗапросJSON) Тогда
		Мсп_ЛогированиеКлиент.Важно("MCP MESSAGE ignored: empty request JSON");
		Возврат Ложь;
	КонецЕсли;

	Запрос = Мсп_ИнструментыКлиент.ПрочитатьJSONСтрокуБезОшибок(ЗапросJSON, Неопределено);
	Если ТипЗнч(Запрос) <> Тип("Структура")
		И ТипЗнч(Запрос) <> Тип("Соответствие") Тогда
		Мсп_ЛогированиеКлиент.Важно("MCP MESSAGE ignored: request is not object");
		Возврат Ложь;
	КонецЕсли;

	Сессия = ПолучитьПараметрИзQuery(Запрос.Получить("query"), "sessionId");
	Если Не ЗначениеЗаполнено(Сессия) Тогда
		Мсп_ЛогированиеКлиент.Важно("MCP MESSAGE ignored: missing sessionId");
		Возврат Ложь;
	КонецЕсли;
	Тело = Запрос.Получить("body");
	Если Не ЗначениеЗаполнено(Тело) Тогда
		Мсп_ЛогированиеКлиент.Важно("MCP MESSAGE ignored: missing body");
		Возврат Ложь;
	КонецЕсли;

	Сообщение = Мсп_ИнструментыКлиент.
	ПрочитатьJSONСтрокуБезОшибок(Тело, Неопределено);
	Если ТипЗнч(Сообщение) <> Тип("Структура")
		И ТипЗнч(Сообщение) <> Тип("Соответствие") Тогда
		Мсп_ЛогированиеКлиент.Важно("MCP MESSAGE ignored: body is not object");
		Возврат Ложь;
	КонецЕсли;

	МетодСообщения = Мсп_ИнструментыКлиент.ПолучитьСвойство(Сообщение, "method", "");
	ИдентификаторСообщения = Мсп_ИнструментыКлиент.ПолучитьСвойство(Сообщение, "id", "");
	Если ЗначениеЗаполнено(МетодСообщения) Тогда
		Мсп_ЛогированиеКлиент.Отладка(СтрШаблон(
			"MCP message: session=%1 method=%2 id=%3",
			Сессия,
			МетодСообщения,
			ИдентификаторСообщения));
	Иначе
		Мсп_ЛогированиеКлиент.Отладка(СтрШаблон(
			"MCP message: session=%1 id=%2",
			Сессия,
			ИдентификаторСообщения));
	КонецЕсли;

	Ответ = Мсп_ИнструментыКлиент.ОбработатьJSONRPC(Сообщение, Сессия);
	Если Ответ = Неопределено Тогда
		Мсп_ЛогированиеКлиент.Отладка(СтрШаблон("MCP response skipped: session=%1 result=undefined", Сессия));
		Возврат Ложь;
	КонецЕсли;
	ОтветJSON = Мсп_ПротоколКлиент.Сериализовать(Ответ);

	Попытка
		Мсп_ЛогированиеКлиент.Отладка(СтрШаблон("MCP response: send session=%1", Сессия));
		РезультатОтправки = Ждать Компонента.ОтправитьSSEАсинх(Сессия, ОтветJSON);
		ОбработкаОтправкиSSE(РезультатОтправки.Значение, РезультатОтправки.Параметры, Сессия);
	Исключение
		ОбработкаОтправкиSSE(Ложь, Неопределено, Сессия);
	КонецПопытки;
	Возврат Истина;
КонецФункции

Функция ПолучитьПараметрИзQuery(Запрос, Имя)
	Если Не ЗначениеЗаполнено(Запрос) Тогда
		Возврат "";
	КонецЕсли;
	Для Каждого Пара Из СтрРазделить(Запрос, "&") Цикл
		Если Не ЗначениеЗаполнено(Пара) Тогда
			Продолжить;
		КонецЕсли;
		ПозицияРавно = СтрНайти(Пара, "=");
		Если ПозицияРавно <= 0 Тогда
			Продолжить;
		КонецЕсли;
		Ключ = Лев(Пара, ПозицияРавно - 1);
		Значение = Сред(Пара, ПозицияРавно + 1);
		Если Ключ = Имя Тогда
			Возврат Значение;
		КонецЕсли;
	КонецЦикла;
	Возврат "";
КонецФункции

Процедура ОбработкаЗапускаHTTP(РезультатВызова, ПараметрыВызова, Компонента = Неопределено) Экспорт
	Если РезультатВызова = Ложь Тогда
		Мсп_ЛогированиеКлиент.Ошибка(СтрШаблон("HTTP start error err=%1", ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке())));
		Если Компонента <> Неопределено Тогда
			Если ЭкземплярСервера() = Компонента Тогда
				УстановитьСостояниеЗначение("Компонента", Неопределено);
			КонецЕсли;
		КонецЕсли;
		Если Компонента = Неопределено Или ЭкземплярСервера() = Компонента Тогда
			УстановитьСостояниеЗначение("СерверЗапущен", Ложь);
		КонецЕсли;
		Возврат;
	КонецЕсли;

	Если Компонента = Неопределено Или ЭкземплярСервера() = Компонента Тогда
		УстановитьСостояниеЗначение("СерверЗапущен", Истина);
	КонецЕсли;
КонецПроцедуры

Процедура ОбработкаОстановкиHTTP(РезультатВызова, ПараметрыВызова, Компонента = Неопределено) Экспорт
	Если РезультатВызова = Ложь Тогда
		Мсп_ЛогированиеКлиент.Ошибка(СтрШаблон("HTTP stop error err=%1", ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке())));
		Если Компонента = Неопределено Или ЭкземплярСервера() = Компонента Тогда
			УстановитьСостояниеЗначение("СерверЗапущен", Истина);
		КонецЕсли;
		Возврат;
	КонецЕсли;

	Если Компонента = Неопределено Или ЭкземплярСервера() = Компонента Тогда
		УстановитьСостояниеЗначение("Компонента", Неопределено);
		УстановитьСостояниеЗначение("SSE_Сессии", Новый Соответствие);
		УстановитьСостояниеЗначение("СерверЗапущен", Ложь);
		Мсп_ЛогированиеКлиент.Информация("Server stopped");
	КонецЕсли;
КонецПроцедуры

Процедура ОбработкаОтправкиSSE(РезультатВызова, ПараметрыВызова, Сессия) Экспорт
	Если РезультатВызова = Ложь Тогда
		Мсп_ЛогированиеКлиент.Ошибка(СтрШаблон("SSE send error session=%1 err=%2", Сессия, ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке())));
		Возврат;
	КонецЕсли;
	Мсп_ЛогированиеКлиент.Отладка(СтрШаблон("SSE send ok session=%1", Сессия));
КонецПроцедуры

Функция ПолучитьСостояниеЗначение(Имя, ЗначениеПоУмолчанию = Неопределено) Экспорт
	Состояние = ПолучитьСостояние();
	Если Состояние.Свойство(Имя) Тогда
		Возврат Состояние[Имя];
	КонецЕсли;
	Возврат ЗначениеПоУмолчанию;
КонецФункции

Процедура УстановитьСостояниеЗначение(Имя, Значение) Экспорт
	Состояние = ПолучитьСостояние();
	Состояние.Вставить(Имя, Значение);
КонецПроцедуры

Функция ПолучитьСостояние()
	Возврат Мсп_СостояниеКлиент.ПолучитьСостояние();
КонецФункции

#КонецОбласти
