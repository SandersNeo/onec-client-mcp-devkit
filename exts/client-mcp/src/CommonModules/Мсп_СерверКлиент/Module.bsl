#Область ПрограммныйИнтерфейс

// Запускает MCP-сервер и инициализирует состояние.
//
// Параметры:
//  НомерПорта - Число - Номер порта для прослушивания.
//  Параметры - Структура - Дополнительные параметры запуска:
//   * log - Булево - Признак необходимости логировать сообщения.
//   * logLevel - Строка - Минимальный уровень логирования (debug, info, warn, error).
//   * logFile - Строка - Путь к файлу логирования (пустая строка отключает запись).
//
// Возвращаемое значение:
//  Булево - Истина, если запрос на запуск отправлен.
Асинх Функция ЗапуститьСервер(НомерПорта, Параметры = Неопределено) Экспорт
	MCP_УстановитьСостояниеЗначение("MCP_Порт", НомерПорта);
	MCP_УстановитьСостояниеЗначение("MCP_Параметры", Параметры);
	Мсп_ЛогированиеКлиент.ПрименитьПараметрыЗапуска(Параметры);
	MCP_Лог(СтрШаблон("Server startup: begin port=%1", НомерПорта), "info");
	MCP_Лог("Server startup: logging params applied", "info");
	
	MCP_Лог("Server startup: connect external component", "info");
	Ждать ПодключитьКомпоненту();
	MCP_Лог("Server startup: external component connected", "info");
	
	MCP_Компонента = ЭкземплярСервера();
	Если MCP_Компонента <> Неопределено Тогда
		MCP_Лог("Server startup: stopping previous HTTP server", "info");
		Попытка
			РезультатОстановки = Ждать MCP_Компонента.ОстановитьHTTPАсинх();
			MCP_ОбработкаОстановкиHTTP(РезультатОстановки.Значение, РезультатОстановки.Параметры, MCP_Компонента);
		Исключение
			MCP_ОбработкаОстановкиHTTP(Ложь, Неопределено, MCP_Компонента);
		КонецПопытки;
		MCP_Лог("Server startup: stop requested for previous server", "info");
	КонецЕсли;
	
	MCP_Лог("Server startup: create addin AddIn.WebTransport.mcp", "info");
	MCP_Компонента = Новый("AddIn.WebTransport.mcp");
	MCP_Лог(СтрШаблон("Server startup: HTTP start requested address=%1", АдресПрослушивания()), "info");
	MCP_УстановитьСостояниеЗначение("MCP_Компонента", MCP_Компонента);
	MCP_УстановитьСостояниеЗначение("MCP_SSE_Сессии", Новый Соответствие);
	
	Попытка
		РезультатЗапуска = Ждать MCP_Компонента.ЗапуститьHTTPАсинх(АдресПрослушивания());
		MCP_ОбработкаЗапускаHTTP(РезультатЗапуска.Значение, РезультатЗапуска.Параметры, MCP_Компонента);
	Исключение
		MCP_ОбработкаЗапускаHTTP(Ложь, Неопределено, MCP_Компонента);
	КонецПопытки;
	
	MCP_Лог("Server startup: initialize registries", "info");
	Мсп_ИнструментыКлиент.MCP_ИнициализироватьРеестры();
	MCP_Лог(СтрШаблон("Server start requested on %1", АдресПрослушивания()));
	
	Возврат Истина;
КонецФункции

// Останавливает MCP-сервер.
//
// Возвращаемое значение:
//  Булево - Истина, если запрос на остановку обработан.
Асинх Функция ОстановитьСервер() Экспорт
	MCP_Компонента = ЭкземплярСервера();
	MCP_УстановитьСостояниеЗначение("MCP_СерверЗапущен", Ложь);
	Если MCP_Компонента <> Неопределено Тогда
		Попытка
			РезультатОстановки = Ждать MCP_Компонента.ОстановитьHTTPАсинх();
			MCP_ОбработкаОстановкиHTTP(РезультатОстановки.Значение, РезультатОстановки.Параметры, MCP_Компонента);
		Исключение
			MCP_ОбработкаОстановкиHTTP(Ложь, Неопределено, MCP_Компонента);
		КонецПопытки;
	КонецЕсли;
	MCP_Лог("Server stop requested");
	Возврат Истина;
КонецФункции

// Обрабатывает события внешней компоненты MCP.
//
// Параметры:
//  Источник - Строка - Имя источника события.
//  Событие - Строка - Имя события.
//  Данные - Строка - Данные события.
//
// Возвращаемое значение:
//  Булево - Истина, если событие обработано.
Асинх Функция ОбработатьВнешнееСобытие(Источник, Событие, Данные) Экспорт
	Если Источник <> "WebTransport" Тогда
		Возврат Ложь;
	КонецЕсли;

	Если Событие = "MCP_MESSAGE" Тогда
		Возврат Ждать MCP_ОбработатьMcpСообщение(Данные);
	ИначеЕсли Событие = "SSE_OPEN" Тогда
		MCP_ОбработатьSseOpen(Данные);
		Возврат Истина;
	КонецЕсли;

	Возврат Ложь;
КонецФункции

// Отправляет уведомление всем активным SSE-сессиям.
//
// Параметры:
//  СообщениеJSON - Строка - JSON-строка уведомления.
//
// Возвращаемое значение:
//  Булево - Истина, если уведомление обработано.
Асинх Функция ОтправитьУведомление(СообщениеJSON) Экспорт
	MCP_Компонента = ЭкземплярСервера();
	Если MCP_Компонента = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;
	MCP_SSE_Сессии = MCP_ПолучитьСостояниеЗначение("MCP_SSE_Сессии", Неопределено);
	Если MCP_SSE_Сессии = Неопределено Тогда
		MCP_SSE_Сессии = Новый Соответствие;
		MCP_УстановитьСостояниеЗначение("MCP_SSE_Сессии", MCP_SSE_Сессии);
	КонецЕсли;
	Успешно = Истина;
	Для Каждого Элемент Из MCP_SSE_Сессии Цикл
		Попытка
			РезультатОтправки = Ждать MCP_Компонента.ОтправитьSSEАсинх(Элемент.Ключ, СообщениеJSON);
			MCP_ОбработкаОтправкиSSE(РезультатОтправки.Значение, РезультатОтправки.Параметры, Элемент.Ключ);
			Если РезультатОтправки.Значение = Ложь Тогда
				Успешно = Ложь;
			КонецЕсли;
		Исключение
			MCP_ОбработкаОтправкиSSE(Ложь, Неопределено, Элемент.Ключ);
			Успешно = Ложь;
		КонецПопытки;
	КонецЦикла;
	Возврат Успешно;
КонецФункции

// Возвращает экземпляр внешней компоненты MCP (если инициализирована).
//
// Возвращаемое значение:
//  ВнешнийОбъект - Экземпляр внешней компоненты или Неопределено.
Функция ЭкземплярСервера() Экспорт
	Возврат MCP_ПолучитьСостояниеЗначение("MCP_Компонента", Неопределено);
КонецФункции

// Проверяет, запущен ли MCP-сервер.
//
// Возвращаемое значение:
//  Булево - Истина, если сервер запущен.
Функция СерверЗапущен() Экспорт
	Возврат MCP_ПолучитьСостояниеЗначение(
		"MCP_СерверЗапущен",
		ЭкземплярСервера() <> Неопределено);
КонецФункции

// Возвращает порт MCP-сервера.
//
// Возвращаемое значение:
//  Число - Порт сервера или 0, если не задан.
Функция ПолучитьПортСервера() Экспорт
	Возврат MCP_ПолучитьСостояниеЗначение("MCP_Порт", 0);
КонецФункции

// Возвращает адрес прослушивания MCP-сервера.
//
// Возвращаемое значение:
//  Строка - Адрес прослушивания или пустая строка.
Функция ПолучитьАдресПрослушивания() Экспорт
	Если MCP_ПолучитьСостояниеЗначение("MCP_Порт", 0) <= 0 Тогда
		Возврат "";
	КонецЕсли;
	Возврат АдресПрослушивания();
КонецФункции

// Возвращает признак логирования.
//
// Возвращаемое значение:
//  Булево - Истина, если логирование включено.
Функция ПолучитьЛогировать() Экспорт
	Возврат Мсп_ЛогированиеКлиент.ПолучитьЛогировать();
КонецФункции

// Возвращает путь к файлу лога.
//
// Возвращаемое значение:
//  Строка - Путь к файлу лога или пустая строка.
Функция ПолучитьФайлЛога() Экспорт
	Возврат Мсп_ЛогированиеКлиент.ПолучитьФайлЛога();
КонецФункции

// Возвращает минимальный уровень логирования.
//
// Возвращаемое значение:
//  Строка - Минимальный уровень логирования (debug, info, warn, error).
Функция ПолучитьУровеньЛога() Экспорт
	Возврат Мсп_ЛогированиеКлиент.ПолучитьУровеньЛога();
КонецФункции

// Устанавливает параметры логирования.
//
// Параметры:
//  Логировать - Булево - Признак необходимости логировать сообщения.
//  ФайлЛога - Строка - Путь к файлу лога.
//  УровеньЛога - Строка - Минимальный уровень логирования (debug, info, warn, error).
Процедура УстановитьПараметрыЛогирования(Логировать, ФайлЛога, УровеньЛога = Неопределено) Экспорт
	Мсп_ЛогированиеКлиент.УстановитьПараметрыЛогирования(Логировать, ФайлЛога, УровеньЛога);
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Подключает внешнюю компоненту WebTransport.
//
// Возвращаемое значение:
//  Булево - Истина при успешном подключении.
Асинх Функция ПодключитьКомпоненту() Экспорт
	МакетКомпоненты = "ОбщийМакет.Мсп_webTransport";
	ИмяКомпоненты = "WebTransport";
	MCP_Лог(СтрШаблон("Component connect: begin name=%1 layout=%2", ИмяКомпоненты, МакетКомпоненты), "info");

	Попытка
		MCP_Лог("Component connect: try connect", "info");
		Подключено = Ждать ПодключитьВнешнююКомпонентуАсинх(
			МакетКомпоненты,
			ИмяКомпоненты,
			ТипВнешнейКомпоненты.Native,
			ТипПодключенияВнешнейКомпоненты.НеИзолированно);

		Если Не Подключено Тогда
			MCP_Лог("Component connect: install component from layout", "info");
			Ждать УстановитьВнешнююКомпонентуАсинх(МакетКомпоненты);
			MCP_Лог("Component connect: retry connect", "info");
			Подключено = Ждать ПодключитьВнешнююКомпонентуАсинх(
				МакетКомпоненты,
				ИмяКомпоненты,
				ТипВнешнейКомпоненты.Native,
				ТипПодключенияВнешнейКомпоненты.НеИзолированно);
		КонецЕсли;
	Исключение
		ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		MCP_Лог(СтрШаблон("Component connect error: %1", ТекстОшибки), "error");
		ВызватьИсключение СтрШаблон(
			"Не удалось подключить внешнюю компоненту %1 (%2): %3",
			ИмяКомпоненты,
			МакетКомпоненты,
			ТекстОшибки);
	КонецПопытки;

	Если Не Подключено Тогда
		MCP_Лог("Component connect failed: no connection established", "error");
		ВызватьИсключение СтрШаблон(
			"Не удалось подключить внешнюю компоненту %1 (%2).",
			ИмяКомпоненты,
			МакетКомпоненты);
	КонецЕсли;

	MCP_Лог("Component connect: success", "info");
	Возврат Истина;
КонецФункции

Функция АдресПрослушивания()
	Порт = MCP_ПолучитьСостояниеЗначение("MCP_Порт", 0);
	Возврат "127.0.0.1:" + Формат(Порт, "ЧГ=0");
КонецФункции

Процедура MCP_ОбработатьSseOpen(ЗапросJSON)
	MCP_SSE_Сессии = MCP_ПолучитьСостояниеЗначение("MCP_SSE_Сессии", Неопределено);
	Если MCP_SSE_Сессии = Неопределено Тогда
		MCP_SSE_Сессии = Новый Соответствие;
		MCP_УстановитьСостояниеЗначение("MCP_SSE_Сессии", MCP_SSE_Сессии);
	КонецЕсли;
	Если Не ЗначениеЗаполнено(ЗапросJSON) Тогда
		Возврат;
	КонецЕсли;
	Данные = Мсп_ИнструментыКлиент.MCP_ПрочитатьJSONСтрокуБезОшибок(ЗапросJSON, Неопределено);
	Если ТипЗнч(Данные) <> Тип("Структура")
		И ТипЗнч(Данные) <> Тип("Соответствие") Тогда
		Возврат;
	КонецЕсли;
	Сессия = Мсп_ИнструментыКлиент.MCP_ПолучитьСвойство(Данные, "id", "");
	Если ЗначениеЗаполнено(Сессия) Тогда
		MCP_SSE_Сессии.Вставить(Сессия, Истина);
		MCP_Лог(СтрШаблон("SSE open session=%1", Сессия), "debug");
	КонецЕсли;
КонецПроцедуры

Асинх Функция MCP_ОбработатьMcpСообщение(ЗапросJSON)
	MCP_Компонента = ЭкземплярСервера();
	Если MCP_Компонента = Неопределено Тогда
		MCP_Лог("MCP_MESSAGE ignored: MCP_Компонента is undefined", "warn");
		Возврат Ложь;
	КонецЕсли;
	Если Не ЗначениеЗаполнено(ЗапросJSON) Тогда
		MCP_Лог("MCP_MESSAGE ignored: empty request JSON", "warn");
		Возврат Ложь;
	КонецЕсли;

	Запрос = Мсп_ИнструментыКлиент.MCP_ПрочитатьJSONСтрокуБезОшибок(ЗапросJSON, Неопределено);
	Если ТипЗнч(Запрос) <> Тип("Структура")
		И ТипЗнч(Запрос) <> Тип("Соответствие") Тогда
		MCP_Лог("MCP_MESSAGE ignored: request is not object", "warn");
		Возврат Ложь;
	КонецЕсли;

	Сессия = MCP_ПолучитьПараметрИзQuery(Запрос.Получить("query"), "sessionId");
	Если Не ЗначениеЗаполнено(Сессия) Тогда
		MCP_Лог("MCP_MESSAGE ignored: missing sessionId", "warn");
		Возврат Ложь;
	КонецЕсли;
	Тело = Запрос.Получить("body");
	Если Не ЗначениеЗаполнено(Тело) Тогда
		MCP_Лог("MCP_MESSAGE ignored: missing body", "warn");
		Возврат Ложь;
	КонецЕсли;

	Сообщение = Мсп_ИнструментыКлиент.MCP_ПрочитатьJSONСтрокуБезОшибок(Тело, Неопределено);
	Если ТипЗнч(Сообщение) <> Тип("Структура")
		И ТипЗнч(Сообщение) <> Тип("Соответствие") Тогда
		MCP_Лог("MCP_MESSAGE ignored: body is not object", "warn");
		Возврат Ложь;
	КонецЕсли;

	Ответ = Мсп_ИнструментыКлиент.MCP_ОбработатьJSONRPC(Сообщение, Сессия);
	Если Ответ = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;
	ОтветJSON = Мсп_ИнструментыКлиент.MCP_ЗаписатьJSON(Ответ);

	Попытка
		РезультатОтправки = Ждать MCP_Компонента.ОтправитьSSEАсинх(Сессия, ОтветJSON);
		MCP_ОбработкаОтправкиSSE(РезультатОтправки.Значение, РезультатОтправки.Параметры, Сессия);
	Исключение
		MCP_ОбработкаОтправкиSSE(Ложь, Неопределено, Сессия);
	КонецПопытки;
	Возврат Истина;
КонецФункции

Функция MCP_ПолучитьПараметрИзQuery(Запрос, Имя)
	Если Не ЗначениеЗаполнено(Запрос) Тогда
		Возврат "";
	КонецЕсли;
	Для Каждого Пара Из СтрРазделить(Запрос, "&") Цикл
		Если Не ЗначениеЗаполнено(Пара) Тогда
			Продолжить;
		КонецЕсли;
		ПозицияРавно = СтрНайти(Пара, "=");
		Если ПозицияРавно <= 0 Тогда
			Продолжить;
		КонецЕсли;
		Ключ = Лев(Пара, ПозицияРавно - 1);
		Значение = Сред(Пара, ПозицияРавно + 1);
		Если Ключ = Имя Тогда
			Возврат Значение;
		КонецЕсли;
	КонецЦикла;
	Возврат "";
КонецФункции

Процедура MCP_Лог(Текст, Уровень = "info")
	Мсп_ЛогированиеКлиент.MCP_Лог(Текст, Уровень);
КонецПроцедуры

Процедура MCP_ОбработкаЗапускаHTTP(РезультатВызова, ПараметрыВызова, Компонента = Неопределено) Экспорт
	Если РезультатВызова = Ложь Тогда
		MCP_Лог(СтрШаблон("HTTP start error err=%1", ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке())), "error");
		Если Компонента <> Неопределено Тогда
			Если ЭкземплярСервера() = Компонента Тогда
				MCP_УстановитьСостояниеЗначение("MCP_Компонента", Неопределено);
			КонецЕсли;
		КонецЕсли;
		Если Компонента = Неопределено Или ЭкземплярСервера() = Компонента Тогда
			MCP_УстановитьСостояниеЗначение("MCP_СерверЗапущен", Ложь);
		КонецЕсли;
		Возврат;
	КонецЕсли;

	Если Компонента = Неопределено Или ЭкземплярСервера() = Компонента Тогда
		MCP_УстановитьСостояниеЗначение("MCP_СерверЗапущен", Истина);
	КонецЕсли;
КонецПроцедуры

Процедура MCP_ОбработкаОстановкиHTTP(РезультатВызова, ПараметрыВызова, Компонента = Неопределено) Экспорт
	Если РезультатВызова = Ложь Тогда
		MCP_Лог(СтрШаблон("HTTP stop error err=%1", ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке())), "error");
		Если Компонента = Неопределено Или ЭкземплярСервера() = Компонента Тогда
			MCP_УстановитьСостояниеЗначение("MCP_СерверЗапущен", Истина);
		КонецЕсли;
		Возврат;
	КонецЕсли;

	Если Компонента = Неопределено Или ЭкземплярСервера() = Компонента Тогда
		MCP_УстановитьСостояниеЗначение("MCP_Компонента", Неопределено);
		MCP_УстановитьСостояниеЗначение("MCP_SSE_Сессии", Новый Соответствие);
		MCP_УстановитьСостояниеЗначение("MCP_СерверЗапущен", Ложь);
		MCP_Лог("Server stopped");
	КонецЕсли;
КонецПроцедуры

Процедура MCP_ОбработкаОтправкиSSE(РезультатВызова, ПараметрыВызова, Сессия) Экспорт
	Если РезультатВызова = Ложь Тогда
		MCP_Лог(СтрШаблон("SSE send error session=%1 err=%2", Сессия, ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке())), "error");
	КонецЕсли;
КонецПроцедуры

Функция MCP_ПолучитьСостояниеЗначение(Имя, ЗначениеПоУмолчанию = Неопределено) Экспорт
	Состояние = MCP_ПолучитьСостояние();
	Если Состояние.Свойство(Имя) Тогда
		Возврат Состояние[Имя];
	КонецЕсли;
	Возврат ЗначениеПоУмолчанию;
КонецФункции

Процедура MCP_УстановитьСостояниеЗначение(Имя, Значение) Экспорт
	Состояние = MCP_ПолучитьСостояние();
	Состояние.Вставить(Имя, Значение);
КонецПроцедуры

Функция MCP_ПолучитьСостояние()
	Возврат Мсп_СостояниеКлиент.ПолучитьСостояние();
КонецФункции

#КонецОбласти
