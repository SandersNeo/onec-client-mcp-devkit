		Строка.Описание = ПреобразоватьВСтроку(Мсп_ИнструментыКлиент.MCP_ПолучитьСвойство(Дескриптор, "description", ""));
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьСессии()
	Сессии.Очистить();
	Реестр = Мсп_РеестрMCPКлиент.MCP_ПолучитьРеестр("MCP_Сессии");
