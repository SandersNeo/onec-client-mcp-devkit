#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Порт = 8080;
	РазрешенныеOrigins = "";
	ТаймаутСек = 900;
	УровеньЛога = "info";
	ИнициализироватьСписокУровнейЛога();
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	ОбновитьСостояние();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ЛогироватьПриИзменении(Элемент)
	Мсп_ЛогированиеКлиент.УстановитьПараметрыЛогирования(Логировать, ФайлЛога, УровеньЛога);
КонецПроцедуры

&НаКлиенте
Процедура ФайлЛогаПриИзменении(Элемент)
	Мсп_ЛогированиеКлиент.УстановитьПараметрыЛогирования(Логировать, ФайлЛога, УровеньЛога);
КонецПроцедуры

&НаКлиенте
Процедура УровеньЛогаПриИзменении(Элемент)
	Если Не ЗначениеЗаполнено(УровеньЛога) Тогда
		УровеньЛога = "info";
	КонецЕсли;
	Мсп_ЛогированиеКлиент.УстановитьПараметрыЛогирования(Логировать, ФайлЛога, УровеньЛога);
КонецПроцедуры

&НаКлиенте
Процедура АдресНажатие(Элемент, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	
	Если ЗначениеЗаполнено(Адрес) Тогда
		ПерейтиПоНавигационнойСсылке(Адрес);
	КонецЕсли;
КонецПроцедуры
#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыИнструменты

&НаКлиенте
Процедура ИнструментыПриАктивизацииСтроки(Элемент)
	ТекущаяСтрока = Элементы.Инструменты.ТекущиеДанные;
	Если ТекущаяСтрока = Неопределено Тогда
		СхемаИнструмента = "";
	Иначе
		СхемаИнструмента = ТекущаяСтрока.СхемаПараметров;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Асинх Процедура ИнструментыВключёнПриИзменении(Элемент)
	ТекущаяСтрока = Элементы.Инструменты.ТекущиеДанные;
	Если ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	Мсп_РеестрКлиент.УстановитьВключён(Мсп_РеестрКлиент.РеестрИнструментов(), ТекущаяСтрока.Имя, ТекущаяСтрока.Включён);
	Ждать Мсп_ТранспортРеестрыКлиент.СинхронизироватьИнструменты();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыРесурсы

&НаКлиенте
Асинх Процедура РесурсыВключёнПриИзменении(Элемент)
	ТекущаяСтрока = Элементы.Ресурсы.ТекущиеДанные;
	Если ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	Мсп_РеестрКлиент.УстановитьВключён(Мсп_РеестрКлиент.РеестрРесурсов(), ТекущаяСтрока.URI, ТекущаяСтрока.Включён);
	Ждать Мсп_ТранспортРеестрыКлиент.СинхронизироватьРесурсы();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыШаблоныРесурсов

&НаКлиенте
Асинх Процедура ШаблоныРесурсовВключёнПриИзменении(Элемент)
	ТекущаяСтрока = Элементы.ШаблоныРесурсов.ТекущиеДанные;
	Если ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	Мсп_РеестрКлиент.УстановитьВключён(Мсп_РеестрКлиент.РеестрШаблоновРесурсов(), ТекущаяСтрока.URIШаблон, ТекущаяСтрока.Включён);
	Ждать Мсп_ТранспортРеестрыКлиент.СинхронизироватьРесурсы();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыПромпты

&НаКлиенте
Асинх Процедура ПромптыВключёнПриИзменении(Элемент)
	ТекущаяСтрока = Элементы.Промпты.ТекущиеДанные;
	Если ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	Мсп_РеестрКлиент.УстановитьВключён(Мсп_РеестрКлиент.РеестрПромптов(), ТекущаяСтрока.Имя, ТекущаяСтрока.Включён);
	Ждать Мсп_ТранспортРеестрыКлиент.СинхронизироватьПромпты();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Асинх Процедура Запустить(Команда)
	Если Порт <= 0 Тогда
		ПоказатьСообщение("Укажите порт сервера.");
		Возврат;
	КонецЕсли;
	Если ТаймаутСек <= 0 Тогда
		ТаймаутСек = 900;
	КонецЕсли;
	
	Попытка
		Мсп_ЛогированиеКлиент.УстановитьПараметрыЛогирования(Логировать, ФайлЛога, УровеньЛога);
		Ждать Мсп_Сервер.ЗапуститьСервер(Порт, РазрешенныеOrigins, ТаймаутСек);
	Исключение
		ПоказатьСообщение(ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		Возврат;
	КонецПопытки;
	
	ОбновитьСостояние();
КонецПроцедуры

&НаКлиенте
Асинх Процедура Остановить(Команда)
	Ждать Мсп_Сервер.Остановить();
	ОбновитьСостояние();
КонецПроцедуры

&НаКлиенте
Процедура Обновить(Команда)
	ОбновитьСостояние();
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ПоказатьСообщение(Текст)
	Сообщение = Новый СообщениеПользователю;
	Сообщение.Текст = Текст;
	Сообщение.Сообщить();
КонецПроцедуры

&НаСервере
Процедура ИнициализироватьСписокУровнейЛога()
	ЭлементУровеньЛога = Элементы.УровеньЛога;
	СписокУровней = ЭлементУровеньЛога.СписокВыбора;
	СписокУровней.Очистить();
	СписокУровней.Добавить("debug", "debug");
	СписокУровней.Добавить("info", "info");
	СписокУровней.Добавить("warn", "warn");
	СписокУровней.Добавить("error", "error");
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСостояние()
	Запущен = Мсп_ТранспортСерверКлиент.СерверЗапущен();
	Если Запущен Тогда
		Состояние = "Запущен";
		Порт = Мсп_ТранспортСерверКлиент.ПолучитьПортСервера();
		Адрес = СтрШаблон("http://%1/mcp", Мсп_ТранспортСерверКлиент.ПолучитьАдресПрослушивания());

		РазрешенныеOrigins = Мсп_ТранспортСерверКлиент.ПолучитьРазрешенныеOrigins();
		ТаймаутСек = Мсп_ТранспортСерверКлиент.ПолучитьТаймаутСек();
	Иначе
		Состояние = "Остановлен";
		Адрес = "";
	КонецЕсли;
	
	ОбновитьСписки();
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСписки()
	ЗаполнитьИнструменты();
	ЗаполнитьРесурсы();
	ЗаполнитьШаблоныРесурсов();
	ЗаполнитьПромпты();
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьИнструменты()
	Инструменты.Очистить();
	Для Каждого Элемент Из Мсп_РеестрКлиент.РеестрИнструментов() Цикл
		Дескриптор = Элемент.Значение;
		Строка = Инструменты.Добавить();
		Строка.Имя = Элемент.Ключ;
		Строка.Описание = Дескриптор.Описание;
		Если ТипЗнч(Дескриптор.СхемаПараметров) = Тип("Строка") Тогда
			Строка.СхемаПараметров = Дескриптор.СхемаПараметров;
		Иначе
			Строка.СхемаПараметров = Мсп_СериализацияКлиент.Сериализовать(Дескриптор.СхемаПараметров);
		КонецЕсли;
		Строка.Включён = Дескриптор.Включён;
		Строка.Провайдер = Дескриптор.ИсточникРегистрации;
	КонецЦикла;
	СхемаИнструмента = "";
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьРесурсы()
	Ресурсы.Очистить();
	Для Каждого Элемент Из Мсп_РеестрКлиент.РеестрРесурсов() Цикл
		Дескриптор = Элемент.Значение;
		Строка = Ресурсы.Добавить();
		Строка.URI = Дескриптор.URI;
		Строка.Описание = Дескриптор.Описание;
		Строка.Включён = Дескриптор.Включён;
		Строка.Провайдер = Дескриптор.Провайдер;
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьШаблоныРесурсов()
	ШаблоныРесурсов.Очистить();
	Для Каждого Элемент Из Мсп_РеестрКлиент.РеестрШаблоновРесурсов() Цикл
		Дескриптор = Элемент.Значение;
		Строка = ШаблоныРесурсов.Добавить();
		Строка.URIШаблон = Дескриптор.URIШаблон;
		Строка.Описание = Дескриптор.Описание;
		Строка.Включён = Дескриптор.Включён;
		Строка.Провайдер = Дескриптор.Провайдер;
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьПромпты()
	Промпты.Очистить();
	Для Каждого Элемент Из Мсп_РеестрКлиент.РеестрПромптов() Цикл
		Дескриптор = Элемент.Значение;
		Строка = Промпты.Добавить();
		Строка.Имя = Дескриптор.Имя;
		Строка.Описание = Дескриптор.Описание;
		Строка.Включён = Дескриптор.Включён;
		Строка.Провайдер = Дескриптор.Провайдер;
	КонецЦикла;
КонецПроцедуры

#КонецОбласти
