#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Порт = 8080;
	УровеньЛога = "info";
	ИнициализироватьСписокУровнейЛога();
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	ОбновитьСостояние();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ЛогироватьПриИзменении(Элемент)
	Мсп_ЛогированиеКлиент.УстановитьПараметрыЛогирования(Логировать, ФайлЛога, УровеньЛога);
КонецПроцедуры

&НаКлиенте
Процедура ФайлЛогаПриИзменении(Элемент)
	Мсп_ЛогированиеКлиент.УстановитьПараметрыЛогирования(Логировать, ФайлЛога, УровеньЛога);
КонецПроцедуры

&НаКлиенте
Процедура УровеньЛогаПриИзменении(Элемент)
	Если Не ЗначениеЗаполнено(УровеньЛога) Тогда
		УровеньЛога = "info";
	КонецЕсли;
	Мсп_ЛогированиеКлиент.УстановитьПараметрыЛогирования(Логировать, ФайлЛога, УровеньЛога);
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Асинх Процедура Запустить(Команда)
	Если Порт <= 0 Тогда
		ПоказатьСообщение("Укажите порт сервера.");
		Возврат;
	КонецЕсли;
	
	Попытка
		Мсп_ЛогированиеКлиент.УстановитьПараметрыЛогирования(Логировать, ФайлЛога, УровеньЛога);
		Ждать Мсп_СерверКлиент.ЗапуститьСервер(Порт);
	Исключение
		ПоказатьСообщение(ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		Возврат;
	КонецПопытки;
	
	ОбновитьСостояние();
КонецПроцедуры

&НаКлиенте
Асинх Процедура Остановить(Команда)
	Ждать Мсп_СерверКлиент.ОстановитьСервер();
	ОбновитьСостояние();
КонецПроцедуры

&НаКлиенте
Процедура Обновить(Команда)
	ОбновитьСостояние();
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ПоказатьСообщение(Текст)
	Сообщение = Новый СообщениеПользователю;
	Сообщение.Текст = Текст;
	Сообщение.Сообщить();
КонецПроцедуры

&НаСервере
Процедура ИнициализироватьСписокУровнейЛога()
	ЭлементУровеньЛога = Элементы.УровеньЛога;
	СписокУровней = ЭлементУровеньЛога.СписокВыбора;
	СписокУровней.Очистить();
	СписокУровней.Добавить("debug", "debug");
	СписокУровней.Добавить("info", "info");
	СписокУровней.Добавить("warn", "warn");
	СписокУровней.Добавить("error", "error");
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСостояние()
	Запущен = Мсп_СерверКлиент.СерверЗапущен();
	Если Запущен Тогда
		Состояние = "Запущен";
		Порт = Мсп_СерверКлиент.ПолучитьПортСервера();
		Адрес = Мсп_СерверКлиент.ПолучитьАдресПрослушивания();
	Иначе
		Состояние = "Остановлен";
		Адрес = "";
	КонецЕсли;
	
	ОбновитьСписки();
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСписки()
	Мсп_РеестрКлиент.ИнициализироватьРеестры();
	
	ЗаполнитьИнструменты();
	ЗаполнитьРесурсы();
	ЗаполнитьПромпты();
	ЗаполнитьСессии();
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьИнструменты()
	Инструменты.Очистить();
	Для Каждого Элемент Из Мсп_РеестрКлиент.РеестрИнструментов() Цикл
		Дескриптор = Элемент.Значение;
		Строка = Инструменты.Добавить();
		Строка.Имя = Элемент.Ключ;
		Строка.Описание = Мсп_ИнструментыКлиент.ПолучитьСвойство(Дескриптор, "description", "");
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьРесурсы()
	Ресурсы.Очистить();
	Для Каждого Элемент Из Мсп_РеестрКлиент.РеестрРесурсов() Цикл
		Дескриптор = Элемент.Значение;
		Строка = Ресурсы.Добавить();
		Строка.URI = Мсп_ИнструментыКлиент.ПолучитьСвойство(Дескриптор, "uri", Элемент.Ключ);
		Строка.Описание = Мсп_ИнструментыКлиент.ПолучитьСвойство(Дескриптор, "description", "");
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьПромпты()
	Промпты.Очистить();
	Для Каждого Элемент Из Мсп_РеестрКлиент.РеестрПромптов() Цикл
		Дескриптор = Элемент.Значение;
		Строка = Промпты.Добавить();
		Строка.Имя = Мсп_ИнструментыКлиент.ПолучитьСвойство(Дескриптор, "name", Элемент.Ключ);
		Строка.Описание = Мсп_ИнструментыКлиент.ПолучитьСвойство(Дескриптор, "description", "");
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьСессии()
	Сессии.Очистить();
	Для Каждого Элемент Из Мсп_РеестрКлиент.Сессии() Цикл
		Дескриптор = Элемент.Значение;
		Строка = Сессии.Добавить();
		Строка.Идентификатор = Элемент.Ключ;
		Строка.ВерсияПротокола = Мсп_ИнструментыКлиент.ПолучитьСвойство(Дескриптор, "protocolVersion", "");
	КонецЦикла;
КонецПроцедуры

#КонецОбласти
