#Область ОбработчикиСобытийФормы

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	Если Не ЗначениеЗаполнено(Порт) Тогда
		ПортСервера = Мсп_СерверКлиент.ПолучитьПортСервера();
		Если ПортСервера > 0 Тогда
			Порт = ПреобразоватьВСтроку(ПортСервера);
		Иначе
			Порт = "8080";
		КонецЕсли;
	КонецЕсли;

	Логировать = Мсп_ЛогированиеКлиент.ПолучитьЛогировать();
	ФайлЛога = Мсп_ЛогированиеКлиент.ПолучитьФайлЛога();
	УровеньЛога = Мсп_ЛогированиеКлиент.ПолучитьУровеньЛога();
	Если Не ЗначениеЗаполнено(УровеньЛога) Тогда
		УровеньЛога = "info";
	КонецЕсли;

	ИнициализироватьСписокУровнейЛога();
	
	ОбновитьСостояние();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ЛогироватьПриИзменении(Элемент)
	Мсп_ЛогированиеКлиент.УстановитьПараметрыЛогирования(Логировать, ФайлЛога, УровеньЛога);
КонецПроцедуры

&НаКлиенте
Процедура ФайлЛогаПриИзменении(Элемент)
	Мсп_ЛогированиеКлиент.УстановитьПараметрыЛогирования(Логировать, ФайлЛога, УровеньЛога);
КонецПроцедуры

&НаКлиенте
Процедура УровеньЛогаПриИзменении(Элемент)
	Если Не ЗначениеЗаполнено(УровеньЛога) Тогда
		УровеньЛога = "info";
	КонецЕсли;
	Мсп_ЛогированиеКлиент.УстановитьПараметрыЛогирования(Логировать, ФайлЛога, УровеньЛога);
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Асинх Процедура Запустить(Команда)
	ПортСервера = ПолучитьПортИзПоля();
	Если ПортСервера <= 0 Тогда
		ПоказатьСообщение("Укажите порт сервера.");
		Возврат;
	КонецЕсли;

	Попытка
		Ждать Мсп_СерверКлиент.ЗапуститьСервер(ПортСервера);
	Исключение
		ПоказатьСообщение(ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		Возврат;
	КонецПопытки;

	ОбновитьСостояние();
КонецПроцедуры

&НаКлиенте
Асинх Процедура Остановить(Команда)
	Ждать Мсп_СерверКлиент.ОстановитьСервер();
	ОбновитьСостояние();
КонецПроцедуры

&НаКлиенте
Процедура Обновить(Команда)
	ОбновитьСостояние();
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ПоказатьСообщение(Текст)
	Сообщение = Новый СообщениеПользователю;
	Сообщение.Текст = Текст;
	Сообщение.Сообщить();
КонецПроцедуры

&НаКлиенте
Процедура ИнициализироватьСписокУровнейЛога()
	ЭлементУровеньЛога = Элементы.Найти("УровеньЛога");
	Если ЭлементУровеньЛога = Неопределено Тогда
		Возврат;
	КонецЕсли;
	СписокУровней = ЭлементУровеньЛога.СписокВыбора;
	СписокУровней.Очистить();
	СписокУровней.Добавить("debug", "debug");
	СписокУровней.Добавить("info", "info");
	СписокУровней.Добавить("warn", "warn");
	СписокУровней.Добавить("error", "error");
КонецПроцедуры

&НаКлиенте
Функция ПреобразоватьВСтроку(Значение)
	Если Значение = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	Возврат Строка(Значение);
КонецФункции

&НаКлиенте
Функция ПолучитьПортИзПоля()
	Попытка
		Возврат Число(Порт);
	Исключение
		Возврат 0;
	КонецПопытки;
КонецФункции

&НаКлиенте
Процедура ОбновитьСостояние()
	Запущен = Мсп_СерверКлиент.СерверЗапущен();
	Если Запущен Тогда
		Состояние = "Запущен";
	Иначе
		Состояние = "Остановлен";
	КонецЕсли;

	ПортСервера = Мсп_СерверКлиент.ПолучитьПортСервера();
	Если ПортСервера > 0 Тогда
		Порт = ПреобразоватьВСтроку(ПортСервера);
	КонецЕсли;

	Если Запущен Тогда
		Адрес = Мсп_СерверКлиент.ПолучитьАдресПрослушивания();
	Иначе
		Адрес = "";
	КонецЕсли;

	ОбновитьСписки();
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСписки()
	Мсп_ИнструментыКлиент.MCP_ИнициализироватьРеестры();

	ЗаполнитьИнструменты();
	ЗаполнитьРесурсы();
	ЗаполнитьПромпты();
	ЗаполнитьСессии();
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьИнструменты()
	Инструменты.Очистить();
	Реестр = Мсп_РеестрMCPКлиент.MCP_ПолучитьРеестр("MCP_Инструменты");
	Для Каждого Элемент Из Реестр Цикл
		Дескриптор = Элемент.Значение;
		Строка = Инструменты.Добавить();
		Строка.Имя = ПреобразоватьВСтроку(Элемент.Ключ);
		Строка.Описание = ПреобразоватьВСтроку(Мсп_ИнструментыКлиент.MCP_ПолучитьСвойство(Дескриптор, "description", ""));
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьРесурсы()
	Ресурсы.Очистить();
	Реестр = Мсп_РеестрMCPКлиент.MCP_ПолучитьРеестр("MCP_Ресурсы");
	Для Каждого Элемент Из Реестр Цикл
		Дескриптор = Элемент.Значение;
		Строка = Ресурсы.Добавить();
		Строка.URI = ПреобразоватьВСтроку(Мсп_ИнструментыКлиент.MCP_ПолучитьСвойство(Дескриптор, "uri", Элемент.Ключ));
		Строка.Описание = ПреобразоватьВСтроку(Мсп_ИнструментыКлиент.MCP_ПолучитьСвойство(Дескриптор, "description", ""));
	КонецЦикла;
КонецПроцедуры

